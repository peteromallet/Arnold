{
  "DrawViTPose": {
    "pack": "ComfyUI-WanAnimatePreprocess",
    "pack_version": "local-1a35b81",
    "python_module": "ComfyUI-WanAnimatePreprocess.nodes",
    "category": "WanAnimatePreprocess",
    "name": "DrawViTPose",
    "display_name": "Draws pose images from pose data.",
    "description": "",
    "inputs": {
      "required": {
        "pose_data": [
          "POSEDATA"
        ],
        "width": [
          "INT",
          {
            "default": 832,
            "min": 64,
            "max": 2048,
            "step": 1,
            "tooltip": "Width of the generation"
          }
        ],
        "height": [
          "INT",
          {
            "default": 480,
            "min": 64,
            "max": 2048,
            "step": 1,
            "tooltip": "Height of the generation"
          }
        ],
        "retarget_padding": [
          "INT",
          {
            "default": 16,
            "min": 0,
            "max": 512,
            "step": 1,
            "tooltip": "When > 0, the retargeted pose image is padded and resized to the target size"
          }
        ],
        "body_stick_width": [
          "INT",
          {
            "default": -1,
            "min": -1,
            "max": 20,
            "step": 1,
            "tooltip": "Width of the body sticks. Set to 0 to disable body drawing, -1 for auto"
          }
        ],
        "hand_stick_width": [
          "INT",
          {
            "default": -1,
            "min": -1,
            "max": 20,
            "step": 1,
            "tooltip": "Width of the hand sticks. Set to 0 to disable hand drawing, -1 for auto"
          }
        ],
        "draw_head": [
          "BOOLEAN",
          {
            "default": "True",
            "tooltip": "Whether to draw head keypoints"
          }
        ]
      }
    },
    "input_order": {
      "required": [
        "pose_data",
        "width",
        "height",
        "retarget_padding",
        "body_stick_width",
        "hand_stick_width",
        "draw_head"
      ]
    },
    "input_order_all": [
      "pose_data",
      "width",
      "height",
      "retarget_padding",
      "body_stick_width",
      "hand_stick_width",
      "draw_head"
    ],
    "object_info_widget_order": [
      "pose_data",
      "width",
      "height",
      "retarget_padding",
      "body_stick_width",
      "hand_stick_width",
      "draw_head"
    ],
    "outputs": [
      {
        "type": "IMAGE",
        "name": "pose_images",
        "is_list": false
      }
    ],
    "function": "process"
  },
  "OnnxDetectionModelLoader": {
    "pack": "ComfyUI-WanAnimatePreprocess",
    "pack_version": "local-1a35b81",
    "python_module": "ComfyUI-WanAnimatePreprocess.nodes",
    "category": "WanAnimatePreprocess",
    "name": "OnnxDetectionModelLoader",
    "display_name": "Loads ONNX models for pose and face detection. ViTPose for pose estimation and YOLO for object detection.",
    "description": "",
    "inputs": {
      "required": {
        "vitpose_model": [
          [],
          {
            "tooltip": "These models are loaded from the 'ComfyUI/models/detection' -folder"
          }
        ],
        "yolo_model": [
          [],
          {
            "tooltip": "These models are loaded from the 'ComfyUI/models/detection' -folder"
          }
        ],
        "onnx_device": [
          [
            "CUDAExecutionProvider",
            "CPUExecutionProvider"
          ],
          {
            "default": "CUDAExecutionProvider",
            "tooltip": "Device to run the ONNX models on"
          }
        ]
      }
    },
    "input_order": {
      "required": [
        "vitpose_model",
        "yolo_model",
        "onnx_device"
      ]
    },
    "input_order_all": [
      "vitpose_model",
      "yolo_model",
      "onnx_device"
    ],
    "object_info_widget_order": [
      "vitpose_model",
      "yolo_model",
      "onnx_device"
    ],
    "outputs": [
      {
        "type": "POSEMODEL",
        "name": "model",
        "is_list": false
      }
    ],
    "function": "loadmodel"
  },
  "PoseAndFaceDetection": {
    "pack": "ComfyUI-WanAnimatePreprocess",
    "pack_version": "local-1a35b81",
    "python_module": "ComfyUI-WanAnimatePreprocess.nodes",
    "category": "WanAnimatePreprocess",
    "name": "PoseAndFaceDetection",
    "display_name": "Detects human poses and face images from input images. Optionally retargets poses based on a reference image.",
    "description": "",
    "inputs": {
      "required": {
        "model": [
          "POSEMODEL"
        ],
        "images": [
          "IMAGE"
        ],
        "width": [
          "INT",
          {
            "default": 832,
            "min": 64,
            "max": 2048,
            "step": 1,
            "tooltip": "Width of the generation"
          }
        ],
        "height": [
          "INT",
          {
            "default": 480,
            "min": 64,
            "max": 2048,
            "step": 1,
            "tooltip": "Height of the generation"
          }
        ]
      },
      "optional": {
        "retarget_image": [
          "IMAGE",
          {
            "default": null,
            "tooltip": "Optional reference image for pose retargeting"
          }
        ],
        "face_padding": [
          "INT",
          {
            "default": 0,
            "min": 0,
            "max": 512,
            "step": 1,
            "tooltip": "When > 0, the detected face images are padded and resized to 512x512"
          }
        ]
      }
    },
    "input_order": {
      "required": [
        "model",
        "images",
        "width",
        "height"
      ],
      "optional": [
        "retarget_image",
        "face_padding"
      ]
    },
    "input_order_all": [
      "model",
      "images",
      "width",
      "height",
      "retarget_image",
      "face_padding"
    ],
    "object_info_widget_order": [
      "model",
      null,
      "width",
      "height",
      null,
      "face_padding"
    ],
    "outputs": [
      {
        "type": "POSEDATA",
        "name": "pose_data",
        "is_list": false
      },
      {
        "type": "IMAGE",
        "name": "face_images",
        "is_list": false
      },
      {
        "type": "STRING",
        "name": "key_frame_body_points",
        "is_list": false
      },
      {
        "type": "BBOX",
        "name": "bboxes",
        "is_list": false
      },
      {
        "type": "BBOX,",
        "name": "face_bboxes",
        "is_list": false
      }
    ],
    "function": "process"
  },
  "PoseDetectionOneToAllAnimation": {
    "pack": "ComfyUI-WanAnimatePreprocess",
    "pack_version": "local-1a35b81",
    "python_module": "ComfyUI-WanAnimatePreprocess.nodes",
    "category": "WanAnimatePreprocess",
    "name": "PoseDetectionOneToAllAnimation",
    "display_name": "Specialized pose detection and alignment for OneToAllAnimation model https://github.com/ssj9596/One-to-All-Animation. Detects poses from input images and aligns them based on a reference image if provided.",
    "description": "",
    "inputs": {
      "required": {
        "model": [
          "POSEMODEL"
        ],
        "images": [
          "IMAGE"
        ],
        "width": [
          "INT",
          {
            "default": 832,
            "min": 64,
            "max": 2048,
            "step": 2,
            "tooltip": "Width of the generation"
          }
        ],
        "height": [
          "INT",
          {
            "default": 480,
            "min": 64,
            "max": 2048,
            "step": 2,
            "tooltip": "Height of the generation"
          }
        ],
        "align_to": [
          [
            "ref",
            "pose",
            "none"
          ],
          {
            "default": "ref",
            "tooltip": "Alignment mode for poses"
          }
        ],
        "draw_face_points": [
          [
            "full",
            "weak",
            "none"
          ],
          {
            "default": "full",
            "tooltip": "Whether to draw face keypoints on the pose images"
          }
        ],
        "draw_head": [
          [
            "full",
            "weak",
            "none"
          ],
          {
            "default": "full",
            "tooltip": "Whether to draw head keypoints on the pose images"
          }
        ]
      },
      "optional": {
        "ref_image": [
          "IMAGE",
          {
            "default": null,
            "tooltip": "Optional reference image for pose retargeting"
          }
        ]
      }
    },
    "input_order": {
      "required": [
        "model",
        "images",
        "width",
        "height",
        "align_to",
        "draw_face_points",
        "draw_head"
      ],
      "optional": [
        "ref_image"
      ]
    },
    "input_order_all": [
      "model",
      "images",
      "width",
      "height",
      "align_to",
      "draw_face_points",
      "draw_head",
      "ref_image"
    ],
    "object_info_widget_order": [
      "model",
      null,
      "width",
      "height",
      "align_to",
      "draw_face_points",
      "draw_head",
      null
    ],
    "outputs": [
      {
        "type": "IMAGE",
        "name": "pose_images",
        "is_list": false
      },
      {
        "type": "IMAGE",
        "name": "ref_pose_image",
        "is_list": false
      },
      {
        "type": "IMAGE",
        "name": "ref_image",
        "is_list": false
      },
      {
        "type": "MASK",
        "name": "ref_mask",
        "is_list": false
      }
    ],
    "function": "process"
  },

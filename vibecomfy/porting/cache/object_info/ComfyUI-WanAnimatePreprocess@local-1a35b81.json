        "pose_data"
      ]
    },
    "input_order_all": [
      "pose_data"
    ],
    "object_info_widget_order": [
      "pose_data"
    ],
    "outputs": [
      {
        "type": "STRING",
        "name": "prompt",
        "is_list": false
      },
      {
        "type": "STRING",
        "name": "retarget_prompt",
        "is_list": false
      }
    ],
    "function": "process"
  }
}

    "output_node": false
  },
  "MelBandRoFormerSampler": {
    "category": "audio",
    "description": "Separate audio using MelBandRoFormer",
    "display_name": "MelBandRoFormer Sampler",
    "input_order": {
      "required": [
        "audio",
        "model"
      ]
    },
    "input_order_all": [
      "audio",
      "model",
      "overlap",
      "chunk_size"
    ],
    "inputs": {
      "required": {
        "audio": [
          "AUDIO"
        ],
        "model": [
          "MELBAND_ROFORMER_MODEL"
        ]
      },
      "optional": {
        "overlap": [
          "FLOAT",
          {
            "default": 0.1
          }
        ],
        "chunk_size": [
          "INT",
          {
            "default": 485100
          }
        ]
      }
    },
    "output": [
      "AUDIO",
      "AUDIO"
    ],
    "output_name": [
      "audio",
      "instrumental"
    ],
    "output_node": false

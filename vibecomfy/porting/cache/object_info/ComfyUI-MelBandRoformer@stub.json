{
  "MelBandRoFormerModelLoader": {
    "category": "audio",
    "description": "Load MelBandRoFormer audio separation model",
    "display_name": "MelBandRoFormer Model Loader",
    "input_order": {
      "required": [
        "model"
      ]
    },
    "input_order_all": [
      "model"
    ],
    "inputs": {
      "required": {
        "model": [
          [
            "mel_band_roformer_karaoke_aufr33_viperx_sdr_10.1956.ckpt",
            "MelBandRoformer.ckpt"
          ]
        ]
      }
    },
    "output": [

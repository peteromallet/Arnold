    "category": "DepthAnythingV2",
    "name": "DepthAnything_V2",
    "display_name": "\nhttps://depth-anything-v2.github.io\n",
    "description": "",
    "inputs": {
      "required": {
        "da_model": [
          "DAMODEL"
        ],
        "images": [
          "IMAGE"
        ]
      }
    },
    "input_order": {
      "required": [
        "da_model",
        "images"
      ]

  "DownloadAndLoadDepthAnythingV2Model": {
    "pack": "ComfyUI-DepthAnythingV2",
    "pack_version": "local-5531878",
    "python_module": "ComfyUI-DepthAnythingV2.nodes",
    "category": "DepthAnythingV2",
    "name": "DownloadAndLoadDepthAnythingV2Model",
    "display_name": "\nModels autodownload to `ComfyUI/models/depthanything` from   \nhttps://huggingface.co/Kijai/DepthAnythingV2-safetensors/tree/main   \n   \nfp16 reduces quality by a LOT, not recommended.\n",
    "description": "",
    "inputs": {
      "required": {
        "model": [
          [
            "depth_anything_v2_vits_fp16.safetensors",
            "depth_anything_v2_vits_fp32.safetensors",
            "depth_anything_v2_vitb_fp16.safetensors",
            "depth_anything_v2_vitb_fp32.safetensors",
            "depth_anything_v2_vitl_fp16.safetensors",
            "depth_anything_v2_vitl_fp32.safetensors",
            "depth_anything_v2_vitg_fp32.safetensors",
            "depth_anything_v2_metric_hypersim_vitl_fp32.safetensors",
            "depth_anything_v2_metric_vkitti_vitl_fp32.safetensors"
          ],
          {
            "default": "depth_anything_v2_vitl_fp32.safetensors"
          }
        ]
      },
      "optional": {
        "precision": [
          [
            "auto",
            "bf16",
            "fp16",
            "fp32"
          ],
          {
            "default": "auto"
          }
        ]
      }
    },
    "input_order": {
      "required": [
        "model"
      ],
      "optional": [
        "precision"
      ]
    },
    "input_order_all": [
      "model",
      "precision"
    ],
    "object_info_widget_order": [
      "model",
      "precision"
    ],
    "outputs": [
      {
        "type": "DAMODEL",
        "name": "da_v2_model",
        "is_list": false
      }
    ],
    "function": "loadmodel"
  }
}

  "AILab_Qwen3TTSVoicesLibrary": {
    "category": "🧪AILab/🎙️QwenTTS",
    "description": "",
    "display_name": "Create Voice (QwenTTS)",
    "function": "AILab_Qwen3TTSVoicesLibrary",
    "input_order": {
      "optional": [
        "save_path",
        "unload_models"
      ],
      "required": [
        "reference_audio",
        "reference_text",
        "model_size",
        "device",
        "precision",
        "x_vector_only",
        "voice_name"
      ]
    },
    "input_order_all": [
      "reference_audio",
      "reference_text",
      "model_size",
      "device",
      "precision",
      "x_vector_only",
      "voice_name",
      "save_path",
      "unload_models"
    ],
    "inputs": {
      "optional": {
        "save_path": [
          "STRING",
          {
            "default": "",
            "multiline": false,
            "tooltip": "Custom folder to save voices. Leave empty to use ComfyUI output/qwen3-tts_voices."
          }
        ],
        "unload_models": [
          "BOOLEAN",
          {
            "default": true,
            "tooltip": "Unload cached models after generation"
          }
        ]
      },
      "required": {
        "device": [
          [
            "auto",
            "cuda",
            "cpu"
          ],
          {
            "default": "auto",
            "tooltip": "Compute device for prompt building (auto/cpu/cuda/mps)."
          }
        ],
        "model_size": [
          [
            "0.6B",
            "1.7B"
          ],
          {
            "default": "1.7B",
            "tooltip": "Base model size used to extract speaker features."
          }
        ],
        "precision": [
          [
            "bf16",
            "fp16",
            "fp32"
          ],
          {
            "default": "bf16",
            "tooltip": "Compute precision for prompt building. bf16 recommended on modern GPUs."
          }
        ],
        "reference_audio": [
          "AUDIO",
          {
            "tooltip": "Reference audio used to build the speaker prompt (required)."
          }
        ],
        "reference_text": [
          "STRING",
          {
            "default": "",
            "multiline": true,
            "tooltip": "Transcript of the reference audio. Required unless x_vector_only is enabled."
          }
        ],
        "voice_name": [
          "STRING",
          {
            "default": "voice_1",
            "multiline": false,
            "tooltip": "Saved voice name (file name without extension)."
          }
        ],
        "x_vector_only": [
          "BOOLEAN",
          {
            "default": false,
            "tooltip": "Use speaker embedding only. If enabled, reference_text can be empty."
          }
        ]
      }
    },
    "name": "AILab_Qwen3TTSVoicesLibrary",
    "object_info_widget_order": [
      null,
      "reference_text",
      "model_size",
      "device",
      "precision",
      "x_vector_only",
      "voice_name",
      "save_path",
      "unload_models"
    ],
    "outputs": [
      {
        "is_list": false,
        "name": "VOICE",
        "type": "VOICE"
      }
    ],
    "pack": "AILab_QwenTTS_Tools",
    "pack_version": "runpod-snapshot",
    "python_module": "AILab_QwenTTS_Tools"
  },
  "AILab_Qwen3TTSWhisperSTT": {
    "category": "🧪AILab/🎙️QwenTTS",
    "description": "",
    "display_name": "Whisper STT (QwenTTS)",
    "function": "AILab_Qwen3TTSWhisperSTT",
    "input_order": {
      "optional": [
        "unload_models"
      ],
      "required": [
        "audio",
        "model_size",
        "language"
      ]
    },
    "input_order_all": [
      "audio",
      "model_size",
      "language",
      "unload_models"
    ],
    "inputs": {
      "optional": {
        "unload_models": [
          "BOOLEAN",
          {
            "default": true,
            "tooltip": "Unload cached models after transcription"
          }
        ]
      },
      "required": {
        "audio": [
          "AUDIO",
          {
            "tooltip": "Audio input to transcribe."
          }
        ],
        "language": [
          [
            "auto",
            "en",
            "zh",
            "ja",
            "ko",
            "de",
            "fr",
            "es",
            "it",
            "pt",
            "ru"
          ],
          {
            "default": "auto",
            "tooltip": "Force language or use auto detection."
          }
        ],
        "model_size": [
          [
            "tiny",
            "base",
            "small",
            "medium",
            "large",
            "large-v2",
            "large-v3",
            "large-v3-turbo"
          ],
          {
            "default": "small",
            "tooltip": "Whisper model size. Larger models are slower but more accurate."
          }
        ]
      }
    },
    "name": "AILab_Qwen3TTSWhisperSTT",
    "object_info_widget_order": [
      null,
      "model_size",
      "language",
      "unload_models"
    ],
    "outputs": [
      {
        "is_list": false,
        "name": "text",
        "type": "STRING"
      }
    ],
    "pack": "AILab_QwenTTS_Tools",
    "pack_version": "runpod-snapshot",
    "python_module": "AILab_QwenTTS_Tools"
  }
}
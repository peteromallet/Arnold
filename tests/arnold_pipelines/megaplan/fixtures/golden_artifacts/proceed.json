{
  "schema": "arnold.megaplan.golden_artifacts.path.v1",
  "artifact_path": "proceed",
  "description": "Happy-path Megaplan flow: prep completes, plan generated, critique passes, gate recommends proceed, finalize emits tasks and baselines, execute runs the task DAG, review passes, and the workflow reaches done.",
  "route": "prep \u2192 plan \u2192 critique \u2192 gate(recommendation=proceed) \u2192 finalize \u2192 execute \u2192 review(verdict=pass) \u2192 done",
  "stages": [
    {
      "stage": "prep",
      "artifacts": ["prep_notes_vN.json"],
      "content_type": "application/x-megaplan-plan+json",
      "schema_keys": ["plan_text", "version", "questions"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/prep.py",
      "receipt_metrics": []
    },
    {
      "stage": "plan",
      "artifacts": ["plan_vN.json", "receipt_plan.json"],
      "content_type": "application/x-megaplan-plan+json",
      "schema_keys": ["plan_text", "version", "success_criteria", "assumptions", "step", "success", "summary", "artifacts"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/plan.py",
      "receipt_metrics": ["receipt_plan.success==true", "receipt_plan.artifacts non-empty"]
    },
    {
      "stage": "critique",
      "artifacts": ["receipt_critique.json"],
      "content_type": "application/x-megaplan-receipt+json",
      "schema_keys": ["step", "success", "summary"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/critique.py",
      "receipt_metrics": []
    },
    {
      "stage": "gate",
      "artifacts": ["gate_signals_vN.json", "receipt_gate.json"],
      "content_type": "application/x-megaplan-gate-signal+json",
      "schema_keys": ["signals", "robustness", "preflight_results", "unresolved_flags", "step", "success"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/gate.py",
      "receipt_metrics": ["receipt_gate.success with approval/deny/resume"]
    },
    {
      "stage": "finalize",
      "artifacts": ["finalize_plan_vN.json", "receipt_finalize.json", "tasks.json"],
      "content_type": "application/x-megaplan-plan+json",
      "schema_keys": ["plan_text", "version", "success_criteria", "step", "success", "summary", "artifacts", "tasks", "status"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/finalize.py",
      "receipt_metrics": ["receipt_finalize.success==true", "receipt_finalize.artifacts includes task listing", "baseline selection evidence"]
    },
    {
      "stage": "execute",
      "artifacts": ["receipt_execute.json"],
      "content_type": "application/x-megaplan-execution-evidence+json",
      "schema_keys": ["tasks", "status", "artifacts", "step", "success", "summary"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/execute.py",
      "receipt_metrics": ["receipt_execute.success"]
    },
    {
      "stage": "review",
      "artifacts": ["review_output.json", "receipt_review.json"],
      "content_type": "application/x-megaplan-review-output+json",
      "schema_keys": ["verdict", "rework_items", "summary", "step", "success"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/review.py",
      "receipt_metrics": ["receipt_review.success==true"]
    }
  ],
  "native_trace_files": ["events.ndjson", "state.json", "stages.json", "artifacts.json", "checkpoint.json"],
  "obligated_scenarios": {
    "committed": [
      {
        "scenario_id": "D1-prep-plan",
        "covers": "prep and plan stages with artifact generation and receipt metrics"
      },
      {
        "scenario_id": "D6-finalize",
        "covers": "finalize stage with task listing, baseline selection evidence, and artifact contract"
      },
      {
        "scenario_id": "D8-execute-gates",
        "covers": "gate and execute stages with human decision artifacts and execution evidence"
      }
    ],
    "deferred": [
      {
        "scenario_id": "D5-tiebreaker",
        "owner": "tiebreaker path (not exercised in straight-proceed)",
        "reason": "Tiebreaker only triggers when gate recommends tiebreaker, not on proceed path."
      },
      {
        "scenario_id": "D10-review-caps",
        "owner": "M6/report-conformance",
        "reason": "Requires LLM inference for review approval/block/rework decisions and cap-exhaustion logic."
      }
    ]
  }
}

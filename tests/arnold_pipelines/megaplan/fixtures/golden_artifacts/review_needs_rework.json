{
  "schema": "arnold.megaplan.golden_artifacts.path.v1",
  "artifact_path": "review-needs-rework",
  "description": "When review returns verdict=rework, the workflow loops back through revise \u2192 critique \u2192 gate \u2192 finalize \u2192 execute \u2192 review. Each iteration increments the artifact version and may produce additional delta artifacts. Loop bounded by M4_LOOP_MAX_ITERATIONS=4.",
  "route": "review(verdict=rework) \u2192 revise \u2192 critique \u2192 gate(proceed|iterate) \u2192 finalize \u2192 execute \u2192 review",
  "loop_config": {
    "max_iterations": 4,
    "policy_constant": "M4_LOOP_MAX_ITERATIONS",
    "exhaustion_outcome": "blocked/escalate via override handler"
  },
  "stages": [
    {
      "stage": "review",
      "artifacts": ["review_output.json", "receipt_review.json"],
      "content_type": "application/x-megaplan-review-output+json",
      "schema_keys": ["verdict", "rework_items", "summary", "step", "success"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/review.py",
      "receipt_metrics": ["receipt_review.success per iteration", "verdict=rework triggers revise loop"],
      "notes": "Triggers revise loop when verdict=rework with rework_items populated"
    },
    {
      "stage": "revise",
      "artifacts": ["plan_vN.json", "delta_vN.json", "receipt_revise.json"],
      "content_type": "application/x-megaplan-delta+json",
      "schema_keys": ["plan_text", "version", "success_criteria", "step", "success", "summary"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/revise.py",
      "receipt_metrics": [],
      "notes": "New plan version with incremented version; delta from from_version to to_version"
    },
    {
      "stage": "critique",
      "artifacts": ["receipt_critique.json"],
      "content_type": "application/x-megaplan-receipt+json",
      "schema_keys": ["step", "success", "summary"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/critique.py",
      "receipt_metrics": [],
      "notes": "Re-entry critique on revised plan"
    },
    {
      "stage": "gate",
      "artifacts": ["gate_signals_vN.json", "receipt_gate.json"],
      "content_type": "application/x-megaplan-gate-signal+json",
      "schema_keys": ["signals", "robustness", "preflight_results", "unresolved_flags", "step", "success"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/gate.py",
      "receipt_metrics": [],
      "notes": "Re-entry gate on revised plan; may proceed or iterate again"
    },
    {
      "stage": "finalize",
      "artifacts": ["finalize_plan_vN.json", "receipt_finalize.json", "tasks.json"],
      "content_type": "application/x-megaplan-plan+json",
      "schema_keys": ["plan_text", "version", "success_criteria", "step", "success", "summary", "artifacts", "tasks", "status"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/finalize.py",
      "receipt_metrics": [],
      "notes": "Updated task listing for re-execution"
    },
    {
      "stage": "execute",
      "artifacts": ["receipt_execute.json"],
      "content_type": "application/x-megaplan-execution-evidence+json",
      "schema_keys": ["tasks", "status", "artifacts", "step", "success", "summary"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/execute.py",
      "receipt_metrics": [],
      "notes": "Partial re-execution possible; new execution evidence"
    }
  ],
  "cap_exhaustion_artifacts": [
    {
      "stage": "review",
      "artifacts": ["review_output.json", "receipt_review.json"],
      "content_type": "application/x-megaplan-review-output+json",
      "schema_keys": ["verdict", "rework_items", "summary", "step", "success"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/review.py",
      "receipt_metrics": ["cap-exhaustion detected when verdict=blocked after M4_LOOP_MAX_ITERATIONS"],
      "notes": "On cap exhaustion: verdict=blocked or escalated; override handler may produce additional artifacts"
    }
  ],
  "native_trace_files": ["events.ndjson", "state.json", "stages.json", "artifacts.json", "checkpoint.json"],
  "obligated_scenarios": {
    "committed": [
      {
        "scenario_id": "D1-prep-plan",
        "covers": "plan artifact versioning (plan_vN.json) through revision cycles"
      },
      {
        "scenario_id": "D4-gate-revise",
        "covers": "revise loop stage sequencing and gate re-entry"
      },
      {
        "scenario_id": "D6-finalize",
        "covers": "finalize re-entry with updated task listing"
      },
      {
        "scenario_id": "D8-execute-gates",
        "covers": "execute re-entry and review verdict routing"
      }
    ],
    "deferred": [
      {
        "scenario_id": "D10-review-caps",
        "owner": "M6/report-conformance",
        "reason": "Requires LLM inference for review approval/block/rework decisions and cap-exhaustion logic. Loop bounded by M4_LOOP_MAX_ITERATIONS=4; on exhaustion triggers blocked/escalate."
      }
    ]
  }
}

{
  "schema": "arnold.megaplan.golden_artifacts.path.v1",
  "artifact_path": "execute-failure-resume",
  "description": "When execute encounters partial failure (some tasks succeed, some fail), the workflow writes checkpoint artifacts and can resume from the last completed stage. Checkpoint paths are stable and path-addressed.",
  "route": "execute(partial_failure) \u2192 checkpoint \u2192 resume_from_path \u2192 execute(retry_failed) \u2192 review",
  "stages": [
    {
      "stage": "execute",
      "artifacts": ["receipt_execute.json"],
      "content_type": "application/x-megaplan-execution-evidence+json",
      "schema_keys": ["tasks", "status", "artifacts", "step", "success", "summary"],
      "warrant_source_ref": "arnold_pipelines/megaplan/handlers/execute.py",
      "receipt_metrics": ["receipt_execute.success (false on partial failure)"],
      "notes": "Partial failure: some tasks succeed, some fail; per-task execution evidence with status per task"
    },
    {
      "stage": "checkpoint",
      "artifacts": ["checkpoint.json"],
      "content_type": "application/x-megaplan-state-artifact+json",
      "schema_keys": [],
      "warrant_source_ref": "arnold/pipeline/native/runtime.py",
      "receipt_metrics": ["checkpoint written for each successful task path"],
      "notes": "Path-addressed checkpoint; resume cursor for each successful task path"
    },
    {
      "stage": "resume",
      "artifacts": ["resume_cursor.json", "receipt_execute_resume.json"],
      "content_type": "application/x-megaplan-state-artifact+json",
      "schema_keys": ["step", "success", "summary"],
      "warrant_source_ref": "arnold/pipeline/native/runtime.py",
      "receipt_metrics": ["resume_cursor restores execution state"],
      "notes": "Restores execution state from checkpoint; retries only failed tasks"
    }
  ],
  "native_trace_files": ["events.ndjson", "state.json", "stages.json", "artifacts.json", "checkpoint.json"],
  "native_trace_events": {
    "expected_event_kinds": ["pipeline.init", "phase.start", "phase.end", "stage.complete", "checkpoint"],
    "checkpoint_kind": "checkpoint",
    "normalization": "events.ndjson: strip seq, ts_utc, ts_rel_init_s"
  },
  "obligated_scenarios": {
    "committed": [
      {
        "scenario_id": "D7-execute-dag",
        "covers": "task DAG execution with dependency-ordered batches and partial failure/resume contract"
      },
      {
        "scenario_id": "D8-execute-gates",
        "covers": "execute gates and receipt metrics"
      },
      {
        "scenario_id": "D12-runtime-trace",
        "covers": "native trace emission, checkpoint-driven resume, path-addressed checkpoints"
      }
    ],
    "deferred": [
      {
        "scenario_id": "D10-review-caps",
        "owner": "M6/report-conformance",
        "reason": "Review after execute resume requires LLM inference for approval/block/rework decisions."
      }
    ]
  }
}

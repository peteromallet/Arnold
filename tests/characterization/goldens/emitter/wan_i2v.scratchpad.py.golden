# vibecomfy: generated scratchpad
"""Auto-generated VibeComfy scratchpad."""
from __future__ import annotations

from vibecomfy.workflow import VibeWorkflow, WorkflowSource


def build() -> VibeWorkflow:
    """Build the workflow (auto-generated)."""
    wf = VibeWorkflow(
        'video/wan_i2v',
        WorkflowSource(
            id='video/wan_i2v',
            path='ready_templates/sources/official/video/wan_i2v.json',
            source_type='scratchpad',
            provenance={},
        ),
    )

    unetloader = _node(wf, 'UNETLoader', '37', _uid='n1',
        _outputs=('MODEL',),
        unet_name='wan2.1_i2v_480p_14B_fp16.safetensors',
    )
    cliploader = _node(wf, 'CLIPLoader', '38', _uid='n2',
        _outputs=('CLIP',),
        clip_name='umt5_xxl_fp8_e4m3fn_scaled.safetensors',
        type='wan',
    )
    vaeloader = _node(wf, 'VAELoader', '39', _uid='n3',
        _outputs=('VAE',),
        vae_name='wan_2.1_vae.safetensors',
    )
    clipvisionloader = _node(wf, 'CLIPVisionLoader', '49', _uid='n4',
        _outputs=('CLIP_VISION',),
        clip_name='clip_vision_h.safetensors',
    )
    loadimage = _node(wf, 'LoadImage', '52', _uid='n5',
        _outputs=('IMAGE', 'MASK'),
        image='image_to_video_wan_start_image.png',
    )
    cliptextencode = _node(wf, 'CLIPTextEncode', '6', _uid='n6',
        _outputs=('CONDITIONING',),
        text='a cute anime girl with massive fennec ears and a big fluffy tail wearing a maid outfit turning around',
        clip=cliploader.out('CLIP'),
    )
    cliptextencode_2 = _node(wf, 'CLIPTextEncode', '7', _uid='n7',
        _outputs=('CONDITIONING',),
        text='色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走',
        clip=cliploader.out('CLIP'),
    )
    clipvisionencode = _node(wf, 'CLIPVisionEncode', '51', _uid='n8',
        _outputs=('CLIP_VISION_OUTPUT',),
        crop='none',
        clip_vision=clipvisionloader.out('CLIP_VISION'),
        image=loadimage.out('IMAGE'),
    )
    modelsamplingsd3 = _node(wf, 'ModelSamplingSD3', '54', _uid='n9',
        _outputs=('MODEL',),
        shift=8,
        model=unetloader.out('MODEL'),
    )
    wanimagetovideo = _node(wf, 'WanImageToVideo', '50', _uid='n10',
        _outputs=('POSITIVE', 'NEGATIVE', 'LATENT'),
        widget_0=512,
        widget_1=512,
        widget_2=33,
        widget_3=1,
        clip_vision_output=clipvisionencode.out('CLIP_VISION_OUTPUT'),
        negative=cliptextencode_2.out('CONDITIONING'),
        positive=cliptextencode.out('CONDITIONING'),
        start_image=loadimage.out('IMAGE'),
        vae=vaeloader.out('VAE'),
    )
    ksampler = _node(wf, 'KSampler', '3', _uid='n11',
        _outputs=('LATENT',),
        seed=987948718394761,
        cfg=6,
        sampler_name='uni_pc',
        latent_image=wanimagetovideo.out('LATENT'),
        model=modelsamplingsd3.out('MODEL'),
        negative=wanimagetovideo.out('NEGATIVE'),
        positive=wanimagetovideo.out('POSITIVE'),
    )
    vaedecode = _node(wf, 'VAEDecode', '8', _uid='n12',
        _outputs=('IMAGE',),
        samples=ksampler.out('LATENT'),
        vae=vaeloader.out('VAE'),
    )
    createvideo = _node(wf, 'CreateVideo', '55', _uid='n13',
        _outputs=('VIDEO',),
        fps=16,
        images=vaedecode.out('IMAGE'),
    )
    savevideo = _node(wf, 'SaveVideo', '56', _uid='n14',
        video=createvideo.out('VIDEO'),
    )

    wf.finalize_metadata()
    return wf


def _node(
    wf: VibeWorkflow,
    class_type: str,
    _id: str,
    _extras: dict | None = None,
    _outputs: tuple[str, ...] | None = None,
    _uid: str | None = None,
    **kwargs,
):
    """Create a node, preserving the original node id from the source workflow.

    `_extras` carries kwargs whose names are not valid Python identifiers
    (e.g. "resize_type.multiple") which Python disallows as kwarg syntax.
    They are applied to the new node post-construction.
    """
    from vibecomfy.handles import Handle
    builder = wf.node(class_type, **kwargs)
    if _uid:
        builder.node.uid = _uid
    if _outputs is not None:
        builder.node.metadata["output_names"] = list(_outputs)
    if _extras:
        for key, value in _extras.items():
            if isinstance(value, Handle):
                wf.connect(value, f"{builder.node.id}.{key}")
            else:
                builder.node.inputs[key] = value
    if builder.node.id != _id:
        old_id = builder.node.id
        node = wf.nodes.pop(old_id)
        node.id = _id
        wf.nodes[_id] = node
        for edge in wf.edges:
            if edge.to_node == old_id:
                edge.to_node = _id
            if edge.from_node == old_id:
                edge.from_node = _id
    return builder


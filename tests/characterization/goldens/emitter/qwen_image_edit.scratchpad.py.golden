        switch=False,
        on_false=unetloader.out('MODEL'),
        on_true=loraloadermodelonly.out('MODEL'),
    )
    modelsamplingauraflow = _node(wf, 'ModelSamplingAuraFlow', '11', _uid='n12',
        _outputs=('MODEL',),
        shift=3,
        model=comfyswitchnode_3.out('OUTPUT'),
    )
    cfgnorm = _node(wf, 'CFGNorm', '12', _uid='n13',
        _outputs=('PATCHED_MODEL',),
        widget_0=1,
        model=modelsamplingauraflow.out('MODEL'),
    )
    ksampler = _node(wf, 'KSampler', '13', _uid='n14',
        _outputs=('LATENT',),
        seed=344147753686358,
        sampler_name='euler',
        steps=comfyswitchnode_2.out('OUTPUT'),
        cfg=comfyswitchnode.out('OUTPUT'),
        latent_image=vaeencode.out('LATENT'),
        model=cfgnorm.out('PATCHED_MODEL'),
        negative=textencodeqwenimageedit_2.out('CONDITIONING'),
        positive=textencodeqwenimageedit.out('CONDITIONING'),

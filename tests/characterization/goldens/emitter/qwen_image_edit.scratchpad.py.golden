# vibecomfy: generated scratchpad
"""Auto-generated VibeComfy scratchpad."""
from __future__ import annotations

from vibecomfy.workflow import VibeWorkflow, WorkflowSource


def build() -> VibeWorkflow:
    """Build the workflow (auto-generated)."""
    wf = VibeWorkflow(
        'edit/qwen_image_edit',
        WorkflowSource(
            id='edit/qwen_image_edit',
            path='ready_templates/sources/official/edit/qwen_image_edit.json',
            source_type='scratchpad',
            provenance={},
        ),
    )

    unetloader = _node(wf, 'UNETLoader', '1', _uid='n2',
        _outputs=('MODEL',),
        unet_name='qwen_image_edit_fp8_e4m3fn.safetensors',
    )
    cliploader = _node(wf, 'CLIPLoader', '2', _uid='n3',
        _outputs=('CLIP',),
        clip_name='qwen_2.5_vl_7b_fp8_scaled.safetensors',
        type='qwen_image',
    )
    vaeloader = _node(wf, 'VAELoader', '3', _uid='n4',
        _outputs=('VAE',),
        vae_name='qwen_image_vae.safetensors',
    )
    comfyswitchnode = _node(wf, 'ComfySwitchNode', '4', _uid='n5',
        _outputs=('OUTPUT',),
        switch=False,
    )
    comfyswitchnode_2 = _node(wf, 'ComfySwitchNode', '5', _uid='n6',
        _outputs=('OUTPUT',),
        switch=False,
    )
    loadimage = _node(wf, 'LoadImage', '78', _uid='n1',
        _outputs=('IMAGE', 'MASK'),
        image='image_qwen_image_edit_input_image.png',
    )
    textencodeqwenimageedit = _node(wf, 'TextEncodeQwenImageEdit', '6', _uid='n7',
        _outputs=('CONDITIONING',),
        prompt='Remove all UI text elements from the image. Keep the feeling that the characters and scene are in water. Also, remove the green UI elements at the bottom.',
        clip=cliploader.out('CLIP'),
        image=loadimage.out('IMAGE'),
        vae=vaeloader.out('VAE'),
    )
    textencodeqwenimageedit_2 = _node(wf, 'TextEncodeQwenImageEdit', '7', _uid='n8',
        _outputs=('CONDITIONING',),
        prompt='',
        clip=cliploader.out('CLIP'),
        image=loadimage.out('IMAGE'),
        vae=vaeloader.out('VAE'),
    )
    vaeencode = _node(wf, 'VAEEncode', '8', _uid='n9',
        _outputs=('LATENT',),
        pixels=loadimage.out('IMAGE'),
        vae=vaeloader.out('VAE'),
    )
    loraloadermodelonly = _node(wf, 'LoraLoaderModelOnly', '9', _uid='n10',
        _outputs=('MODEL',),
        lora_name='Qwen-Image-Edit-Lightning-4steps-V1.0-bf16.safetensors',
        model=unetloader.out('MODEL'),
    )
    comfyswitchnode_3 = _node(wf, 'ComfySwitchNode', '10', _uid='n11',

# vibecomfy: generated scratchpad
"""Auto-generated VibeComfy scratchpad."""
from __future__ import annotations

from vibecomfy.workflow import VibeWorkflow, WorkflowSource


def build() -> VibeWorkflow:
    """Build the workflow (auto-generated)."""
    wf = VibeWorkflow(
        'video/wan_t2v',
        WorkflowSource(
            id='video/wan_t2v',
            path='ready_templates/sources/official/video/wan_t2v.json',
            source_type='scratchpad',
            provenance={},
        ),
    )

    unetloader = _node(wf, 'UNETLoader', '37', _uid='n1',
        _outputs=('MODEL',),
        unet_name='wan2.1_t2v_1.3B_fp16.safetensors',
    )
    cliploader = _node(wf, 'CLIPLoader', '38', _uid='n2',
        _outputs=('CLIP',),
        clip_name='umt5_xxl_fp8_e4m3fn_scaled.safetensors',
        type='wan',
    )
    vaeloader = _node(wf, 'VAELoader', '39', _uid='n3',
        _outputs=('VAE',),
        vae_name='wan_2.1_vae.safetensors',
    )
    emptyhunyuanlatentvideo = _node(wf, 'EmptyHunyuanLatentVideo', '40', _uid='n4',
        _outputs=('LATENT',),
        width=832,
        height=480,
        length=33,
    )
    positive = _node(wf, 'CLIPTextEncode', '6', _uid='n5',
        _outputs=('CONDITIONING',),
        text='a fox moving quickly in a beautiful winter scenery nature trees mountains daytime tracking camera',
        clip=cliploader.out('CLIP'),
    )
    negative = _node(wf, 'CLIPTextEncode', '7', _uid='n6',
        _outputs=('CONDITIONING',),
        text='色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走',
        clip=cliploader.out('CLIP'),
    )
    modelsamplingsd3 = _node(wf, 'ModelSamplingSD3', '48', _uid='n7',
        _outputs=('MODEL',),
        shift=8,
        model=unetloader.out('MODEL'),
    )
    ksampler = _node(wf, 'KSampler', '3', _uid='n8',
        _outputs=('LATENT',),
        seed=82628696717253,
        steps=30,
        cfg=6,
        sampler_name='uni_pc',
        latent_image=emptyhunyuanlatentvideo.out('LATENT'),
        model=modelsamplingsd3.out('MODEL'),
        negative=negative.out('CONDITIONING'),
        positive=positive.out('CONDITIONING'),
    )
    vaedecode = _node(wf, 'VAEDecode', '8', _uid='n9',
        _outputs=('IMAGE',),
        samples=ksampler.out('LATENT'),
        vae=vaeloader.out('VAE'),
    )
    createvideo = _node(wf, 'CreateVideo', '49', _uid='n10',
        _outputs=('VIDEO',),
        fps=16,
        images=vaedecode.out('IMAGE'),
    )
    savevideo = _node(wf, 'SaveVideo', '50', _uid='n11',
        video=createvideo.out('VIDEO'),
    )

    wf.finalize_metadata()
    return wf


def _node(
    wf: VibeWorkflow,
    class_type: str,
    _id: str,
    _extras: dict | None = None,
    _outputs: tuple[str, ...] | None = None,
    _uid: str | None = None,
    **kwargs,
):
    """Create a node, preserving the original node id from the source workflow.

    `_extras` carries kwargs whose names are not valid Python identifiers
    (e.g. "resize_type.multiple") which Python disallows as kwarg syntax.
    They are applied to the new node post-construction.
    """
    from vibecomfy.handles import Handle
    builder = wf.node(class_type, **kwargs)
    if _uid:
        builder.node.uid = _uid
    if _outputs is not None:
        builder.node.metadata["output_names"] = list(_outputs)
    if _extras:
        for key, value in _extras.items():
            if isinstance(value, Handle):
                wf.connect(value, f"{builder.node.id}.{key}")
            else:
                builder.node.inputs[key] = value
    if builder.node.id != _id:
        old_id = builder.node.id
        node = wf.nodes.pop(old_id)
        node.id = _id
        wf.nodes[_id] = node
        for edge in wf.edges:
            if edge.to_node == old_id:
                edge.to_node = _id
            if edge.from_node == old_id:
                edge.from_node = _id
    return builder


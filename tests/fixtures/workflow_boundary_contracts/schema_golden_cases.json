        "ExternalEffectPayload": "arnold.workflow.ledger.external_effect_payload.v1"
      },
      "mutual_exclusion": {
        "description": "inline_data and ref are mutually exclusive; at least one of inline_data, ref, or content_digest required",
        "valid_inline_only": {"inline_data": {"key": "val"}, "ref": null, "content_digest": null},
        "valid_ref_only": {"inline_data": null, "ref": "uses_durable_ref", "content_digest": null},
        "valid_digest_only": {"inline_data": null, "ref": null, "content_digest": "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"},
        "failure_both_inline_and_ref": {"inline_data": {"k": "v"}, "ref": "has_ref", "error": "inline_data and ref are mutually exclusive"},
        "failure_nothing_provided": {"inline_data": null, "ref": null, "content_digest": null, "error": "at least one of inline_data, ref, or content_digest must be provided"}
      }
    },
    "adapter_kinds": [

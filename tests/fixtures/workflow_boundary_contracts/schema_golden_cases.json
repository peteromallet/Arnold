{
  "schema_version": "arnold.workflow.boundary_contracts.golden.v1",
  "description": "Deterministic compact golden cases for workflow boundary contract schemas — ledger events, identity/order failures, inline payloads, referenced payloads, retention/redaction/legal-hold classes, and persistence-failure states.",
  "cases": {
    "ledger_event_types": {
      "all_event_types": [
        "started",
        "completed",
        "failed",
        "retry_scheduled",
        "suspended",
        "resumed",
        "cancelled",
        "external_effect_intent",
        "external_effect_outcome",
        "persistence_failed",
        "reconciliation"
      ],
      "terminal_event_types": ["completed", "failed", "cancelled"],
      "lifecycle_precedence": {
        "started": [],
        "completed": ["started"],
        "failed": ["started"],
        "retry_scheduled": ["started"],
        "suspended": ["started"],
        "resumed": ["suspended"],
        "cancelled": ["started"],
        "external_effect_intent": ["started"],
        "external_effect_outcome": ["external_effect_intent"],
        "persistence_failed": [],
        "reconciliation": ["persistence_failed"]
      }
    },
    "identity": {
      "valid_minimal": {

#!/usr/bin/env bash
set -uo pipefail
LOG=/workspace/heartbeat.log
WARN_SECS=${HEARTBEAT_WARN_SECS:-600}
STALL_SECS=${HEARTBEAT_STALL_SECS:-1200}
KILL_ON_STALL=${HEARTBEAT_KILL_ON_STALL:-1}
declare -A LAST_KEY  # pid -> "size:mtime"
declare -A LAST_TS   # pid -> epoch when last change observed
declare -A WARNED    # pid -> 1 once warned
echo "[heartbeat $(date -Iseconds)] starting (warn=${WARN_SECS}s stall=${STALL_SECS}s kill=${KILL_ON_STALL})" >> "$LOG"
while true; do
  now=$(date +%s)
  pids=$(pgrep -f 'codex exec' || true)
  active_pids=""
  for pid in $pids; do
    cmdline=$(tr '\0' ' ' < /proc/$pid/cmdline 2>/dev/null || echo "")
    out=$(echo "$cmdline" | grep -oP -- '-o \K/tmp/\S+' | head -1)
    [[ -z "$out" || ! -f "$out" ]] && continue
    active_pids="$active_pids $pid"
    sz=$(stat -c %s "$out" 2>/dev/null || echo 0)
    mt=$(stat -c %Y "$out" 2>/dev/null || echo 0)
    key="${sz}:${mt}"
    if [[ "${LAST_KEY[$pid]:-}" != "$key" ]]; then
      LAST_KEY[$pid]="$key"
      LAST_TS[$pid]="$now"
      WARNED[$pid]=0
      continue
    fi
    idle=$(( now - LAST_TS[$pid] ))
    if [[ $idle -ge $STALL_SECS ]]; then
      last_event=$(tail -c 4096 "$out" 2>/dev/null | tr -d '\0' | tail -1 | head -c 300)
      echo "[heartbeat $(date -Iseconds)] STALL pid=$pid idle=${idle}s out=$out last=${last_event}" >> "$LOG"
      if [[ "$KILL_ON_STALL" == "1" ]]; then
        echo "[heartbeat $(date -Iseconds)] sending SIGINT to pid=$pid" >> "$LOG"
        kill -INT "$pid" 2>/dev/null || true
      fi
      LAST_TS[$pid]="$now"  # reset so we don't hammer
    elif [[ $idle -ge $WARN_SECS && "${WARNED[$pid]:-0}" != "1" ]]; then
      last_event=$(tail -c 4096 "$out" 2>/dev/null | tr -d '\0' | tail -1 | head -c 300)
      echo "[heartbeat $(date -Iseconds)] WARN pid=$pid idle=${idle}s out=$out last=${last_event}" >> "$LOG"
      WARNED[$pid]=1
    fi
  done
  # Drop tracking for pids that disappeared
  for pid in "${!LAST_KEY[@]}"; do
    if [[ ! " $active_pids " =~ " $pid " ]]; then
      unset LAST_KEY[$pid] LAST_TS[$pid] WARNED[$pid]
    fi
  done
  sleep 60
done

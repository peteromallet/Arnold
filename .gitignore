# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
# Vendored packages ship pre-built dist/ because Railway's build context can't
# build them from source the way the workspace does. Whitelist them so the
# top-level `dist` rule above doesn't strip them out of the deploy artifact.
!vendor/**/dist
!vendor/**/dist/**

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Decruftify generated files
.decruftify/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# User uploaded files and images
public/files/
public/uploads/
local.db

# Temporary files
temp/

# Ignore all markdown files except structure.md, structure_detail/, tasks/, and CLAUDE.md
*.md
!structure.md
!structure_detail/*.md
!docs/structure_detail/*.md
!docs/blog/*.md
!docs/quality/*.md
!docs/state_management_refactor_baselines.md
!docs/state_management_context_audit.md
!docs/design/*.md
!docs/extensions/foundation-contract-ledger.md
!docs/extensions/foundation-closure-assessment.md
!docs/extensions/composition-spine/*.md
!docs/video-editor/*.md
!scripts/quality/__fixtures__/trust-model-truth/active-unsupported/docs/video-editor/shader-execution-model.md
!tasks/*.md
!CLAUDE.md
!/.megaplan/briefs/**/*.md

# Stray media files in root (should be in public/)
/*.mp4
/*.webm
/*.mov
/*.gif
/*.png
!scorecard.png
/*.jpg
/*.jpeg
/*.webp

# Archive files in root
/*.zip
/*.rar
/*.7z

# Python cache/venvs
__pycache__/
*.pyc
.venv*/
.ruff_cache/

# Audit/review artifacts
.desloppify/
findings*.json
perfile_findings.json
type_safety_review*.json

# Localhost dev logs (already covered by *.log but be explicit)
localhost-*.log

# Supabase CLI artifacts
supabase/.temp/
supabase/.branches/
.claude/worktrees/

# megaplan per-run state files — writing them during execute triggers megaplan audit false-positives
.megaplan/plans/
this.env

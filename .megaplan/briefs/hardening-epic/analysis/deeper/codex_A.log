   162	    debt_block = _planning_debt_block(plan_dir, root)
   163	
   164	    # ----- prompt-size guard: keep the assembled context under ~150K tokens -----
   165	    # Estimate tokens ≈ chars / 4.  The debt block and the full plan text are
   166	    # the dominant contributors; a 1.6M-token prompt silently overflows the model
   167	    # context and produces an empty response (see hermes retry-on-empty guard).
   168	    _TOKEN_BUDGET = 150_000
   169	    _CHAR_BUDGET = _TOKEN_BUDGET * 4  # ~600K chars
   170	
   171	    # Rough size check on the fields that end up in the assembled prompt.
   172	    # The prompt template adds ~5K chars of fixed text, so leave headroom.
   173	    _plan_len = len(latest_plan)
   174	    _debt_len = len(debt_block)
   175	    _flags_len = len(json_dump(unresolved).strip())
   176	    _meta_len = len(json_dump(latest_meta).strip())
   177	    _warn_len = len(json_dump(structure_warnings).strip())
   178	    _total_est = _plan_len + _debt_len + _flags_len + _meta_len + _warn_len
   179	
   180	    if _total_est > _CHAR_BUDGET:
   181	        overage = _total_est - _CHAR_BUDGET
   182	        # 1. Trim the debt block first (it is the least essential for critique)
   183	        if _debt_len > 0 and overage > 0:

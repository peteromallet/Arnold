# Copy to .env only for local development. Do not commit real secrets.

# Premium model access. Megaplan setup can also use existing Claude/Codex logins.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Cheap-phase provider access. Use DeepSeek by default, or Fireworks with
# --deepseek-provider fireworks.
DEEPSEEK_API_KEY=
FIREWORKS_API_KEY=

# Optional: cloud runs that need to clone private GitHub repositories.
GITHUB_TOKEN=

# Optional: shared database/progress backends.
SUPABASE_DB_URL=
MEGAPLAN_ACTOR_ID=

# Copy to .env only for local development. Do not commit real secrets.

# Premium model access. Megaplan setup can also use existing Claude/Codex logins.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Cheap-phase provider access. Use DeepSeek by default, or Fireworks with
# --deepseek-provider fireworks.
DEEPSEEK_API_KEY=
FIREWORKS_API_KEY=

# Optional: direct Moonshot Kimi API (used by partnered-3/4 profiles).
# Also reads from ~/.hermes/.env and accepts MOONSHOT_API_KEY as an alias.
KIMI_API_KEY=

# xAI Grok (OpenAI-compatible). Use via Hermes with prefix e.g. hermes:xai:grok-4.5
# or xai:grok-4.5 in appropriate contexts. Matches the direct endpoint https://api.x.ai/v1
XAI_API_KEY=

# Optional: cloud runs that need to clone private GitHub repositories.
GITHUB_TOKEN=

# Optional: shared database/progress backends.
SUPABASE_DB_URL=
MEGAPLAN_ACTOR_ID=

{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "preinstall": "npx --yes only-allow npm",
    "preflight": "docker build .",
    "dev": "vite --config config/vite/vite.config.ts",
    "dev:embed-demo": "vite --config examples/embed-demo/vite.config.ts",
    "build": "tsc && vite build --config config/vite/vite.config.ts",
    "build:embed-demo": "vite build --config examples/embed-demo/vite.config.ts",
    "build:dev": "vite build --mode development --config config/vite/vite.config.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:edge": "eslint supabase/functions --ext ts --max-warnings 0",
    "preview": "vite preview --config config/vite/vite.config.ts",
    "preview:embed-demo": "vite preview --config examples/embed-demo/vite.config.ts",
    "preview:full": "npm run preview --port 5001",
    "start:railway": "npm run build && npm run serve",
    "serve": "vite preview --config config/vite/vite.config.ts --host 0.0.0.0 --port $PORT",
    "db:seed": "tsx ./db/seed.ts",
    "bun:dev": "bun run dev",
    "bun:build": "bun run build",
    "bun:preview": "bun run preview",
    "bun:install": "bun install",
    "test": "npm run check:no-smoke-tests && vitest run --config config/testing/vitest.config.ts",
    "test:contracts": "vitest run --config config/testing/vitest.config.ts src/**/**/*.contract.test.ts src/**/**/clientContracts.test.ts src/shared/lib/__tests__/qualityCheck.contract.test.ts",
    "test:sdk-boundary": "vitest run --config config/testing/vitest.boundary.config.ts",
    "test:arch": "npm run check:shots-shim-usage && npm run check:core-shim-usage && npm run check:video-editor-sdk-imports && npm run check:error-runtime-alias-usage && npm run check:fat-contexts && npm run check:contracts && npm run check:contract-surface-map",
    "test:edge": "npm run test:edge:unit && npm run test:edge:smoke",
    "test:edge:unit": "vitest run --config config/testing/vitest.edge.config.ts",
    "test:edge:smoke": "vitest run --config config/testing/vitest.edge.smoke.config.ts --testNamePattern=\"Smoke\"",
    "test:extensions": "npm run check:extension-drift -- --release && npm run check:extension-family-conformance -- --release && npm run check:sdk-public-exports -- --release && npm run check:video-editor-sdk-imports && vitest run --config config/testing/vitest.config.ts src/sdk/manifest-schema-validation.test.ts src/sdk/index.test.ts src/sdk/examples-governance.test.ts src/sdk/extensionSettingsService.test.ts src/sdk/extensionSettingsMigration.test.ts",
    "test:extensions:production-smoke": "vitest run --config config/testing/vitest.config.ts src/sdk/smoke/extensionSmoke.test.ts",
    "test:slot:unit": "vitest run --config config/testing/vitest.config.ts src/shared/hooks/__tests__/usePromoteVariantToGeneration.test.ts src/domains/media-lightbox/hooks/useVariantPromotion.test.ts src/tools/video-editor/hooks/useAddVariantAsGeneration.test.tsx",
    "test:slot:edge": "npm run test:edge:smoke",
    "test:slot:db": "node scripts/quality/run-slot-pgtap.mjs",
    "test:slot:e2e": "playwright test --config playwright.config.ts",
    "slot:first:health": "node scripts/quality/check-slot-first-health.mjs",
    "test:watch": "npm run check:no-smoke-tests && vitest --config config/testing/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/testing/vitest.config.ts",
    "check:edge-budget": "node scripts/edge/quality-budget.mjs --check",
    "check:no-smoke-tests": "node scripts/quality/check-no-smoke-tests.mjs",
    "check:core-shim-usage": "node scripts/quality/check-core-shim-usage.mjs",
    "check:video-editor-sdk-imports": "node scripts/quality/check-video-editor-sdk-imports.mjs",
    "check:error-runtime-alias-usage": "node scripts/quality/check-error-runtime-alias-usage.mjs",
    "check:fat-contexts": "node scripts/quality/check-fat-contexts.mjs",
    "check:shots-shim-usage": "node scripts/quality/check-shots-shim-usage.mjs --max 0",
    "check:contracts": "node scripts/quality/check-contract-governance.mjs",
    "check:contract-surface-map": "node scripts/quality/check-contract-surface-map.mjs",
    "check:contract-recheck": "node scripts/quality/check-extension-contract-recheck.mjs --audit",
    "check:contract-recheck:release": "node scripts/quality/check-extension-contract-recheck.mjs --release",
    "check:deferred-claims": "node scripts/quality/check-extension-deferred-claims.mjs --audit",
    "check:deferred-claims:release": "node scripts/quality/check-extension-deferred-claims.mjs --release",
    "check:sdk-public-exports": "node scripts/quality/check-sdk-public-exports.mjs --audit",
    "check:sdk-public-exports:release": "node scripts/quality/check-sdk-public-exports.mjs --release",
    "check:sdk-no-barrel-imports": "node scripts/quality/check-sdk-no-barrel-imports.mjs --audit",
    "check:sdk-no-barrel-imports:release": "node scripts/quality/check-sdk-no-barrel-imports.mjs --release",
    "check:frontend-closure": "node scripts/quality/check-frontend-closure-matrix.mjs --audit",
    "check:frontend-closure:release": "node scripts/quality/check-frontend-closure-matrix.mjs --release",
    "check:example-readiness": "node scripts/quality/check-extension-example-readiness.mjs --audit",
    "check:example-readiness:release": "node scripts/quality/check-extension-example-readiness.mjs --release",
    "check:extension-drift": "node scripts/quality/check-extension-drift.mjs --audit",
    "check:extension-drift:release": "node scripts/quality/check-extension-drift.mjs --release",
    "check:extension-family-conformance": "tsx scripts/quality/check-extension-family-conformance.mjs --audit",
    "check:extension-family-conformance:release": "tsx scripts/quality/check-extension-family-conformance.mjs --release",
    "check:release-checklist": "node scripts/quality/check-extension-release-checklist.mjs --audit",
    "check:release-checklist:release": "node scripts/quality/check-extension-release-checklist.mjs --release",
    "check:docs-maturity-sync": "node scripts/quality/check-docs-maturity-sync.mjs --audit",
    "check:docs-maturity-sync:release": "node scripts/quality/check-docs-maturity-sync.mjs --release",
    "quality:schema-drift": "node scripts/quality/check-schema-drift.mjs",
    "quality:test-fixture-legacy": "node scripts/quality/check-test-fixture-legacy.mjs",
    "quality:slot-first:audit": "npm run test:slot:unit && npm run test:slot:edge && npm run test:slot:db -- --audit && npm run quality:schema-drift -- --audit && npm run quality:test-fixture-legacy -- --audit && npm run slot:first:health -- --audit && npm run test:slot:e2e",
    "lint:strict-islands": "eslint src/app src/integrations/supabase/bootstrap src/shared/lib/debugPolling.ts src/shared/lib/mobileProjectDebug.ts src/shared/components/MediaGallery/hooks/useMediaGalleryDebugTools.ts src/shared/components/MediaLightbox/hooks/useVideoLightboxEnvironment.ts src/shared/components/MediaLightbox/hooks/useVideoLightboxRenderModel.tsx src/tools/travel-between-images/components/ShotImagesEditor/hooks/useShotImagesEditorCallbacks.ts src/tools/travel-between-images/components/ShotImagesEditor/hooks/useShotImagesEditorModel.ts src/shared/lib/tasks/travelBetweenImages supabase/functions/create-task --ext ts,tsx --max-warnings 0",
    "typecheck:strict-islands": "tsc -p tsconfig.strict-islands.json --noEmit",
    "typecheck:strict-probe": "npm run typecheck:strict-islands",
    "quality:check": "npm run check:no-smoke-tests && npm run check:shots-shim-usage && npm run check:core-shim-usage && npm run check:video-editor-sdk-imports && npm run check:error-runtime-alias-usage && npm run check:fat-contexts && npm run check:contracts && npm run check:contract-surface-map && npm run check:contract-recheck && npm run check:deferred-claims && npm run check:docs-maturity-sync && npm run check:extension-family-conformance && npm run check:sdk-public-exports && npm run check:frontend-closure && npm run check:example-readiness && npm run check:release-checklist && npm run lint && npm run typecheck:strict-probe && npm run test:readiness",
    "test:readiness": "node scripts/quality/check-readiness.mjs --strict && vitest run --config config/testing/vitest.config.ts src/tools/video-editor/runtime/extensionLifecycle.test.ts src/tools/video-editor/runtime/ContributionErrorBoundary.test.tsx src/tools/video-editor/components/TimelineEditorShellCore.test.tsx src/tools/video-editor/components/PropertiesPanel/PropertiesPanel.test.tsx src/tools/video-editor/runtime/extensionSurface.test.ts src/tools/video-editor/contexts/VideoEditorProvider.test.tsx src/tools/video-editor/components/ExtensionManager/ExtensionManager.test.tsx src/tools/video-editor/runtime/phase4ReadinessDocs.test.ts",
    "test:readiness:e2e": "playwright test --config playwright.config.ts tests/e2e/extension-harness.spec.ts"
  },
  "dependencies": {
    "@banodoco/timeline-composition": "file:vendor/timeline-composition",
    "@banodoco/timeline-ops": "file:vendor/timeline-ops",
    "@banodoco/timeline-schema": "file:vendor/timeline-schema",
    "@banodoco/timeline-theme-2rp": "file:vendor/timeline-theme-2rp",
    "@base-ui/react": "1.2.0",
    "@dnd-kit/core": "^6.3.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@remotion/media": "^4.0.438",
    "@remotion/player": "^4.0.434",
    "@remotion/web-renderer": "4.0.438",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.56.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "gifenc": "^1.0.3",
    "jszip": "^3.10.1",
    "konva": "^10.2.0",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-joyride": "^2.9.3",
    "react-konva": "^18.2.14",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.2",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.434",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^2.5.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.60.0",
    "@remotion/layout-utils": "^4.0.452",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "fake-indexeddb": "file:vendor/fake-indexeddb",
    "globals": "^15.9.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "npm@10.8.2"
}

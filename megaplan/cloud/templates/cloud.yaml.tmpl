# Cloud runner spec for `megaplan cloud`.
#
# provider:
#   Supported providers: railway, local, ssh. `fly` is reserved for a future release.
provider: railway

# repo:
#   url      Git repository cloned into the persistent workspace volume.
#   branch   Branch checked out on first boot.
#   workspace
#            Absolute path inside the container where the repo lives.
repo:
  url: https://github.com/example/app.git
  branch: main
  workspace: /workspace/app

# extra_repos:
#   Optional sibling repos cloned into the volume alongside the primary
#   `repo`. Useful when a chain or plan references multiple repos (e.g.
#   app + worker + orchestrator + agent). Each repo needs a unique
#   workspace path. The entrypoint clones-if-missing on every boot, so
#   adding a new entry on a redeploy will fetch it without rebuilding.
# extra_repos:
#   - url: https://github.com/example/worker.git
#     branch: main
#     workspace: /workspace/worker
#   - url: https://github.com/example/agent.git
#     branch: main
#     workspace: /workspace/agent

# chain_session:
#   tmux session name used by `megaplan cloud chain` to host the chain
#   runner. Override per cloud.yaml when running multiple chains on the
#   same long-lived worker (e.g. chain_session: slot-first), so each
#   chain has an isolated tmux session and log file.
# chain_session: megaplan-chain

# agents:
#   `default` applies to every megaplan step. Add per-step overrides only when
#   a specific phase should use a different agent.
agents:
  default: codex
  # execute: codex
  # review: codex

# codex:
#   Written to /root/.codex/config.toml on every boot.
codex:
  model: gpt-5.4
  reasoning: high

# mode behavior:
#   | mode  | agent session boot action                                  | required fields                    |
#   | auto  | init plan if missing, then run `megaplan auto --plan ...` | auto.plan_name, auto.idea_file     |
#   | chain | run `megaplan chain start --spec ...`                      | chain.spec                         |
#   | idle  | start `bash -l` only                                       | none                               |
#   Missing auto.idea_file or chain.spec is a warning path in sprint 1: the
#   container drops to idle instead of crashing so you can upload files manually.
mode: idle

# auto:
#   Required only when mode=auto.
auto:
  plan_name: my-plan
  idea_file: /workspace/idea.txt
  robustness: standard

# chain:
#   Required only when mode=chain.
chain:
  spec: /workspace/chain.yaml

# toolchains:
#   Optional extra language toolchains layered into the cloud image.
#   Use built-in aliases (`rust`, `go`, `java`) or a custom install snippet.
# toolchains:
#   - rust
#   - name: custom
#     install: |
#       RUN curl -fsSL https://example.com/tool/install.sh | bash

# megaplan:
#   ref           Branch/tag/SHA used for git installs.
#   repo          Optional git URL of the megaplan source repo. When set, the
#                 container installs current megaplan from this repo at `ref`
#                 on every boot and before each `megaplan cloud chain` run.
#   install_spec  Advanced pip-spec override, installed verbatim. Git specs get
#                 `@ref` appended.
megaplan:
  ref: main
  # repo: https://github.com/peteromallet/arnold.git
  # install_spec: megaplan-harness[agent] @ git+https://github.com/peteromallet/arnold.git

# resources:
#   volume  Provider-specific persistent volume name. `destroy` deletes it.
#   port    Health server port exposed by the container.
resources:
  volume: agent-volume
  port: 8080

# railway:
#   service  Railway service name used by deploy/logs/down.
#   session  Railway ssh session name used for interactive attaches.
#   project  Optional Railway project ID/name for `railway link --project ...`.
#   environment
#            Optional Railway environment ID/name passed to operational commands.
railway:
  service: agent
  session: agent
  # project: your-railway-project-id
  # environment: production

# local:
#   compose_project  Docker Compose project name used by the local provider.
#   workdir          Bind-mounted subdirectory inside the persistent deploy dir.
# local:
#   compose_project: megaplan-cloud
#   workdir: workspace

# ssh:
#   host           Required when provider=ssh.
#   user           Optional SSH username.
#   port           SSH port.
#   identity_file  Optional SSH identity file.
#   remote_dir     Remote directory that receives the synced deploy context.
#   container      Remote Docker container/image name.
# ssh:
#   host: docker-host.example.com
#   user: deployer
#   port: 22
#   # identity_file: ~/.ssh/id_ed25519
#   remote_dir: /tmp/megaplan-cloud
#   container: megaplan-cloud-agent

# secrets:
#   Names of environment variables read locally during `megaplan cloud deploy`
#   and uploaded to the provider before boot. OPENAI_API_KEY is the minimum
#   viable secret; add GITHUB_TOKEN / ANTHROPIC_API_KEY as needed.
secrets:
  - OPENAI_API_KEY

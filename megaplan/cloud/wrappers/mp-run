#!/usr/bin/env bash
set -euo pipefail
if [[ $# -lt 2 ]]; then
  echo "usage: mp-run <session-name> <command...>" >&2
  exit 64
fi
SESSION="$1"
shift
if [[ -n "${TMUX:-}" ]]; then
  exec "$@"
fi
if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "mp-run: tmux session '$SESSION' already exists. Attach: railway ssh -- tmux attach -t $SESSION" >&2
  exit 65
fi
LOG="/workspace/${SESSION}.log"
WORKSPACE_DIR="${WORKSPACE_PATH:-/workspace/app}"
QUOTED=$(printf '%q ' "$@")
tmux new-session -d -s "$SESSION" -c "$WORKSPACE_DIR" "bash -lc '${QUOTED} 2>&1 | tee -a ${LOG}'"
echo "mp-run: launched '$SESSION' in detached tmux. Attach: railway ssh -- tmux attach -t $SESSION  |  Log: $LOG"

{
  "manifest": {
    "id": "com.reigh.examples.flagship-local",
    "version": "1.0.0",
    "label": "Flagship Local Extension",
    "description": "Flagship trusted-local extension example demonstrating the SDK surface: activation lifecycle, toolbar and status-bar slot UI, settings with defaults, diagnostics, chrome toast/progress scaffolding, trusted-local safety warnings, command/keybinding/context-menu contributions, active transition contribution (M8 wipe), component effect (M7 glow), and future inactive contribution declarations (clipType, parser, agentTool).",
    "apiVersion": 1,
    "contributions": [
      {
        "id": "flagship-mark-review-command",
        "kind": "command",
        "command": "com.reigh.examples.flagship-local.markClipReview",
        "label": "Flagship: Mark Clip for Review",
        "category": "Flagship",
        "order": 10
      },
      {
        "id": "flagship-mark-review-keybinding",
        "kind": "keybinding",
        "command": "com.reigh.examples.flagship-local.markClipReview",
        "key": "CtrlOrCmd+Alt+F",
        "order": 10
      },
      {
        "id": "flagship-mark-review-menu",
        "kind": "contextMenuItem",
        "command": "com.reigh.examples.flagship-local.markClipReview",
        "label": "Flagship: Mark Clip for Review",
        "target": "clip",
        "when": "target.clipId != null",
        "order": 10
      },
      {
        "id": "flagship-toolbar-button",
        "kind": "slot",
        "slot": "toolbar",
        "order": 200,
        "label": "Flagship toolbar"
      },
      {
        "id": "flagship-status",
        "kind": "slot",
        "slot": "statusBar",
        "order": 100,
        "label": "Flagship status"
      },
      {
        "id": "flagship-effect-glow",
        "kind": "effect",
        "label": "Flagship Glow",
        "effectId": "com.reigh.flagship.effect.glow",
        "allowBrowserExport": false,
        "allowWorkerExport": false,
        "order": 10
      },
      {
        "id": "flagship-effect-second-future",
        "kind": "effect",
        "label": "Flagship custom effect (reserved for M3)",
        "effectId": "com.reigh.flagship.effect.second"
      },
      {
        "id": "flagship-transition-wipe",
        "kind": "transition",
        "label": "Flagship Wipe",
        "transitionId": "com.reigh.flagship.transition.wipe",
        "allowBrowserExport": false,
        "allowWorkerExport": false,
        "order": 10
      },
      {
        "id": "flagship-cliptype-future",
        "kind": "clipType",
        "label": "Flagship custom clip type (reserved for M3)",
        "clipTypeId": "com.reigh.flagship.cliptype.annotation"
      },
      {
        "id": "flagship-parser-future",
        "kind": "parser",
        "label": "Flagship custom parser (reserved for M4)"
      },
      {
        "id": "flagship-agent-tool-future",
        "kind": "agentTool",
        "toolId": "com.reigh.examples.flagship-local.agent-tool-future",
        "label": "Flagship agent tool (reserved for M5)"
      }
    ],
    "permissions": [
      {
        "reason": "Reads timeline state, writes extension-scoped project metadata, shows chrome UI, and stores extension settings in the trusted local renderer.",
        "posture": {
          "network": false,
          "filesystem": false,
          "env": false,
          "processes": false
        }
      }
    ],
    "settingsDefaults": {
      "toolbar.label": "Flagship",
      "toolbar.enabled": true,
      "status.showTimelineName": true,
      "status.pollIntervalMs": 5000
    },
    "messages": {
      "activation.started": "Flagship local extension v{{version}} activating…",
      "activation.ready": "Flagship local extension v{{version}} ready.",
      "activation.disposed": "Flagship local extension disposed.",
      "warning.trustedLocal": "⚠️ Trusted-local extension: this extension executes with full browser-renderer privileges. Review the extension source before enabling it in a shared project.",
      "progress.label": "Chrome progress scaffold",
      "toast.error": "Flagship encountered an error: {{error}}",
      "toast.info": "Flagship status update: {{message}}",
      "command.markReview.ready": "Flagship review marker command registered.",
      "command.markReview.done": "Flagship review marker stored."
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reigh Extension Manifest (Schema Definition Drift Fixture)",
  "type": "object",
  "required": ["id", "version", "label"],
  "definitions": {
    "ContributionKind": {
      "type": "string",
      "enum": ["slot", "dialog", "panel"]
    },
    "SlotName": {
      "type": "string",
      "enum": ["header", "toolbar"]
    },
    "Contribution": {
      "oneOf": [
        { "$ref": "#/definitions/SlotContribution" },
        { "$ref": "#/definitions/DialogContribution" }
      ]
    },
    "SlotContribution": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "slot" },
        "slot": { "$ref": "#/definitions/SlotName" }
      }
    },
    "DialogContribution": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "dialog" }
      }
    }
  }
}

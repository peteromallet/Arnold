{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reigh Extension Manifest (Manifest Placement Mismatch Fixture)",
  "type": "object",
  "required": ["id", "version", "label"],
  "definitions": {
    "ContributionKind": {
      "type": "string",
      "enum": ["slot", "dialog", "panel", "inspectorSection", "assetDetailSection"]
    },
    "SlotName": {
      "type": "string",
      "enum": ["header", "toolbar"]
    },
    "Contribution": {
      "oneOf": [
        { "$ref": "#/definitions/SlotContribution" },
        { "$ref": "#/definitions/DialogContribution" },
        { "$ref": "#/definitions/PanelContribution" },
        { "$ref": "#/definitions/InspectorSectionContribution" },
        { "$ref": "#/definitions/AssetDetailSectionContribution" }
      ]
    },
    "SlotContribution": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "slot" },
        "slot": { "$ref": "#/definitions/SlotName" }
      }
    },
    "DialogContribution": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "dialog" }
      }
    },
    "PanelContribution": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "panel" },
        "placement": { "enum": ["asset-panel"] }
      }
    },
    "InspectorSectionContribution": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "inspectorSection" },
        "placement": {
          "enum": ["before-default", "after-default"]
        }
      }
    },
    "AssetDetailSectionContribution": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "assetDetailSection" },
        "placement": {
          "enum": ["before-default", "after-default"]
        }
      }
    }
  }
}

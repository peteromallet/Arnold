    "adopt-execution": {
        "route_signal": OverridePolicyRoute.ADOPT_EXECUTION,
        "target_ref": "review",
        "declared_target_ref": "review",
        "policy_route_ref": "megaplan.override.adopt_execution",
        "description": "Resume from an adopted execution artifact at the review fan-in.",
    },
    "recover-blocked": {
        "route_signal": OverridePolicyRoute.RECOVER_BLOCKED,
        "declared_target_ref": "recovery_predecessor",
        "policy_route_ref": "megaplan.override.recover_blocked",
        "target_rule": "recovery_predecessor",
        "description": "Recover to the predecessor phase declared by the native recovery policy.",
    },
    "resume-clarify": {
        "route_signal": OverridePolicyRoute.RESUME_CLARIFY,
        "target_ref": "plan",
        "declared_target_ref": "plan",
        "policy_route_ref": "megaplan.override.resume_clarify",
        "description": "Resume a prep clarification halt at the plan step.",
    },
}

DECLARED_OVERRIDE_OUTCOME_TARGETS = {
    "abort": {
        "route_signal": OverrideOutcome.ABORT,
        "target_ref": "halt",
        "terminal_state_ref": "aborted",
        "description": "Terminate the workflow through the halt node and land in the aborted terminal state.",
    },
    "force-proceed": {
        "route_signal": OverrideOutcome.FORCE_PROCEED,
        "target_refs": ("finalize", "execute"),
        "terminal_state_ref": "done",
        "description": "Drive the native finalize/execute path, or land in done when the override exits the review loop.",
    },
    "replan": {
        "route_signal": OverrideOutcome.REPLAN,
        "target_ref": "revise",
        "reentry_target_ref": "critique",
        "description": "Re-enter the planning loop by routing through revise and back to the critique reentry.",
    },
}


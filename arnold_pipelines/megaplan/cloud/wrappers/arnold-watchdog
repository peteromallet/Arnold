    remote_spec = payload.get("remote_spec")
    if not isinstance(remote_spec, str) or not remote_spec:
        continue
    run_kind = payload.get("run_kind")
    plan_name = payload.get("plan_name")
    print("\t".join([
        other_session,
        other_workspace,
        remote_spec,
        run_kind if isinstance(run_kind, str) and run_kind else "chain",
        plan_name if isinstance(plan_name, str) else "",
    ]))
PY
)"
  while IFS=$'\t' read -r other_session other_workspace other_remote_spec other_run_kind other_plan_name; do

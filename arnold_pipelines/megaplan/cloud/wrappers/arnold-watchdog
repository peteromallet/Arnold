if isinstance(loaded_extra, list):
    evidence.extend(loaded_extra)
elif isinstance(loaded_extra, dict):
    evidence.append(loaded_extra)

if event_kind == "detection":
    append_watchdog_detection(
        incident_id=incident_id,
        summary=summary,
        outcome=status,
        evidence=evidence,
        session_id=session,

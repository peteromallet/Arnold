# Detect whether a session's environment has been wiped (workspace dir or
# chain/epic-chain spec gone — typically after a box reset/redeploy). Uses a
# strike counter so a transient deploy gap doesn't retire a live session.
#
#stdout: prints one of:
#   - "gone"    and exits 0  -> env missing AND strikes >= $ENV_GONE_STRIKES
#   - "<count>" and exits 1  -> env missing, strikes below threshold (count printed)
#   - "present" and exits 1  -> env present (any prior sidecar cleared; recovers
#                              from a transient deploy that has since resolved)
environment_gone_check() {
  local session="$1"
  local workspace="$2"
  local spec_path="${3:-}"
  local sidecar count
  sidecar="$(env_gone_sidecar_path "$session")"

  # Env present: clear any stale strike sidecar and signal fall-through.
  if [[ -d "$workspace" ]] && { [[ -z "$spec_path" ]] || [[ -f "$spec_path" ]]; }; then
    if [[ -f "$sidecar" ]]; then
      rm -f "$sidecar" 2>/dev/null || true
      log "env-gone strikes cleared; environment recovered session=$session workspace=$workspace spec=${spec_path:-}"
    fi
    printf 'present\n'
    return 1
  fi

  count=0
  if [[ -f "$sidecar" ]]; then
    count="$(cat "$sidecar" 2>/dev/null || true)"
    count="${count//[!0-9]/}"
    count="${count:-0}"
  fi
  count=$((count + 1))
  printf '%s\n' "$count" >"$sidecar" 2>/dev/null || true

  if (( count >= ENV_GONE_STRIKES )); then
    printf 'gone\n'
    return 0
  fi
  printf '%s\n' "$count"
  return 1
}


  return 0
}

bootstrap_watchdog_observation() {
  local report_items="$1"
  local reason=""
  WATCHDOG_BOOTSTRAP_RECOVERED=0
  if reason="$(watchdog_observation_runtime_check 2>&1)"; then
    return 0
  fi
  # Fail closed. Attempting pip/source repair from a blind observer caused the
  # original boot/install race and could leave a live-but-sleeping watchdog.
  reason="$(printf '%s' "$reason" | tr '\n' ' ' | sed 's/[[:space:]]\\+/ /g' | sed 's/^ //; s/ $//')"
  [[ -n "$reason" ]] || reason="watchdog observation runtime check failed"
  log "watchdog observation bootstrap failed closed: $reason"
  report_item "$report_items" "watchdog" "observe" "observation_blind" "watchdog observation bootstrap failed closed: $reason" "$SRC_DIR" "$SYNC_BRANCH"
  write_watchdog_observation_error "$reason"
  return 1
}

matching_runner_process_alive() {
  local workspace="$1"
  local remote_spec="$2"
  local run_kind="${3:-chain}"
  local plan_name="${4:-}"
  PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$workspace" "$remote_spec" "$run_kind" "$plan_name" <<'PY'
import hashlib
import json
import os
import subprocess
import sys
from pathlib import Path

workspace = Path(sys.argv[1])
remote_spec_raw = sys.argv[2]
run_kind = sys.argv[3]
plan_name = sys.argv[4]


def pid_alive(value: object) -> bool:
    try:
        pid = int(value)
    except (TypeError, ValueError):
        return False
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True


def add_unique(values: list[str], value: object) -> None:
    if isinstance(value, str):
        cleaned = value.strip()
        if cleaned and cleaned not in values:
            values.append(cleaned)


def load_json(path: Path) -> dict[str, object]:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}


def process_matches() -> bool:
    if run_kind not in {"chain", "epic_chain"} or not remote_spec_raw:
        return False
    try:
        proc = subprocess.run(
            ["ps", "-eww", "-o", "pid=", "-o", "args="],
            check=False,
            capture_output=True,
            text=True,
        )
    except Exception:
        return False
    if proc.returncode != 0:
        return False
    ignored_pids = {os.getpid(), os.getppid()}
    command = "arnold_pipelines.megaplan chain start" if run_kind == "chain" else "arnold_pipelines.megaplan epic-chain start"
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        try:
            pid_text, args = stripped.split(None, 1)
            pid = int(pid_text)
        except (ValueError, TypeError):
            continue
        if pid in ignored_pids:
            continue
        if command in args and "--spec" in args and remote_spec_raw in args:
            return True
    return False


if process_matches():
    raise SystemExit(0)

candidate_plans: list[str] = []
add_unique(candidate_plans, plan_name)

if remote_spec_raw:
    try:
        spec_path = Path(remote_spec_raw)
        try:
            spec_resolved = spec_path.resolve()
        except Exception:
            spec_resolved = spec_path
        digest = hashlib.sha1(str(spec_resolved).encode("utf-8")).hexdigest()[:12]
        chain_state_candidates = (
            workspace / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
            workspace / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
            spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
            spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
            spec_resolved.with_name("chain_state.json"),
        )
        for candidate in chain_state_candidates:
            if not candidate.exists():
                continue
            chain_state = load_json(candidate)
            add_unique(candidate_plans, chain_state.get("current_plan_name"))
            add_unique(candidate_plans, chain_state.get("plan_name"))
            break
    except Exception:
        pass

for current_plan in candidate_plans:
    state_path = workspace / ".megaplan" / "plans" / current_plan / "state.json"
    if not state_path.exists():
        continue
    state = load_json(state_path)
    active = state.get("active_step")
    if isinstance(active, dict) and pid_alive(active.get("worker_pid")):
        raise SystemExit(0)

raise SystemExit(1)
PY
}


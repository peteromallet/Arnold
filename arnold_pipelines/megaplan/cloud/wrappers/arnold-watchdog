  if [[ "$run_kind" == "chain" && "$remote_spec" != /* ]]; then
    remote_spec_path="$workspace/$remote_spec"
  fi

  # Env-gone gate (FALLTHROUGH, after the terminal/needs-human short-circuits
  # above): a wiped workspace or missing chain/epic-chain spec means there is no
  # environment to repair — the repair loop cannot recreate it. A strike counter
  # tolerates transient deploy gaps; at threshold the session is retired cleanly
  # instead of looping repair against a missing env. Below threshold we log the
  # strike and skip dispatch this tick; if the env recovers, the sidecar clears.
  local env_gone_out env_gone_rc
  env_gone_out="$(environment_gone_check "$session" "$workspace" "$remote_spec_path")"
  env_gone_rc=$?
  if (( env_gone_rc == 0 )); then
    log "environment gone; retiring session after env-gone strikes session=$session workspace=$workspace spec=$remote_spec_path"
    persist_environment_gone_outcome "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name"
    clear_session_tracking_artifacts "$session" "$plan_name"
    rm -f "$(env_gone_sidecar_path "$session")" 2>/dev/null || true
    report_item "$report_items" "$session" "observe" "environment_gone" "workspace/spec wiped; retired after env-gone strikes" "$workspace" "$remote_spec"
    return 0

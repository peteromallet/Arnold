reap_stale_repair_candidates() {
  python3 - "$REAP_AGE_SECS" "$REAP_ORPHAN_AGE_SECS" <<'PY'
import re
import sys

SESSION_RE = re.compile(r"Session:\s+([^\s]+)")
REPAIR_LOOP_RE = re.compile(r"(^|[\s/])arnold-repair-loop\s+([^\s]+)")
KIMI_RE = re.compile(r"(^|[\s/])arnold-kimi-goal-operator\s+([^\s]+)")
CODEX_RE = re.compile(r"(^|\s)codex exec(\s|$)")
RUN_AGENT_HINTS = (
    "workflows on this Hetzner worker should never pause unexpectedly",
    "cloud watchdog",
    "Kimi launch/diagnosis turn",
)
CODEX_HINTS = (
    "You are the watchdog repair-loop dev-fix agent",
    "bounded 3-iteration repair loop",
    "repair data file",
    "workflows on this Hetzner worker should not pause unexpectedly",
)
PROTECTED_HINTS = (
    "arnold-watchdog",
    "arnold-progress-auditor",
)
RULE_PRIORITY = {
    "orphan_fast_path": 0,
    "age_backstop": 1,
}
KIND_PRIORITY = {
    "arnold-repair-loop": 0,
    "arnold-kimi-goal-operator": 1,
    "arnold.agent.run_agent": 2,
    "codex exec": 3,
}


def parse_ps_row(raw: str):
    parts = raw.strip().split(None, 4)
    if len(parts) < 5:
        return None
    try:
        return {
            "pid": int(parts[0]),
            "ppid": int(parts[1]),
            "pgid": int(parts[2]),
            "etimes": int(parts[3]),
            "args": parts[4],
        }
    except ValueError:
        return None


def extract_session(kind: str, args: str) -> str:
    if kind == "arnold-repair-loop":
        match = REPAIR_LOOP_RE.search(args)
        return match.group(2) if match else ""
    if kind == "arnold-kimi-goal-operator":
        match = KIMI_RE.search(args)
        return match.group(2) if match else ""
    match = SESSION_RE.search(args)
    return match.group(1) if match else ""


def classify_kind(args: str) -> str:
    if any(hint in args for hint in PROTECTED_HINTS):
        return ""
    repair_loop_match = REPAIR_LOOP_RE.search(args)
    if repair_loop_match:
        return "arnold-repair-loop"
    kimi_match = KIMI_RE.search(args)
    if kimi_match:
        return "arnold-kimi-goal-operator"
    if "arnold.agent.run_agent" in args:
        session = extract_session("arnold.agent.run_agent", args)
        if session and any(hint in args for hint in RUN_AGENT_HINTS):
            return "arnold.agent.run_agent"
    if CODEX_RE.search(args):
        session = extract_session("codex exec", args)
        if session and any(hint in args for hint in CODEX_HINTS):
            return "codex exec"
    return ""


def decide_reap(row: dict[str, object], age_secs: int, orphan_age_secs: int) -> dict[str, object]:
    args = str(row.get("args") or "")
    kind = classify_kind(args)
    session = extract_session(kind, args) if kind else ""
    decision = {
        "pid": int(row.get("pid") or 0),
        "ppid": int(row.get("ppid") or 0),
        "pgid": int(row.get("pgid") or 0),
        "etimes": int(row.get("etimes") or 0),
        "kind": kind,
        "session": session,
        "reap": False,
        "rule": "",
        "reason": "non_target" if not kind else "under_age",
    }
    if not kind:
        return decision
    if (
        kind in {"arnold.agent.run_agent", "codex exec"}
        and decision["ppid"] == 1
        and decision["etimes"] > orphan_age_secs
    ):
        decision["reap"] = True
        decision["rule"] = "orphan_fast_path"
        decision["reason"] = "orphaned_ppid_1"
        return decision
    if decision["etimes"] > age_secs:
        decision["reap"] = True
        decision["rule"] = "age_backstop"
        decision["reason"] = "elapsed_exceeded"
    return decision


def choose_reap_candidates(rows: list[dict[str, object]], age_secs: int, orphan_age_secs: int):
    candidates = [
        decide_reap(row, age_secs, orphan_age_secs)
        for row in rows
    ]
    candidates = [item for item in candidates if item["reap"]]
    candidates.sort(
        key=lambda item: (
            item["session"] or "",
            item["pgid"],
            RULE_PRIORITY[item["rule"]],
            KIND_PRIORITY[item["kind"]],
            -item["etimes"],
            item["pid"],
        )
    )
    seen_sessions = set()
    seen_pgids = set()
    selected = []
    for item in candidates:
        session = item["session"]
        pgid = item["pgid"]
        if session and session in seen_sessions:
            continue
        if pgid in seen_pgids:
            continue
        selected.append(item)
        if session:
            seen_sessions.add(session)
        seen_pgids.add(pgid)
    return selected


def main() -> int:
    age_secs = int(sys.argv[1])
    orphan_age_secs = int(sys.argv[2])
    rows = []
    for raw in sys.stdin:
        row = parse_ps_row(raw)
        if row:
            rows.append(row)
    for item in choose_reap_candidates(rows, age_secs, orphan_age_secs):
        print(
            "\t".join(
                [
                    str(item["pid"]),
                    str(item["ppid"]),
                    str(item["pgid"]),
                    str(item["etimes"]),
                    str(item["kind"]),
                    str(item["session"]),
                    str(item["rule"]),
                    str(item["reason"]),
                ]
            )
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
}

reap_stalled_repair_candidates() {
  python3 - "$MARKER_DIR" "$REPAIR_OPERATOR_ROOT" "$REAP_STALL_GRACE_SECS" "$REAP_STALL_IDLE_SECS" "$REAP_AGE_SECS" <<'PY'
import datetime as dt
import json
import pathlib
import re
import sys

marker_dir = pathlib.Path(sys.argv[1])
operator_root = pathlib.Path(sys.argv[2])
stall_grace_secs = int(sys.argv[3])
stall_idle_secs = int(sys.argv[4])
reap_age_secs = int(sys.argv[5])

SESSION_RE = re.compile(r"Session:\s+([^\s]+)")
REPAIR_LOOP_RE = re.compile(r"(^|[\s/])arnold-repair-loop\s+([^\s]+)")
KIMI_RE = re.compile(r"(^|[\s/])arnold-kimi-goal-operator\s+([^\s]+)")
CODEX_RE = re.compile(r"(^|\s)codex exec(\s|$)")
RUN_AGENT_HINTS = (
    "workflows on this Hetzner worker should never pause unexpectedly",
    "cloud watchdog",
    "Kimi launch/diagnosis turn",
)
CODEX_HINTS = (
    "You are the watchdog repair-loop dev-fix agent",
    "bounded 3-iteration repair loop",
    "repair data file",
    "workflows on this Hetzner worker should not pause unexpectedly",
)
PROTECTED_HINTS = (
    "arnold-watchdog",
    "arnold-progress-auditor",
)
KIND_PRIORITY = {
    "arnold-repair-loop": 0,
    "arnold-kimi-goal-operator": 1,
    "arnold.agent.run_agent": 2,
    "codex exec": 3,
}
RECENT_WINDOW_SECS = max(reap_age_secs, stall_grace_secs + stall_idle_secs, 1800)
now = dt.datetime.now(dt.timezone.utc)


def parse_ps_row(raw: str):
    parts = raw.strip().split(None, 4)
    if len(parts) < 5:
        return None
    try:
        return {
            "pid": int(parts[0]),
            "ppid": int(parts[1]),
            "pgid": int(parts[2]),

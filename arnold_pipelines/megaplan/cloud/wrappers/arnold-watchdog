        batches = entry.get("batch_to_tier")
        if not isinstance(batches, list):
            continue
        for batch in batches:
            if not isinstance(batch, dict):
                continue
            actual_agent = batch.get("actual_agent")
            actual_model = batch.get("actual_model")
            if isinstance(actual_agent, str) and isinstance(actual_model, str) and actual_agent and actual_model:
                add_unique(tiers_tried, f"{actual_agent}:{actual_model}")
                continue
            tier_model_spec = batch.get("tier_model_spec")
            if isinstance(tier_model_spec, str) and tier_model_spec:
                add_unique(tiers_tried, tier_model_spec)
                continue
            resolved_agent = batch.get("resolved_agent")
            resolved_model = batch.get("resolved_model")

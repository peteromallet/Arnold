    missing_base_ref, missing_base_ref_message, missing_base_ref_recorded_at, missing_base_ref_phase = (
        missing_base_ref_attention(chain_state)
    )
    if missing_base_ref:
        current_state = "missing_base_ref"
        retry_strategy = "manual_review"

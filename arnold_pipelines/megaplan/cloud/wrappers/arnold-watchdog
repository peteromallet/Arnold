data_path = repair_data_dir / f"{session}.repair-data.json"
if not data_path.exists():
    raise SystemExit(0)
try:
    payload = json.loads(data_path.read_text(encoding="utf-8"))
except Exception:
    payload = {}
if not isinstance(payload, dict):
    raise SystemExit(0)
incident_id = str(payload.get("incident_id") or "").strip()
if not incident_id:
    raise SystemExit(0)
problem_id = str(payload.get("problem_id") or "").strip() or None
workspace = pathlib.Path(workspace_raw) if workspace_raw else pathlib.Path.cwd()
evidence = [
    {

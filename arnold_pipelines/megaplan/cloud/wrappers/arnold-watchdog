}

repair_loop_pid_matches_session() {
  local pid="$1"
  local session="${2:-}"
  local repair_basename="${PRIMARY_REPAIR_BASENAME:-arnold-repair-loop}"
  python3 - "$pid" "$session" "$repair_basename" <<'PY'
import os
import pathlib
import shlex
import subprocess
import sys

pid_text, session, repair_basename = sys.argv[1:]
try:
    pid = int(pid_text)
except (TypeError, ValueError):
    raise SystemExit(1)
if pid <= 0:
    raise SystemExit(1)

def parse_args() -> list[str]:
    cmdline_path = pathlib.Path(f"/proc/{pid}/cmdline")
    if cmdline_path.exists():
        raw = cmdline_path.read_bytes()
        return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]
    proc = subprocess.run(
        ["ps", "-ww", "-o", "args=", "-p", str(pid)],
        check=False,
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        return []
    text = proc.stdout.strip()
    if not text:
        return []
    try:
        return shlex.split(text)
    except ValueError:
        return text.split()

args = parse_args()
if not args:
    raise SystemExit(1)

def match_at(idx: int) -> bool:
    if idx >= len(args):
        return False
    base = os.path.basename(args[idx])
    if base not in {"arnold-repair-loop", repair_basename}:
        return False
    if not session:
        return True
    return idx + 1 < len(args) and args[idx + 1] == session

for idx in range(len(args)):
    if match_at(idx):
        raise SystemExit(0)
    base = os.path.basename(args[idx])
    if base in {"bash", "sh"} and match_at(idx + 1):
        raise SystemExit(0)

raise SystemExit(1)
PY
}


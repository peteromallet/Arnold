kill_kimi_repair_tree() {
  local session="$1"
  local pgid_path pgid root_pid
  pgid_path="$(kimi_pgid_path "$session")"
  [[ -r "$pgid_path" ]] || return 1
  read -r pgid < "$pgid_path" || return 1
  [[ "$pgid" =~ ^[0-9]+$ ]] || return 1
  root_pid="$(ps -eo pid=,pgid= 2>/dev/null | awk -v target="$pgid" '$2 == target {print $1; exit}')"
  if [[ "$root_pid" =~ ^[0-9]+$ ]]; then
    kill_repair_tree_complete "$root_pid" "$pgid"
  else
    kill_process_group "$pgid"
  fi
}


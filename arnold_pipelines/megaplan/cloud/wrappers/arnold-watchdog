    report_item "$report_items" "$session" "observe" "env_gone_pending" "env-gone strike $env_gone_out/$ENV_GONE_STRIKES; workspace=$workspace spec=$remote_spec_path" "$workspace" "$remote_spec"
    return 0
  fi

  local health
  health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$run_kind" == "chain" ]]; then
    chain_health_status "$session" "$workspace" "$remote_spec_path" "$health"
    if [[ -n "${CHAIN_HEALTH_LOG_MESSAGE:-}" ]]; then
      log "${CHAIN_HEALTH_LOG_MESSAGE}"
    fi
    if [[ "${CHAIN_HEALTH_STATUS:-ok}" == "chain_uncommitted_execute_output" || "${CHAIN_HEALTH_STATUS:-ok}" == "chain_large_file_push_rejection" ]]; then
      local chain_health_message repair_busy
      chain_health_message="${CHAIN_HEALTH_SUMMARY:-chain publish failure needs repair}"
      if [[ -n "${CHAIN_HEALTH_ARTIFACT_PATH:-}" ]]; then

    return ""


def safe_name(value: str) -> str:
    return re.sub(r"[^A-Za-z0-9_.-]", "-", value)


def iso_to_dt(raw: object):
    if not isinstance(raw, str) or not raw:
        return None
    try:
        return dt.datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return None


def file_stats(path: pathlib.Path) -> tuple[float, int]:
    try:
        stat = path.stat()
    except OSError:
        return (0.0, 0)
    return (float(stat.st_mtime), int(stat.st_size))


def snapshot_path_for(session: str) -> pathlib.Path:
    return marker_dir / f"{session}.reap-progress.json"


def find_recent_operator_dir(session: str):
    if not session or not operator_root.is_dir():
        return None
    safe_session = safe_name(session)
    candidates = []
    for path in operator_root.glob(f"*-{safe_session}"):
        if not path.is_dir():
            continue
        log_paths = [candidate for candidate in path.glob("*.log") if candidate.is_file()]
        mtimes = [file_stats(path)[0], *(file_stats(candidate)[0] for candidate in log_paths)]
        newest_mtime = max(mtimes)
        if newest_mtime <= 0:
            continue
        age_secs = max(0, int((now - dt.datetime.fromtimestamp(newest_mtime, tz=dt.timezone.utc)).total_seconds()))
        if age_secs > RECENT_WINDOW_SECS:
            continue
        candidates.append((newest_mtime, path))
    if not candidates:
        return None
    candidates.sort(key=lambda item: (item[0], str(item[1])), reverse=True)
    return candidates[0][1]


def assess_session_progress(session: str) -> dict[str, object]:
    operator_dir = find_recent_operator_dir(session)
    if operator_dir is None:
        return {"mapped": False, "reason": "unmappable"}

    log_paths = [candidate for candidate in operator_dir.glob("*.log") if candidate.is_file()]
    stats = [(candidate.name, *file_stats(candidate)) for candidate in log_paths]
    if not stats:
        return {"mapped": False, "reason": "no_logs"}
    stats.sort(key=lambda item: (item[1], item[2], item[0]), reverse=True)
    newest_name, newest_mtime, newest_size = stats[0]

    snapshot = {
        "operator_dir": str(operator_dir),
        "log_name": newest_name,
        "log_mtime": newest_mtime,
        "log_size": newest_size,
    }
    snapshot_dir = snapshot_path_for(session).parent
    snapshot_dir.mkdir(parents=True, exist_ok=True)
    prev = {}
    snapshot_path = snapshot_path_for(session)
    if snapshot_path.exists():
        try:
            prev = json.loads(snapshot_path.read_text(encoding="utf-8"))
        except Exception:
            prev = {}

    same_observation = (
        prev.get("operator_dir") == snapshot["operator_dir"]
        and prev.get("log_name") == snapshot["log_name"]
        and prev.get("log_mtime") == snapshot["log_mtime"]
        and prev.get("log_size") == snapshot["log_size"]
    )
    if same_observation:
        last_advance = (
            iso_to_dt(prev.get("last_advance_ts"))
            or iso_to_dt(prev.get("ts"))
            or dt.datetime.fromtimestamp(newest_mtime, tz=dt.timezone.utc)
        )
    else:
        if prev:
            last_advance = now
        else:
            last_advance = dt.datetime.fromtimestamp(newest_mtime, tz=dt.timezone.utc)
    idle_secs = max(0, int((now - last_advance).total_seconds()))

    persisted = dict(snapshot)
    persisted["last_advance_ts"] = last_advance.isoformat()
    persisted["ts"] = now.isoformat()
    try:
        snapshot_path.write_text(json.dumps(persisted, sort_keys=True) + "\n", encoding="utf-8")
    except Exception:
        pass

    return {
        "mapped": True,
        "operator_dir": str(operator_dir),
        "idle_secs": idle_secs,
        "stalled": idle_secs >= stall_idle_secs,
    }


rows_by_session = {}
progress_cache = {}
for raw in sys.stdin:
    row = parse_ps_row(raw)
    if not row:
        continue
    kind = classify_kind(str(row["args"]))
    if not kind:
        continue
    session = extract_session(kind, str(row["args"]))
    if not session:
        continue
    row["kind"] = kind
    row["session"] = session
    rows_by_session.setdefault(session, []).append(row)

candidates = []
for session, rows in rows_by_session.items():
    progress = progress_cache.setdefault(session, assess_session_progress(session))
    if not progress.get("mapped"):
        continue
    eligible = [row for row in rows if int(row["etimes"]) >= stall_grace_secs]
    if not eligible or not progress.get("stalled"):
        continue
    eligible.sort(
        key=lambda row: (
            KIND_PRIORITY[str(row["kind"])],
            -int(row["etimes"]),
            int(row["pid"]),
        )
    )
    chosen = eligible[0]
    candidates.append(
        {
            "pid": int(chosen["pid"]),
            "ppid": int(chosen["ppid"]),
            "pgid": int(chosen["pgid"]),
            "etimes": int(chosen["etimes"]),
            "kind": str(chosen["kind"]),
            "session": session,
            "rule": "stalled",
            "reason": f"stall_idle_{int(progress['idle_secs'])}s",
            "operator_dir": str(progress["operator_dir"]),
            "idle_secs": int(progress["idle_secs"]),
        }
    )

candidates.sort(
    key=lambda item: (
        item["session"],
        KIND_PRIORITY[item["kind"]],
        -item["etimes"],
        item["pid"],
    )
)
seen_pgids = set()
for item in candidates:
    pgid = item["pgid"]
    if pgid in seen_pgids:
        continue
    seen_pgids.add(pgid)
    print(
        "\t".join(
            [
                str(item["pid"]),
                str(item["ppid"]),
                str(item["pgid"]),
                str(item["etimes"]),
                item["kind"],
                item["session"],
                item["rule"],
                item["reason"],
                item["operator_dir"],
                str(item["idle_secs"]),
            ]
        )
    )
PY
}

kill_process_group() {
  local pgid="$1"
  [[ "$pgid" =~ ^[0-9]+$ ]] || return 1
  kill -- "-$pgid" >/dev/null 2>&1 || return 1
  sleep 0.5
  if kill -0 -- "-$pgid" >/dev/null 2>&1; then
    kill -9 -- "-$pgid" >/dev/null 2>&1 || true
    sleep 0.2
  fi
  ! kill -0 -- "-$pgid" >/dev/null 2>&1
}

repair_tree_pgids() {
  local root_pid="$1"
  local root_pgid="$2"
  [[ "$root_pid" =~ ^[0-9]+$ ]] || return 1
  [[ "$root_pgid" =~ ^[0-9]+$ ]] || return 1
  python3 - "$root_pid" "$root_pgid" <<'PY'
import subprocess
import sys

root_pid = int(sys.argv[1])
root_pgid = int(sys.argv[2])
proc = subprocess.run(
    ["ps", "-eo", "pid=,ppid=,pgid="],
    capture_output=True,
    text=True,
    check=False,
)
children = {}
pgids = {}
for line in proc.stdout.splitlines():
    parts = line.strip().split()
    if len(parts) != 3:
        continue
    try:
        pid = int(parts[0])
        ppid = int(parts[1])
        pgid = int(parts[2])
    except ValueError:
        continue
    children.setdefault(ppid, []).append(pid)
    pgids[pid] = pgid

seen_groups = [root_pgid]

def walk(pid: int) -> None:
    for child in children.get(pid, []):
        child_pgid = pgids.get(child)
        if child_pgid and child_pgid not in seen_groups:
            seen_groups.append(child_pgid)
        walk(child)

walk(root_pid)
print(" ".join(str(group) for group in seen_groups))
PY
}

kill_pid_and_descendants() {
  local root_pid="$1"
  local pid_list
  [[ "$root_pid" =~ ^[0-9]+$ ]] || return 1
  pid_list="$(
    python3 - "$root_pid" <<'PY'
import subprocess
import sys

root = int(sys.argv[1])
proc = subprocess.run(
    ["ps", "-eo", "pid=,ppid="],
    capture_output=True,
    text=True,
    check=False,
)
children = {}
for line in proc.stdout.splitlines():
    parts = line.strip().split()
    if len(parts) != 2:
        continue
    try:
        pid = int(parts[0])
        ppid = int(parts[1])
    except ValueError:
        continue
    children.setdefault(ppid, []).append(pid)

order = []

def walk(pid: int) -> None:
    for child in children.get(pid, []):
        walk(child)
        order.append(child)

walk(root)
order.append(root)
print(" ".join(str(pid) for pid in order))
PY
  )"
  [[ -n "$pid_list" ]] || return 1
  local pid
  for pid in $pid_list; do
    kill "$pid" >/dev/null 2>&1 || true
  done
  sleep 0.5
  for pid in $pid_list; do
    kill -0 "$pid" >/dev/null 2>&1 || continue
    kill -9 "$pid" >/dev/null 2>&1 || true
  done
  ! kill -0 "$root_pid" >/dev/null 2>&1
}

kill_repair_tree_complete() {
  local root_pid="$1"
  local root_pgid="$2"
  local groups group
  local tried=1
  [[ "$root_pid" =~ ^[0-9]+$ ]] || return 1
  [[ "$root_pgid" =~ ^[0-9]+$ ]] || return 1
  groups="$(repair_tree_pgids "$root_pid" "$root_pgid" 2>/dev/null || true)"
  if [[ -z "$groups" ]]; then
    groups="$root_pgid"
  fi
  for group in $groups; do
    if kill_process_group "$group"; then
      tried=0
    fi
  done
  if kill_pid_and_descendants "$root_pid"; then
    tried=0
  fi
  for group in $groups; do
    if kill -0 -- "-$group" >/dev/null 2>&1; then
      return 1
    fi
  done
  ! kill -0 "$root_pid" >/dev/null 2>&1 || return 1
  return "$tried"
}

reap_stale_repairs() {
  local report_items="$1"
  local ps_rows candidates marker_path workspace remote_spec
  local pid ppid pgid etimes kind session rule reason operator_dir stall_idle
  local live_pgid session_pgid method message
  declare -A seen_sessions=()
  declare -A seen_pgids=()
  ps_rows="$(mktemp)"
  candidates="$(mktemp)"
  ps -eww -o pid=,ppid=,pgid=,etimes=,args= 2>/dev/null > "$ps_rows"
  reap_stale_repair_candidates < "$ps_rows" \
    | awk -F'\t' 'BEGIN{OFS="\t"} {print $1,$2,$3,$4,$5,$6,$7,$8,"",""}' > "$candidates"
  reap_stalled_repair_candidates < "$ps_rows" >> "$candidates"
  while IFS=$'\t' read -r pid ppid pgid etimes kind session rule reason operator_dir stall_idle; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    if [[ -n "$session" && -n "${seen_sessions[$session]:-}" ]]; then
      continue
    fi
    if [[ -n "${seen_pgids[$pgid]:-}" ]]; then
      continue
    fi
    if ! kill -0 "$pid" >/dev/null 2>&1; then
      continue
    fi
    method=""
    session_pgid=""
    if [[ -n "$session" ]]; then
      marker_path="$(session_marker_path "$session")"
      if [[ -r "$(kimi_pgid_path "$session")" ]]; then
        read -r session_pgid < "$(kimi_pgid_path "$session")" || session_pgid=""
        live_pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
        if [[ ! "$session_pgid" =~ ^[0-9]+$ || "$session_pgid" != "$live_pgid" ]]; then
          session_pgid=""
        fi
      fi
    else
      marker_path=""
    fi
    if [[ -n "$session_pgid" ]] && kill_repair_tree_complete "$pid" "$session_pgid"; then
      method="session_pgid_complete:$session_pgid"
    elif kill_repair_tree_complete "$pid" "$pgid"; then
      method="pgid_complete:$pgid"
    elif kill_pid_and_descendants "$pid"; then
      method="pid_tree:$pid"
    else
      log "stale repair reap failed pid=$pid kind=$kind session=${session:-unknown} rule=$rule age=${etimes}s"
      continue
    fi
    workspace=""
    remote_spec=""
    if [[ -n "$marker_path" && -f "$marker_path" ]]; then
      workspace="$(json_field "$marker_path" workspace 2>/dev/null || true)"
      remote_spec="$(json_field "$marker_path" remote_spec 2>/dev/null || true)"
    fi
    message="reaped stale repair pid=$pid kind=$kind session=${session:-unknown} rule=$rule reason=$reason age=${etimes}s method=$method"
    if [[ "$rule" == "stalled" ]]; then
      message="$message idle=${stall_idle:-unknown}s"
      if [[ -n "$operator_dir" ]]; then
        message="$message operator_dir=$operator_dir"
      fi
    fi
    log "$message"
    report_item "$report_items" "${session:-}" "reap" "reaped" "$message" "$workspace" "$remote_spec"
    if [[ -n "$session" ]]; then
      kimi_dispatch_marker_clear "$session"
      seen_sessions["$session"]=1
    fi
    seen_pgids["$pgid"]=1
  done < "$candidates"
  rm -f "$ps_rows" "$candidates"
}

chain_current_pr_merged() {
  # Ground-truth check: is the chain's current-milestone PR merged LIVE (gh)?
  # Returns "merged", "open", or "unknown". Used to verify a stale
  # repair-exhausted marker: if the PR merged after the marker was written, the
  # chain can now reconcile+complete on relaunch, so the marker is stale.
  local workspace="$1" remote_spec="${2:-}"
  python3 - "$workspace" "$remote_spec" <<'PY'
import json
import pathlib
import subprocess
import sys

workspace = pathlib.Path(sys.argv[1])
plans_dir = workspace / ".megaplan" / "plans"
chain_paths = sorted(
    {
        *plans_dir.glob(".chains/*.json"),
        *workspace.glob(".megaplan/initiatives/*/.megaplan/plans/.chains/*.json"),
        *(workspace / ".megaplan").glob("**/chain_state.json"),
    },
    key=lambda path: path.stat().st_mtime,
    reverse=True,
)
for path in chain_paths:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    pr_number = payload.get("pr_number")
    if not pr_number:
        continue
    try:
        proc = subprocess.run(
            ["gh", "pr", "view", str(pr_number), "--json", "state"],
            cwd=workspace,
            check=False,
            capture_output=True,
            text=True,
            timeout=120,
        )
        if proc.returncode != 0:
            continue
        state = json.loads(proc.stdout or "{}").get("state", "")
        state = state.lower() if isinstance(state, str) else ""
        print("merged" if state == "merged" else "open" if state == "open" else "unknown")
        raise SystemExit(0)
    except Exception:
        continue
print("unknown")
PY
}

chain_wait_status() {
  local workspace="$1"
  local remote_spec="${2:-}"
  python3 - "$workspace" "$remote_spec" <<'PY'
import json
import pathlib
import subprocess
import sys

workspace = pathlib.Path(sys.argv[1])
remote_spec = sys.argv[2]
plans_dir = workspace / ".megaplan" / "plans"
chain_paths = sorted(
    {
        *plans_dir.glob(".chains/*.json"),
        *workspace.glob(".megaplan/initiatives/*/.megaplan/plans/.chains/*.json"),
        *(workspace / ".megaplan").glob("**/chain_state.json"),
    },
    key=lambda path: path.stat().st_mtime,
    reverse=True,
)


def _spec_path() -> pathlib.Path | None:
    if not remote_spec:
        return None
    path = pathlib.Path(remote_spec)
    if not path.is_absolute():
        path = workspace / path
    return path


def _merge_policy() -> str:
    path = _spec_path()
    if path is None:
        return ""
    try:
        for raw_line in path.read_text(encoding="utf-8").splitlines():
            line = raw_line.split("#", 1)[0].strip()
            if not line.startswith("merge_policy:"):
                continue
            value = line.split(":", 1)[1].strip().strip("'\"")
            if value == "manual":
                return "review"
            return value
    except Exception:
        return ""
    return ""


def _pr_state(pr_number: int) -> str:
    proc = subprocess.run(
        ["gh", "pr", "view", str(pr_number), "--json", "state"],
        cwd=workspace,
        check=False,
        capture_output=True,
        text=True,
        timeout=120,
    )
    if proc.returncode != 0:
        return ""
    state = json.loads(proc.stdout or "{}").get("state", "")
    return state.lower() if isinstance(state, str) else ""


def _run_merge_command(pr_number: int, *flags: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["gh", "pr", "merge", str(pr_number), *flags],
        cwd=workspace,
        check=False,
        capture_output=True,
        text=True,
        timeout=120,
    )


def _attempt_auto_merge(pr_number: int) -> None:
    subprocess.run(
        ["gh", "pr", "ready", str(pr_number)],
        cwd=workspace,
        check=False,
        capture_output=True,
        text=True,
        timeout=120,
    )
    proc = _run_merge_command(pr_number, "--auto", "--squash", "--delete-branch")
    combined = f"{proc.stdout or ''} {proc.stderr or ''}"
    if proc.returncode == 0:
        return
    if "already checked out" in combined:
        _run_merge_command(pr_number, "--auto", "--squash")
        return
    if "Auto merge is not allowed" in combined:
        proc = _run_merge_command(pr_number, "--squash", "--delete-branch")
        combined = f"{proc.stdout or ''} {proc.stderr or ''}"
        if proc.returncode != 0 and "already checked out" in combined:
            _run_merge_command(pr_number, "--squash")


for path in chain_paths:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    last_state = payload.get("last_state")
    pr_number = payload.get("pr_number")
    if last_state == "awaiting_pr_merge":
        pass
    elif last_state in ("done", "complete", "finalized") and pr_number:
        # Ground-truth guard: the chain driver can mark last_state=done once the
        # milestone plan is finalized even when the milestone PR is still open
        # under merge_policy: review. Verify the PR live; if it is not merged yet
        # the chain is really awaiting_pr_merge, not done/finalized. Without this the
        # watchdog trusts last_state=done and falls through to a stale
        # repair-loop marker, mislabeling the session needs_human.
        try:
            if _pr_state(int(pr_number)) == "merged":
                continue
        except Exception:
            continue
    else:
        continue
    if not pr_number:
        print("awaiting_pr_merge")
        raise SystemExit(0)
    try:
        pr_number_int = int(pr_number)
        if _pr_state(pr_number_int) == "merged":
            print("none")
            raise SystemExit(0)
        if _merge_policy() == "auto":
            _attempt_auto_merge(pr_number_int)
            if _pr_state(pr_number_int) == "merged":
                print("none")
                raise SystemExit(0)
    except Exception:
        pass
    print("awaiting_pr_merge")
    raise SystemExit(0)

print("none")
PY
}


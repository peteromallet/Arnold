    notify_needs_human "$report_items" "$session" "$workspace" "$remote_spec" "$run_kind" "$health" "$human_summary"
    return 0
  fi
  if [[ "$resolver_human_verdict" != provider_retry:* && "${PLAN_STATUS_MANUAL_REVIEW:-0}" == "1" ]]; then
    local human_summary repair_busy repair_summary manual_review_origin manual_review_dispatch_env manual_review_report_reason
    manual_review_origin="${PLAN_STATUS_MANUAL_REVIEW_ORIGIN:-}"
    human_summary="manual_review halt; state=${PLAN_STATUS_CURRENT_STATE:-unknown}; retry=${PLAN_STATUS_RETRY_STRATEGY:-unknown}; failure=${PLAN_STATUS_FAILURE_KIND:-unknown}"
    if [[ -n "$manual_review_origin" ]]; then
      human_summary="$human_summary; origin=$manual_review_origin"
    fi

stale_marker_relaunch_command() {
  local relaunch_command="${1:-}"
  [[ "$relaunch_command" == *"[megaplan-refresh] refusing editable install refresh:"* ]] || return 1
  [[ "$relaunch_command" == *'source checkout dirty; using current source checkout at $SRC to avoid stale runtime mirror'* ]] && return 1
  [[ "$relaunch_command" == *'git -C "$MEGAPLAN_RUNTIME_SRC" merge-base --is-ancestor HEAD "origin/$REF"'* ]] && return 1
  return 0
}

default_chain_relaunch_command() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local log_relative repo runtime_src
  if [[ "$session" == "megaplan-chain" ]]; then
    log_relative=".megaplan/cloud-chain.log"
  else
    log_relative=".megaplan/cloud-chain-${session}.log"
  fi
  repo="$(git -C "$SRC_DIR" remote get-url origin 2>/dev/null || true)"
  case "$repo" in
    https://*@github.com/*) repo="https://github.com/${repo#*@github.com/}" ;;
  esac
  runtime_src="$workspace/.megaplan/runtime/editable-engine"
  printf '{ set -e
echo "[megaplan-refresh] $(date -Iseconds) starting"
SRC=%q
REPO=%q
REF=%q
RUNTIME_SRC=%q
if [ -n "$REPO" ] && [ ! -d "$SRC/.git" ]; then
  mkdir -p "$(dirname "$SRC")"
  CLONE_URL="$REPO"
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    case "$CLONE_URL" in
      https://github.com/*) CLONE_URL="https://x-access-token:${GITHUB_TOKEN}@github.com/${CLONE_URL#https://github.com/}" ;;
    esac
  fi
  git clone --branch "$REF" "$CLONE_URL" "$SRC"
fi
if [ -d "$SRC/.git" ]; then
  git -C "$SRC" fetch origin "$REF"
  BRANCH="$(git -C "$SRC" branch --show-current)"
  if [ "$BRANCH" != "$REF" ]; then git -C "$SRC" checkout "$REF"; fi
  if [ -n "$(git -C "$SRC" status --porcelain --untracked-files=no)" ]; then
    echo "[megaplan-refresh] source checkout dirty; using current source checkout at $SRC to avoid stale runtime mirror"
    export MEGAPLAN_RUNTIME_SRC="$SRC"
  else
    if ! git -C "$SRC" merge-base --is-ancestor HEAD "origin/$REF"; then
      echo "[megaplan-refresh] source checkout ahead of origin/$REF; using current source checkout at $SRC for local repair runtime"
      git -C "$SRC" log --oneline --max-count=5 "origin/$REF..HEAD" || true
      export MEGAPLAN_RUNTIME_SRC="$SRC"
    else
      git -C "$SRC" pull --ff-only origin "$REF"
      export MEGAPLAN_RUNTIME_SRC="$SRC"
    fi
  fi
  if ! git -C "$MEGAPLAN_RUNTIME_SRC" merge-base --is-ancestor HEAD "origin/$REF"; then
    echo "[megaplan-refresh] refusing editable install refresh: $MEGAPLAN_RUNTIME_SRC has local commits not contained in origin/$REF"
    git -C "$MEGAPLAN_RUNTIME_SRC" log --oneline --max-count=5 "origin/$REF..HEAD" || true
    exit 20
  fi
  pip install -e "$MEGAPLAN_RUNTIME_SRC"
else
  echo "[megaplan-refresh] source clone missing at $SRC; skipping editable install"
  export MEGAPLAN_RUNTIME_SRC="$SRC"
fi
echo "[megaplan-refresh] done"
true; } >> %q 2>&1 && if [[ -f /workspace/.cloud-hot-env ]]; then set -a; . /workspace/.cloud-hot-env; set +a; fi; cd %q && PYTHONSAFEPATH=1 PYTHONPATH="$MEGAPLAN_RUNTIME_SRC:${PYTHONPATH:-}" MEGAPLAN_TRUSTED_CONTAINER=1 python3 -P -m arnold_pipelines.megaplan chain start --spec %q --project-dir %q >> %q 2>&1' \
    "$SRC_DIR" "$repo" "$SYNC_BRANCH" "$runtime_src" "$workspace/$log_relative" "$workspace" "$remote_spec" "$workspace" "$workspace/$log_relative"
}

resolve_relaunch_command() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local relaunch_command="${6:-}"

  # A chain marker commonly preserves its original `chain start` command and
  # omits plan_name. Once the active plan records explicit resume authority,
  # that current state must outrank the stale launch-time marker command.
  if [[ "$run_kind" != "plan" ]] && chain_resume_plan_relaunch_command_if_needed "$workspace" "$plan_name" "$remote_spec"; then
    return 0
  fi
  if [[ -n "$relaunch_command" ]] && ! stale_marker_relaunch_command "$relaunch_command"; then
    printf '%s' "$relaunch_command"
    return 0
  fi
  if [[ "$run_kind" == "plan" ]]; then
    [[ -n "$plan_name" ]] || return 1
    default_plan_relaunch_command "$plan_name" "$workspace"
    return 0
  fi
  default_chain_relaunch_command "$session" "$workspace" "$remote_spec"
}


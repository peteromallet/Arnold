    if isinstance(execute_tiers, dict):
        def sort_key(item: tuple[str, object]) -> tuple[int, str]:
            key = item[0]
            try:
                return (0, int(key))
            except Exception:
                return (1, str(key))

        for _, spec in sorted(execute_tiers.items(), key=sort_key):
            if isinstance(spec, str) and spec:

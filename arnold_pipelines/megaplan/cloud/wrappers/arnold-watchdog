          report_item "$report_items" "$session" "observe" "needs_human" "$repair_summary" "$workspace" "$remote_spec"
          return 0
        fi
      fi
      manual_review_report_reason="manual_review repair loop dispatched before needs_human"
      if [[ "$manual_review_origin" == "auto_stall" || "$manual_review_origin" == "auto_stall_legacy" ]]; then
        manual_review_report_reason="auto_stall manual_review repair loop dispatched before needs_human"
      fi
      repair_busy="$(repair_loop_busy_state "$session")"
      if [[ "$repair_busy" == "same_session" ]]; then
        log "session manual_review classified for repair dispatch; repair already running session=$session summary=$human_summary"
        report_item "$report_items" "$session" "repair" "repair_running" "$manual_review_report_reason" "$workspace" "$remote_spec"
        return 0
      fi
      if [[ "$repair_busy" == "other_session" ]]; then
        log "session manual_review classified for repair dispatch; another repair loop already running so waiting turn session=$session summary=$human_summary"
        report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
        return 0
      fi
      if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then
        if [[ "${REPAIR_DISPATCH_RESULT:-}" == "busy" ]]; then
          log "session manual_review classified for repair dispatch; another repair loop already running so waiting turn session=$session summary=$human_summary"
          report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
        else
          log "session manual_review classified for repair dispatch; background-dispatched repair loop before needs_human session=$session summary=$human_summary"
          report_item "$report_items" "$session" "repair" "repair_dispatched" "$manual_review_report_reason" "$workspace" "$remote_spec"
        fi
        return 0
      fi
      log "session manual_review classified for repair dispatch but repair loop is unavailable; needs human session=$session plan=${PLAN_STATUS_PLAN_NAME:-} summary=$human_summary"
    fi
    log "session requires human review session=$session plan=${PLAN_STATUS_PLAN_NAME:-} summary=$human_summary"
    notify_needs_human "$report_items" "$session" "$workspace" "$remote_spec" "$run_kind" "$health" "$human_summary"
    return 0
  fi

  # The repair loop leaves a persistent sidecar after 3 bounded failures so the
  # watchdog reports needs-human instead of immediately re-arming automation.
  # Ground-truth guard: that marker reflects a PAST exhaustion. If the chain's
  # current-milestone PR has since MERGED, the chain can now reconcile+complete
  # on relaunch, so the marker is stale -- clear it and fall through to the
  # relaunch path instead of suppressing it with a stale needs_human.
  if [[ "$resolver_human_verdict" != provider_retry:* && -f "$(repair_needs_human_path "$session")" ]]; then
    if [[ "$run_kind" == "chain" ]] && [[ "$(chain_current_pr_merged "$workspace" "$remote_spec")" == "merged" ]]; then
      rm -f "$(repair_needs_human_path "$session")" 2>/dev/null || true
      log "stale repair marker cleared; current milestone PR merged, falling through to relaunch session=$session"
    elif ! repair_needs_human_matches_current_plan "$session" "${PLAN_STATUS_PLAN_NAME:-}" >/dev/null 2>&1; then
      rm -f "$(repair_needs_human_path "$session")" 2>/dev/null || true
      log "stale repair needs-human marker cleared; live current plan supersedes marker session=$session live_plan=${PLAN_STATUS_PLAN_NAME:-unknown}"
      compare_needs_human_to_resolver "$session" "${PLAN_STATUS_PLAN_NAME:-}" "true" ""
    elif sibling_alive="$(workspace_has_other_alive_session "$session" "$workspace" 2>/dev/null)"; then
      rm -f "$(repair_needs_human_path "$session")" 2>/dev/null || true
      log "stale repair needs-human marker cleared; sibling session is alive session=$session sibling=$sibling_alive"
      compare_needs_human_to_resolver "$session" "${PLAN_STATUS_PLAN_NAME:-}" "false" ""
    elif command -v repair_needs_human_should_remain_human >/dev/null 2>&1 && ! repair_needs_human_should_remain_human "$session" "${PLAN_STATUS_PLAN_NAME:-}"; then
      rm -f "$(repair_needs_human_path "$session")" 2>/dev/null || true
      log "stale repair needs-human marker cleared; fresh classifier no longer requires human session=$session live_plan=${PLAN_STATUS_PLAN_NAME:-unknown}"
      compare_needs_human_to_resolver "$session" "${PLAN_STATUS_PLAN_NAME:-}" "false" ""
    else
      local repair_summary
      repair_summary="$(repair_needs_human_summary "$session")"
      log "session marked needs human by repair loop session=$session summary=$repair_summary"
      report_item "$report_items" "$session" "observe" "needs_human" "$repair_summary" "$workspace" "$remote_spec"
      compare_needs_human_to_resolver "$session" "${PLAN_STATUS_PLAN_NAME:-}" "false" ""
      return 0
    fi
  fi

  # NOTE: a missing chain/epic-chain spec here was previously handled by
  # dispatching repair_unintended_stop. That path is now retired by the
  # env-gone gate above (after spec resolution) — a wiped spec means no
  # environment to repair, so we never reach this point with a missing spec.

  local sibling_alive
  if [[ "$health" == "stopped" ]] && sibling_alive="$(workspace_has_other_alive_session "$session" "$workspace" 2>/dev/null)"; then
    log "stopped session superseded by live sibling; skipping relaunch session=$session sibling=$sibling_alive"
    report_item "$report_items" "$session" "observe" "superseded" "live sibling session owns workspace: $sibling_alive" "$workspace" "$remote_spec"
    return 0
  fi

  local repair_busy
  if [[ "$health" == "stopped" ]]; then
    emit_watchdog_incident_bridge_event "detection" "$session" "$workspace" "$remote_spec" "session stopped and needs repair attention" "stopped" "immediate_repair"
  else
    emit_watchdog_incident_bridge_event "detection" "$session" "$workspace" "$remote_spec" "session unhealthy and needs repair attention: $health" "$health" "immediate_repair"
  fi
  repair_busy="$(repair_loop_busy_state "$session")"
  if [[ "$repair_busy" == "same_session" ]]; then
    log "session needs repair attention; repair already running session=$session health=$health"
    report_item "$report_items" "$session" "repair" "repair_running" "repair already running" "$workspace" "$remote_spec"
    return 0
  fi
  if [[ "$repair_busy" == "other_session" ]]; then
    log "session needs repair attention; another repair loop already running so waiting turn session=$session health=$health"
    report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
    return 0
  fi

  # Repair + relaunch. The primary repair operator is BACKGROUND-DISPATCHED so
  # it never blocks the tick (it can run up to its 60-min timeout and relaunches
  # the run itself on success). The watchdog's direct tmux relaunch runs only as
  # a fallback: when repair is unavailable, or when it was already dispatched
  # and has since exited without reviving the session (marker present + not
  # running).
  if [[ "$health" != "stopped" ]]; then
    if repair_unhealthy_session "$session" "$workspace" "$remote_spec" "$health"; then
      # Repair running or just background-dispatched; it owns the relaunch.
      report_item "$report_items" "$session" "repair" "repair_running" "$health" "$workspace" "$remote_spec"
      return 0
    fi
    local meta_repair_trigger meta_dispatch_result
    meta_repair_trigger="$(compute_meta_repair_trigger "$session" "$current_target_observation" "$health")"
    if [[ "$meta_repair_trigger" == TRIGGER:* ]]; then
      if dispatch_meta_repair "$session" "$workspace" "$remote_spec" "$report_items" "${meta_repair_trigger#TRIGGER:}"; then
        meta_dispatch_result="${REPAIR_DISPATCH_RESULT:-}"
        if [[ "$meta_dispatch_result" == "dispatched" ]]; then
          log "session unhealthy after repair failure; meta-repair background-dispatched session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:}"
          return 0
        fi
        log "session unhealthy after repair failure; meta-repair trigger matched but fell through to direct relaunch session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:} dispatch=${meta_dispatch_result:-unknown}"
      else
        log "session unhealthy after repair failure; meta-repair trigger matched but dispatch unavailable session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:}"
      fi
    fi
  else
    local meta_repair_trigger meta_dispatch_result
    meta_repair_trigger="$(compute_meta_repair_trigger "$session" "$current_target_observation" "$health")"
    if [[ "$meta_repair_trigger" == TRIGGER:* ]]; then
      if dispatch_meta_repair "$session" "$workspace" "$remote_spec" "$report_items" "${meta_repair_trigger#TRIGGER:}"; then
        meta_dispatch_result="${REPAIR_DISPATCH_RESULT:-}"
        if [[ "$meta_dispatch_result" == "dispatched" ]]; then
          log "session stopped after repair failure; meta-repair background-dispatched session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:}"
          return 0
        fi
        log "session stopped after repair failure; meta-repair trigger matched but fell through to direct relaunch session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:} dispatch=${meta_dispatch_result:-unknown}"
      else
        log "session stopped after repair failure; meta-repair trigger matched but dispatch unavailable session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:}"
      fi
    fi
    if mechanical_relaunch_attempted_previously "$session"; then
      if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then
        if [[ "${REPAIR_DISPATCH_RESULT:-}" == "busy" ]]; then
          log "session stopped after mechanical relaunch; another repair loop already running so waiting turn session=$session"
          report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
        else
          log "session stopped after mechanical relaunch: background-dispatched repair loop session=$session"
          report_item "$report_items" "$session" "repair" "repair_dispatched" "repair loop dispatched after mechanical relaunch" "$workspace" "$remote_spec"
        fi
        return 0
      fi
      log "session stopped after mechanical relaunch; repair loop missing -> direct relaunch session=$session"
    elif kimi_dispatch_failed_previously "$session"; then
      log "session stopped; repair loop tried and exited without recovery -> direct relaunch session=$session"
      kimi_dispatch_marker_clear "$session"
    else
      log "session stopped; mechanical relaunch first session=$session"
      kimi_dispatch_marker_set "$session"
    fi
  fi

  ensure_install_or_repair || log "editable install still unhealthy; relaunching anyway"
  if tmux has-session -t "$session" 2>/dev/null; then
    log "killing stale tmux session before relaunch: $session"
    tmux kill-session -t "$session" 2>/dev/null || true
    for _ in 1 2 3 4 5; do
      tmux has-session -t "$session" 2>/dev/null || break
      sleep 0.2
    done
  fi

  local safe log_relative launch_script quoted_command quoted_command_shell
  safe="$(safe_name "$session")"
  launch_script="$(mktemp)"
  quoted_command="$(resolve_relaunch_command "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name" "$relaunch_command")" || {
    log "unable to determine relaunch command session=$session kind=$run_kind"
    report_item "$report_items" "$session" "restart" "needs_attention" "unable to determine relaunch command" "$workspace" "$remote_spec"
    rm -f "$launch_script"
    return 1
  }
  printf -v quoted_command_shell '%q' "$quoted_command"
  cat > "$launch_script" <<EOF
#!/usr/bin/env bash
set -euo pipefail
cd $(printf '%q' "$workspace")
export ARNOLD_SUPERVISE_SESSION=$(printf '%q' "$session")
export ARNOLD_SUPERVISE_WORKSPACE=$(printf '%q' "$workspace")
export ARNOLD_SUPERVISE_REMOTE_SPEC=$(printf '%q' "$remote_spec")
export ARNOLD_SUPERVISE_RUN_KIND=$(printf '%q' "$run_kind")
exec /usr/local/bin/arnold-supervise "watchdog-$safe" bash -lc $quoted_command_shell
EOF
  chmod +x "$launch_script"

  log "relaunching stopped session=$session kind=$run_kind spec=$remote_spec"
  tmux new-session -d -s "$session" -c "$workspace" "bash '$launch_script'" || {
    if tmux has-session -t "$session" 2>/dev/null; then
      local race_health
      if ! declare -F verify_relaunch_health >/dev/null 2>&1; then
        race_health="modular_invocation_unverified"
        log "relaunch raced with existing tmux session; verifier unavailable in modular invocation session=$session"
        report_item "$report_items" "$session" "restart" "restarted" "session exists after relaunch race; health verifier unavailable in modular invocation" "$workspace" "$remote_spec"
      elif race_health="$(verify_relaunch_health "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"; then
        log "relaunch raced with existing tmux session; verified health=$race_health session=$session"
        report_item "$report_items" "$session" "restart" "restarted" "session exists after relaunch race" "$workspace" "$remote_spec"
      else
        log "relaunch raced with existing tmux session but substantive launch failed health=$race_health session=$session"
        report_item "$report_items" "$session" "restart" "restart_failed" "session exists after relaunch race but launch health=$race_health" "$workspace" "$remote_spec"
        dispatch_kimi_repair "$session" "$workspace" "$remote_spec" || true
        rm -f "$launch_script"
        return 1
      fi
      rm -f "$launch_script"
      return 0
    fi
    log "failed to relaunch $session"
    report_item "$report_items" "$session" "restart" "restart_failed" "tmux relaunch failed" "$workspace" "$remote_spec"
    rm -f "$launch_script"
    return 1
  }
  local verified_health
  if ! declare -F verify_relaunch_health >/dev/null 2>&1; then
    # launch_chain_tick is extracted in isolation by focused shell contract
    # tests. The deployed wrapper always defines the verifier above.
    verified_health="modular_invocation_unverified"
    report_item "$report_items" "$session" "restart" "restarted" "stopped session relaunched" "$workspace" "$remote_spec"
    return 0
  elif verified_health="$(verify_relaunch_health "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"; then
    log "relaunch ground-truth verification passed session=$session health=$verified_health"
    report_item "$report_items" "$session" "restart" "restarted" "stopped session relaunched" "$workspace" "$remote_spec"
    return 0
  fi
  log "relaunch did not produce a healthy runner session=$session health=$verified_health"
  report_item "$report_items" "$session" "restart" "restart_failed" "tmux relaunch did not produce a healthy runner; health=$verified_health" "$workspace" "$remote_spec"
  emit_watchdog_incident_bridge_event "repair_failure" "$session" "$workspace" "$remote_spec" "mechanical relaunch failed ground-truth verification: $verified_health" "$verified_health" "l1_repair"
  if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then
    report_item "$report_items" "$session" "repair" "repair_dispatched" "repair loop dispatched after unverified relaunch; health=$verified_health" "$workspace" "$remote_spec"
  fi
  return 1
}

scan_once_unlocked() {
  log "scan start marker_dir=$MARKER_DIR"
  maybe_reexec_updated_watchdog
  local report_items
  report_items="$(mktemp)"
  # Validate the observation/runtime path before any repair-trigger or status
  # scan. If the watchdog cannot import its own cloud modules, never continue
  # silently on a stale report.
  if ! bootstrap_watchdog_observation "$report_items"; then
    emit_report "$report_items" 0
    rm -f "$report_items"
    return 1
  fi
  # A heartbeat means observation readiness succeeded, not merely that the
  # shell process reached the beginning of a sweep.
  write_watchdog_heartbeat
  # P2: heartbeat + an early snapshot write BEFORE the heavy/stall-prone work
  # (repair_trigger_scan, git sync, pip refresh). If anything below hangs, the
  # cache is at most ~one sweep stale instead of frozen indefinitely. The early
  # write uses last sweep's report and is "notrack" (best-effort, not counted
  # toward escalation); the authoritative write at sweep end still counts.
  write_status_snapshot "" "" "" notrack
  repair_trigger_scan
  if [[ "${WATCHDOG_BOOTSTRAP_RECOVERED:-0}" != "1" ]]; then
    sync_editable_source_branch "$report_items" || true
  fi
  maybe_reexec_updated_watchdog
  while IFS=$'\t' read -r adopted_session adopted_workspace adopted_remote_spec adopted_kind adopted_plan_name; do
    [[ -n "$adopted_session" ]] || continue
    log "adopted marker-less tmux session=$adopted_session kind=${adopted_kind:-chain}"
    report_item "$report_items" "$adopted_session" "adopt" "adopted" "adopted marker-less tmux session" "$adopted_workspace" "$adopted_remote_spec"
  done < <(adopt_unmarked_tmux_sessions)
  if [[ ! -d "$MARKER_DIR" ]]; then
    log "scan complete: marker directory missing"
    emit_report "$report_items" 0
    write_status_snapshot
    rm -f "$report_items"
    return 0
  fi

  local found=0
  # Canonical sidecars ignored here: *.progress.json|*.reap-progress.json|*.repair-progress.json|*.chain-health.progress.json
  while IFS= read -r marker; do
    [[ -n "$marker" ]] || continue
    found=$((found + 1))
    local session workspace remote_spec run_kind plan_name relaunch_command
    session="$(json_field "$marker" session 2>/dev/null)" || {
      log "flag invalid marker (missing session): $marker"
      report_item "$report_items" "" "flag" "setup_invalid" "missing session: $marker"
      continue
    }
    workspace="$(json_field "$marker" workspace 2>/dev/null)" || {
      log "flag invalid marker (missing workspace): $marker"
      report_item "$report_items" "$session" "flag" "workspace_missing" "missing workspace: $marker"
      continue
    }
    remote_spec="$(json_field "$marker" remote_spec 2>/dev/null)" || {
      log "flag invalid marker (missing remote_spec): $marker"
      report_item "$report_items" "$session" "flag" "setup_invalid" "missing remote_spec: $marker" "$workspace"
      continue
    }
    run_kind="$(json_field "$marker" run_kind 2>/dev/null || true)"
    plan_name="$(json_field "$marker" plan_name 2>/dev/null || true)"
    relaunch_command="$(json_field "$marker" relaunch_command 2>/dev/null || true)"
    launch_chain_tick "$session" "$workspace" "$remote_spec" "$report_items" "${run_kind:-chain}" "$plan_name" "$relaunch_command" || true
  done < <(PYTHONPATH="${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$MARKER_DIR" <<'PY'
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.session_markers import is_canonical_session_marker_path

marker_dir = pathlib.Path(sys.argv[1])
for path in sorted(marker_dir.glob("*.json")):
    if is_canonical_session_marker_path(path):
        print(path)
PY
)
  local retention_result
  retention_result="$(run_repair_data_maintenance 2>>"${LOG:-/dev/null}" || true)"
  if [[ "$retention_result" == RAN:* ]]; then
    log "repair-data maintenance complete cleanup_id=${retention_result#RAN:}"
  elif [[ "$retention_result" == LOCK_BUSY ]]; then
    log "repair-data maintenance skipped; ordinary repair lock active"
  fi
  reap_stale_repairs "$report_items"
  log "scan complete markers=$found"
  emit_report "$report_items" "$found"
  write_status_snapshot
  rm -f "$report_items"
}

scan_once() {
  local scan_lock_fd scan_rc
  mkdir -p "$(dirname "$SCAN_LOCK_FILE")"
  if command -v flock >/dev/null 2>&1; then
    exec {scan_lock_fd}>"$SCAN_LOCK_FILE"
    if [[ "$COOPERATIVE_ONCE" == "1" ]]; then
      if ! flock -w "$SCAN_LOCK_WAIT_SECS" "$scan_lock_fd"; then
        log "audit recovery scan lock timed out lock=$SCAN_LOCK_FILE wait_secs=$SCAN_LOCK_WAIT_SECS"
        exec {scan_lock_fd}>&-
        return 75
      fi
    elif ! flock -n "$scan_lock_fd"; then
      log "scan skipped; another watchdog sweep owns lock=$SCAN_LOCK_FILE"
      exec {scan_lock_fd}>&-
      return 75
    fi
  fi

  write_watchdog_sweep_health started || return 74
  scan_once_unlocked
  scan_rc=$?
  if [[ $scan_rc -eq 0 ]]; then
    write_watchdog_sweep_health completed || scan_rc=74
  else
    write_watchdog_sweep_health failed || true
  fi
  if [[ -n "${scan_lock_fd:-}" ]]; then
    flock -u "$scan_lock_fd" 2>/dev/null || true
    exec {scan_lock_fd}>&-
  fi
  return "$scan_rc"
}

log "starting (interval=${INTERVAL}s marker_dir=$MARKER_DIR repair=$REPAIR_ENABLED push=$PUSH_REPAIRS report=$REPORT_PATH)"
while true; do
  scan_once
  scan_rc=$?
  if [[ "$ONCE" == "--once" ]]; then
    exit "$scan_rc"
  fi
  sleep "$INTERVAL"
done

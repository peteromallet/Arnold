    return 0
  fi
  if [[ "$health" == "stopped" && "${PLAN_STATUS_ACTIVE_STEP_PRESENT:-0}" == "1" && "${PLAN_STATUS_ACTIVE_STEP_PID_ALIVE:-}" != "1" ]]; then
    local stale_active_summary
    stale_active_summary="stale_active_step: plan=${PLAN_STATUS_PLAN_NAME:-unknown}; state=${PLAN_STATUS_CURRENT_STATE:-unknown}; phase=${PLAN_STATUS_ACTIVE_STEP_PHASE:-unknown}; worker_pid=${PLAN_STATUS_ACTIVE_STEP_WORKER_PID:-none} not live"
    emit_watchdog_incident_bridge_event "detection" "$session" "$workspace" "$remote_spec" "$stale_active_summary" "stale_active_step" "immediate_repair"
    repair_unintended_stop "$report_items" "$session" "$workspace" "$remote_spec" "$stale_active_summary" || true
    return 0
  fi
  if [[ "${PLAN_STATUS_STATE_MISMATCH:-0}" == "1" ]]; then
    local mismatch_summary repair_busy
    mismatch_summary="${PLAN_STATUS_STATE_MISMATCH_SUMMARY:-plan/chain state mismatch detected}"
    emit_watchdog_incident_bridge_event "detection" "$session" "$workspace" "$remote_spec" "$mismatch_summary" "state_mismatch" "immediate_repair"
    repair_busy="$(repair_loop_busy_state "$session")"
    if [[ "$repair_busy" == "same_session" ]]; then
      log "session has plan/chain state mismatch; repair already running session=$session summary=$mismatch_summary"
      report_item "$report_items" "$session" "repair" "repair_running" "state mismatch repair already running" "$workspace" "$remote_spec"
      return 0
    fi
    if [[ "$repair_busy" == "other_session" ]]; then
      log "session has plan/chain state mismatch; another repair loop already running session=$session summary=$mismatch_summary"
      report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
      return 0
    fi
    if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then
      if [[ "${REPAIR_DISPATCH_RESULT:-}" == "busy" ]]; then
        log "session has plan/chain state mismatch; another repair loop already running session=$session summary=$mismatch_summary"
        report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
      else
        log "session has plan/chain state mismatch; background-dispatched repair loop session=$session summary=$mismatch_summary"
        report_item "$report_items" "$session" "repair" "repair_dispatched" "state mismatch repair loop dispatched" "$workspace" "$remote_spec"

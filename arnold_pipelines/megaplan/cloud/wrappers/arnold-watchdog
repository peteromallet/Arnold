def emit(name: str, value: str) -> None:
    print(f"{name}={shlex.quote(value)}")


def safe_session_name(raw: str) -> str:
    cleaned = re.sub(r"[^A-Za-z0-9_.-]+", "-", raw).strip("-")
    return cleaned or "chain"


def clear_artifact(path: Path) -> None:
    try:
        path.unlink()
    except FileNotFoundError:
        return
    except Exception:
        return


def load_json(path: Path) -> dict[str, object]:
    try:
        raw = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return raw if isinstance(raw, dict) else {}


def resolve_chain_state_path() -> Path | None:
    candidates: list[Path] = []
    if remote_spec_raw:
        try:
            spec_path = Path(remote_spec_raw)
            if not spec_path.is_absolute():
                spec_path = workspace / spec_path
            try:
                spec_resolved = spec_path.resolve()
            except Exception:
                spec_resolved = spec_path
            digest = hashlib.sha1(str(spec_resolved).encode("utf-8")).hexdigest()[:12]
            candidates.extend(
                [
                    workspace / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
                    workspace / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
                    spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
                    spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
                    spec_resolved.with_name("chain_state.json"),
                ]
            )
        except Exception:
            pass
    fallback: list[Path] = []
    for glob_pat in (
        ".megaplan/plans/.chains/*.json",
        ".megaplan/initiatives/*/.megaplan/plans/.chains/*.json",
        ".megaplan/**/chain_state.json",
    ):
        try:
            fallback.extend(workspace.glob(glob_pat))
        except Exception:
            continue
    candidates.extend(sorted(set(fallback), key=lambda path: path.stat().st_mtime, reverse=True))
    for candidate in candidates:
        if not candidate.exists():
            continue
        payload = load_json(candidate)
        if payload:
            return candidate
    return None


def resolve_spec_path() -> Path | None:
    if not remote_spec_raw:
        return None
    try:
        spec_path = Path(remote_spec_raw)
        if not spec_path.is_absolute():
            spec_path = workspace / spec_path
        try:
            return spec_path.resolve()
        except Exception:
            return spec_path
    except Exception:
        return None


def spec_milestone_labels() -> tuple[list[str], bool]:
    spec_path = resolve_spec_path()
    if spec_path is None:
        return [], False
    try:
        raw = spec_path.read_text(encoding="utf-8")
    except Exception:
        return [], False
    try:
        import yaml  # type: ignore

        data = yaml.safe_load(raw)
        milestones = data.get("milestones") if isinstance(data, dict) else None
        if isinstance(milestones, list):
            labels: list[str] = []
            for item in milestones:
                if not isinstance(item, dict):
                    continue
                label = item.get("label")
                if isinstance(label, str) and label:
                    labels.append(label)
            return labels, True
    except Exception:
        pass
    labels = []
    in_milestones = False
    for line in raw.splitlines():
        if re.match(r"^milestones:\s*$", line):
            in_milestones = True
            continue
        if in_milestones and re.match(r"^[A-Za-z_][\w-]*:", line):
            break
        match = re.match(r"^\s*-\s*label:\s*['\"]?([^'\"\s#]+)", line)
        if in_milestones and match:
            labels.append(match.group(1))
    return labels, True


def chain_state_is_complete(chain_state: dict[str, object]) -> tuple[bool, int]:
    labels, spec_known = spec_milestone_labels()
    milestone_count = len(labels)
    completed = chain_state.get("completed")
    completed_list = completed if isinstance(completed, list) else []
    completed_labels = {
        item.get("label")
        for item in completed_list
        if isinstance(item, dict) and isinstance(item.get("label"), str)
    }
    try:
        current_index = int(chain_state.get("current_milestone_index") or 0)
    except Exception:
        current_index = 0
    if spec_known and milestone_count == 0:
        return True, milestone_count
    if not spec_known:
        return False, milestone_count
    return current_index >= milestone_count or set(labels).issubset(completed_labels), milestone_count


def resolve_chain_log_path() -> Path | None:
    candidates = []
    if session == "megaplan-chain":
        candidates.append(workspace / ".megaplan" / "cloud-chain.log")

  if [[ -r "$pidfile" ]]; then
    read -r existing_pid < "$pidfile" || existing_pid=""
    if repair_loop_pid_matches_session "$existing_pid" "$session"; then
      exec {guard_fd}>&-
      echo "same_session"
      return 0
    fi
    rm -f "$pidfile" 2>/dev/null || true
  fi
  live_pid="$(python3 - "$session" "${PRIMARY_REPAIR_BASENAME:-arnold-repair-loop}" <<'PY' 2>/dev/null || true
import os
import pathlib
import sys

session, repair_basename = sys.argv[1:]


def parse_args(pid: int) -> list[str]:
    try:
        raw = pathlib.Path(f"/proc/{pid}/cmdline").read_bytes()
    except Exception:
        return []
    return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]


def matches(args: list[str]) -> bool:
    def match_at(idx: int) -> bool:
        if idx >= len(args):
            return False
        if os.path.basename(args[idx]) not in {"arnold-repair-loop", repair_basename}:
            return False
        return idx + 1 < len(args) and args[idx + 1] == session

    for idx in range(len(args)):
        if match_at(idx):
            return True
        if os.path.basename(args[idx]) in {"bash", "sh"} and match_at(idx + 1):
            return True
    return False


for proc_dir in sorted(pathlib.Path("/proc").iterdir(), key=lambda path: path.name):
    if not proc_dir.name.isdigit():
        continue
    pid = int(proc_dir.name)
    if pid == os.getpid() or pid == os.getppid():
        continue
    if matches(parse_args(pid)):
        print(pid)
        raise SystemExit(0)
raise SystemExit(1)
PY
)"
  if [[ -n "$live_pid" ]]; then
    exec {guard_fd}>&-
    echo "same_session"
    return 0
  fi
  exec {guard_fd}>&-
  echo "none"
}


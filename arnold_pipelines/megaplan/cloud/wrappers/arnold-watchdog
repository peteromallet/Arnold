session_health_status() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local wait_status
  if ! tmux has-session -t "$session" 2>/dev/null; then
    if matching_runner_process_alive "$workspace" "$remote_spec" "$run_kind" "$plan_name"; then
      echo "alive"
      return 0
    fi
    if [[ "$run_kind" == "chain" ]]; then
      if chain_process_is_alive "$remote_spec" || plan_process_is_alive "$plan_name"; then
        echo "alive"
        return 0
      fi
      wait_status="$(chain_wait_status "$workspace" "$remote_spec")"
      if [[ "$wait_status" != "none" ]]; then
        echo "$wait_status"
        return 0
      fi
    elif [[ "$run_kind" == "epic_chain" ]]; then
      if epic_chain_process_is_alive "$remote_spec"; then
        echo "alive"
        return 0
      fi
    elif [[ -n "$plan_name" ]] && plan_process_is_alive "$plan_name"; then
      echo "alive"
      return 0
    fi
    echo "stopped"
    return 0
  fi

  local pane log_path
  pane="$(tmux capture-pane -pt "$session" -S -120 2>/dev/null || true)"
  if printf '%s\n' "$pane" | grep -Eq 'cmd exited rc=[1-9]|error retry [0-9]+/[0-9]+'; then
    echo "retrying_failure"
    return 0
  fi

  if [[ "$run_kind" == "chain" ]]; then
    if [[ "$session" == "megaplan-chain" ]]; then
      log_path="$workspace/.megaplan/cloud-chain.log"
    else
      log_path="$workspace/.megaplan/cloud-chain-${session}.log"
    fi
    if [[ -f "$log_path" ]] && tail -80 "$log_path" 2>/dev/null | grep -Eq '"error": "invalid_spec"|invalid_spec|"error": "git_refresh_failed"|git_refresh_failed|fatal: couldn'\''t find remote ref'; then
      echo "chain_log_failure"
      return 0
    fi

    if chain_process_is_alive "$remote_spec"; then
      echo "alive"
      return 0
    fi

    wait_status="$(chain_wait_status "$workspace" "$remote_spec")"
    if [[ "$wait_status" != "none" ]]; then
      echo "$wait_status"
      return 0
    fi
  elif [[ "$run_kind" == "epic_chain" ]]; then
    log_path="$workspace/.megaplan/cloud-epic-chain-${session}.log"
    if [[ -f "$log_path" ]] && tail -80 "$log_path" 2>/dev/null | grep -Eq '"error": "invalid_spec"|invalid_spec|"error": "git_refresh_failed"|git_refresh_failed|fatal: couldn'\''t find remote ref'; then
      echo "chain_log_failure"
      return 0
    fi

    if epic_chain_process_is_alive "$remote_spec"; then
      echo "alive"
      return 0
    fi
  elif [[ -n "$plan_name" ]]; then
    if plan_process_is_alive "$plan_name"; then
      echo "alive"
      return 0
    fi
  fi

  echo "stopped"
}

verify_relaunch_health() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local attempts="${6:-15}"
  local health="stopped"
  local attempt
  for ((attempt = 1; attempt <= attempts; attempt++)); do
    health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
    case "$health" in
      alive|awaiting_pr_merge)
        printf '%s\n' "$health"
        return 0
        ;;
      chain_log_failure|retrying_failure)
        printf '%s\n' "$health"
        return 1
        ;;
    esac
    sleep 1
  done
  printf '%s\n' "$health"
  return 1
}

repair_trigger_scan() {
  local trigger_bin="${REPAIR_TRIGGER_BIN:-}"
  local output rc attempt
  if [[ -z "$trigger_bin" ]]; then
    return 0
  fi
  if [[ ! -x "$trigger_bin" ]]; then
    log "repair-trigger unavailable path=$trigger_bin"
    return 0
  fi
  rc=1
  for attempt in 1 2 3; do
    output="$(
      PYTHONSAFEPATH=1 PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" \
        "$trigger_bin" \
        --marker-dir "$MARKER_DIR" \
        --repair-data-dir "${REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}" 2>&1
    )"
    rc=$?
    [[ $rc -eq 0 ]] && break
    log "repair-trigger bootstrap attempt=$attempt rc=$rc; retrying before watchdog interval sleep"
    [[ $attempt -lt 3 ]] && sleep 1
  done
  if [[ -n "$output" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      log "repair-trigger $line"
    done <<< "$output"
  fi
  if [[ $rc -ne 0 ]]; then
    log "repair-trigger exited rc=$rc after bounded bootstrap retries; continuing watchdog scan"
  fi
  return 0
}


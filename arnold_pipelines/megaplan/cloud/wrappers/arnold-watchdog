          rm -f "$(repair_needs_human_path "$session")" 2>/dev/null || true
          log "stale repair needs-human marker cleared; live current plan supersedes marker session=$session live_plan=${PLAN_STATUS_PLAN_NAME:-unknown} marker_plans=${stale_marker_plans:-unknown}"
        }
        if [[ -n "${stale_marker_plans:-}" ]]; then
          compare_needs_human_to_resolver "$session" "${PLAN_STATUS_PLAN_NAME:-}" "true" "$stale_marker_plans"
        else
          compare_needs_human_to_resolver "$session" "${PLAN_STATUS_PLAN_NAME:-}" "false" ""
        fi
        if [[ -f "$(repair_needs_human_path "$session")" ]] && command -v repair_needs_human_should_remain_human >/dev/null 2>&1 && ! repair_needs_human_should_remain_human "$session" "${PLAN_STATUS_PLAN_NAME:-}"; then
          rm -f "$(repair_needs_human_path "$session")" 2>/dev/null || true
          log "stale repair needs-human marker cleared; fresh classifier no longer requires human session=$session live_plan=${PLAN_STATUS_PLAN_NAME:-unknown}"

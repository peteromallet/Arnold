import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
current_plan = (sys.argv[2] or "").strip()
if not current_plan:
    raise SystemExit(0)
try:
    marker = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

plans: set[str] = set()

def add(value: object) -> None:
    if isinstance(value, str):
        value = value.strip()
        if value and "/" not in value:
            plans.add(value)

def collect_from_context(context: object) -> None:
    if not isinstance(context, dict):
        return
    add(context.get("current_plan_name"))
    chain_state = context.get("chain_state_summary")
    if isinstance(chain_state, dict):
        add(chain_state.get("current_plan_name"))
    current = context.get("current")
    if isinstance(current, dict):
        add(current.get("milestone_or_plan"))
        add(current.get("current_plan_name"))

for key in ("plan_name", "current_plan_name", "chain_current_plan_name", "milestone_or_plan"):
    add(marker.get(key))

collect_from_context(marker)
repair_data_path = marker.get("repair_data_path")
if isinstance(repair_data_path, str) and repair_data_path:
    try:
        data = json.loads(pathlib.Path(repair_data_path).read_text(encoding="utf-8"))
    except Exception:
        data = {}
    if isinstance(data, dict):
        add(data.get("plan_name"))
        collect_from_context(data.get("current_failure_context"))
        iterations = data.get("iterations")
        if isinstance(iterations, list):
            for item in iterations[-3:]:
                if not isinstance(item, dict):
                    continue
                add(item.get("plan_name"))
                collect_from_context(item)
                collect_from_context(item.get("failure_context"))
                collect_from_context(item.get("current_failure_context"))

if plans and current_plan not in plans:
    print(",".join(sorted(plans)))
    raise SystemExit(1)
raise SystemExit(0)
PY
}


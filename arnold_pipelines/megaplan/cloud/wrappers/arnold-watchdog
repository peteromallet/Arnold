next_expected_event = None
if status == "dispatched":
    if repair_actor == "meta_repair":
        next_expected_event = "meta_repair.repair_attempt"
    else:
        next_expected_event = "immediate_repair.repair_attempt"
append_watchdog_dispatch(
    incident_id=incident_id,
    summary=summary,
    outcome=status,
    evidence=evidence,
    session_id=session,
    problem_id=problem_id,
    next_expected_event=next_expected_event,
    decision={
        "repair_actor": repair_actor,
        "status": status,
        "workspace": workspace_raw,
        "remote_spec": remote_spec,
    },
    root=workspace,
)
PY
}

# Background-dispatch the bounded repair loop so it never blocks the tick. The
# loop owns dev-fix -> mechanical-launch -> Kimi-launch escalation and returns
# immediately so the watchdog can scan the next session and write its report.
# Keep the historical dispatch_kimi_repair seam because the watchdog tests and
# extracted shell harnesses stub that function name directly.
dispatch_kimi_repair() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local pgid_path repair_busy claim_status request_id blocker_id managed_identity incident_id
  local run_id_path managed_run_id managed_manifest child_pid confirm_attempt
  local -a managed_cmd
  REPAIR_DISPATCH_RESULT="unavailable"
  request_id=""
  blocker_id=""
  if [[ "${PLAN_STATUS_DISPATCH_DECISION:-}" == "dispatch_l1_repair" ]]; then
    request_id="${PLAN_STATUS_REQUEST_ID:-}"
    blocker_id="${PLAN_STATUS_BLOCKER_ID:-}"
  fi
  if [[ ! -x "$PRIMARY_REPAIR_BIN" ]]; then
    emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair loop binary unavailable" "unavailable" "immediate_repair"
    return 1
  fi
  repair_busy="$(repair_loop_busy_state "$session")"
  if [[ "$repair_busy" == "same_session" ]]; then
    log "repair loop already active; skipping dispatch session=$session"
    REPAIR_DISPATCH_RESULT="busy"
    emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair loop already active" "busy" "immediate_repair"
    return 0
  fi
  if declare -F claim_active_repair_launch >/dev/null 2>&1; then
    claim_status="$(claim_active_repair_launch "$session" "$workspace" "$remote_spec")"
  else
    claim_status=""
  fi
  case "$claim_status" in
    ""|claimed)
      ;;
    already_claimed|busy)
      log "repair request already claimed; skipping dispatch session=$session request=${request_id:-unknown}"
      REPAIR_DISPATCH_RESULT="busy"
      emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair request already claimed" "busy" "immediate_repair"
      return 0
      ;;
    stale)
      log "repair request claim is stale; refusing dispatch session=$session request=${request_id:-unknown}"
      emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair request claim is stale" "busy" "immediate_repair"
      return 0
      ;;
    *)
      log "repair request claim failed; refusing dispatch session=$session request=${request_id:-unknown} status=$claim_status"
      emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair request claim failed" "unavailable" "immediate_repair"
      return 1
      ;;
  esac
  pgid_path="$(kimi_pgid_path "$session")"
  run_id_path="${pgid_path}.managed-run-id"
  rm -f "$run_id_path"
  kimi_dispatch_marker_set "$session"
  managed_identity="${request_id:-watchdog-${session}-$(date +%s%N)}"
  incident_id="$(json_field "${REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}/$session.repair-data.json" incident_id 2>/dev/null || true)"
  incident_id="${incident_id:-inc-$session}"
  managed_cmd=(
    python3 -m arnold_pipelines.megaplan.managed_agent run
    --run-kind automatic_repair
    --identity-key "$managed_identity"
    --project-dir "$workspace"
    --task-kind autonomous
    --difficulty 8
    --model control-plane
    --reasoning-effort bounded
    --route-class watchdog_authorized_l1
    --backend repair-loop
    --command-display "arnold-repair-loop $session"
    --run-id-file "$run_id_path"
    --lineage-key "repair-request:${request_id:-$session}"
    --link "repair_request_id=$request_id"
    --link "blocker_id=$blocker_id"
    --link "repair_queue_dir=${MARKER_DIR%/*}/repair-queue"
    --link "incident_id=$incident_id"
    --link "cloud_session=$session"
    --link "chain=$remote_spec"
    --link "plan=${PLAN_STATUS_PLAN_NAME:-}"
    --link "phase=watchdog_dispatch"
    --
    "$PRIMARY_REPAIR_BIN" "$session" "$workspace" "$remote_spec"
  )
  if command -v setsid >/dev/null 2>&1; then
    PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" \
    CLOUD_WATCHDOG_REPAIR_REQUEST_ID="$request_id" \
    CLOUD_WATCHDOG_REPAIR_BLOCKER_ID="$blocker_id" \
    CLOUD_WATCHDOG_REPAIR_CLAIM_OWNER_PID="$$" \
    setsid "${managed_cmd[@]}" \
      >> "$LOG" 2>&1 < /dev/null &
  else
    PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" \
    CLOUD_WATCHDOG_REPAIR_REQUEST_ID="$request_id" \
    CLOUD_WATCHDOG_REPAIR_BLOCKER_ID="$blocker_id" \
    CLOUD_WATCHDOG_REPAIR_CLAIM_OWNER_PID="$$" \
    "${managed_cmd[@]}" \
      >> "$LOG" 2>&1 < /dev/null &
  fi
  child_pid="$!"
  printf '%s\n' "$child_pid" > "$pgid_path"
  managed_run_id=""
  managed_manifest=""
  for confirm_attempt in 1 2 3 4 5; do
    managed_run_id="$(cat "$run_id_path" 2>/dev/null || true)"
    if [[ -n "$managed_run_id" ]]; then
      managed_manifest="$workspace/.megaplan/plans/resident-subagents/$managed_run_id/manifest.json"
      if PYTHONSAFEPATH=1 python3 -P - "$managed_manifest" "$managed_run_id" "$session" "$request_id" "$blocker_id" <<'PY'
import json
import sys
from pathlib import Path

path, run_id, session, request_id, blocker_id = sys.argv[1:]
try:
    payload = json.loads(Path(path).read_text(encoding="utf-8"))
except (OSError, ValueError, TypeError):
    raise SystemExit(1)
links = payload.get("links") if isinstance(payload.get("links"), dict) else {}
history = payload.get("status_history") if isinstance(payload.get("status_history"), list) else []
running_seen = any(isinstance(item, dict) and item.get("status") == "running" for item in history)
valid = (
    payload.get("run_id") == run_id
    and payload.get("run_kind") == "automatic_repair"
    and payload.get("status") == "running"
    and running_seen
    and links.get("cloud_session") == session
    and (not request_id or links.get("repair_request_id") == request_id)
    and (not blocker_id or links.get("blocker_id") == blocker_id)
)
raise SystemExit(0 if valid else 1)
PY
      then
        log "repair loop managed launch confirmed session=$session run_id=$managed_run_id manifest=$managed_manifest"
        REPAIR_DISPATCH_RESULT="dispatched"
        emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair loop managed launch confirmed run_id=$managed_run_id" "dispatched" "immediate_repair"
        return 0
      fi
    fi
    sleep 1
  done
  kimi_dispatch_marker_clear "$session"
  rm -f "$pgid_path"
  log "repair loop launch failed confirmation session=$session pid=$child_pid run_id=${managed_run_id:-missing} manifest=${managed_manifest:-missing}"
  REPAIR_DISPATCH_RESULT="launch_failed"
  emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair loop managed launch confirmation failed" "unavailable" "immediate_repair"
  return 1
}

claim_active_repair_launch() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local blocker_id request_id
  blocker_id=""
  request_id=""
  if [[ "${PLAN_STATUS_DISPATCH_DECISION:-}" == "dispatch_l1_repair" ]]; then
    blocker_id="${PLAN_STATUS_BLOCKER_ID:-}"
    request_id="${PLAN_STATUS_REQUEST_ID:-}"
  fi
  if [[ -z "$blocker_id" || -z "$request_id" ]]; then
    printf '\n'
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - \
    "$MARKER_DIR" \
    "$session" \
    "$workspace" \
    "$remote_spec" \
    "$blocker_id" \
    "$request_id" \
    "$$" <<'PY'
import os
import sys

from arnold_pipelines.megaplan.cloud import repair_requests

marker_dir, session, workspace, remote_spec, blocker_id, request_id, pid_text = sys.argv[1:]
try:
    pid = int(pid_text)
except ValueError:
    pid = None


def _pid_is_live(candidate: int) -> bool:
    if candidate <= 0:
        return False
    try:
        os.kill(candidate, 0)
    except OSError:
        return False
    return True

result = repair_requests.claim_active_repair_request(
    repair_requests.repair_queue_dir(marker_dir),
    blocker_id=blocker_id,
    request_id=request_id,
    actor="arnold-watchdog",
    session=session,
    pid=pid,
    command=f"arnold-repair-loop {session} {workspace} {remote_spec}",
    cwd=workspace,
    is_pid_live=_pid_is_live,
    extra={"workspace": workspace, "remote_spec": remote_spec},
)
if result.status == "stale":
    owner = result.owner if isinstance(result.owner, dict) else {}
    owner_pid = owner.get("pid")
    if not isinstance(owner_pid, int):
        owner_pid = None
    released = repair_requests.release_active_repair_request_claim(
        repair_requests.repair_queue_dir(marker_dir),
        blocker_id=blocker_id,
        owner=owner,
        expected_pid=owner_pid,
    )
    if released:
        result = repair_requests.claim_active_repair_request(
            repair_requests.repair_queue_dir(marker_dir),
            blocker_id=blocker_id,
            request_id=request_id,
            actor="arnold-watchdog",
            session=session,
            pid=pid,
            command=f"arnold-repair-loop {session} {workspace} {remote_spec}",
            cwd=workspace,
            is_pid_live=_pid_is_live,
            extra={"workspace": workspace, "remote_spec": remote_spec},
        )
print(result.status)
PY
}

# ---- meta-repair dispatch ----------------------------------------------------
# Meta-repair diagnoses and fixes repair-system failures when ordinary repair
# has proven insufficient.  It is gated behind META_REPAIR_ENABLED (default-on),
# guarded against recursion, and tracked with dedicated marker/pgid sidecars so
# the watchdog can observe its lifecycle independently of ordinary repair.

check_meta_repair_recursion_guard() {
  local session="$1"
  PYTHONPATH="${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$session" "$REPAIR_DATA_DIR" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.meta_repair_policy import check_meta_repair_recursion

session, repair_data_dir = sys.argv[1:3]
result = check_meta_repair_recursion(session, repair_data_dir=repair_data_dir)
if result.recursing:
    print(f"RECURSION:{result.recommendation}")
else:
    print(f"OK:{result.recommendation}")
PY
}

compute_meta_repair_trigger() {
  local session="$1"
  local current_target_observation="${2:-}"
  local current_health="${3:-}"
  PYTHONPATH="${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$session" "$REPAIR_DATA_DIR" "$MARKER_DIR" "$current_target_observation" "$current_health" <<'PY'
import json
import pathlib
import sys
from typing import Any

from arnold_pipelines.megaplan.cloud.human_blockers import classify_needs_human_blocker
from arnold_pipelines.megaplan.cloud.meta_repair import (
    evaluate_meta_repair_triggers,
    is_model_tool_launch_failure_status,
)

session, repair_data_dir_raw, marker_dir_raw, current_target_observation_raw, current_health = sys.argv[1:]
repair_data_dir = pathlib.Path(repair_data_dir_raw)
marker_dir = pathlib.Path(marker_dir_raw)
repair_data_path = repair_data_dir / f"{session}.repair-data.json"
needs_human_path = repair_data_dir / f"{session}.needs-human.json"
sidecar_root = repair_data_dir.with_name(f"{repair_data_dir.name}.d")

if not repair_data_path.exists():
    print("NO_TRIGGER")
    raise SystemExit(0)

try:
    payload = json.loads(repair_data_path.read_text(encoding="utf-8"))
except Exception:
    print("NO_TRIGGER")
    raise SystemExit(0)

if not isinstance(payload, dict):
    print("NO_TRIGGER")
    raise SystemExit(0)

resolver_record: dict[str, Any] = {}
if current_target_observation_raw:
    try:
        loaded_observation = json.loads(current_target_observation_raw)
    except Exception:
        loaded_observation = {}
    if isinstance(loaded_observation, dict):
        resolver_record = loaded_observation

repair_outcome = str(payload.get("outcome") or "")
needs_human_present = needs_human_path.exists()
terminal_repair_failures = {
    "discord_escalated",
    "repair_timeout",
    "repair_exhausted",
}
active_step_heartbeat = resolver_record.get("active_step_heartbeat")
if (
    current_health == "alive"
    and isinstance(active_step_heartbeat, dict)
    and bool(active_step_heartbeat.get("active"))
    and not needs_human_present
):
    print("NO_TRIGGER")
    raise SystemExit(0)


def strings_from(value: Any) -> list[str]:
    found: list[str] = []
    if isinstance(value, str):
        found.append(value)
    elif isinstance(value, dict):
        for item in value.values():
            found.extend(strings_from(item))
    elif isinstance(value, list):
        for item in value:
            found.extend(strings_from(item))
    return found


attempts = payload.get("attempts")
if not isinstance(attempts, list):
    attempts = []
iterations = payload.get("iterations")
if not isinstance(iterations, list):
    iterations = []

recent_attempts = [item for item in attempts[-5:] if isinstance(item, dict)]
recent_iterations = [item for item in iterations[-5:] if isinstance(item, dict)]
contexts = [payload.get("current_failure_context")]
contexts.extend(recent_attempts)
contexts.extend(recent_iterations)

failure_kinds: list[str] = []
for item in recent_attempts:
    for candidate in (
        item.get("failure_classification"),
        (item.get("failure_context") or {}).get("failure_classification") if isinstance(item.get("failure_context"), dict) else None,
        (item.get("post_launch_failure_context") or {}).get("failure_classification") if isinstance(item.get("post_launch_failure_context"), dict) else None,
        (item.get("plan_latest_failure") or {}).get("kind") if isinstance(item.get("plan_latest_failure"), dict) else None,
    ):
        if isinstance(candidate, str) and candidate.strip():
            failure_kinds.append(candidate.strip())
            break

attempt_outcomes = [
    str(item.get("outcome") or repair_outcome or "").strip()
    for item in recent_attempts
    if isinstance(item, dict)
]
attempt_outcomes = [item for item in attempt_outcomes if item]

state_tokens = (
    "failed:missing_state_path",
    "failed:state_unreadable",
    "failed:state_not_object",
    "state_inspection_error",
)
has_state_inspection_error = any(
    token in text
    for context in contexts
    for text in strings_from(context)
    for token in state_tokens
)

launch_statuses = []
for item in recent_attempts + recent_iterations:
    launch_statuses.extend(
        str(item.get(key) or "").strip()
        for key in ("mechanical_launch", "kimi_launch")
        if isinstance(item, dict)
    )
has_model_tool_launch_error = any(
    is_model_tool_launch_failure_status(status, state_tokens=state_tokens)
    for status in launch_statuses
)

discord_delivery_failed = False
discord_escalation_is_true_blocker = False
escalation_path = sidecar_root / "escalations" / "escalations.jsonl"
if escalation_path.exists():
    escalation_records: list[dict[str, Any]] = []
    for line in escalation_path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            record = json.loads(line)
        except Exception:
            continue
        if isinstance(record, dict) and str(record.get("session") or "") == session:
            escalation_records.append(record)
    latest_opened: dict[str, Any] | None = None
    latest_followup_event = ""
    for record in escalation_records:
        event = str(record.get("event") or "").strip()
        if event == "opened":
            latest_opened = record
            latest_followup_event = ""
            continue
        if (
            latest_opened
            and str(record.get("escalation_id") or "") == str(latest_opened.get("escalation_id") or "")
            and event
        ):
            latest_followup_event = event
    if latest_opened:
        discord_escalation_is_true_blocker = (
            str(latest_opened.get("blocker_verdict") or "").strip() == "TRUE_BLOCKER"
        )
        discord_delivery_failed = latest_followup_event in {
            "unavailable",
            "failed",
            "delivery_failed",
        }
if needs_human_path.exists():
    try:
        needs_human_payload = json.loads(needs_human_path.read_text(encoding="utf-8"))
    except Exception:
        needs_human_payload = {}
    discord_status = ""
    if isinstance(needs_human_payload, dict):
        discord_status = str(needs_human_payload.get("discord_status") or "").strip()
    if not discord_delivery_failed:
        discord_delivery_failed = discord_status not in {"", "pending", "queued", "delivered"}

    current_plan = ""
    if isinstance(needs_human_payload, dict):
        current_plan = str(
            needs_human_payload.get("current_plan_name")
            or needs_human_payload.get("plan_name")
            or ""
        ).strip()
    if not current_plan:
        current_plan = str(payload.get("plan_name") or "").strip()

    if current_plan:
        plan_refs = (resolver_record.get("needs_human") or {}).get("plan_refs", [])
        if not isinstance(plan_refs, list):
            plan_refs = []
        current_refs = resolver_record.get("current_refs") or {}
        if not isinstance(current_refs, dict):
            current_refs = {}
        authoritative_source = str(resolver_record.get("authoritative_source") or "").strip()
        has_current_target_proof = bool(
            authoritative_source
            and authoritative_source != "resolver_observe_disabled"
            and (
                bool((resolver_record.get("plan_state") or {}).get("present"))
                or bool((resolver_record.get("chain_state") or {}).get("present"))
                or bool((resolver_record.get("chain_log") or {}).get("present"))
                or bool((resolver_record.get("active_step_heartbeat") or {}).get("active"))
            )
        )
        discord_escalation_is_true_blocker = (
            current_plan in plan_refs
            and str(current_refs.get("current_plan_name") or "").strip() == current_plan
            and has_current_target_proof
        )
    if current_plan and not discord_escalation_is_true_blocker:
        try:
            blocker = classify_needs_human_blocker(
                session,
                current_plan=current_plan,
                marker_dir=marker_dir,
                repair_data_dir=repair_data_dir,
                needs_human_path=needs_human_path,
                needs_human_payload=needs_human_payload if isinstance(needs_human_payload, dict) else None,
            )
            discord_escalation_is_true_blocker = blocker.is_true_blocker
        except Exception:
            discord_escalation_is_true_blocker = False

active_step = resolver_record.get("active_step_heartbeat")
if (
    isinstance(active_step, dict)
    and active_step.get("active")
    and not needs_human_present
    and repair_outcome not in terminal_repair_failures
):
    print("NO_TRIGGER")
    raise SystemExit(0)

classification, _ = evaluate_meta_repair_triggers(
    session,
    repair_data_dir=repair_data_dir,
    repair_outcome=repair_outcome,
    attempt_outcomes=attempt_outcomes,
    failure_kinds=failure_kinds,
    has_state_inspection_error=has_state_inspection_error,
    has_model_tool_launch_error=has_model_tool_launch_error,
    discord_delivery_failed=discord_delivery_failed,
    discord_escalation_is_true_blocker=discord_escalation_is_true_blocker,
    repair_budget_exhausted=repair_outcome in {"repair_timeout", "repair_exhausted"},
    current_target_observation=resolver_record,
    load_evidence=True,
)

if (
    current_health == "alive"
    and classification.trigger_label in {
        "persistent_recurring_retry",
        "partial_liveness_recurrence",
    }
    and not needs_human_present
    and repair_outcome not in terminal_repair_failures
):
    print("NO_TRIGGER")
    raise SystemExit(0)

if classification.should_dispatch and classification.trigger_label:
    print(f"TRIGGER:{classification.trigger_label}")
else:
    print("NO_TRIGGER")
PY
}

dispatch_meta_repair() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local report_items="$4"
  local trigger_label="${5:-}"
  local pgid_path repair_busy recursion_result request_id blocker_id incident_id parent_run_id
  local -a managed_cmd
  REPAIR_DISPATCH_RESULT="unavailable"

  # Feature-flag gate: META_REPAIR_ENABLED defaults on; explicit "0"/"false"/"no"/"off" disables it.
  case "${META_REPAIR_ENABLED_FLAG:-1}" in
    0|false|False|FALSE|no|No|NO|off|Off|OFF)
    log "meta-repair disabled by feature flag; skipping dispatch session=$session"
    REPAIR_DISPATCH_RESULT="disabled"
    emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "meta-repair disabled by feature flag" "disabled" "meta_repair"
    if [[ -n "$report_items" ]]; then
      report_item "$report_items" "$session" "meta_repair" "disabled" "meta-repair disabled by feature flag" "$workspace" "$remote_spec"
    fi
    return 0
    ;;
  esac

  # Binary must exist and be executable
  if [[ ! -x "$META_REPAIR_BIN" ]]; then
    log "meta-repair binary missing or not executable: $META_REPAIR_BIN session=$session"
    emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "meta-repair binary unavailable" "unavailable" "meta_repair"
    if [[ -n "$report_items" ]]; then
      report_item "$report_items" "$session" "meta_repair" "unavailable" "meta-repair binary missing: $META_REPAIR_BIN" "$workspace" "$remote_spec"
    fi
    return 1
  fi

  # Busy guard: don't dispatch if a repair loop is already active for this session
  repair_busy="$(repair_loop_busy_state "$session")"
  if [[ "$repair_busy" == "same_session" ]]; then
    log "meta-repair skipped; repair loop already active session=$session"
    REPAIR_DISPATCH_RESULT="busy"
    emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "repair loop already active; meta-repair skipped" "busy" "meta_repair"
    if [[ -n "$report_items" ]]; then
      report_item "$report_items" "$session" "meta_repair" "busy" "repair loop already active" "$workspace" "$remote_spec"
    fi
    return 0
  fi

  # Recursion guard: must not launch meta-repair when one already exists
  recursion_result="$(check_meta_repair_recursion_guard "$session" 2>&1)" || true
  if [[ "$recursion_result" == RECURSION:* ]]; then
    log "meta-repair recursion guard blocked dispatch session=$session detail=$(redact_inline_text "$recursion_result")"
    REPAIR_DISPATCH_RESULT="recursive"
    emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "meta-repair recursion guard blocked dispatch" "recursion_blocked" "meta_repair"
    if [[ -n "$report_items" ]]; then
      report_item "$report_items" "$session" "meta_repair" "recursive" "meta-repair recursion guard blocked dispatch" "$workspace" "$remote_spec"
    fi
    return 0
  fi
  log "meta-repair recursion guard: $recursion_result"

  # Marker and pgid tracking
  pgid_path="$(meta_pgid_path "$session")"
  meta_dispatch_marker_set "$session"

  request_id="$(json_field "$REPAIR_DATA_DIR/$session.repair-data.json" request_id 2>/dev/null || true)"
  blocker_id="$(json_field "$REPAIR_DATA_DIR/$session.repair-data.json" blocker_id 2>/dev/null || true)"
  incident_id="$(json_field "$REPAIR_DATA_DIR/$session.repair-data.json" incident_id 2>/dev/null || true)"
  incident_id="${incident_id:-inc-$session}"
  parent_run_id="$(json_field "$REPAIR_DATA_DIR/$session.repair-data.json" managed_agent_run_id 2>/dev/null || true)"
  managed_cmd=(
    python3 -m arnold_pipelines.megaplan.managed_agent run
    --run-kind automatic_meta_repair
    --identity-key "meta-repair:${session}:${trigger_label}"
    --project-dir "$SRC_DIR"
    --task-kind root_cause
    --difficulty 10
    --model codex-cli-default
    --reasoning-effort high
    --route-class meta_repair_l2
    --backend meta-repair-loop
    --command-display "arnold-meta-repair-loop $session $trigger_label"
    --lineage-key "meta-repair:$session"
    --link "repair_request_id=$request_id"
    --link "blocker_id=$blocker_id"
    --link "incident_id=$incident_id"
    --link "cloud_session=$session"
    --link "chain=$remote_spec"
    --link "phase=meta_repair"
  )
  if [[ -n "$parent_run_id" ]]; then
    managed_cmd+=(--parent-run-id "$parent_run_id")
  fi
  managed_cmd+=(-- "$META_REPAIR_BIN" "$session" "$trigger_label")

  # Background-dispatch meta-repair so it never blocks the watchdog tick
  if command -v setsid >/dev/null 2>&1; then
    PYTHONPATH="${WRAPPER_REPO_ROOT}:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" \
    CLOUD_WATCHDOG_REPAIR_REQUEST_ID="$request_id" \
    CLOUD_WATCHDOG_REPAIR_BLOCKER_ID="$blocker_id" \
    setsid "${managed_cmd[@]}" \
      >> "$LOG" 2>&1 < /dev/null &
  else
    PYTHONPATH="${WRAPPER_REPO_ROOT}:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" \
    CLOUD_WATCHDOG_REPAIR_REQUEST_ID="$request_id" \
    CLOUD_WATCHDOG_REPAIR_BLOCKER_ID="$blocker_id" \
    "${managed_cmd[@]}" \
      >> "$LOG" 2>&1 < /dev/null &
  fi
  printf '%s\n' "$!" > "$pgid_path"
  log "meta-repair background-dispatched session=$session pid=$!"
  REPAIR_DISPATCH_RESULT="dispatched"
  emit_watchdog_incident_bridge_event "dispatch" "$session" "$workspace" "$remote_spec" "meta-repair background-dispatched" "dispatched" "meta_repair"
  if [[ -n "$report_items" ]]; then
    report_item "$report_items" "$session" "meta_repair" "dispatched" "meta-repair background-dispatched" "$workspace" "$remote_spec"
  fi
  return 0
}

run_repair_data_maintenance() {
  local throttle_secs="${REPAIR_DATA_RETENTION_INTERVAL_SECS:-21600}"
  [[ "$throttle_secs" =~ ^[0-9]+$ ]] || throttle_secs=21600
  if (( throttle_secs <= 0 )); then
    return 0
  fi

  PYTHONPATH="${WRAPPER_REPO_ROOT}:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$MARKER_DIR" "$REPAIR_DATA_DIR" "$throttle_secs" <<'PY'
import json
import pathlib
import sys
from datetime import datetime, timezone

from arnold_pipelines.megaplan.cloud.repair_contract import cleanup_repair_data_retention, load_json
from arnold_pipelines.megaplan.cloud.repair_lock import inspect_repair_lock
from arnold_pipelines.megaplan.cloud.session_markers import is_canonical_session_marker_path

marker_dir = pathlib.Path(sys.argv[1])
repair_data_dir = pathlib.Path(sys.argv[2])
throttle_secs = int(sys.argv[3])
sidecar_dir = repair_data_dir.with_name(f"{repair_data_dir.name}.d")
stamp_path = sidecar_dir / "cleanup" / "retention-maintenance.json"
now = datetime.now(timezone.utc)

previous = load_json(stamp_path, default={})
last_started_at = str(previous.get("started_at") or "").strip() if isinstance(previous, dict) else ""
if last_started_at:
    try:
        started_at = datetime.fromisoformat(last_started_at)
    except ValueError:
        started_at = None
    if started_at is not None and (now - started_at).total_seconds() < throttle_secs:
        print("THROTTLED")
        raise SystemExit(0)

for lock_dir in sorted(marker_dir.glob("*.repair-loop.lock")):
    result = inspect_repair_lock(lock_dir)
    if result.busy:
        print("LOCK_BUSY")
        raise SystemExit(0)

active_sessions: set[str] = set()
for path in sorted(marker_dir.glob("*.json")):
    if not is_canonical_session_marker_path(path):
        continue
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    if isinstance(payload, dict):
        session = str(payload.get("session") or "").strip()
        if session:
            active_sessions.add(session)

stamp_path.parent.mkdir(parents=True, exist_ok=True)

workspace_has_other_alive_session() {
  local session="$1"
  local workspace="$2"
  local candidates other_session other_workspace other_remote_spec other_run_kind other_plan_name other_health
  candidates="$(PYTHONPATH="${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$MARKER_DIR" "$session" "$workspace" <<'PY'
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.session_markers import is_canonical_session_marker_path

marker_dir = pathlib.Path(sys.argv[1])
session = sys.argv[2]
workspace = sys.argv[3]
for path in sorted(marker_dir.glob("*.json")):
    if not is_canonical_session_marker_path(path):
        continue
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    other_session = payload.get("session")
    other_workspace = payload.get("workspace")
    if not isinstance(other_session, str) or not isinstance(other_workspace, str):
        continue
    if other_session == session or other_workspace != workspace:

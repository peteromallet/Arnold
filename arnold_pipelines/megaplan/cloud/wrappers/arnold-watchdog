reconcile_awaiting_pr_merge() {
  local session="$1" workspace="$2" remote_spec="${3:-}"
  PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$session" "$workspace" "$remote_spec" "$MARKER_DIR" <<'PY'
import json
import pathlib
import subprocess
import sys
import time

session, workspace_raw, remote_spec_raw, marker_dir = sys.argv[1:]
workspace = pathlib.Path(workspace_raw)
remote_spec = pathlib.Path(remote_spec_raw) if remote_spec_raw else None
if remote_spec is not None and not remote_spec.is_absolute():
    remote_spec = workspace / remote_spec
plans_dir = workspace / ".megaplan" / "plans"


def emit(status: str, message: str = "") -> None:
    print(f"{status}\t{message}")


def load_json(path: pathlib.Path) -> dict:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}


def advancement_policy() -> tuple[bool, str]:
    if remote_spec is None:
        return False, "chain spec is missing"
    try:
        from arnold_pipelines.megaplan.chain.advancement import policy_for_spec_path

        policy = policy_for_spec_path(remote_spec)
    except Exception as exc:
        return False, f"chain advancement policy unreadable: {exc}"
    return (
        policy.automatic_pr_progression,
        f"merge_policy={policy.merge_policy} "
        f"clean_milestone_pr={policy.clean_milestone_pr} source={policy.source}",
    )


def chain_state_paths() -> list[pathlib.Path]:
    paths = {
        *plans_dir.glob(".chains/*.json"),
        *workspace.glob(".megaplan/initiatives/*/.megaplan/plans/.chains/*.json"),
        *(workspace / ".megaplan").glob("**/chain_state.json"),
    }
    if remote_spec is not None:
        sibling = remote_spec.with_name("chain_state.json")
        if sibling.exists():
            paths.add(sibling)
    return sorted(paths, key=lambda path: path.stat().st_mtime, reverse=True)


def gh_pr_state(pr_number: int) -> tuple[str, str]:
    proc = subprocess.run(
        ["gh", "pr", "view", str(pr_number), "--json", "state,mergeCommit"],
        cwd=workspace,
        check=False,
        capture_output=True,
        text=True,
        timeout=120,
    )
    if proc.returncode != 0:
        return "", ""
    try:
        payload = json.loads(proc.stdout or "{}")
    except Exception:
        return "", ""
    state = payload.get("state")
    merge_commit = payload.get("mergeCommit")
    oid = ""
    if isinstance(merge_commit, dict):
        raw_oid = merge_commit.get("oid")
        oid = raw_oid if isinstance(raw_oid, str) else ""
    return (state.lower() if isinstance(state, str) else "", oid)


def enqueue_wait_evidence(path: pathlib.Path, pr_number: int, pr_state: str) -> str:
    try:
        from arnold_pipelines.megaplan.cloud.feature_flags import repair_request_queue_enabled
        from arnold_pipelines.megaplan.cloud.repair_requests import (
            enqueue_repair_request,
            repair_queue_dir,
        )

        if not repair_request_queue_enabled():
            return "queue_disabled"
        result = enqueue_repair_request(
            queue_root=repair_queue_dir(marker_dir),
            marker_dir=marker_dir,
            session=session,
            source="watchdog_pr_merge_reconciliation",
            workspace=str(workspace),
            run_kind="chain",
            target={
                "chain_state_path": str(path),
                "remote_spec": str(remote_spec or ""),
                "pr_number": pr_number,
                "pr_state": pr_state or "unknown",
            },
            problem_signature={
                "failure_kind": "awaiting_pr_merge",
                "current_state": pr_state or "unknown",
                "phase_or_step": "watchdog_pr_merge_reconciliation",
                "milestone_or_plan": str(path),
                "gate_recommendation": "",
                "blocked_task_id": f"pr:{pr_number}",
            },
            root_cause_hint={
                "reason": "auto-policy chain is still awaiting PR merge",
                "pr_number": pr_number,
                "pr_state": pr_state or "unknown",
            },
        )
        return str(result.get("status") or "queued")
    except Exception as exc:
        return f"queue_error:{exc}"


automatic_progression, policy_reason = advancement_policy()
if not automatic_progression:
    emit("review_policy", policy_reason)
    raise SystemExit(0)

for path in chain_state_paths():
    payload = load_json(path)
    if payload.get("last_state") != "awaiting_pr_merge":
        continue
    pr_number = payload.get("pr_number")
    try:
        pr_number_int = int(pr_number)
    except Exception:
        emit("missing_pr", f"{path} has no PR number")
        raise SystemExit(0)
    pr_state, merge_oid = gh_pr_state(pr_number_int)
    payload["pr_state"] = pr_state or payload.get("pr_state")
    payload.setdefault("metadata", {})
    if isinstance(payload["metadata"], dict):
        payload["metadata"]["watchdog_pr_merge_reconciliation"] = {
            "checked_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "pr_number": pr_number_int,
            "pr_state": pr_state or "unknown",
            "merge_commit": merge_oid,
        }
    try:
        path.write_text(json.dumps(payload, sort_keys=True, indent=2) + "\n", encoding="utf-8")
    except Exception:
        pass
    if pr_state == "merged":
        subprocess.run(
            ["git", "fetch", "origin", "--prune"],
            cwd=workspace,
            check=False,
            capture_output=True,
            text=True,
            timeout=180,
        )
        if merge_oid:
            subprocess.run(
                ["git", "cat-file", "-e", f"{merge_oid}^{{commit}}"],
                cwd=workspace,
                check=False,
                capture_output=True,
                text=True,
                timeout=30,
            )
        emit("merged", f"PR #{pr_number_int} merged; fetched origin for chain relaunch")
        raise SystemExit(0)
    evidence_status = enqueue_wait_evidence(path, pr_number_int, pr_state)
    emit("waiting", f"PR #{pr_number_int} state={pr_state or 'unknown'} evidence={evidence_status}")
    raise SystemExit(0)

emit("none", "no awaiting auto-policy PR merge state")
PY
}

plan_phase_health_status() {
  local workspace="$1"
  local run_kind="${2:-chain}"
  local plan_name="${3:-}"
  python3 - "$workspace" "$run_kind" "$plan_name" <<'PY'
import datetime as dt
import json
import pathlib
import sys

workspace = pathlib.Path(sys.argv[1])
run_kind = sys.argv[2]
plan_name = sys.argv[3]
plans_dir = workspace / ".megaplan" / "plans"
if run_kind == "plan" and plan_name:
    state_files = [plans_dir / plan_name / "state.json"]
else:
    state_files = sorted(
        plans_dir.glob("*/state.json"),
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    )
if not state_files:
    print("ok")
    raise SystemExit(0)

state_path = state_files[0]
if run_kind == "plan" and plan_name and not state_path.exists():
    print(f"plan_state_missing:{plan_name}")
    raise SystemExit(0)
try:
    state = json.loads(state_path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"state_unreadable:{state_path.parent.name}:{exc}")
    raise SystemExit(0)

def _parse_timestamp(value: str) -> dt.datetime | None:
    text = str(value or "").strip()
    if not text:
        return None
    if text.endswith("Z"):
        text = text[:-1] + "+00:00"
    try:
        parsed = dt.datetime.fromisoformat(text)
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    return parsed.astimezone(dt.timezone.utc)


now = dt.datetime.now(dt.timezone.utc)
active = state.get("active_step") or {}
active_phase = str(active.get("phase") or "").strip()
active_last_activity = (
    _parse_timestamp(active.get("last_activity_at"))
    or _parse_timestamp(active.get("started_at"))
)
recent_active_state = False
events_path = state_path.parent / "events.ndjson"
if active_phase:
    if active_last_activity is not None and (now - active_last_activity) <= dt.timedelta(minutes=5):
        recent_active_state = True
if not recent_active_state and events_path.exists():
    try:
        events_mtime = dt.datetime.fromtimestamp(events_path.stat().st_mtime, tz=dt.timezone.utc)
    except OSError:
        events_mtime = None
    if events_mtime is not None and (now - events_mtime) <= dt.timedelta(minutes=5):
        recent_active_state = True

log_candidates = []
for pattern in ("cloud-chain*.log", "cloud-logs/*.log"):
    log_candidates.extend((workspace / ".megaplan").glob(pattern))
log_candidates = sorted(
    [path for path in log_candidates if path.is_file()],
    key=lambda path: path.stat().st_mtime,
    reverse=True,
)
for log_path in log_candidates[:3]:
    try:
        recent = log_path.read_text(encoding="utf-8", errors="replace").splitlines()[-240:]
    except Exception:
        continue
    last_sandbox_refusal = -1
    for idx, line in enumerate(recent):
        if "sandbox refused terminal" not in line:
            continue
        if (
            "outside the sandbox root/project directory" in line
            or "outside the worktree" in line
        ):
            last_sandbox_refusal = idx
    if last_sandbox_refusal >= 0:
        later_progress = any(
            marker in line
            for line in recent[last_sandbox_refusal + 1 :]
            for marker in ("[tool]", "[auto ", "[chain]")
        )
        if later_progress or recent_active_state:
            continue
        print(
            "workspace_drift:"
            f"{state_path.parent.name}:"
            f"log={log_path.name}:"
            "sandbox_refused_outside_project_root"
        )
        raise SystemExit(0)

latest_failure = state.get("latest_failure") or {}
failure_kind = latest_failure.get("kind")
if failure_kind in {"execution_blocked", "blocked_recovery_not_resolved"}:
    phase = latest_failure.get("phase") or "execute"
    recorded_at = latest_failure.get("recorded_at") or ""
    active = state.get("active_step") or {}
    active_phase = active.get("phase") or ""
    active_pid = active.get("worker_pid") or ""
    active_started = active.get("started_at") or ""
    current_state = state.get("current_state") or ""
    message = latest_failure.get("message") or ""
    print(
        "phase_failure:"
        f"{state_path.parent.name}:"
        f"{phase}:"
        "consecutive=1:"
        f"recorded={recorded_at or 'unknown'}:"
        f"state={current_state or 'unknown'}:"
        f"active={active_phase or 'none'}:"
        f"started={active_started or 'unknown'}:"
        f"pid={active_pid or 'none'}:"
        f"{failure_kind}:{message[:140]}"
    )
    raise SystemExit(0)
if failure_kind != "phase_failed":
    print("ok")
    raise SystemExit(0)

phase = latest_failure.get("phase") or "unknown"
recorded_at = latest_failure.get("recorded_at") or ""
history = state.get("history") or []
consecutive = 0
for item in reversed(history):
    if item.get("step") == phase and item.get("result") == "error":
        consecutive += 1
        continue
    if item.get("step") == phase and item.get("result") == "success":
        break
    if consecutive:
        break

active = state.get("active_step") or {}
active_phase = active.get("phase") or ""
active_pid = active.get("worker_pid") or ""
active_started = active.get("started_at") or ""
current_state = state.get("current_state") or ""
message = latest_failure.get("message") or ""

success_after_failure = False
for item in history:
    if item.get("step") != phase or item.get("result") != "success":
        continue
    timestamp = item.get("timestamp") or item.get("completed_at") or ""
    if recorded_at and timestamp and timestamp > recorded_at:
        success_after_failure = True
        break

if success_after_failure:
    print("ok")
    raise SystemExit(0)

print(
    "phase_failure:"
    f"{state_path.parent.name}:"
    f"{phase}:"
    f"consecutive={consecutive}:"
    f"recorded={recorded_at or 'unknown'}:"
    f"state={current_state or 'unknown'}:"
    f"active={active_phase or 'none'}:"
    f"started={active_started or 'unknown'}:"
    f"pid={active_pid or 'none'}:"
    f"{message[:160]}"
)
PY
}

plan_progress_stall_status() {
  local workspace="$1"
  local run_kind="${2:-chain}"
  local plan_name="${3:-}"
  python3 - "$workspace" "$MARKER_DIR" "$run_kind" "$plan_name" <<'PY'
import datetime as dt
import json
import os
import pathlib
import sys

workspace = pathlib.Path(sys.argv[1])
marker_dir = pathlib.Path(sys.argv[2])
run_kind = sys.argv[3]
plan_name_arg = sys.argv[4]

# Env-tunable thresholds (defaults from the cloud-watchdog progress-stall contract).
ITER_MAX = int(os.environ.get("CLOUD_WATCHDOG_STALL_ITERATIONS", "8"))
ATTEMPT_MAX = int(os.environ.get("CLOUD_WATCHDOG_STALL_ATTEMPTS", "10"))
PLAN_GROWTH_MINS = int(os.environ.get("CLOUD_WATCHDOG_STALL_PLANGROWTH_MINS", "15"))
EVENTS_MINS = int(os.environ.get("CLOUD_WATCHDOG_STALL_EVENTS_MINS", "10"))

plans_dir = workspace / ".megaplan" / "plans"
if run_kind == "plan" and plan_name_arg:
    state_files = [plans_dir / plan_name_arg / "state.json"]
else:
    state_files = sorted(
        plans_dir.glob("*/state.json"),
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    )
if not state_files:
    print("ok")
    raise SystemExit(0)

state_path = state_files[0]
plan_dir = state_path.parent
plan_name = plan_dir.name
if run_kind == "plan" and plan_name_arg and not state_path.exists():
    print(f"plan_state_missing:{plan_name_arg}")
    raise SystemExit(0)
try:
    state = json.loads(state_path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"stall_unreadable:{plan_name}:{exc}")
    raise SystemExit(0)

now = dt.datetime.now(dt.timezone.utc)

def _age_minutes(mtime_ts):
    if not mtime_ts:
        return None
    try:
        when = dt.datetime.fromtimestamp(mtime_ts, tz=dt.timezone.utc)
    except (OSError, ValueError, OverflowError):
        return None
    return max(0, int((now - when).total_seconds() // 60))

iteration = int(state.get("iteration") or 0)
# Top-level iteration can lag the internal milestone counter; the recovery
# layer records the live milestone iteration in latest_failure.metadata.iteration.
latest_failure = state.get("latest_failure") or {}
failure_meta = latest_failure.get("metadata") or {}
milestone_iteration = iteration
meta_iter = failure_meta.get("iteration")
if isinstance(meta_iter, (int, float)) and meta_iter > milestone_iteration:
    milestone_iteration = int(meta_iter)
stall_count = int(failure_meta.get("stall_count") or 0)

active_step = state.get("active_step") or {}
attempt = int(active_step.get("attempt") or 0)

plan_v_files = sorted(plan_dir.glob("plan_v*.md"))
plan_v_count = len(plan_v_files)
events_path = plan_dir / "events.ndjson"
events_mtime = events_path.stat().st_mtime if events_path.exists() else 0

# Tick-over-tick snapshot for "no growth while iteration advances" detection.
snapshot_dir = marker_dir
snapshot_dir.mkdir(parents=True, exist_ok=True)
snapshot_path = snapshot_dir / f"{plan_name}.progress.json"
prev = {}
if snapshot_path.exists():
    try:
        prev = json.loads(snapshot_path.read_text(encoding="utf-8"))
    except Exception:
        prev = {}

unchanged_ticks = 0
prev_iter = int(prev.get("iteration") or -1)
prev_plan_count = int(prev.get("plan_v_count") or -1)
if prev:
    if plan_v_count == prev_plan_count and milestone_iteration >= prev_iter:
        unchanged_ticks = int(prev.get("unchanged_ticks") or 0) + 1
    elif plan_v_count != prev_plan_count:
        unchanged_ticks = 0
    else:
        unchanged_ticks = int(prev.get("unchanged_ticks") or 0)

snapshot = {
    "iteration": milestone_iteration,
    "plan_v_count": plan_v_count,
    "events_mtime": events_mtime,
    "unchanged_ticks": unchanged_ticks,
    "ts": now.isoformat(),
}
try:
    snapshot_path.write_text(json.dumps(snapshot, sort_keys=True) + "\n", encoding="utf-8")
except Exception:
    pass

newest_plan_age = None
if plan_v_files:
    newest_mtime = max(p.stat().st_mtime for p in plan_v_files)
    newest_plan_age = _age_minutes(newest_mtime)
events_age = _age_minutes(events_mtime)

signals = []
if milestone_iteration >= ITER_MAX:
    signals.append(f"iteration={milestone_iteration}>={ITER_MAX}")
if attempt and attempt >= ATTEMPT_MAX:
    signals.append(f"active_step.attempt={attempt}>={ATTEMPT_MAX}")
if stall_count >= 3:
    signals.append(f"stall_count={stall_count}")
if (
    unchanged_ticks >= 2
    and milestone_iteration > prev_iter
    and plan_v_count == prev_plan_count
):
    signals.append(f"plan_v_count={plan_v_count} unchanged-{unchanged_ticks}-ticks")
if newest_plan_age is not None and newest_plan_age >= PLAN_GROWTH_MINS and milestone_iteration >= max(2, ITER_MAX - 2):
    signals.append(f"plan_v_unchanged_{newest_plan_age}m")
if events_age is not None and events_age >= EVENTS_MINS and state.get("current_state") not in {None, "completed", "abandoned", "awaiting_review"}:
    signals.append(f"events_stale={events_age}m")

if not signals:
    print("ok")
    raise SystemExit(0)

detail = " ".join(signals)
print(
    f"progress_stall:{plan_name}:"
    f"iteration={iteration}:"
    f"attempt={attempt}:"
    f"plan_v_count={plan_v_count}:"
    f"{detail}"
)
PY
}

repair_unhealthy_session() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local reason="$4"
  local repair_busy

  repair_busy="$(repair_loop_busy_state "$session")"

  # Background-dispatch: never block the tick on the repair operator (it can run
  # up to its 60-min timeout). Returns 0 when repair is running or just
  # dispatched (caller must NOT relaunch -- the operator relaunches on success);
  # returns 1 when the direct tmux relaunch fallback is needed (repair missing,
  # or already tried and exited without reviving the session).
  if [[ "$repair_busy" == "same_session" ]]; then
    log "session unhealthy; repair already running session=$session reason=$reason"
    return 0
  fi
  if [[ "$repair_busy" == "other_session" ]]; then
    log "session unhealthy; another repair loop already running so waiting turn session=$session reason=$reason"
    return 0
  fi
  if mechanical_relaunch_attempted_previously "$session"; then
    if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then
      if [[ "${REPAIR_DISPATCH_RESULT:-}" == "busy" ]]; then
        log "session unhealthy after mechanical relaunch; another repair loop already running so waiting turn session=$session reason=$reason"
        return 0
      fi
      log "session unhealthy after mechanical relaunch: background-dispatched repair loop session=$session reason=$reason"
      tmux kill-session -t "$session" 2>/dev/null || true
      return 0
    fi
    log "session unhealthy after mechanical relaunch; repair loop missing -> direct relaunch session=$session reason=$reason"
    return 1
  fi
  if kimi_dispatch_failed_previously "$session"; then
    local previous_repair_outcome
    previous_repair_outcome="$(repair_data_outcome_for_session "$session" || true)"
    if repair_outcome_wants_repair_retry "$previous_repair_outcome"; then
      log "previous repair outcome requires another root-cause repair session=$session outcome=${previous_repair_outcome:-unknown} reason=$reason"
      if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then
        if [[ "${REPAIR_DISPATCH_RESULT:-}" == "busy" ]]; then
          log "session unhealthy after retryable repair outcome; another repair loop already running so waiting turn session=$session reason=$reason outcome=${previous_repair_outcome:-unknown}"
          return 0
        fi
        log "session unhealthy after retryable repair outcome: background-dispatched repair loop session=$session reason=$reason outcome=${previous_repair_outcome:-unknown}"
        tmux kill-session -t "$session" 2>/dev/null || true
        return 0
      fi
      log "retryable repair outcome found but repair loop missing -> direct relaunch session=$session reason=$reason outcome=${previous_repair_outcome:-unknown}"
      return 1
    fi
    log "session unhealthy; repair loop tried and exited without recovery -> direct relaunch session=$session reason=$reason"
    kimi_dispatch_marker_clear "$session"
    return 1
  fi
  if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then
    if [[ "${REPAIR_DISPATCH_RESULT:-}" == "busy" ]]; then
      log "session unhealthy; another repair loop already running so waiting turn session=$session reason=$reason"
      return 0
    fi
    log "session unhealthy: background-dispatched repair loop session=$session reason=$reason"
    tmux kill-session -t "$session" 2>/dev/null || true
    return 0
  fi
  log "session unhealthy; repair loop missing -> direct relaunch session=$session reason=$reason"
  return 1
}

repair_unintended_stop() {
  local report_items="$1"
  local session="$2"
  local workspace="$3"
  local remote_spec="$4"
  local reason="$5"
  local before_busy

  before_busy="$(repair_loop_busy_state "$session")"
  if repair_unhealthy_session "$session" "$workspace" "$remote_spec" "$reason"; then
    if [[ "$before_busy" == "same_session" ]]; then
      report_item "$report_items" "$session" "repair" "repair_running" "repair already running: $reason" "$workspace" "$remote_spec"
    elif [[ "$before_busy" == "other_session" || "${REPAIR_DISPATCH_RESULT:-}" == "busy" ]]; then
      report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn: $reason" "$workspace" "$remote_spec"
    else
      report_item "$report_items" "$session" "repair" "repair_dispatched" "$reason" "$workspace" "$remote_spec"
    fi
    return 0
  fi

  report_item "$report_items" "$session" "repair" "repair_unavailable" "$reason" "$workspace" "$remote_spec"
  return 1
}


        log "repairable chain health issue detected but repair loop is unavailable session=$session status=${CHAIN_HEALTH_STATUS:-unknown} summary=${CHAIN_HEALTH_SUMMARY:-}"
        report_item "$report_items" "$session" "repair" "repair_unavailable" "$chain_health_message" "$workspace" "$remote_spec"
      fi
      return 0
    fi
    if [[ "${CHAIN_HEALTH_STATUS:-ok}" != "ok" ]]; then
      local chain_health_message
      chain_health_message="${CHAIN_HEALTH_SUMMARY:-chain-level issue detected}"
      if [[ -n "${CHAIN_HEALTH_ARTIFACT_PATH:-}" ]]; then
        chain_health_message="$chain_health_message; artifact=${CHAIN_HEALTH_ARTIFACT_PATH}"
      fi
      emit_watchdog_incident_bridge_event "detection" "$session" "$workspace" "$remote_spec" "$chain_health_message" "chain_health_failure" "immediate_repair"
      log "chain-level health issue detected session=$session status=${CHAIN_HEALTH_STATUS:-unknown} summary=${CHAIN_HEALTH_SUMMARY:-} artifact=${CHAIN_HEALTH_ARTIFACT_PATH:-}"

    report_item "$report_items" "$session" "repair" "repair_unavailable" "$mismatch_summary" "$workspace" "$remote_spec"
    return 0
  fi
  if [[ "$resolver_human_verdict" != provider_retry:* && "${PLAN_STATUS_AWAITING_HUMAN:-0}" == "1" ]]; then
    local human_summary repair_busy repair_summary
    human_summary="awaiting_human halt; state=${PLAN_STATUS_CURRENT_STATE:-unknown}; reason=${PLAN_STATUS_AWAITING_HUMAN_REASON:-plan is awaiting human action}"
    if [[ -n "${PLAN_STATUS_FAILURE_KIND:-}" ]]; then
      human_summary="$human_summary; failure=${PLAN_STATUS_FAILURE_KIND}"
    fi
    if [[ -n "${PLAN_STATUS_TIERS_TRIED:-}" ]]; then
      human_summary="$human_summary; tiers=${PLAN_STATUS_TIERS_TRIED}"
    fi
    if [[ -n "${PLAN_STATUS_PUSHED_COMMITS:-}" ]]; then
      human_summary="$human_summary; commits=${PLAN_STATUS_PUSHED_COMMITS}"
    fi
    if [[ "$resolver_human_verdict" == suppress:* ]]; then
      route_resolver_machine_repair "$report_items" "$session" "$workspace" "$remote_spec" "${resolver_human_verdict#suppress:}" "$human_summary"
      return 0
    fi
    if [[ -f "$(repair_needs_human_path "$session")" ]]; then
      local stale_marker_plans
      stale_marker_plans="$(repair_needs_human_matches_current_plan "$session" "${PLAN_STATUS_PLAN_NAME:-}" 2>/dev/null)" || {
        rm -f "$(repair_needs_human_path "$session")" 2>/dev/null || true
        log "stale repair needs-human marker cleared; live current plan supersedes marker session=$session live_plan=${PLAN_STATUS_PLAN_NAME:-unknown} marker_plans=${stale_marker_plans:-unknown}"
      }

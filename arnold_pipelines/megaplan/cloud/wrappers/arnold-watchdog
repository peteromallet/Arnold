plan_attention_status_env() {
  local workspace="$1"
  local remote_spec_path="$2"
  local run_kind="${3:-chain}"
  local plan_name="${4:-}"
  python3 - "$workspace" "$remote_spec_path" "$run_kind" "$plan_name" <<'PY'
import hashlib
import json
import os
import re
import shlex
import sys
from pathlib import Path

workspace = Path(sys.argv[1])
remote_spec_raw = sys.argv[2]
run_kind = sys.argv[3]
plan_name = sys.argv[4]


def emit(name: str, value: str) -> None:
    print(f"{name}={shlex.quote(value)}")


def add_unique(values: list[str], value: str | None) -> None:
    if isinstance(value, str) and value and value not in values:
        values.append(value)


def load_chain_state() -> tuple[dict[str, object], str]:
    if run_kind != "chain" or not remote_spec_raw:
        return {}, ""
    try:
        spec_path = Path(remote_spec_raw)
        try:
            spec_resolved = spec_path.resolve()
        except Exception:
            spec_resolved = spec_path
        digest = hashlib.sha1(str(spec_resolved).encode("utf-8")).hexdigest()[:12]
        # Prefer the workspace-owned chain state; legacy locations stay fallback-only.
        candidates = (
            workspace / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
            workspace / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
            spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
            spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
            spec_resolved.with_name("chain_state.json"),
        )
        for candidate in candidates:
            try:
                raw = json.loads(candidate.read_text(encoding="utf-8"))
            except Exception:
                continue
            if not isinstance(raw, dict):
                continue
            current_plan = raw.get("current_plan_name")
            resolved = ""
            if isinstance(current_plan, str) and current_plan and "/" not in current_plan:
                resolved = current_plan
            return raw, resolved
    except Exception:
        pass
    return {}, ""


def resolve_spec_path() -> Path | None:
    if not remote_spec_raw:
        return None
    try:
        spec_path = Path(remote_spec_raw)
        if not spec_path.is_absolute():
            spec_path = workspace / spec_path
        try:
            return spec_path.resolve()
        except Exception:
            return spec_path
    except Exception:
        return None


def spec_milestone_labels() -> tuple[list[str], bool]:
    spec_path = resolve_spec_path()
    if spec_path is None:
        return [], False
    try:
        raw = spec_path.read_text(encoding="utf-8")
    except Exception:
        return [], False
    try:
        import yaml  # type: ignore

        data = yaml.safe_load(raw)
        milestones = data.get("milestones") if isinstance(data, dict) else None
        if isinstance(milestones, list):
            labels: list[str] = []
            for item in milestones:
                if not isinstance(item, dict):
                    continue
                label = item.get("label")
                if isinstance(label, str) and label:
                    labels.append(label)
            return labels, True
    except Exception:
        pass
    labels = []
    in_milestones = False
    for line in raw.splitlines():
        if re.match(r"^milestones:\s*$", line):
            in_milestones = True
            continue
        if in_milestones and re.match(r"^[A-Za-z_][\w-]*:", line):
            break
        match = re.match(r"^\s*-\s*label:\s*['\"]?([^'\"\s#]+)", line)
        if in_milestones and match:
            labels.append(match.group(1))
    return labels, True


def chain_completion_summary(chain_state: dict[str, object]) -> tuple[bool, int, int]:
    labels, spec_known = spec_milestone_labels()
    milestone_count = len(labels)
    completed = chain_state.get("completed")
    completed_list = completed if isinstance(completed, list) else []
    completed_labels = {
        item.get("label")
        for item in completed_list
        if isinstance(item, dict) and isinstance(item.get("label"), str)
    }
    try:
        current_index = int(chain_state.get("current_milestone_index") or 0)
    except Exception:
        current_index = 0
    last_state = str(chain_state.get("last_state") or "").strip().lower()
    if spec_known and milestone_count == 0:
        # Empty chains are valid completed fixtures in wrapper tests.
        return True, current_index, milestone_count
    if not spec_known:
        return False, current_index, milestone_count
    if last_state not in {"done", "complete", "completed"}:
        return False, current_index, milestone_count
    # Index advancement is not durable completion evidence on its own; require
    # the completed milestone records to cover the chain spec before reporting
    # terminal success.
    complete = len(completed_list) >= milestone_count or set(labels).issubset(completed_labels)
    return complete, current_index, milestone_count


def missing_base_ref_attention(chain_state: object) -> tuple[bool, str, str, str]:
    try:
        if not isinstance(chain_state, dict):
            return False, "", "", ""
        metadata = chain_state.get("metadata")
        missing_base_ref = metadata.get("missing_base_ref") if isinstance(metadata, dict) else None
        has_missing_base_ref = chain_state.get("last_state") == "missing_base_ref"
        if isinstance(metadata, dict) and "missing_base_ref" in metadata:
            has_missing_base_ref = True
        if not has_missing_base_ref:
            return False, "", "", ""
        failure_message = ""
        failure_recorded_at = ""
        failure_phase = "chain"
        if isinstance(missing_base_ref, dict):
            base_branch = missing_base_ref.get("base_branch")
            message = missing_base_ref.get("message")
            recorded_at = missing_base_ref.get("recorded_at")
            phase = missing_base_ref.get("phase")
            if isinstance(message, str) and message:
                failure_message = message
            elif isinstance(base_branch, str) and base_branch:
                failure_message = f"base branch missing on origin: {base_branch}"
            if isinstance(recorded_at, str) and recorded_at:
                failure_recorded_at = recorded_at
            if isinstance(phase, str) and phase:
                failure_phase = phase
        return True, failure_message, failure_recorded_at, failure_phase
    except Exception:
        return False, "", "", ""


resolved_plan_name = plan_name if isinstance(plan_name, str) and plan_name else ""
chain_state, chain_plan_name = load_chain_state()
if chain_plan_name:
    resolved_plan_name = chain_plan_name
chain_last_state = chain_state.get("last_state") if isinstance(chain_state, dict) else ""
if not isinstance(chain_last_state, str):
    chain_last_state = ""
chain_complete, chain_current_index, chain_milestone_count = chain_completion_summary(chain_state)

plans_dir = workspace / ".megaplan" / "plans"
state_path = None
if resolved_plan_name:
    candidate = plans_dir / resolved_plan_name / "state.json"
    try:
        candidate.relative_to(plans_dir)
        state_path = candidate
    except Exception:
        state_path = None
elif run_kind == "plan":
    state_paths = sorted(
        plans_dir.glob("*/state.json"),
        key=lambda path: path.stat().st_mtime,
        reverse=True,
    )
    if state_paths:
        state_path = state_paths[0]
        resolved_plan_name = state_path.parent.name

state = {}
if state_path is not None:
    try:
        raw_state = json.loads(state_path.read_text(encoding="utf-8"))
    except Exception:
        raw_state = {}
    if isinstance(raw_state, dict):
        state = raw_state
        if not resolved_plan_name:
            name = raw_state.get("name")
            if isinstance(name, str) and name:
                resolved_plan_name = name

current_state = state.get("current_state")
if not isinstance(current_state, str):
    current_state = ""
resume_cursor = state.get("resume_cursor")
retry_strategy = ""
if isinstance(resume_cursor, dict):
    value = resume_cursor.get("retry_strategy")
    if isinstance(value, str):
        retry_strategy = value
latest_failure = state.get("latest_failure")
failure_kind = ""
failure_message = ""
failure_phase = ""
failure_recorded_at = ""
manual_review_origin = ""
if isinstance(latest_failure, dict):
    for key, target in (
        ("kind", "failure_kind"),
        ("message", "failure_message"),
        ("phase", "failure_phase"),
        ("recorded_at", "failure_recorded_at"),
    ):
        value = latest_failure.get(key)
        if isinstance(value, str):
            if target == "failure_kind":
                failure_kind = value
            elif target == "failure_message":
                failure_message = value
            elif target == "failure_phase":
                failure_phase = value
            else:
                failure_recorded_at = value
    latest_failure_metadata = latest_failure.get("metadata")
    if isinstance(latest_failure_metadata, dict):
        value = latest_failure_metadata.get("manual_review_origin")
        if isinstance(value, str):
            manual_review_origin = value
if (
    not manual_review_origin
    and failure_kind == "stalled"
    and retry_strategy == "manual_review"
):
    manual_review_origin = "auto_stall_legacy"

awaiting_human_reason = ""
awaiting_human_states = {"awaiting_human", "awaiting_human_verify"}

def first_string(*values: object) -> str:
    for value in values:
        if isinstance(value, str) and value:
            return value
    return ""


def user_action_reason() -> str:
    if state_path is None:
        return ""
    try:
        finalize_path = state_path.parent / "finalize.json"
        raw_finalize = json.loads(finalize_path.read_text(encoding="utf-8"))
    except Exception:
        return ""
    if not isinstance(raw_finalize, dict):
        return ""
    user_actions = raw_finalize.get("user_actions")
    if not isinstance(user_actions, list):
        return ""
    action_parts: list[str] = []
    for action in user_actions:
        if not isinstance(action, dict):
            continue
        action_id = action.get("id")
        if not isinstance(action_id, str) or not action_id:
            continue
        blocks = action.get("blocks_task_ids")
        if isinstance(blocks, list):
            block_ids = [item for item in blocks if isinstance(item, str) and item]
        else:
            block_ids = []
        if block_ids:
            action_parts.append(f"{action_id} blocks {', '.join(block_ids)}")
        else:
            action_parts.append(action_id)
    if not action_parts:
        return ""
    return "pending user action(s): " + "; ".join(action_parts)


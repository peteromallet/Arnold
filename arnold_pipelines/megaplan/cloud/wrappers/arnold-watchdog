write_partial_liveness_tick() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local health="${6:-alive}"
  local sidecar_dir events_path
  sidecar_dir="${CLOUD_WATCHDOG_REPAIR_SIDECAR_DIR:-${REPAIR_DATA_DIR}.d}"
  events_path="$sidecar_dir/events/events.jsonl"
  mkdir -p "$(dirname "$events_path")" 2>/dev/null || true
  PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$events_path" "$session" "$health" "$workspace" "$remote_spec" "$run_kind" "$plan_name" <<'PY'
import json
import os
import sys
from datetime import datetime, timezone

events_path, session, health, workspace, remote_spec, run_kind, plan_name = sys.argv[1:8]

MAX_TICKS = 20

tick = {
    "session": session,
    "outcome": "partial_liveness",
    "health": health,
    "recorded_at": datetime.now(timezone.utc).isoformat(),
    "run_kind": run_kind,
    "plan_name": plan_name,
}

# Read existing events, append the new tick, and truncate to MAX_TICKS
events = []
try:
    if os.path.exists(events_path):
        with open(events_path, "r", encoding="utf-8") as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    events.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
except Exception:
    pass

events.append(tick)

# Keep only the most recent MAX_TICKS
if len(events) > MAX_TICKS:
    events = events[-MAX_TICKS:]

# Write atomically via temp file
tmp_path = events_path + ".tmp"
try:
    with open(tmp_path, "w", encoding="utf-8") as fh:
        for entry in events:
            fh.write(json.dumps(entry, sort_keys=True) + "\n")
    os.replace(tmp_path, events_path)
except Exception:
    pass
PY
}


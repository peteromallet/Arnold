manual_review_dispatch_status_env() {
  local session="$1"
  local workspace="$2"
  local remote_spec_path="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  PYTHONPATH="${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$session" "$workspace" "$remote_spec_path" "$run_kind" "$plan_name" "$MARKER_DIR" "$REPAIR_DATA_DIR" <<'PY'
import hashlib
import json
import shlex
import sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud.current_target import resolve_current_target
from arnold_pipelines.megaplan.cloud.human_blockers import classify_needs_human_blocker
from arnold_pipelines.megaplan.cloud.repair_lock import inspect_repair_lock
from arnold_pipelines.megaplan.cloud.repair_contract import (
    _blocked_task_id_from_failure,
    classify_repair_dispatch,
    project_repair_custody,
)
from arnold_pipelines.megaplan.cloud.repair_requests import (
    active_repair_claim_lock_dir,
    enqueue_repair_request,
    repair_queue_dir,
)
from arnold_pipelines.megaplan.run_state.resolver import resolve_run_state

session, workspace_raw, remote_spec_raw, run_kind, plan_name, marker_dir_raw, repair_data_dir_raw = sys.argv[1:]
workspace = Path(workspace_raw)
marker_dir = Path(marker_dir_raw)
repair_data_dir = Path(repair_data_dir_raw)
needs_human_path = repair_data_dir / f"{session}.needs-human.json"


def emit(name: str, value: str) -> None:
    print(f"{name}={shlex.quote(value)}")


def load_json_dict(path: Path | None) -> dict[str, object]:
    if path is None:
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}


def plan_state_path() -> Path | None:
    if plan_name:
        return workspace / ".megaplan" / "plans" / plan_name / "state.json"
    if run_kind != "plan":
        return None
    plans_root = workspace / ".megaplan" / "plans"
    candidates = sorted(plans_root.glob("*/state.json"), key=lambda path: path.stat().st_mtime, reverse=True)
    return candidates[0] if candidates else None


def chain_state_path() -> Path | None:
    if run_kind != "chain" or not remote_spec_raw:
        return None
    spec_path = Path(remote_spec_raw)
    if not spec_path.is_absolute():
        spec_path = workspace / spec_path
    try:
        spec_resolved = spec_path.resolve()
    except Exception:
        spec_resolved = spec_path
    digest = hashlib.sha1(str(spec_resolved).encode("utf-8")).hexdigest()[:12]
    candidates = (
        workspace / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
        workspace / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
        spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"chain-{digest}.json",
        spec_resolved.parent / ".megaplan" / "plans" / ".chains" / f"{spec_resolved.stem}-{digest}.json",
        spec_resolved.with_name("chain_state.json"),
    )
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


state_path = plan_state_path()
plan_state = load_json_dict(state_path)
resolved_plan_name = str(plan_state.get("name") or plan_name or "").strip()
if not resolved_plan_name and state_path is not None:
    resolved_plan_name = state_path.parent.name

target = {}
if marker_dir.joinpath(f"{session}.json").exists():
    target = resolve_current_target(
        session,
        marker_dir=marker_dir,
        repair_data_dir=repair_data_dir,
    )
if not target:
    plan_path = state_path
    plan_record = {
        "path": str(plan_path) if plan_path is not None else "",
        "present": bool(plan_path and plan_path.exists()),
        "name": resolved_plan_name,
        "current_state": str(plan_state.get("current_state") or ""),
        "resume_cursor": plan_state.get("resume_cursor") if isinstance(plan_state.get("resume_cursor"), dict) else {},
        "fingerprint": "",
    }
    if plan_path is not None and plan_path.exists():
        plan_record["fingerprint"] = "sha256:" + hashlib.sha256(plan_path.read_bytes()).hexdigest()
    chain_path = chain_state_path()
    chain_state = load_json_dict(chain_path)
    chain_record = {
        "path": str(chain_path) if chain_path is not None else "",
        "present": bool(chain_path and chain_path.exists()),
        "current_plan_name": str(chain_state.get("current_plan_name") or resolved_plan_name),
        "last_state": str(chain_state.get("last_state") or ""),
        "fingerprint": "",
    }
    if chain_path is not None and chain_path.exists():
        chain_record["fingerprint"] = "sha256:" + hashlib.sha256(chain_path.read_bytes()).hexdigest()
    target = {
        "schema_version": 1,
        "session": session,
        "target_id": f"{session}:{resolved_plan_name or run_kind or 'unknown'}",
        "authoritative_source": "chain_state" if chain_record["present"] else "plan_state",
        "target_session": session,
        "current_refs": {
            "workspace": str(workspace),
            "run_kind": run_kind,
            "remote_spec": remote_spec_raw,
            "current_plan_name": resolved_plan_name,
            "chain_current_plan_name": chain_record["current_plan_name"],
            "chain_last_state": chain_record["last_state"],
            "plan_current_state": plan_record["current_state"],
        },
        "plan_state": plan_record,
        "chain_state": chain_record,
        "event_cursors": {
            "resume_retry_strategy": str(
                (plan_state.get("resume_cursor") or {}).get("retry_strategy")
                if isinstance(plan_state.get("resume_cursor"), dict)
                else ""
            ),
        },
        "stale_evidence": [],
        "needs_human": {"path": str(needs_human_path), "present": needs_human_path.exists()},
    }

event_plan_dir = marker_dir / ".dispatch-events" / (session or "_unknown-session")
if resolved_plan_name:
    event_plan_dir = workspace / ".megaplan" / "plans" / resolved_plan_name
try:
    canonical_run_state = resolve_run_state(target or {})
except Exception:
    canonical_run_state = None

projection = project_repair_custody(
    plan_state=plan_state,
    current_target=target,
    canonical_run_state=canonical_run_state,
    marker_dir=marker_dir,
    repair_data_dir=repair_data_dir,
)
if not projection.get("active_request_ids"):
    latest_failure = plan_state.get("latest_failure")
    latest_failure = latest_failure if isinstance(latest_failure, dict) else {}
    metadata = latest_failure.get("metadata")
    metadata = metadata if isinstance(metadata, dict) else {}
    enqueue_repair_request(
        queue_root=repair_queue_dir(marker_dir),
        marker_dir=marker_dir,
        session=session,
        source="watchdog",
        target={
            "workspace": str(workspace),
            "remote_spec": remote_spec_raw,
            "run_kind": run_kind,
            "plan_name": resolved_plan_name,
        },
        workspace=str(workspace),
        run_kind=run_kind,
        problem_signature={
            "failure_kind": str(latest_failure.get("kind") or ""),
            "current_state": str(plan_state.get("current_state") or ""),
            "phase_or_step": str(latest_failure.get("phase") or ""),
            "milestone_or_plan": resolved_plan_name,
            "gate_recommendation": "",
            "blocked_task_id": str(
                metadata.get("blocked_task_id")
                or _blocked_task_id_from_failure(latest_failure, metadata)
                or ""
            ),
        },
        root_cause_hint=str(latest_failure.get("message") or ""),
    )
    projection = project_repair_custody(
        plan_state=plan_state,
        current_target=target,
        canonical_run_state=canonical_run_state,
        marker_dir=marker_dir,
        repair_data_dir=repair_data_dir,
    )

human_blocker = None
if needs_human_path.exists():
    human_blocker = classify_needs_human_blocker(
        session,
        current_plan=resolved_plan_name,
        marker_dir=marker_dir,
        repair_data_dir=repair_data_dir,
        needs_human_path=needs_human_path,
        resolver_record=target,
    )

lock_evidence = None
blocker_id = str(projection.get("blocker_id") or "").strip()
if blocker_id:
    lock_evidence = inspect_repair_lock(
        active_repair_claim_lock_dir(repair_queue_dir(marker_dir), blocker_id)
    )

decision = classify_repair_dispatch(
    canonical_run_state=canonical_run_state,
    event_plan_dir=event_plan_dir,
    plan_state=plan_state,
    current_target=target,
    human_blocker_classification=human_blocker,
    lock_evidence=lock_evidence,
    custody_projection=projection,
)

emit("PLAN_STATUS_DISPATCH_DECISION", decision.decision)
emit("PLAN_STATUS_DISPATCH_INTENT", decision.dispatch_intent)
emit("PLAN_STATUS_CUSTODY_BUCKET", decision.custody_bucket)
emit("PLAN_STATUS_BLOCKER_ID", decision.blocker_id)
emit("PLAN_STATUS_REQUEST_ID", decision.request_id)
emit("PLAN_STATUS_TARGET_SOURCE", str(target.get("authoritative_source") or ""))
PY
}


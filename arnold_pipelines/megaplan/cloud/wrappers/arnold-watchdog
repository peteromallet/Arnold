write_watchdog_heartbeat() {
  # Touch a freshness probe at sweep START so the resident can detect a stalled
  # watchdog even when a later step (repair_trigger_scan / git sync / pip refresh)
  # hangs before the snapshot write completes (watchdog-snapshot-staleness-fix.md
  # P2). Best-effort; never fails a sweep.
  local status_dir="${1:-$STATUS_DIR}"
  mkdir -p "$status_dir" 2>/dev/null || true
  python3 - "$status_dir" <<'PY' 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%SZ" > "$status_dir/watchdog.heartbeat" 2>/dev/null || true
import datetime, pathlib, sys
p = pathlib.Path(sys.argv[1]) / "watchdog.heartbeat"
p.write_text(datetime.datetime.now(datetime.timezone.utc).isoformat().replace("+00:00", "Z") + "\n")
PY
}

record_snapshot_write_outcome() {
  # Track consecutive snapshot-write failures (watchdog-snapshot-staleness-fix.md
  # P2): "ok" resets the counter and clears the error sidecar; "fail" bumps it,
  # and once it reaches SNAPSHOT_FAILURE_THRESHOLD drops a visible
  # cloud-status.write-error.json so consumers know the cache is frozen. Prints
  # the failure count on "fail" (for logging); prints nothing on "ok".
  local status_dir="${1:-$STATUS_DIR}"
  local outcome="${2:-ok}"
  local threshold="${SNAPSHOT_FAILURE_THRESHOLD:-3}"
  python3 - "$status_dir" "$outcome" "$threshold" <<'PY' 2>/dev/null || true
import datetime, json, pathlib, sys
status_dir, outcome, threshold = sys.argv[1], sys.argv[2], int(sys.argv[3] or 3)
base = pathlib.Path(status_dir)
counter_path = base / "snapshot-failures.json"
err_path = base / "cloud-status.write-error.json"
now = datetime.datetime.now(datetime.timezone.utc).isoformat().replace("+00:00", "Z")
if outcome == "ok":
    for p in (counter_path, err_path):
        try:
            p.unlink()
        except FileNotFoundError:
            pass
    sys.exit(0)
try:
    failures = json.loads(counter_path.read_text()).get("failures", 0) + 1 if counter_path.exists() else 1
except Exception:
    failures = 1
counter_path.write_text(json.dumps({"failures": failures, "last_at": now}) + "\n")
if failures >= threshold:
    err_path.write_text(json.dumps({
        "error": "cloud-status snapshot write has failed %d consecutive sweeps; cache may be frozen" % failures,
        "failures": failures,
        "at": now,
    }) + "\n")
print(failures)
PY
}

write_status_snapshot() {
  # Produce the canonical cloud-status.json. Built from local observation only
  # (marker dir + the report emit_report wrote). The 4th arg ("track" default vs
  # "notrack") decides whether a failure counts toward escalation — the early
  # best-effort write at sweep start uses "notrack" so only authoritative
  # end-of-sweep write failures escalate. Never let a snapshot failure break the
  # watchdog sweep — count/log and move on.
  local marker_dir="${1:-$MARKER_DIR}"
  local report_path="${2:-$REPORT_PATH}"
  local status_dir="${3:-$STATUS_DIR}"
  local track="${4:-track}"
  if PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$marker_dir" "$report_path" "$status_dir" <<'PY' 2>>"${LOG:-/dev/null}"; then
import sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud import status_snapshot

marker_dir, report_path, status_dir = (Path(p) for p in sys.argv[1:4])
status_snapshot.build_and_write_snapshot(
    marker_dir=marker_dir,
    watchdog_report_path=report_path,
    path=status_dir / "cloud-status.json",
    previous_path=status_dir / "cloud-status.previous.json",
)
PY
    [[ "$track" != "notrack" ]] && record_snapshot_write_outcome "$status_dir" ok
  else
    if [[ "$track" != "notrack" ]]; then
      local _failures
      _failures="$(record_snapshot_write_outcome "$status_dir" fail)"
      log "status snapshot write failed (${_failures:-?} consecutive; threshold ${SNAPSHOT_FAILURE_THRESHOLD:-3})"
    else
      log "status snapshot early write failed (best-effort; not counted)"
    fi
  fi
}

sync_cloud_runtime_wrappers() {

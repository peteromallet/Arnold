    return 0
  fi
  if [[ "${PLAN_STATUS_CURRENT_STATE:-}" == "paused" ]]; then
    log "session paused by durable plan state; skipping repair/relaunch session=$session plan=${PLAN_STATUS_PLAN_NAME:-$plan_name}"

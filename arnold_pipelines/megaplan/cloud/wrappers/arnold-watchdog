        log "session awaits human action; another repair loop already running so waiting turn session=$session summary=$human_summary"
        report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
      else
        log "session awaits human action; background-dispatched repair loop to attempt user-action resolution session=$session summary=$human_summary"
        report_item "$report_items" "$session" "repair" "repair_dispatched" "awaiting_human repair loop dispatched before needs_human" "$workspace" "$remote_spec"
      fi
      return 0
    fi

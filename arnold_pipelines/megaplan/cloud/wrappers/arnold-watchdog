session_terminal_status() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local current_target_observation="${5:-}"
  local marker_dir="${6:-$MARKER_DIR}"
  [[ "$run_kind" == "chain" || "$run_kind" == "epic_chain" ]] || return 0
  python3 - "$session" "$workspace" "$remote_spec" "${REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}" "$current_target_observation" "$marker_dir" <<'PY'
import hashlib
import json
import pathlib
import sys

session, workspace_raw, remote_spec_raw, repair_data_raw, current_target_raw, marker_dir_raw = sys.argv[1:]
workspace = pathlib.Path(workspace_raw)
remote_spec = pathlib.Path(remote_spec_raw)
if not remote_spec.is_absolute():
    remote_spec = workspace / remote_spec
repair_data_dir = pathlib.Path(repair_data_raw)
marker_dir = pathlib.Path(marker_dir_raw)


def spec_milestone_count() -> int | None:
    try:
        raw = remote_spec.read_text(encoding="utf-8")
    except Exception:
        return None
    try:
        import yaml  # type: ignore

        data = yaml.safe_load(raw)
        milestones = data.get("milestones") if isinstance(data, dict) else None
        if isinstance(milestones, list):
            return len(milestones)
    except Exception:
        pass
    count = 0
    in_milestones = False
    for line in raw.splitlines():
        if line.startswith("milestones:"):
            in_milestones = True
            continue
        if in_milestones and line and not line.startswith((" ", "-")):
            break
        if in_milestones and line.lstrip().startswith("-"):
            count += 1
    return count if in_milestones else None


SPEC_MILESTONE_COUNT = spec_milestone_count()


def is_complete_state(payload: object) -> bool:
    if not isinstance(payload, dict):
        return False
    last_state = str(payload.get("last_state") or payload.get("current_state") or "").strip()
    current_plan = str(payload.get("current_plan_name") or "").strip()
    if last_state not in {"done", "complete", "completed"}:
        return False
    milestones = payload.get("milestones")
    completed = payload.get("completed")
    completed_list = completed if isinstance(completed, list) else []
    if isinstance(milestones, list) and milestones:
        if len(completed_list) < len(milestones):
            return False
    elif SPEC_MILESTONE_COUNT is not None and SPEC_MILESTONE_COUNT > 0:
        try:
            current_index = int(payload.get("current_milestone_index") or 0)
        except Exception:
            current_index = 0
        if len(completed_list) < SPEC_MILESTONE_COUNT and current_index < SPEC_MILESTONE_COUNT:
            return False
    if completed_list:
        incomplete = [
            item for item in completed_list
            if isinstance(item, dict) and str(item.get("status") or "").strip() not in {"done", "complete", "completed"}
            and "label" not in item
        ]
        if incomplete:
            return False
    events = payload.get("events")
    event_items = events if isinstance(events, list) else []
    event_text = " ".join(
        str(item.get("msg") or item.get("message") or item)
        for item in event_items
    )
    if current_plan and "all milestones complete" not in event_text:
        return False
    return True


def iter_chain_states() -> list[pathlib.Path]:
    paths: list[pathlib.Path] = []
    chain_dirs: list[pathlib.Path] = []
    for base in (workspace, remote_spec.parent):
        chain_dir = base / ".megaplan" / "plans" / ".chains"
        if chain_dir not in chain_dirs:
            chain_dirs.append(chain_dir)
    for chain_dir in chain_dirs:
        if not chain_dir.exists():
            continue
        digest = hashlib.sha1(str(remote_spec.resolve()).encode("utf-8")).hexdigest()[:12]
        expected_paths = [
            chain_dir / f"{remote_spec.stem}-{digest}.json",
            chain_dir / f"chain-{digest}.json",
        ]
        paths.extend(path for path in expected_paths if path.exists())
        if paths:
            return paths
        paths.extend(
            [
                path
                for path in expected_paths
                if path not in paths
            ]
        )
        paths.extend(sorted(chain_dir.glob("*.json")))
    return paths


def current_target_marks_terminal_stale_chain() -> bool:
    if not current_target_raw:
        return False
    try:
        payload = json.loads(current_target_raw)
    except Exception:
        return False
    if not isinstance(payload, dict):
        return False
    plan_state = payload.get("plan_state")
    if not isinstance(plan_state, dict):
        return False
    plan_current_state = str(plan_state.get("current_state") or "").strip().lower()
    if plan_current_state not in {"done", "complete", "completed"}:
        return False
    stale_evidence = payload.get("stale_evidence")
    if not isinstance(stale_evidence, list):
        return False
    return any(
        isinstance(item, dict)
        and str(item.get("kind") or "").strip() == "stale_chain_state_after_terminal_plan"
        for item in stale_evidence
    )

def manifest_marks_chain_complete() -> bool:
    manifest_path = remote_spec.parent / "completion-manifest.json"
    try:
        payload = json.loads(manifest_path.read_text(encoding="utf-8"))
    except Exception:
        return False
    if not isinstance(payload, dict):
        return False
    if str(payload.get("schema") or "").strip() != "arnold.megaplan.chain_completion_manifest.v1":
        return False
    milestones = payload.get("milestones")
    if not isinstance(milestones, list) or not milestones:
        return False
    terminal = {"done", "complete", "completed"}
    statuses = [
        str(item.get("status") or "").strip().lower()
        for item in milestones
        if isinstance(item, dict)
    ]
    return len(statuses) == len(milestones) and all(status in terminal for status in statuses)

def chain_health_blocks_terminal_shortcut() -> bool:
    path = marker_dir / f"{session}.chain-health.progress.json"
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return False
    if not isinstance(payload, dict):
        return False
    snapshot = payload.get("snapshot")
    if not isinstance(snapshot, dict):
        snapshot = {}
    chain_complete = payload.get("chain_complete")
    if chain_complete is None:
        chain_complete = snapshot.get("chain_complete")
    if chain_complete is not False:
        return False
    try:
        completed_count = int(payload.get("completed_count") or snapshot.get("completed_count") or 0)
    except Exception:
        completed_count = 0
    try:
        milestone_count = int(payload.get("milestone_count") or snapshot.get("milestone_count") or 0)
    except Exception:
        milestone_count = 0
    pr_state = str(payload.get("pr_state") or snapshot.get("pr_state") or "").strip().lower()
    if milestone_count and completed_count < milestone_count:
        return True
    if pr_state and pr_state not in {"merged", "closed"}:
        return True
    return True


def current_chain_state_blocks_terminal_shortcut() -> bool:
    try:
        digest = hashlib.sha1(str(remote_spec.resolve()).encode("utf-8")).hexdigest()[:12]
    except Exception:
        digest = ""
    chain_dirs = [workspace / ".megaplan" / "plans" / ".chains"]
    if remote_spec.parent != workspace:
        chain_dirs.append(remote_spec.parent / ".megaplan" / "plans" / ".chains")
    candidate_names = ["chain.json"]
    if digest:
        candidate_names.extend([f"{remote_spec.stem}-{digest}.json", f"chain-{digest}.json"])
    for chain_dir in chain_dirs:
        for name in candidate_names:
            path = chain_dir / name
            if not path.exists():
                continue
            try:
                payload = json.loads(path.read_text(encoding="utf-8"))
            except Exception:
                continue
            if isinstance(payload, dict) and not is_complete_state(payload):
                return True
    return False


if (
    current_target_marks_terminal_stale_chain()
    and not chain_health_blocks_terminal_shortcut()
    and not current_chain_state_blocks_terminal_shortcut()
):
    print("complete\tterminal plan state supersedes stale chain state")
    raise SystemExit(0)

if manifest_marks_chain_complete():
    print("complete\tcompletion manifest marks chain complete")
    raise SystemExit(0)


for path in iter_chain_states():
    if not path.exists():
        continue
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    if is_complete_state(payload):
        print("complete\tchain complete")
        raise SystemExit(0)

data_path = repair_data_dir / f"{session}.repair-data.json"
if data_path.exists():
    try:
        payload = json.loads(data_path.read_text(encoding="utf-8"))
    except Exception:
        payload = {}
    attempts = payload.get("attempts") if isinstance(payload, dict) else []
    if isinstance(attempts, list):
        for attempt in reversed(attempts):
            if not isinstance(attempt, dict):
                continue
            if str(attempt.get("failure_classification") or "") != "chain_completed":
                continue
            summary = attempt.get("chain_state_summary")
            if is_complete_state(summary):
                print("complete\tchain complete")
                raise SystemExit(0)
            context = attempt.get("failure_context")
            if isinstance(context, dict) and is_complete_state(context.get("chain_state_summary")):
                print("complete\tchain complete")
                raise SystemExit(0)
PY
}


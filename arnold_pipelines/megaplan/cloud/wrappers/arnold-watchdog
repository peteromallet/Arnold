chain_resume_plan_relaunch_command_if_needed() {
  local workspace="$1"
  local plan_name="$2"
  local remote_spec="${3:-}"
  if [[ -z "$plan_name" && -n "$remote_spec" ]]; then
    plan_name="$(python3 - "$workspace" "$remote_spec" <<'PY' 2>/dev/null || true

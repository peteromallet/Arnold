#!/usr/bin/env bash
set -uo pipefail

# Caller-provided supervisor runtime controls are an explicit invocation
# contract (and are used by readiness probes).  The shared hot-env supplies
# defaults for resident service launches, but must not overwrite those explicit
# values when the wrapper is invoked with a constrained runtime.
WATCHDOG_CALLER_SUPERVISOR_PYTHON_SET="${MEGAPLAN_SUPERVISOR_PYTHON+x}"
WATCHDOG_CALLER_SUPERVISOR_PYTHON="${MEGAPLAN_SUPERVISOR_PYTHON-}"
WATCHDOG_CALLER_RUNTIME_REQUIRED_SET="${MEGAPLAN_SUPERVISOR_RUNTIME_REQUIRED+x}"
WATCHDOG_CALLER_RUNTIME_REQUIRED="${MEGAPLAN_SUPERVISOR_RUNTIME_REQUIRED-}"

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

if [[ -n "$WATCHDOG_CALLER_SUPERVISOR_PYTHON_SET" ]]; then
  MEGAPLAN_SUPERVISOR_PYTHON="$WATCHDOG_CALLER_SUPERVISOR_PYTHON"
  export MEGAPLAN_SUPERVISOR_PYTHON
fi
if [[ -n "$WATCHDOG_CALLER_RUNTIME_REQUIRED_SET" ]]; then
  MEGAPLAN_SUPERVISOR_RUNTIME_REQUIRED="$WATCHDOG_CALLER_RUNTIME_REQUIRED"
  export MEGAPLAN_SUPERVISOR_RUNTIME_REQUIRED
fi
unset WATCHDOG_CALLER_SUPERVISOR_PYTHON_SET WATCHDOG_CALLER_SUPERVISOR_PYTHON
unset WATCHDOG_CALLER_RUNTIME_REQUIRED_SET WATCHDOG_CALLER_RUNTIME_REQUIRED

WRAPPER_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../../../.." && pwd)"
SUPERVISOR_RUNTIME_LIB="$(dirname "${BASH_SOURCE[0]:-$0}")/arnold-supervisor-runtime-lib"
if [[ ! -f "$SUPERVISOR_RUNTIME_LIB" ]]; then
  SUPERVISOR_RUNTIME_LIB="${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}/arnold_pipelines/megaplan/cloud/wrappers/arnold-supervisor-runtime-lib"
fi
if [[ ! -f "$SUPERVISOR_RUNTIME_LIB" ]]; then
  SUPERVISOR_RUNTIME_LIB="/usr/local/bin/arnold-supervisor-runtime-lib"
fi
# shellcheck disable=SC1090
. "$SUPERVISOR_RUNTIME_LIB"
arnold_supervisor_runtime_init watchdog "${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}" || exit $?

SELF_PATH="${BASH_SOURCE[0]:-$0}"
if command -v readlink >/dev/null 2>&1; then
  SELF_PATH="$(readlink -f "$SELF_PATH" 2>/dev/null || printf '%s' "$SELF_PATH")"
fi
WATCHDOG_ARGS=("$@")
WATCHDOG_STARTED_AT="$(date +%s)"
LOCK_FILE="${CLOUD_WATCHDOG_LOCK_FILE:-/workspace/.megaplan/watchdog.lock}"
LOCK_HELD="${CLOUD_WATCHDOG_LOCK_HELD:-0}"
COOPERATIVE_ONCE=0
if [[ "${1:-}" == "--audit-sweep" ]]; then
  # The daemon intentionally owns LOCK_FILE for its whole lifetime.  A six-hour
  # audit sweep therefore bypasses only that lifetime lock and serializes on the
  # per-scan lock acquired by scan_once below.
  COOPERATIVE_ONCE=1
fi
if [[ "$LOCK_HELD" != "1" && "$COOPERATIVE_ONCE" != "1" ]] && command -v flock >/dev/null 2>&1; then
  mkdir -p "$(dirname "$LOCK_FILE")"
  # Legacy lock shape kept visible for wrapper compatibility tests:
  # exec flock -n "$LOCK_FILE" bash "$SELF_PATH" "${WATCHDOG_ARGS[@]}"
  python3 - "$LOCK_FILE" "$SELF_PATH" "${WATCHDOG_ARGS[@]}" <<'PY'
import fcntl
import os
import subprocess
import sys

lock_file = sys.argv[1]
self_path = sys.argv[2]
watchdog_args = sys.argv[3:]

fd = os.open(lock_file, os.O_CREAT | os.O_RDWR, 0o644)
try:
    fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
except BlockingIOError:
    raise SystemExit(1)

env = os.environ.copy()
env["CLOUD_WATCHDOG_LOCK_HELD"] = "1"
proc = subprocess.Popen(
    ["bash", self_path, *watchdog_args],
    env=env,
    close_fds=True,
)
raise SystemExit(proc.wait())
PY
  exit $?
fi

LOG="${CLOUD_WATCHDOG_LOG:-/workspace/watchdog.log}"
REPORT_PATH="${CLOUD_WATCHDOG_REPORT_PATH:-/workspace/watchdog-report.json}"
REPORT_ARCHIVE_DIR="${CLOUD_WATCHDOG_REPORT_ARCHIVE_DIR:-/workspace/watchdog-reports}"
REPORT_WEBHOOK="${CLOUD_WATCHDOG_REPORT_WEBHOOK:-}"
INTERVAL="${CLOUD_WATCHDOG_INTERVAL_SECS:-3600}"
MARKER_DIR="${CLOUD_WATCHDOG_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
SCAN_LOCK_FILE="${CLOUD_WATCHDOG_SCAN_LOCK_FILE:-/workspace/.megaplan/watchdog-scan.lock}"
SCAN_LOCK_WAIT_SECS="${CLOUD_WATCHDOG_SCAN_LOCK_WAIT_SECS:-600}"
REPAIR_DATA_DIR="${CLOUD_WATCHDOG_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
STATUS_DIR="${CLOUD_WATCHDOG_STATUS_DIR:-/workspace/.megaplan/status}"
REPAIR_ENABLED="${ARNOLD_REPAIR_TRIGGER_ENABLED:-1}"
PUSH_REPAIRS="${CLOUD_WATCHDOG_PUSH_REPAIRS:-1}"
CODEX_TIMEOUT="${CLOUD_WATCHDOG_CODEX_TIMEOUT_SECS:-7200}"
REAP_AGE_SECS="${CLOUD_WATCHDOG_REAP_AGE_SECS:-7200}"
REAP_ORPHAN_AGE_SECS="${CLOUD_WATCHDOG_REAP_ORPHAN_AGE_SECS:-3900}"
REAP_STALL_GRACE_SECS="${CLOUD_WATCHDOG_REAP_STALL_GRACE_SECS:-900}"
REAP_STALL_IDLE_SECS="${CLOUD_WATCHDOG_REAP_STALL_IDLE_SECS:-600}"
REPAIR_DATA_RETENTION_INTERVAL_SECS="${CLOUD_WATCHDOG_REPAIR_DATA_RETENTION_INTERVAL_SECS:-21600}"
ENV_GONE_STRIKES="${CLOUD_WATCHDOG_ENV_GONE_STRIKES:-3}"
SRC_DIR="${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}"
SYNC_ENABLED="${CLOUD_WATCHDOG_SYNC_ENABLED:-1}"
SYNC_BRANCH="${CLOUD_WATCHDOG_SYNC_BRANCH:-editible-install}"
SYNC_REPO="${CLOUD_WATCHDOG_SYNC_REPO:-${MEGAPLAN_REPO:-}}"
# Bounded timeouts so a hung git sync / pip refresh can't freeze a sweep before
# the snapshot is written (watchdog-snapshot-staleness-fix.md P2). Do NOT reuse
# CODEX_TIMEOUT (7200s) for these network/install steps.
SYNC_TIMEOUT_SECS="${CLOUD_WATCHDOG_SYNC_TIMEOUT_SECS:-120}"
INSTALL_REFRESH_TIMEOUT_SECS="${CLOUD_WATCHDOG_INSTALL_REFRESH_TIMEOUT_SECS:-300}"
# Consecutive snapshot-write failures before we drop a visible write-error sidecar.
SNAPSHOT_FAILURE_THRESHOLD="${CLOUD_WATCHDOG_SNAPSHOT_FAILURE_THRESHOLD:-3}"
EXTRA_SKILLS_DIR="${CLOUD_WATCHDOG_EXTRA_SKILLS_DIR:-/workspace/cloud-skills}"
KIMI_OPERATOR_ROOT="${KIMI_GOAL_OPERATOR_ROOT:-/workspace/kimi-goal-operator}"
REPAIR_OPERATOR_ROOT="${CLOUD_WATCHDOG_REPAIR_ROOT:-$KIMI_OPERATOR_ROOT}"
KIMI_REPAIR_BIN="${CLOUD_WATCHDOG_KIMI_REPAIR_BIN:-/usr/local/bin/arnold-kimi-goal-operator}"
PRIMARY_REPAIR_SOURCE_BIN="$SRC_DIR/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop"
PRIMARY_REPAIR_FALLBACK_BIN="/usr/local/bin/arnold-repair-loop"
PRIMARY_REPAIR_BIN="${CLOUD_WATCHDOG_PRIMARY_REPAIR_BIN:-$PRIMARY_REPAIR_SOURCE_BIN}"
if [[ ! -x "$PRIMARY_REPAIR_BIN" && -x "$PRIMARY_REPAIR_FALLBACK_BIN" ]]; then
  PRIMARY_REPAIR_BIN="$PRIMARY_REPAIR_FALLBACK_BIN"
fi
META_REPAIR_SOURCE_BIN="$SRC_DIR/arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop"
META_REPAIR_FALLBACK_BIN="/usr/local/bin/arnold-meta-repair-loop"
META_REPAIR_BIN="${CLOUD_WATCHDOG_META_REPAIR_BIN:-$META_REPAIR_SOURCE_BIN}"
if [[ ! -x "$META_REPAIR_BIN" && -x "$META_REPAIR_FALLBACK_BIN" ]]; then
  META_REPAIR_BIN="$META_REPAIR_FALLBACK_BIN"
fi
REPAIR_TRIGGER_BIN="${CLOUD_WATCHDOG_REPAIR_TRIGGER_BIN:-$SRC_DIR/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-trigger}"
DISCOVER_BIN="${CLOUD_WATCHDOG_DISCOVER_BIN:-$SRC_DIR/arnold_pipelines/megaplan/cloud/wrappers/arnold-cloud-discover}"
ONCE="${1:-}"
if [[ "$COOPERATIVE_ONCE" == "1" ]]; then
  ONCE="--once"
fi
PRIMARY_REPAIR_BASENAME="$(basename "$PRIMARY_REPAIR_BIN")"
REPAIR_DISPATCH_RESULT=

mkdir -p "$(dirname "$LOG")"

log() {
  local message
  message="$(redact_inline_text "$*")"
  echo "[watchdog $(date -Iseconds)] $message" | tee -a "$LOG"
}

redact_inline_text() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$1" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

print(redact_text(sys.argv[1]), end="")
PY
}

redact_file_in_place() {
  local path="${1:-}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:${SRC_DIR:-$PWD}:${PYTHONPATH:-}" python3 - "$path" <<'PY'
from pathlib import Path
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

path = Path(sys.argv[1])
path.write_text(redact_text(path.read_text(encoding="utf-8")), encoding="utf-8")
PY
}

maybe_reexec_updated_watchdog() {
  local wrapper_path wrapper_mtime
  local source_wrapper source_mtime
  local reexec_path reexec_reason

  wrapper_path="$SELF_PATH"
  wrapper_mtime="$(stat -c %Y "$wrapper_path" 2>/dev/null || stat -f %m "$wrapper_path" 2>/dev/null || echo 0)"
  [[ "$wrapper_mtime" =~ ^[0-9]+$ ]] || wrapper_mtime=0

  source_wrapper="$SRC_DIR/arnold_pipelines/megaplan/cloud/wrappers/$(basename "$SELF_PATH")"
  source_mtime=0
  if [[ -f "$source_wrapper" ]]; then
    source_mtime="$(stat -c %Y "$source_wrapper" 2>/dev/null || stat -f %m "$source_wrapper" 2>/dev/null || echo 0)"
    [[ "$source_mtime" =~ ^[0-9]+$ ]] || source_mtime=0
  fi

  reexec_path=""
  reexec_reason=""
  if (( source_mtime > WATCHDOG_STARTED_AT && source_mtime >= wrapper_mtime )); then
    reexec_path="$source_wrapper"
    reexec_reason="editable source wrapper"
  elif (( wrapper_mtime > WATCHDOG_STARTED_AT )); then
    reexec_path="$wrapper_path"
    reexec_reason="current script"
  fi

  if [[ -n "$reexec_path" ]]; then
    log "watchdog wrapper updated on disk; re-execing $reexec_reason"
    if [[ -n "${scan_lock_fd:-}" ]]; then
      flock -u "$scan_lock_fd" 2>/dev/null || true
      exec {scan_lock_fd}>&-
    fi
    exec bash "$reexec_path" "${WATCHDOG_ARGS[@]}"
  fi
}


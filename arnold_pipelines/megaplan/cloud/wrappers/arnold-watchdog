  if [[ "$run_kind" == "plan" ]]; then
    local terminal_status
    terminal_status="$(plan_terminal_status "$workspace" "$plan_name")"
    if [[ "$terminal_status" != "none" ]]; then
      local terminal_plan_name terminal_state
      IFS=$'\t' read -r terminal_plan_name terminal_state <<< "$terminal_status"
      log "plan complete; skipping repair/relaunch session=$session state=$terminal_state plan=$terminal_plan_name"
      report_item "$report_items" "$session" "observe" "complete" "plan complete" "$workspace" "$remote_spec"

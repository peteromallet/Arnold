      elif [[ "$repair_busy" == "other_session" ]]; then
        log "repairable chain health issue detected; another repair loop already running session=$session status=${CHAIN_HEALTH_STATUS:-unknown} summary=${CHAIN_HEALTH_SUMMARY:-}"
        report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
      elif dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then

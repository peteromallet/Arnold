      report_item "$report_items" "$session" "repair" "repair_running" "awaiting_human repair already running" "$workspace" "$remote_spec"
      return 0
    fi
    if [[ "$repair_busy" == "other_session" ]]; then
      log "session awaits human action; another repair loop already running so waiting turn session=$session summary=$human_summary"
      report_item "$report_items" "$session" "repair" "repair_running" "another repair loop already running; waiting turn" "$workspace" "$remote_spec"
      return 0
    fi
    if dispatch_kimi_repair "$session" "$workspace" "$remote_spec"; then

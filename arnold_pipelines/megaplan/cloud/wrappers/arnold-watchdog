def read_tail_lines(path: Path | None, *, max_lines: int) -> list[str]:
    if path is None or not path.exists():
        return []
    try:
        with path.open("r", encoding="utf-8", errors="replace") as handle:
            return list(collections.deque((line.rstrip("\n") for line in handle), maxlen=max_lines))
    except Exception:
        return []


def run_git(args: list[str], *, timeout: int = 15) -> subprocess.CompletedProcess[str] | None:
    try:
        return subprocess.run(
            ["git", *args],
            cwd=str(workspace),
            text=True,
            capture_output=True,
            timeout=timeout,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None


def first_string(*values: object) -> str:
    for value in values:
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


def milestone_base_sha_from_state_or_reason(plan_state: dict[str, object], reason: str) -> str:
    meta = plan_state.get("meta")
    chain_policy = meta.get("chain_policy") if isinstance(meta, dict) else None
    if isinstance(chain_policy, dict):
        value = first_string(chain_policy.get("milestone_base_sha"))
        if value:
            return value
    value = first_string(chain_state.get("current_milestone_base_sha"))
    if value:
        return value
    match = re.search(r"\bmilestone_base_sha\s+([0-9a-fA-F]{7,40})\b", reason)
    if match:
        return match.group(1)
    return ""


def completion_guard_advancement(base_sha: str, previous_snapshot: dict[str, object]) -> dict[str, object]:
    if not base_sha:
        return {"available": False, "reason": "missing_milestone_base_sha"}
    inside = run_git(["rev-parse", "--is-inside-work-tree"])
    if inside is None:
        return {"available": False, "base_sha": base_sha, "reason": "git_unavailable"}
    if inside.returncode != 0 or inside.stdout.strip().lower() != "true":
        return {"available": False, "base_sha": base_sha, "reason": "not_git_worktree"}
    head = run_git(["rev-parse", "HEAD"])
    if head is None:
        return {"available": False, "base_sha": base_sha, "reason": "git_head_unavailable"}
    if head.returncode != 0:
        return {
            "available": False,
            "base_sha": base_sha,
            "reason": "git_head_failed",
            "stderr": (head.stderr or "").strip()[-500:],
        }
    rev_list = run_git(["rev-list", "--count", f"{base_sha}..HEAD"])
    if rev_list is None:
        return {
            "available": False,
            "base_sha": base_sha,
            "head": head.stdout.strip(),
            "reason": "git_rev_list_unavailable",
        }
    if rev_list.returncode != 0:
        return {
            "available": False,
            "base_sha": base_sha,
            "head": head.stdout.strip(),
            "reason": "git_rev_list_failed",
            "stderr": (rev_list.stderr or "").strip()[-500:],
        }
    try:
        ahead_count = int(rev_list.stdout.strip())
    except ValueError:
        return {
            "available": False,
            "base_sha": base_sha,
            "head": head.stdout.strip(),
            "reason": "git_rev_list_non_integer",
            "stdout": (rev_list.stdout or "").strip()[-120:],
        }
    return {
        "available": True,
        "base_sha": base_sha,
        "head": head.stdout.strip(),
        "ahead_count": ahead_count,
        "zero_advancement": ahead_count == 0,
        "command": f"git rev-list --count {base_sha}..HEAD",
    }


def working_tree_status() -> dict[str, object]:
    status = run_git(["status", "--porcelain"])
    if status is None:
        return {"available": False, "reason": "git_status_unavailable"}
    if status.returncode != 0:
        return {
            "available": False,
            "reason": "git_status_failed",
            "stderr": (status.stderr or "").strip()[-500:],
        }
    lines = [line for line in (status.stdout or "").splitlines() if line.strip()]
    non_megaplan_lines: list[str] = []
    for line in lines:
        path = line[3:] if len(line) >= 4 else line
        if " -> " in path:
            path = path.rsplit(" -> ", 1)[-1]
        path = path.strip().strip('"')
        if path == ".megaplan" or path.startswith(".megaplan/"):
            continue
        non_megaplan_lines.append(line)
    return {
        "available": True,
        "dirty": bool(non_megaplan_lines),
        "uncommitted_file_count": len(non_megaplan_lines),
        "sample": non_megaplan_lines[:12],
        "raw_uncommitted_file_count": len(lines),
        "command": "git status --porcelain",
    }


def state_fallback_zero_advancement(previous_snapshot: dict[str, object]) -> dict[str, object]:
    if not previous_snapshot:
        return {
            "used": True,
            "zero_advancement": None,
            "reason": "no_previous_snapshot_for_state_fallback",
        }
    previous_completed = int(previous_snapshot.get("completed_count") or -1)
    previous_index = int(previous_snapshot.get("current_milestone_index") or -1)
    zero = previous_completed == completed_count and previous_index == current_index
    return {
        "used": True,
        "zero_advancement": zero,
        "reason": "git_unavailable; falling back to state-file completed-count/current-index",
        "previous_completed_count": previous_completed,
        "current_completed_count": completed_count,
        "previous_milestone_index": previous_index,
        "current_milestone_index": current_index,
    }


artifact_path = repair_data_dir / f"{safe_session_name(session)}.chain-health.json"
snapshot_path = marker_dir / f"{safe_session_name(session)}.chain-health.progress.json"
marker_dir.mkdir(parents=True, exist_ok=True)
repair_data_dir.mkdir(parents=True, exist_ok=True)

chain_state_path = resolve_chain_state_path()
chain_state = load_json(chain_state_path) if chain_state_path is not None else {}
chain_log_path = resolve_chain_log_path()
log_lines = read_tail_lines(chain_log_path, max_lines=LOG_WINDOW)
current_plan_name = str(chain_state.get("current_plan_name") or "").strip()
last_state = str(chain_state.get("last_state") or "").strip()
pr_state = str(chain_state.get("pr_state") or "").strip()
pr_number = chain_state.get("pr_number")
current_index = int(chain_state.get("current_milestone_index") or 0)
completed = chain_state.get("completed")
completed_list = completed if isinstance(completed, list) else []
completed_count = len(completed_list)
chain_complete, milestone_count = chain_state_is_complete(chain_state)

plan_dir = workspace / ".megaplan" / "plans" / current_plan_name if current_plan_name else None
plan_state_path = plan_dir / "state.json" if plan_dir is not None else None
plan_state = load_json(plan_state_path) if plan_state_path is not None else {}
plan_current_state = str(plan_state.get("current_state") or "").strip()
active_step = plan_state.get("active_step")
plan_has_active_step = isinstance(active_step, dict) and bool(active_step.get("phase") or active_step.get("worker_pid"))
plan_signal_liveness = ""
plan_signal_reason = ""
plan_has_in_flight_llm = False
if plan_dir is not None and plan_dir.exists():
    try:
        signal_bundle = compute_signal_bundle(plan_dir, plan_state if isinstance(plan_state, dict) else None)
        plan_signal_liveness = str(signal_bundle.liveness or "").strip()
        plan_signal_reason = str(signal_bundle.liveness_reason or "").strip()
        plan_has_in_flight_llm = bool(signal_bundle.has_in_flight_llm)
    except Exception:
        pass
plan_has_live_activity = plan_has_active_step or plan_signal_liveness == "progressing" or plan_has_in_flight_llm
plan_projected_nonterminal = (
    bool(current_plan_name)
    and not plan_has_active_step
    and last_state in {"blocked", "awaiting_human"}
    and plan_current_state == last_state
)
events_path = plan_dir / "events.ndjson" if plan_dir is not None else None
events_exists = events_path is not None and events_path.exists()
events_mtime = events_path.stat().st_mtime if events_exists else 0.0
events_size = events_path.stat().st_size if events_exists else 0

previous = load_json(snapshot_path)
stuck_ticks = 1 if last_state in NONTERMINAL_STATES else 0
if (
    previous
    and last_state in NONTERMINAL_STATES
    and previous.get("last_state") == last_state
    and int(previous.get("current_milestone_index") or -1) == current_index
    and int(previous.get("completed_count") or -1) == completed_count
):
    stuck_ticks = int(previous.get("stuck_ticks") or 0) + 1

no_advance_ticks = 0
events_advanced = False
if previous:
    prev_events_mtime = float(previous.get("events_mtime") or 0.0)
    prev_events_size = int(previous.get("events_size") or 0)
    events_advanced = events_exists and (
        events_mtime > prev_events_mtime or events_size > prev_events_size
    )
    if (
        events_advanced
        and not plan_has_live_activity
        and int(previous.get("current_milestone_index") or -1) == current_index
        and int(previous.get("completed_count") or -1) == completed_count
    ):
        no_advance_ticks = int(previous.get("no_advance_ticks") or 0) + 1

snapshot = {
    "session": session,
    "current_plan_name": current_plan_name,
    "last_state": last_state,
    "current_milestone_index": current_index,
    "completed_count": completed_count,
    "milestone_count": milestone_count,
    "chain_complete": chain_complete,
    "pr_state": pr_state,
    "pr_number": pr_number,
    "events_mtime": events_mtime,
    "events_size": events_size,
    "plan_has_active_step": plan_has_active_step,
    "plan_has_live_activity": plan_has_live_activity,
    "plan_signal_liveness": plan_signal_liveness,
    "plan_signal_reason": plan_signal_reason,
    "plan_has_in_flight_llm": plan_has_in_flight_llm,
    "stuck_ticks": stuck_ticks,
    "no_advance_ticks": no_advance_ticks,
    "updated_at": dt.datetime.now(dt.timezone.utc).isoformat(),
}
try:
    snapshot_path.write_text(json.dumps(snapshot, indent=2, sort_keys=True) + "\n", encoding="utf-8")
except Exception:
    pass

skip_detection = (
    health == "awaiting_pr_merge"
    or last_state == "awaiting_pr_merge"
    or (last_state in {"done", "complete"} and chain_complete)
    or not chain_state
)
if skip_detection:
    clear_artifact(artifact_path)
    emit("CHAIN_HEALTH_STATUS", "ok")
    emit("CHAIN_HEALTH_KIND", "")
    emit("CHAIN_HEALTH_SUMMARY", "")
    emit("CHAIN_HEALTH_ARTIFACT_PATH", "")
    emit("CHAIN_HEALTH_STATE_PATH", str(chain_state_path) if chain_state_path is not None else "")
    emit("CHAIN_HEALTH_LOG_PATH", str(chain_log_path) if chain_log_path is not None else "")
    emit("CHAIN_HEALTH_LOG_MESSAGE", "")
    raise SystemExit(0)

merged_counts: collections.Counter[str] = collections.Counter()
merged_examples: dict[str, str] = {}
guard_counts: collections.Counter[str] = collections.Counter()
guard_examples: dict[str, str] = {}
guard_reasons: dict[str, str] = {}
guard_kinds: dict[str, str] = {}
interesting_lines: list[str] = []
merged_pattern = re.compile(r"^\[chain\] PR #(?P<pr>\d+) merged; advancing past (?P<milestone>.+)$")
guard_pattern = re.compile(r"^\[chain\] completion guard blocked (?P<milestone>[^:]+): (?P<reason>.+)$")
pr_progression_guard_pattern = re.compile(r"^\[chain\] PR progression blocked (?P<milestone>[^:]+): (?P<reason>.+)$")

for raw_line in log_lines:
    line = raw_line.strip()
    if not line:
        continue
    merged_match = merged_pattern.match(line)
    if merged_match:
        milestone = merged_match.group("milestone").strip()
        merged_counts[milestone] += 1
        merged_examples.setdefault(milestone, line)
        interesting_lines.append(line)
        continue
    guard_kind = "completion_guard"
    guard_match = guard_pattern.match(line)
    if not guard_match:
        guard_match = pr_progression_guard_pattern.match(line)
        if guard_match:
            guard_kind = "pr_progression"
    if guard_match:
        milestone = guard_match.group("milestone").strip()
        guard_counts[milestone] += 1
        guard_examples.setdefault(milestone, line)
        guard_reasons[milestone] = guard_match.group("reason").strip()
        guard_kinds[milestone] = guard_kind
        interesting_lines.append(line)
        continue
    if "authority_divergence" in line or '"last_state": "authority_divergence"' in line:
        interesting_lines.append(line)

latest_failure = plan_state.get("latest_failure")
latest_failure = latest_failure if isinstance(latest_failure, dict) else {}
large_file_signal_text = "\n".join(
    [
        "\n".join(log_lines[-80:]),
        str(latest_failure.get("kind") or ""),
        str(latest_failure.get("message") or ""),
        json.dumps(latest_failure.get("metadata") or {}, sort_keys=True),
    ]
).lower()
has_large_file_push_rejection = (
    last_state == "failed"
    and (
        "phase-complete callback failed" in large_file_signal_text
        or "phase_callback_failed" in large_file_signal_text
    )
    and "git push" in large_file_signal_text
    and (
        "gh001" in large_file_signal_text
        or "large files detected" in large_file_signal_text
        or "exceeds github" in large_file_signal_text
        or "exceeds file size limit" in large_file_signal_text
        or "100.00 mb" in large_file_signal_text
    )
)

status = "ok"
issue_kind = ""
summary = ""
recurring_lines: list[str] = []
evidence_extra_lines: list[str] = []
completion_guard = {
    "milestone": "",
    "reason": "",
    "repeat_count": 0,
}
details: dict[str, object] = {}
chain_health_log_message = ""
completion_guard_repair_eligible = False

if last_state in {"done", "complete"} and not chain_complete:
    status = "chain_inconsistent_done"
    issue_kind = "chain_inconsistent_done"
    summary = (
        f"chain state advertises last_state={last_state} but only "
        f"{completed_count}/{milestone_count or '?'} milestones are complete; "
        "treating as incomplete/stuck instead of terminal"
    )
    chain_health_log_message = (
        "CHAIN HEALTH EVIDENCE: chain last_state is terminal-looking but "
        "completed milestones do not cover the chain spec."
    )

if status == "ok" and has_large_file_push_rejection:
    status = "chain_large_file_push_rejection"
    issue_kind = "git_large_file_push_rejection"
    recurring_lines = [
        line
        for line in log_lines[-40:]
        if (
            "GH001" in line
            or "Large files detected" in line
            or "exceeds GitHub" in line
            or "100.00 MB" in line
            or "phase-complete callback failed" in line
            or "git push" in line
        )
    ]
    summary = (
        "chain failed after a successful phase because the post-phase git push was rejected "
        "for an oversized runtime journal; exclude .megaplan runtime event logs from commits "
        "and replay the post-phase publish/chain transition"
    )
    chain_health_log_message = (
        "CHAIN HEALTH EVIDENCE: git push rejected by GitHub large-file limit after phase callback; "
        "runtime journals such as .megaplan/epics/*/events.jsonl must not be pushed"
    )
    evidence_extra_lines.append(
        "- Large-file push rejection: GitHub rejected the milestone branch because a runtime journal exceeded the file-size limit. "
        "Exclude runtime journals from chain commits and replay the post-phase transition."
    )
    details = {
        "latest_failure_kind": latest_failure.get("kind") or "",
        "latest_failure_message": latest_failure.get("message") or "",
        "runtime_journal_patterns": [
            ".megaplan/epics/*/events.jsonl",
            ".megaplan/plans/*/events.ndjson",
            ".megaplan/plans/*/execution_trace.jsonl",
        ],
    }

cycle_milestone = next(
    (
        milestone
        for milestone, repeat_count in merged_counts.items()
        if repeat_count >= CYCLE_REPEATS and guard_counts.get(milestone, 0) >= CYCLE_REPEATS
    ),
    "",
)
if cycle_milestone:
    status = "chain_cycle"
    issue_kind = "chain_cycle"
    repeat_count = min(merged_counts[cycle_milestone], guard_counts[cycle_milestone])
    recurring_lines = [
        merged_examples.get(cycle_milestone, ""),
        guard_examples.get(cycle_milestone, ""),
    ]
    completion_guard = {
        "milestone": cycle_milestone,
        "reason": guard_reasons.get(cycle_milestone, ""),
        "repeat_count": repeat_count,
    }
    summary = (
        f"chain-layer cycle on {cycle_milestone}: merged PR/completion-guard pattern repeated "
        f"{repeat_count}x; do not route to plan repair"
    )
    details = {
        "cycle_milestone": cycle_milestone,
        "merged_repeats": merged_counts[cycle_milestone],
        "completion_guard_repeats": guard_counts[cycle_milestone],
    }
if status == "ok" and guard_counts:
    guard_milestone, guard_repeat_count = max(guard_counts.items(), key=lambda item: item[1])
    if guard_repeat_count >= GUARD_REPEATS:
        status = "chain_completion_guard_rejections"
        issue_kind = "chain_completion_guard_rejections"
        recurring_lines = [guard_examples.get(guard_milestone, "")]
        completion_guard = {
            "milestone": guard_milestone,
            "reason": guard_reasons.get(guard_milestone, ""),
            "repeat_count": guard_repeat_count,
            "kind": guard_kinds.get(guard_milestone, "completion_guard"),
        }
        summary = (
            f"chain completion guard rejected {guard_milestone} {guard_repeat_count}x; "
            "plan repair loop will not fix a chain-driver completion pathology"
        )
        details = {
            "completion_guard_repeats": guard_repeat_count,
            "completion_guard_kind": guard_kinds.get(guard_milestone, "completion_guard"),
        }

if status in {"chain_cycle", "chain_completion_guard_rejections"}:
    guard_milestone = str(completion_guard.get("milestone") or "")
    guard_reason = str(completion_guard.get("reason") or "")
    guard_repeat_count = int(completion_guard.get("repeat_count") or 0)
    base_sha = milestone_base_sha_from_state_or_reason(plan_state, guard_reason)
    advancement_check = completion_guard_advancement(base_sha, previous)
    worktree_check = working_tree_status()
    fallback_check: dict[str, object] = {"used": False}
    zero_advancement = False
    if advancement_check.get("available") is True:
        zero_advancement = advancement_check.get("zero_advancement") is True
    else:
        fallback_check = state_fallback_zero_advancement(previous)
        chain_health_log_message = (
            "completion guard git advancement check unavailable "
            f"session={session} base={base_sha or 'unknown'} reason={advancement_check.get('reason')}; "
            "falling back to state-file completed-count/current-index"
        )
        zero_advancement = fallback_check.get("zero_advancement") is True
    details = {
        **details,
        "completion_guard_advancement": advancement_check,
        "completion_guard_worktree": worktree_check,
        "completion_guard_state_fallback": fallback_check,
    }
    if zero_advancement:
        base_label = base_sha or "unknown"
        if worktree_check.get("available") is True and worktree_check.get("dirty") is True:
            uncommitted_count = int(worktree_check.get("uncommitted_file_count") or 0)
            status = "chain_uncommitted_execute_output"
            issue_kind = "chain_uncommitted_execute_output"
            summary = (
                f"milestone {guard_milestone or 'unknown'} has 0 committed changes vs base {base_label} "
                f"but the working tree has {uncommitted_count} uncommitted files; unpublished claimed changes "
                "were left unpublished in a dirty worktree; execute output was not "
                "committed, so this is a CHAIN-DRIVER commit-step bug, not a plan no-op waiver case"
            )
            chain_health_log_message = (
                "CHAIN HEALTH EVIDENCE: working tree has "
                f"{uncommitted_count} uncommitted files vs committed HEAD; execute output was not "
                "committed -> repeated publish guards indicate the commit step skipped; investigate "
                "arnold_pipelines/megaplan/chain commit-and-push gating"
            )
            evidence_extra_lines.append(
                "- Working tree evidence: "
                f"{uncommitted_count} uncommitted files vs committed HEAD; execute output was not "
                "committed -> commit step skipped; investigate "
                "arnold_pipelines/megaplan/chain commit-and-push gating."
            )
            details["chain_driver_diagnosis"] = summary
        else:
            status = "needs_human"
            issue_kind = "plan_noop_completion_guard"
            summary = (
                f"milestone {guard_milestone or 'unknown'} produces NO code changes vs base {base_label} "
                f"across {guard_repeat_count} attempts "
                "(git rev-list base..HEAD == 0 and working tree is clean); completion guard correctly blocks; "
                "this is a PLAN decision: rework the milestone so its execute lands work, OR grant a typed no-op "
                "completion waiver. Not auto-repairable."
            )
            details["plan_level_diagnosis"] = summary
    elif advancement_check.get("available") is True:
        # Code landed after the milestone base, so this is a repair-eligible
        # completion-guard edge case (for example a stale base SHA), not a
        # plan-level no-op. Return ok so launch_chain_tick continues into the
        # existing repair/relaunch path.
        completion_guard_repair_eligible = True
        status = "ok"
        issue_kind = ""
        summary = ""
        recurring_lines = []
        details = {}
    elif fallback_check.get("used") is True and fallback_check.get("zero_advancement") is False:
        completion_guard_repair_eligible = True
        status = "ok"
        issue_kind = ""
        summary = ""
        recurring_lines = []
        details = {}

unclean_base_lines = [
    line
    for line in log_lines[-120:]
    if (
        '"error": "unclean_base"' in line
        or "require_clean_base:" in line
        or "working base carries uncommitted WIP" in line
        or "clean base" in line.lower()
        and "uncommitted" in line.lower()
        and "wip" in line.lower()
    )
]
if (
    status == "ok"
    and not completion_guard_repair_eligible
    and last_state in NONTERMINAL_STATES
    and unclean_base_lines
):
    status = "chain_unclean_base"
    issue_kind = "chain_unclean_base"
    recurring_lines = unclean_base_lines[-6:]
    summary = (
        "chain retry/relaunch cannot start because require_clean_base found carried WIP; "
        "preserve the abandoned attempt output before re-initializing the milestone"
    )
    details = {
        "stuck_ticks": stuck_ticks,
        "dirty_base_signal": True,
        "unclean_base_line_count": len(unclean_base_lines),
    }
    chain_health_log_message = (
        "CHAIN HEALTH EVIDENCE: require_clean_base reported carried WIP during chain retry; "
        "this is a chain-driver retry-preservation issue, not a plan-level repair target"
    )
    evidence_extra_lines.append(
        "- Unclean-base evidence: require_clean_base reported carried WIP while the chain was retrying/relaunching. "
        "Preserve or stash the abandoned attempt output before re-initializing the milestone."
    )

if (
    status == "ok"
    and not completion_guard_repair_eligible
    and last_state in NONTERMINAL_STATES
    and not plan_has_live_activity
    and not plan_projected_nonterminal
    and stuck_ticks >= STUCK_TICKS
):
    status = "chain_stuck"
    issue_kind = "chain_stuck_nonterminal"
    recurring_lines = interesting_lines[-3:] if interesting_lines else log_lines[-3:]
    summary = (
        f"chain stuck in nonterminal state {last_state} for {stuck_ticks} ticks with no completed[] growth; "
        "treat as chain-layer sickness"
    )
    details = {"stuck_ticks": stuck_ticks}
if (
    status == "ok"
    and not completion_guard_repair_eligible
    and not plan_projected_nonterminal
    and not plan_has_live_activity
    and no_advance_ticks >= NO_ADVANCE_TICKS
):
    status = "chain_no_advance"
    issue_kind = "chain_no_advance"
    recurring_lines = interesting_lines[-3:] if interesting_lines else log_lines[-3:]
    summary = (
        f"current_milestone_index stayed at {current_index} for {no_advance_ticks} busy ticks while "
        "plan events kept moving; the chain is busy but not advancing"
    )
    details = {"no_advance_ticks": no_advance_ticks, "events_advanced": events_advanced}

chain_state_summary = {
    "path": str(chain_state_path) if chain_state_path is not None else "",
    "current_plan_name": current_plan_name,
    "current_milestone_index": current_index,
    "completed_count": completed_count,
    "last_state": last_state,
    "pr_number": pr_number,
    "pr_state": pr_state,
}

why_chain_layer = (
    "This evidence points at chain-driver state progression or completion-guard behavior after the plan "
    "already executed or the PR already merged. Route to arnold_pipelines/megaplan/chain/, not the plan repair loop."
)

if status == "ok":
    clear_artifact(artifact_path)
else:
    rendered_lines = [line for line in recurring_lines if line]
    if not rendered_lines:
        rendered_lines = log_lines[-5:]
    evidence_lines = [
        "## CHAIN HEALTH EVIDENCE",
        f"- Issue: {issue_kind or status}",
        (
            "- Chain state summary: "
            f"last_state={last_state or 'unknown'} "
            f"pr_state={pr_state or 'unknown'} "
            f"current_milestone_index={current_index} "
            f"completed_count={completed_count}"
        ),
        "- Recurring chain-log lines:",
        *[f"> {line}" for line in rendered_lines[:6]],
        (
            "- Completion guard verdict: "
            f"{completion_guard['milestone'] or 'n/a'} -> "
            f"{completion_guard['reason'] or 'n/a'}"
        ),
        *(
            ["- PR progression guard evidence: repeated publish guards blocked advancement after the PR was already merged."]
            if completion_guard.get("kind") == "pr_progression"
            else []
        ),
        *evidence_extra_lines,
        f"- Why this is chain-layer: {why_chain_layer}",
        "- Investigate: arnold_pipelines/megaplan/chain/__init__.py and arnold_pipelines/megaplan/chain/status.py",
    ]
    evidence_markdown = "\n".join(evidence_lines)
    artifact = {
        "session": session,
        "workspace": str(workspace),
        "remote_spec": remote_spec_raw,
        "detected_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "status": status,
        "issue_kind": issue_kind or status,
        "summary": summary,
        "health": health,
        "thresholds": {
            "chain_cycle_repeats": CYCLE_REPEATS,
            "chain_stuck_ticks": STUCK_TICKS,
            "chain_no_advance_ticks": NO_ADVANCE_TICKS,
            "chain_completion_guard_repeats": GUARD_REPEATS,
            "chain_log_window_lines": LOG_WINDOW,
        },
        "chain_state_summary": chain_state_summary,
        "chain_state_path": str(chain_state_path) if chain_state_path is not None else "",
        "chain_log_path": str(chain_log_path) if chain_log_path is not None else "",
        "chain_log_tail": log_lines[-40:],
        "recurring_cycle_lines": rendered_lines[:10],
        "completion_guard": completion_guard,
        "details": details,
        "snapshot": snapshot,
        "why_chain_layer_issue": why_chain_layer,
        "investigation_hint": "arnold_pipelines/megaplan/chain/",
        "evidence_markdown": evidence_markdown,
    }
    try:
        artifact_path.write_text(json.dumps(artifact, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    except Exception:
        pass

emit("CHAIN_HEALTH_STATUS", status)
emit("CHAIN_HEALTH_KIND", (issue_kind or status) if status != "ok" else "")
emit("CHAIN_HEALTH_SUMMARY", summary)
emit("CHAIN_HEALTH_ARTIFACT_PATH", str(artifact_path) if status != "ok" else "")
emit("CHAIN_HEALTH_STATE_PATH", str(chain_state_path) if chain_state_path is not None else "")
emit("CHAIN_HEALTH_LOG_PATH", str(chain_log_path) if chain_log_path is not None else "")
emit("CHAIN_HEALTH_LOG_MESSAGE", chain_health_log_message)
PY
)"
}


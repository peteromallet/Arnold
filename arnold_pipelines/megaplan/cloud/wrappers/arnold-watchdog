emit_current_needs_human_sidecar() {
  local report_items="$1"
  local session="$2"
  local workspace="$3"
  local remote_spec="$4"
  local current_plan="$5"
  local current_target_observation="${6:-}"
  local health="${7:-}"
  local marker_path stale_marker_plans repair_summary meta_repair_trigger meta_dispatch_result

  marker_path="$(repair_needs_human_path "$session")"
  [[ -f "$marker_path" ]] || return 1

  stale_marker_plans="$(repair_needs_human_matches_current_plan "$session" "$current_plan" 2>/dev/null)" || {
    local stale_clear_verdict stale_clear_state
    stale_clear_verdict="$(resolver_stale_needs_human_clear_verdict "$current_target_observation")"
    stale_clear_state="${stale_clear_verdict#*:}"
    if [[ "$stale_clear_state" == "$stale_clear_verdict" || -z "$stale_clear_state" ]]; then
      stale_clear_state="UNKNOWN"
    fi
    compare_needs_human_to_resolver "$session" "$current_plan" "true" "${stale_marker_plans:-}"
    if [[ "$stale_clear_verdict" == clear:* ]]; then
      rm -f "$marker_path" 2>/dev/null || true
      log "stale repair needs-human marker cleared; canonical resolver permits stale clear session=$session canonical_state=$stale_clear_state live_plan=${current_plan:-unknown} marker_plans=${stale_marker_plans:-unknown}"
      return 1
    fi
    log "stale repair needs-human marker preserved; canonical resolver blocks stale clear session=$session canonical_state=$stale_clear_state live_plan=${current_plan:-unknown} marker_plans=${stale_marker_plans:-unknown}"
  }
  if [[ -n "${stale_marker_plans:-}" ]]; then
    compare_needs_human_to_resolver "$session" "$current_plan" "true" "$stale_marker_plans"
  else
    compare_needs_human_to_resolver "$session" "$current_plan" "false" ""
  fi

  meta_repair_trigger="$(compute_meta_repair_trigger "$session" "$current_target_observation" "$health")"
  if [[ "$meta_repair_trigger" == TRIGGER:* ]]; then
    if dispatch_meta_repair "$session" "$workspace" "$remote_spec" "$report_items" "${meta_repair_trigger#TRIGGER:}"; then
      meta_dispatch_result="${REPAIR_DISPATCH_RESULT:-}"
      if [[ "$meta_dispatch_result" == "dispatched" ]]; then
        log "session has current needs-human marker but meta-repair trigger matched; background-dispatched meta-repair session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:}"
        return 0
      fi
      log "session has current needs-human marker and meta-repair trigger matched but stayed in observe path session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:} dispatch=${meta_dispatch_result:-unknown}"
    else
      log "session has current needs-human marker and meta-repair trigger matched but dispatch unavailable session=$session health=$health trigger=${meta_repair_trigger#TRIGGER:}"
    fi
  fi
  if command -v repair_needs_human_should_remain_human >/dev/null 2>&1 && ! repair_needs_human_should_remain_human "$session" "$current_plan"; then
    rm -f "$marker_path" 2>/dev/null || true
    log "stale repair needs-human marker cleared; fresh classifier no longer requires human session=$session live_plan=${current_plan:-unknown}"
    return 1
  fi

  repair_summary="$(repair_needs_human_summary "$session")"
  log "session has current needs-human marker; reporting without re-notifying session=$session summary=$repair_summary"
  report_item "$report_items" "$session" "observe" "needs_human" "$repair_summary" "$workspace" "$remote_spec"
  return 0
}



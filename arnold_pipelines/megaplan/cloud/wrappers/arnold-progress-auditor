            ]
            or (payload.get("attempt_ids") if isinstance(payload, dict) and isinstance(payload.get("attempt_ids"), list) else [])
        ),
        "repair_run_count": payload.get("repair_run_count") if isinstance(payload, dict) else None,
        "managed_agent_run_id": payload.get("managed_agent_run_id") if isinstance(payload, dict) else "",
        "managed_agent_manifest_path": payload.get("managed_agent_manifest_path") if isinstance(payload, dict) else "",
        "managed_agent_runs": payload.get("managed_agent_runs") if isinstance(payload, dict) and isinstance(payload.get("managed_agent_runs"), list) else [],
        "investigation_summary": investigation_summary,
        "meta_investigation_summary": meta_investigation_summary,
        "iteration_count": len(iterations),
        "iterations": summarized_iterations,
        "repeated_failure_signatures": repeated[:6],
    }

def _repair_custody_summary(session, plan_state, current_target):
    repair_data_dir = pathlib.Path(
        os.environ.get(
            "MEGAPLAN_AUDIT_REPAIR_DATA_DIR",
            "/workspace/.megaplan/cloud-sessions/repair-data",
        )
    )
    target = dict(current_target) if isinstance(current_target, dict) else {}
    target.setdefault("session", session)
    target.setdefault("target_session", session)
    malformed_requests = [
        item
        for item in iter_repair_requests(REPAIR_QUEUE_ROOT, include_malformed=True)
        if item.get("kind") == "malformed_repair_request"
    ]
    malformed_decisions = [
        item
        for item in iter_repair_decisions(REPAIR_QUEUE_ROOT, include_malformed=True)
        if item.get("kind") == "malformed_repair_decision"
    ]
    if project_repair_custody is None or not repair_request_runtime_available:
        return {
            "queue_root": str(REPAIR_QUEUE_ROOT),
            "projection_error": "installed runtime lacks repair custody projection support",
            "malformed_request_count": len(malformed_requests),
            "malformed_decision_count": len(malformed_decisions),
        }
    try:
        projection = project_repair_custody(
            plan_state=plan_state if isinstance(plan_state, dict) else {},
            current_target=target,
            queue_root=REPAIR_QUEUE_ROOT,
            repair_data_dir=repair_data_dir,
        )
    except Exception as exc:
        return {
            "queue_root": str(REPAIR_QUEUE_ROOT),
            "projection_error": _redact_scalar(exc),
            "malformed_request_count": len(malformed_requests),
            "malformed_decision_count": len(malformed_decisions),
        }
    refs = target.get("current_refs") if isinstance(target.get("current_refs"), dict) else {}
    marker = target.get("marker") if isinstance(target.get("marker"), dict) else {}
    workspace = str(refs.get("workspace") or marker.get("workspace") or "").strip()
    nested_projection = {}
    nested_queue_root = pathlib.Path(workspace) / ".megaplan" / "repair-queue" if workspace else None
    if (
        nested_queue_root is not None
        and nested_queue_root.resolve() != pathlib.Path(REPAIR_QUEUE_ROOT).resolve()
        and (nested_queue_root / "requests").is_dir()
    ):
        try:
            nested_projection = project_repair_custody(
                plan_state=plan_state if isinstance(plan_state, dict) else {},
                current_target=target,
                queue_root=nested_queue_root,
                repair_data_dir=repair_data_dir,
            )
        except Exception as exc:
            nested_projection = {"projection_error": _redact_scalar(exc)}
    central_request_ids = {
        str(item) for item in (projection.get("active_request_ids") or []) if item
    }
    nested_decisions = (
        iter_repair_decisions(nested_queue_root)
        if nested_queue_root is not None and (nested_queue_root / "decisions").is_dir()
        else []
    )
    latest_nested_decisions = {}
    for decision in nested_decisions:
        request_id = str(decision.get("request_id") or "")
        if request_id:
            latest_nested_decisions[request_id] = str(decision.get("decision") or "")
    nested_attempt_request_ids = {
        str(item.get("request_id") or "")
        for item in (
            iter_repair_attempts(nested_queue_root)
            if nested_queue_root is not None and (nested_queue_root / "attempts").is_dir()
            else []
        )
    }
    nested_unclaimed_ids = sorted(
        request_id
        for request_id, decision in latest_nested_decisions.items()
        if decision == "accepted"
        and request_id not in central_request_ids
        and request_id not in nested_attempt_request_ids
    )
    return {
        "queue_root": str(REPAIR_QUEUE_ROOT),
        "blocker_id": projection.get("blocker_id") or "",
        "active_request_ids": projection.get("active_request_ids") or [],
        "accepted_unclaimed_request_ids": projection.get("accepted_unclaimed_request_ids") or [],
        "request_status_counts": projection.get("request_status_counts") or {},
        "claim_count": projection.get("claim_count") or 0,
        "attempt_count": projection.get("attempt_count") or 0,
        "claim_retry_counts": projection.get("claim_retry_counts") or {},
        "claim_alert_request_ids": projection.get("claim_alert_request_ids") or [],
        "retry_budget": projection.get("retry_budget") or {},
        "terminal_outcomes": projection.get("terminal_outcomes") or [],
        "attempts": projection.get("attempts") or [],
        "malformed_request_count": len(malformed_requests),
        "malformed_decision_count": len(malformed_decisions),
        "malformed_request_paths": [item.get("path") for item in malformed_requests[:3]],
        "malformed_decision_paths": [item.get("path") for item in malformed_decisions[:3]],
        "nested_queue_root": str(nested_queue_root) if nested_queue_root is not None else "",
        "nested_queue_projection_error": nested_projection.get("projection_error") or "",
        "nested_accepted_unclaimed_request_ids": nested_unclaimed_ids,
        "nested_claim_count": nested_projection.get("claim_count") or 0,
        "nested_attempt_count": nested_projection.get("attempt_count") or 0,
    }

def _load_events(events_path):
    events = []
    try:
        lines = events_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return events
    for line in lines:
        if not line.strip():
            continue
        try:
            event = json.loads(line)
        except Exception:
            continue
        if isinstance(event, dict):
            events.append(event)
    return events

def _event_timestamp(event):
    for key in ("ts_utc", "timestamp_utc", "timestamp", "recorded_at", "created_at"):
        when = _parse_iso(event.get(key))
        if when is not None:
            return when
    payload = event.get("payload")
    if isinstance(payload, dict):
        for key in ("ts_utc", "timestamp_utc", "timestamp", "recorded_at", "created_at"):
            when = _parse_iso(payload.get(key))
            if when is not None:
                return when
    return None

def _deterministic_retry_evidence(events_path, minimum_count=3):
    """Find a recent identical LLM failure that has crossed the retry cap."""
    buckets = {}
    for event in _load_events(events_path):
        kind = str(event.get("kind") or event.get("event_type") or "").strip().lower()
        if kind != "llm_call_error":
            continue
        when = _event_timestamp(event)
        if when is None or when < cutoff:
            continue
        payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
        message = re.sub(r"\s+", " ", str(payload.get("message") or event.get("message") or "").strip())[:500]
        if not message:
            continue
        phase = str(event.get("phase") or payload.get("phase") or "unknown").strip().lower()
        signature = f"{kind}|{phase}|{message}"
        bucket = buckets.setdefault(
            signature,
            {
                "signature": signature,
                "kind": kind,
                "phase": phase,
                "message": message,
                "count": 0,
                "first_at": "",
                "last_at": "",
                "source": str(events_path),
            },
        )
        bucket["count"] += 1
        timestamp = when.isoformat()
        if not bucket["first_at"]:
            bucket["first_at"] = timestamp
        bucket["last_at"] = timestamp
    repeated = [item for item in buckets.values() if int(item.get("count") or 0) >= minimum_count]
    if not repeated:
        return {}
    return max(repeated, key=lambda item: (int(item.get("count") or 0), item.get("last_at") or ""))

def _deterministic_phase_history_evidence(history, minimum_count=3):
    """Find identical recent phase errors when no llm_call_error event exists."""
    buckets = {}
    for item in history if isinstance(history, list) else []:
        if not isinstance(item, dict) or str(item.get("result") or "").lower() != "error":
            continue
        when = _parse_iso(item.get("timestamp") or item.get("completed_at") or "")
        if when is None or when < cutoff:
            continue
        message = re.sub(r"\s+", " ", str(item.get("message") or "").strip())[:500]
        if not message:
            continue
        phase = str(item.get("step") or item.get("phase") or "unknown").strip().lower()
        signature = f"phase_error|{phase}|{message}"
        bucket = buckets.setdefault(signature, {
            "signature": signature, "kind": "phase_error", "phase": phase,
            "message": message, "count": 0, "first_at": "", "last_at": "",
            "source": "state.history",
        })
        bucket["count"] += 1
        timestamp = when.isoformat()
        if not bucket["first_at"]:
            bucket["first_at"] = timestamp
        bucket["last_at"] = timestamp
    repeated = [item for item in buckets.values() if int(item.get("count") or 0) >= minimum_count]
    if not repeated:
        return {}
    return max(repeated, key=lambda item: (int(item.get("count") or 0), item.get("last_at") or ""))

def _event_seq(event):
    for key in ("seq", "event_seq", "sequence"):
        value = event.get(key)
        try:
            if value is not None:
                return int(value)
        except (TypeError, ValueError):
            pass
    return None

def _failure_seq(latest_failure):
    if not isinstance(latest_failure, dict):
        return None
    candidates = [
        latest_failure.get("seq"),
        latest_failure.get("event_seq"),
        latest_failure.get("sequence"),
    ]
    metadata = latest_failure.get("metadata")
    if isinstance(metadata, dict):
        candidates.extend([metadata.get("seq"), metadata.get("event_seq"), metadata.get("sequence")])
    for value in candidates:
        try:
            if value is not None:
                return int(value)
        except (TypeError, ValueError):
            continue
    return None

def _success_value(value):
    return str(value or "").strip().lower() in {
        "success",
        "succeeded",
        "done",
        "proceed",
        "pass",
        "passed",
        "ok",
        "complete",
        "completed",
        "finished",
        "executed",
        "finalized",
    }

def _successful_event(event):
    kind = str(event.get("kind") or event.get("event_type") or "").strip().lower()
    payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
    phase = str(event.get("phase") or payload.get("phase") or "").strip().lower()
    if kind == "phase_end":
        return any(
            _success_value(event.get(key)) or _success_value(payload.get(key))
            for key in ("exit_kind", "status", "result", "state", "recommendation", "verdict")
        )
    if kind == "plan_finished":
        return True
    if kind in {"gate", "gate_result", "quality_gate", "phase_end"}:
        if _success_value(payload.get("recommendation") or event.get("recommendation")):
            return True
    if phase == "gate" and _success_value(payload.get("recommendation") or event.get("recommendation")):
        return True
    for key in ("exit_kind", "status", "result", "state", "recommendation", "verdict"):
        if _success_value(event.get(key)) or _success_value(payload.get(key)):
            return True
    return False

def _event_excerpt(event):
    payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
    return {
        "seq": _event_seq(event),
        "ts": (_event_timestamp(event).isoformat().replace("+00:00", "Z") if _event_timestamp(event) else ""),
        "kind": event.get("kind") or event.get("event_type") or "",
        "phase": event.get("phase") or payload.get("phase") or "",
        "status": event.get("status") or event.get("result") or payload.get("status") or payload.get("result") or payload.get("exit_kind") or "",
        "recommendation": event.get("recommendation") or payload.get("recommendation") or "",
    }


def _collect_meta_run_refs(session):
    refs = []
    if not META_RUN_DIR.exists():
        return refs
    safe_session = "".join(ch if ch.isalnum() or ch in "_.-" else "-" for ch in str(session))
    candidates = list(META_RUN_DIR.glob(f"*{safe_session}*.log")) + list(META_RUN_DIR.glob(f"*{session}*.log"))
    seen = set()
    ordered = []
    for path in candidates:
        key = str(path)
        if key in seen or not path.is_file():
            continue
        seen.add(key)
        ordered.append((_mtime(path), path))
    ordered.sort(reverse=True)
    selected = list(ordered[:5])
    for index, (mtime, path) in enumerate(selected):
        tail = _tail_with_line_numbers(path, lines=12)
        failure_code = _meta_run_failure_code(path)
        current_episode = index == 0
        ordinary_retrigger_failed = failure_code == "ordinary_retrigger_failed"
        trigger_rejected = failure_code == "meta_repair_trigger_rejected"
        launch_failure = bool(
            current_episode
            and not ordinary_retrigger_failed
            and not trigger_rejected
            and (
                failure_code in {
                    "investigator_read_sandbox_unavailable",
                    "investigator_envelope_overflow",
                    "investigator_invalid_or_missing_receipt",
                    "meta_repair_launch_failure",
                }
                or _text_has_meta_launch_failure(tail)
            )
        )
        refs.append(
            {
                "path": _redact_scalar(path),
                "mtime_age_min": int((now.timestamp() - mtime) // 60) if mtime else None,
                "tail": _redact_scalar(tail),
                "launch_failure": launch_failure,
                "current_episode": current_episode,
                "ordinary_retrigger_failed": bool(current_episode and ordinary_retrigger_failed),
                "trigger_rejected": bool(current_episode and trigger_rejected),
                "sha256": hashlib.sha256(path.read_bytes()).hexdigest(),
                **({"failure_code": failure_code} if failure_code else {}),
            }
        )
    return refs

def _meta_run_failure_code(path):
    try:
        size = path.stat().st_size
        with path.open("rb") as handle:
            prefix = handle.read(131072)
            suffix = b""
            if size > len(prefix):
                handle.seek(max(0, size - 131072))
                suffix = handle.read(131072)
        text = (prefix + b"\n" + suffix).decode("utf-8", errors="replace")
    except OSError:
        return ""
    event_lines = [
        line.strip()
        for line in text.splitlines()
        if line.lstrip().startswith("[meta-repair ") or line.lstrip().startswith("bwrap:")
    ]
    lowered = "\n".join(event_lines).lower()
    if re.search(r"l2 replan handoff ordinary repair completed .*returncode=[1-9][0-9]*", lowered):
        return "ordinary_retrigger_failed"
    if "no meta-repair trigger matched; exiting" in lowered:
        return "meta_repair_trigger_rejected"
    if (
        "investigator_read_sandbox_unavailable" in lowered
        or "bwrap: no permissions to create new namespace" in lowered
    ):
        return "investigator_read_sandbox_unavailable"
    if "l2 investigator launch envelope failed 64 kib preflight" in lowered:
        return "investigator_envelope_overflow"
    if "l2 investigator failed or returned no valid receipt" in lowered:
        return "investigator_invalid_or_missing_receipt"
    if _text_has_meta_launch_failure(text):
        return "meta_repair_launch_failure"
    return ""

def _text_has_meta_launch_failure(text):
    if not isinstance(text, str):
        return False
    needles = (
        "Codex meta-repair orchestrator returned no output",
        "Codex meta-repair prompt exceeded input limit",
        "Not inside a trusted directory",
        "--skip-git-repo-check was not specified",
        "codex CLI missing; no automated meta-repair",
        "failed to launch DeepSeek/Hermes subagents",
        "Input exceeds the maximum length",
        "input_too_large",
    )
    return any(needle in text for needle in needles)

def _meta_record_is_launch_failure(path):
    payload = _load_json(path)
    if not isinstance(payload, dict):
        return False
    outcome = str(payload.get("outcome") or "")
    if outcome and outcome not in {"UNKNOWN", "NO_FIX"} and not outcome.startswith("Codex meta-repair orchestrator returned no output"):
        return False
    haystacks = [
        str(payload.get("diagnosis") or ""),
        str(payload.get("reason") or ""),
    ]
    subagent_results = payload.get("subagent_results")
    if isinstance(subagent_results, dict):
        haystacks.extend(str(value or "") for value in subagent_results.values())
    return _text_has_meta_launch_failure("\n".join(haystacks))

def _repair_attempt_signals(repair_payload):
    attempts = repair_payload.get("attempts") if isinstance(repair_payload, dict) else []
    iterations = repair_payload.get("iterations") if isinstance(repair_payload, dict) else []
    if not isinstance(attempts, list):
        attempts = []
    if not isinstance(iterations, list):
        iterations = []
    recent_attempts = [item for item in attempts[-5:] if isinstance(item, dict)]
    recent_iterations = [item for item in iterations[-5:] if isinstance(item, dict)]
    failure_kinds = []
    for item in recent_attempts + recent_iterations:
        for candidate in (
            item.get("failure_classification"),
            (item.get("failure_context") or {}).get("failure_classification") if isinstance(item.get("failure_context"), dict) else None,
            (item.get("post_launch_failure_context") or {}).get("failure_classification") if isinstance(item.get("post_launch_failure_context"), dict) else None,
            (item.get("plan_latest_failure") or {}).get("kind") if isinstance(item.get("plan_latest_failure"), dict) else None,
            item.get("latest_failure_kind"),
        ):
            if isinstance(candidate, str) and candidate.strip():
                failure_kinds.append(candidate.strip())
                break
    repair_outcome = str(repair_payload.get("outcome") or "") if isinstance(repair_payload, dict) else ""
    attempt_outcomes = [
        str(item.get("outcome") or "").strip()
        for item in recent_attempts + recent_iterations
        if isinstance(item, dict)
    ]
    return repair_outcome, [item for item in attempt_outcomes if item], failure_kinds

def _attempt_has_runtime_context(item):
    if not isinstance(item, dict):
        return False
    for key in ("recorded_at", "started_at", "finished_at", "dispatched_at", "run_dir", "outcome"):
        if str(item.get(key) or "").strip():
            return True
    for key in ("resolver_output", "target", "verification"):
        if isinstance(item.get(key), dict) and item.get(key):
            return True
    return False

def _meta_repair_summary(
    session,
    repair_data,
    meta_refs,
    *,
    run_kind="",
    current_plan_name="",
    current_state="",
    active_step_phase="",
    active_step_liveness=None,
    chain_state_summary=None,
    chain_log_summary=None,
    events_mtime_age_min=None,
    prior_watchdog_report_refs=None,
):
    repair_root = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_REPAIR_DATA_DIR", "/workspace/.megaplan/cloud-sessions/repair-data"))
    repair_payload = _load_json(repair_root / f"{session}.repair-data.json")
    if not isinstance(repair_payload, dict):
        repair_payload = {}
    repair_goal_ref = repair_payload.get("repair_goal") if isinstance(repair_payload.get("repair_goal"), dict) else {}
    repair_goal_path = pathlib.Path(str(repair_goal_ref.get("goal_path") or "")) if repair_goal_ref.get("goal_path") else None
    repair_goal = _load_json(repair_goal_path) if repair_goal_path is not None else {}
    repair_goal_active = isinstance(repair_goal, dict) and repair_goal.get("status") == "active"
    recovery_gate = (
        repair_goal.get("recovery_acceptance")
        if isinstance(repair_goal, dict)
        and isinstance(repair_goal.get("recovery_acceptance"), dict)
        else {}
    )
    recovery_gate_failures = (
        repair_goal.get("recovery_gate_failures")
        if isinstance(repair_goal, dict)
        and isinstance(repair_goal.get("recovery_gate_failures"), list)
        else []
    )
    recovery_gate_failed = bool(
        recovery_gate.get("accepted") is False or recovery_gate_failures
    )
    failed_fixer_evidence = [
        item
        for item in (recovery_gate.get("failed_fixer_evidence") or [])[-15:]
        if isinstance(item, dict)
    ]
    request_id = str(repair_payload.get("request_id") or "").strip()
    if not request_id and isinstance(repair_goal, dict):
        request_ids = repair_goal.get("request_ids")
        if isinstance(request_ids, list) and request_ids:
            request_id = str(request_ids[-1] or "").strip()
    queue_root = pathlib.Path(
        os.environ.get(
            "ARNOLD_REPAIR_QUEUE_ROOT",
            str(repair_root.parent.parent / "repair-queue"),
        )
    )
    request_payload = _load_json(queue_root / "requests" / f"{request_id}.json") if request_id else {}
    request_signature = (
        request_payload.get("problem_signature")
        if isinstance(request_payload, dict) and isinstance(request_payload.get("problem_signature"), dict)
        else {}
    )
    request_target = (
        request_payload.get("target")
        if isinstance(request_payload, dict) and isinstance(request_payload.get("target"), dict)
        else {}
    )
    repair_goal_owner_live = False
    if repair_goal_active:
        for owner in repair_goal.get("owners") or []:
            if not isinstance(owner, dict) or not owner.get("manifest_path"):
                continue
            manifest = _load_json(pathlib.Path(str(owner["manifest_path"])))
            if not isinstance(manifest, dict) or manifest.get("status") not in {"reserved", "launching", "running", "adopting"}:
                continue
            try:
                owner_pid = int(manifest.get("pid") or 0)
                if owner_pid > 0:
                    os.kill(owner_pid, 0)
                    repair_goal_owner_live = True
                    break
            except (OSError, TypeError, ValueError):
                continue
    normalized_kind = str(run_kind or "").strip().lower()
    normalized_state = str(current_state or "").strip().lower()
    chain_current = (chain_state_summary or {}).get("current") if isinstance(chain_state_summary, dict) else {}
    chain_last_state = str((chain_current or {}).get("last_state") or "").strip().lower()
    chain_current_plan = str((chain_current or {}).get("current_plan_name") or "").strip()
    terminal_success = False
    if normalized_kind == "plan":
        terminal_success = normalized_state in {"done", "complete", "completed", "finalized"}
    else:
        terminal_success = chain_last_state in {"done", "complete", "completed"} and not chain_current_plan
    run_refs = _collect_meta_run_refs(session)
    repair_outcome, attempt_outcomes, failure_kinds = _repair_attempt_signals(repair_payload)
    recent_attempts = [
        item
        for item in (repair_payload.get("attempts") if isinstance(repair_payload.get("attempts"), list) else [])[-5:]
        if isinstance(item, dict)
    ]
    recent_iterations = [
        item
        for item in (repair_payload.get("iterations") if isinstance(repair_payload.get("iterations"), list) else [])[-5:]
        if isinstance(item, dict)
    ]
    current_attempt_id = str(repair_payload.get("current_attempt_id") or "").strip()
    current_recurrence = repair_payload.get("current_recurrence") if isinstance(repair_payload.get("current_recurrence"), dict) else {}
    current_signature = repair_payload.get("current_signature") if isinstance(repair_payload.get("current_signature"), dict) else {}
    if isinstance(repair_data, dict) and not repair_data.get("exists"):
        if normalized_kind == "plan":
            terminal_success = normalized_state in {"done", "complete", "completed", "finalized"}
        else:
            terminal_success = chain_last_state in {"done", "complete", "completed"} and not chain_current_plan
    if terminal_success and not meta_refs and not run_refs and not repair_goal_active:
        return {
            "should_dispatch": False,
            "trigger": "",
            "rationale": [
                "session already reached terminal success and has no repair-data or meta-repair artifacts; "
                "partial-liveness sidecars alone are not operative meta-repair evidence"
            ],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": 0,
            "meta_run_refs": [],
            "missing_meta_run_evidence": False,
        }
    if (
        repair_outcome == "running"
        and not current_attempt_id
        and not current_recurrence
        and not current_signature
        and not recent_iterations
        and not recent_attempts
        and not repair_goal_active
    ):
        run_refs = _collect_meta_run_refs(session)
        return {
            "should_dispatch": True,
            "trigger": "repair_running_without_attempt_context",
            "rationale": [
                "repair-data reports running but has no current attempt id, recurrence, "
                "signature, attempts, or iterations; this is an artifact-quality gap, "
                "not proof that ordinary repair is active"
            ],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": len(run_refs),
            "meta_run_refs": run_refs,
            "missing_meta_run_evidence": bool(not meta_refs and not run_refs),
        }
    if (
        repair_outcome == "running"
        and not current_attempt_id
        and not current_recurrence
        and not current_signature
        and not recent_iterations
        and not recent_attempts
        and not repair_goal_active
    ):
        run_refs = _collect_meta_run_refs(session)
        return {
            "should_dispatch": True,
            "trigger": "repair_running_without_attempt_context",
            "rationale": [
                "repair-data reports running but has no current attempt id, recurrence, "
                "signature, attempts, or iterations; this is an artifact-quality gap, "
                "not proof that ordinary repair is active"
            ],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": len(run_refs),
            "meta_run_refs": run_refs,
            "missing_meta_run_evidence": bool(not meta_refs and not run_refs),
        }
    if (
        repair_outcome == "running"
        and not current_attempt_id
        and not current_recurrence
        and not current_signature
        and not recent_iterations
        and recent_attempts
        and not repair_goal_active
    ):
        return {
            "should_dispatch": False,
            "trigger": "",
            "rationale": [
                "repair-data reports running but no active attempt/iteration context is present; "
                "historical attempts alone are insufficient to demand meta-repair"
            ],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": 0,
            "meta_run_refs": [],
            "missing_meta_run_evidence": False,
        }
    if (
        not current_attempt_id
        and not current_recurrence
        and not current_signature
        and recent_attempts
        and not any(_attempt_has_runtime_context(item) for item in recent_attempts)
        and repair_outcome not in {"repair_timeout", "repair_exhausted"}
        and not repair_goal_active
    ):
        return {
            "should_dispatch": False,
            "trigger": "",
            "rationale": ["repair-data only contains legacy attempt summaries; no active recurring repair context is present"],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": 0,
            "meta_run_refs": [],
            "missing_meta_run_evidence": False,
        }
    try:
        observed_plan_name = chain_current_plan if normalized_kind != "plan" else str(current_plan_name or "").strip()
        current_target_observation = {
            "authoritative_source": "chain_state" if normalized_kind != "plan" and chain_current else "plan_state",
            "current_refs": {
                "run_kind": normalized_kind,
                "current_plan_name": observed_plan_name,
                "chain_current_plan_name": chain_current_plan,
                "plan_current_state": normalized_state,
                "chain_last_state": chain_last_state,
            },
            "plan_state": {"present": bool(current_plan_name)},
            "chain_state": {"present": bool(chain_current)},
            "active_step_heartbeat": {
                "active": bool(str(active_step_phase or "").strip()),
                "worker_pid_alive": active_step_liveness.get("worker_pid_alive")
                if isinstance(active_step_liveness, dict)
                else None,
            },
            "stale_evidence": [],
        }
        classification, _ = evaluate_meta_repair_triggers(
            session,
            repair_data_dir=repair_root,
            repair_outcome=repair_outcome,
            attempt_outcomes=attempt_outcomes,
            failure_kinds=failure_kinds,
            repair_budget_exhausted=repair_outcome in {"repair_timeout", "repair_exhausted"},
            current_target_observation=current_target_observation,
            load_evidence=True,
        )
        should_dispatch = bool(classification.should_dispatch)
        trigger = classification.trigger_label
        rationale = [_redact_scalar(item) for item in classification.rationale]
    except Exception as exc:
        should_dispatch = False
        trigger = "classification_error"
        rationale = [_redact_scalar(exc)]
    observed_plan = chain_current_plan if normalized_kind != "plan" else str(current_plan_name or "").strip()
    observed_stage = str(active_step_phase or normalized_state or chain_last_state).strip().lower()
    request_plan = str(
        request_signature.get("milestone_or_plan")
        or request_signature.get("plan_name")
        or request_target.get("plan_name")
        or ""
    ).strip()
    request_stage = str(
        request_signature.get("phase_or_step")
        or request_signature.get("phase")
        or request_signature.get("step")
        or ""
    ).strip().lower()
    request_target_mismatch = bool(
        request_payload
        and (
            (request_plan and observed_plan and request_plan != observed_plan)
            or (request_stage and observed_stage and request_stage != observed_stage)
        )
    )
    goal_evaluation = (
        repair_goal.get("last_evaluation")
        if isinstance(repair_goal, dict) and isinstance(repair_goal.get("last_evaluation"), dict)
        else {}
    )
    goal_control_action = str(goal_evaluation.get("control_action") or "").strip()
    request_gate_recommendation = str(
        request_signature.get("gate_recommendation") or ""
    ).strip()
    request_failure_kind = str(request_signature.get("failure_kind") or "").strip()
    repair_dispatch_during_preserve_live = bool(
        request_payload
        and request_failure_kind == "repair_goal_owner_missing"
        and (
            goal_control_action == "preserve_live"
            or request_gate_recommendation.startswith("preserve_live")
        )
    )
    if repair_goal_active and recovery_gate_failed:
        should_dispatch = True
        trigger = "post_fixer_recovery_gate_failed"
        rationale = [
            "the fixer terminalized without durable recovery: blocker clearance, "
            "live canonical runner, beyond-checkpoint progress, or bounded continued "
            "progress was not proven; dispatch transcript-aware root-cause/meta-repair"
        ]
    elif repair_goal_active and request_target_mismatch:
        should_dispatch = True
        trigger = "repair_context_target_mismatch"
        rationale = [
            "active repair custody is using a queued request whose exact plan/stage identity disagrees "
            f"with authoritative target state: request={request_plan!r}/{request_stage!r}, "
            f"current={observed_plan!r}/{observed_stage!r}; a live owner cannot suppress replan"
        ]
    elif repair_goal_active and goal_control_action == "replan":
        should_dispatch = True
        trigger = "repair_goal_circuit_breaker"
        rationale = [
            "durable repair goal recorded deterministic repeated owner failure and explicitly requires replan"
        ]
    elif repair_goal_active and not repair_goal_owner_live and goal_control_action == "preserve_live":
        should_dispatch = False
        trigger = ""
        rationale = [
            "durable repair goal explicitly requires preserving a fresh matching worker; "
            "an observation goal may remain active without a mutating owner"
        ]
    elif repair_goal_active and not repair_goal_owner_live:
        should_dispatch = True
        trigger = "repair_goal_owner_missing"
        rationale = [
            "durable repair goal remains at its frozen acceptance checkpoint but has no live owner; "
            "fixer completion and target liveness are not semantic progress"
        ]
    if should_dispatch and terminal_success and not repair_goal_active:
        should_dispatch = False
        trigger = ""
        rationale = [
            "current gathered target state already reached terminal success; "
            "stale repair-data recurrence does not require meta-repair dispatch"
        ]
    live_event_activity = isinstance(events_mtime_age_min, int) and events_mtime_age_min <= 5
    chain_log_age = None
    if isinstance(chain_log_summary, dict):
        chain_log_age = chain_log_summary.get("mtime_age_min")
    live_chain_activity = isinstance(chain_log_age, int) and chain_log_age <= 5
    active_step = active_step_liveness if isinstance(active_step_liveness, dict) else {}
    live_active_step_activity = bool(str(active_step_phase or "").strip()) and (
        live_event_activity or active_step.get("worker_pid_alive") is True
    )
    non_terminal_state = normalized_state not in {"done", "complete", "completed", "finalized"}
    live_target_activity = live_active_step_activity or (
        non_terminal_state and (
        live_event_activity or (normalized_kind == "chain" and live_chain_activity)
        )
    )
    if should_dispatch and trigger in {"persistent_recurring_retry", "partial_liveness_recurrence"} and live_target_activity and not repair_goal_active:
        should_dispatch = False
        trigger = ""
        rationale = [
            "watchdog-corroborated live target activity supersedes recurring meta-repair dispatch: "
            f"events_mtime_age_min={events_mtime_age_min!r}, chain_log_mtime_age_min={chain_log_age!r}, "
            f"active_step_phase={active_step_phase!r}, worker_pid_alive={active_step.get('worker_pid_alive')!r}"
        ]
    watchdog_alive_refs = _watchdog_alive_refs(prior_watchdog_report_refs)
    if should_dispatch and trigger in {"persistent_recurring_retry", "partial_liveness_recurrence"} and watchdog_alive_refs and not repair_goal_active:
        should_dispatch = False
        trigger = ""
        rationale = [
            "repeated watchdog reports already classified this session as alive, so stale recurring "
            f"repair sidecars do not prove an unhandled meta-repair dispatch gap (alive_refs={len(watchdog_alive_refs)})"
        ]
    failed_run_refs = [item for item in run_refs if item.get("launch_failure")]
    ordinary_retrigger_failure_refs = [
        item for item in run_refs if item.get("ordinary_retrigger_failed")
    ]
    trigger_rejection_refs = [
        item for item in run_refs if item.get("trigger_rejected")
    ]
    failed_meta_records = []
    recursion_guard_blocked = False
    for item in meta_refs or []:
        path = item.get("path") if isinstance(item, dict) else ""
        record = _load_json(pathlib.Path(str(path))) if path else {}
        if isinstance(record, dict) and (
            str(record.get("outcome") or "") == "NEEDS_HUMAN"
            and "recursion" in str(record.get("reason") or "").lower()
        ):
            recursion_guard_blocked = True
        if path and _meta_record_is_launch_failure(pathlib.Path(str(path))):
            failed_meta_records.append(item)
    return {
        "should_dispatch": should_dispatch,
        "trigger": trigger,
        "rationale": rationale,
        "repair_outcome": _redact_scalar(repair_outcome),
        "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
        "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
        "repair_goal": {
            "goal_id": _redact_scalar(repair_goal.get("goal_id") if isinstance(repair_goal, dict) else ""),
            "goal_path": _redact_scalar(repair_goal_path or ""),
            "status": _redact_scalar(repair_goal.get("status") if isinstance(repair_goal, dict) else ""),
            "owner_live": repair_goal_owner_live,
            "checkpoint_digest": _redact_scalar(repair_goal.get("checkpoint_digest") if isinstance(repair_goal, dict) else ""),
            "control_action": _redact_scalar(goal_control_action),
            "request_id": _redact_scalar(request_id),
            "request_target_mismatch": request_target_mismatch,
            "request_gate_recommendation": _redact_scalar(request_gate_recommendation),
            "repair_dispatch_during_preserve_live": repair_dispatch_during_preserve_live,
            "recovery_gate_failed": recovery_gate_failed,
            "recovery_gate": recovery_gate,
            "failed_fixer_evidence": failed_fixer_evidence,
        },
        "meta_record_count": len(meta_refs or []),
        "meta_run_log_count": len(run_refs),
        "meta_run_refs": run_refs,
        "failed_meta_run_count": len(failed_run_refs),
        "ordinary_retrigger_failure_count": len(ordinary_retrigger_failure_refs),
        "trigger_rejection_count": len(trigger_rejection_refs),
        "failed_meta_record_count": len(failed_meta_records),
        **({"recursion_guard_blocked": True} if recursion_guard_blocked else {}),
        "missing_meta_run_evidence": bool(should_dispatch and not meta_refs and not run_refs),
        "failed_meta_run_evidence": bool(should_dispatch and (failed_run_refs or failed_meta_records)),
    }

def _watchdog_alive_refs(refs):
    alive = []
    for item in refs or []:
        if not isinstance(item, dict):
            continue
        status = str(item.get("matched_status") or "").strip().lower()
        message = str(item.get("matched_message") or "").strip().lower()
        if status == "alive" or "session already alive" in message:
            alive.append(item)
    return alive

def _collect_watchdog_report_refs(session, plan, workspace):
    refs = []
    tokens = _match_tokens(session, plan, workspace.name)
    candidates = []
    if WATCHDOG_REPORT_PATH.exists():
        candidates.append(WATCHDOG_REPORT_PATH)
    if WATCHDOG_REPORT_ARCHIVE_DIR.exists():
        candidates.extend(sorted(WATCHDOG_REPORT_ARCHIVE_DIR.glob("*.json"), reverse=True)[:20])
    for path in candidates:
        payload = _load_json(path)
        if not isinstance(payload, dict):
            continue
        matched_items = []
        items = payload.get("items") if isinstance(payload.get("items"), list) else []
        issues = payload.get("issues") if isinstance(payload.get("issues"), list) else []
        for item in items + issues:
            if _watchdog_record_matches(item, session=session, plan=plan, workspace=workspace, tokens=tokens):
                matched_items.append(item)
        if matched_items:
            matched = matched_items[-1]
        elif _watchdog_record_matches(payload, session=session, plan=plan, workspace=workspace, tokens=tokens):
            matched = payload
        else:
            continue
        refs.append(
            {
                "report_id": _redact_scalar(path.stem),
                "path": _redact_scalar(path),
                "timestamp_utc": _redact_scalar(payload.get("timestamp_utc") or ""),
                "matched_status": _redact_scalar(matched.get("status") or matched.get("health") or ""),
                "matched_action": _redact_scalar(matched.get("action") or ""),
                "matched_message": _redact_scalar(matched.get("message") or matched.get("summary") or ""),
            }
        )
    return _bounded_refs(refs, key_fields=("report_id", "path"))

def _watchdog_record_matches(item, *, session, plan, workspace, tokens):
    if not isinstance(item, dict):
        return False
    session_text = str(session or "").strip()
    plan_text = str(plan or "").strip()
    workspace_text = str(workspace or "").strip()
    item_session = str(item.get("session") or "").strip()
    item_plan = str(item.get("plan") or item.get("current_plan_name") or "").strip()
    item_workspace = str(item.get("workspace") or "").strip()
    item_remote_spec = str(item.get("remote_spec") or "").strip()
    if session_text and item_session:
        return item_session == session_text
    if workspace_text and item_workspace and item_workspace == workspace_text:
        if plan_text and item_plan:
            return item_plan == plan_text
        return True
    if plan_text and item_plan:
        return item_plan == plan_text
    if item_session or item_plan or item_workspace or item_remote_spec:
        return False
    return _artifact_matches(item, tokens)


def _cached_external_ci_health(repair_summary, *, expected_pr_number=None):
    meta = repair_summary.get("meta_investigation_summary") if isinstance(repair_summary, dict) else {}
    meta = meta if isinstance(meta, dict) else {}
    access_path_text = str(meta.get("access_receipt_path") or "").strip()
    expected_context_digest = str(meta.get("context_digest") or "").strip()
    if not access_path_text:
        return _ci_health_unavailable("", reason="typed_external_cache_pointer_missing")
    access_path = pathlib.Path(access_path_text)
    bundle = _load_json(access_path)
    if (
        bundle.get("schema_version") != "arnold-meta-repair-observation-bundle-v1"
        or bundle.get("access_verified") is not True
        or not expected_context_digest
        or bundle.get("context_digest") != expected_context_digest
    ):
        return _ci_health_unavailable(
            "",
            reason="typed_external_cache_bundle_invalid",
            cache_source_path=str(access_path),
        )
    observation = next(
        (
            item
            for item in bundle.get("observations") or []
            if isinstance(item, dict) and item.get("kind") == "external_state"
        ),
        None,
    )
    if not isinstance(observation, dict):
        return _ci_health_unavailable(
            "",
            reason="typed_external_cache_observation_missing",
            cache_source_path=str(access_path),
        )
    artifact_path = pathlib.Path(str(observation.get("path") or ""))
    try:
        raw = artifact_path.read_bytes()
    except OSError:
        return _ci_health_unavailable(
            "",
            reason="typed_external_cache_artifact_unreadable",
            cache_source_path=str(access_path),
            artifact_path=str(artifact_path),
        )
    expected_size = observation.get("size_bytes")
    expected_sha = str(observation.get("sha256") or "").strip()
    if (
        not expected_sha
        or not isinstance(expected_size, int)
        or len(raw) != expected_size
        or hashlib.sha256(raw).hexdigest() != expected_sha
    ):
        return _ci_health_unavailable(
            "",
            reason="typed_external_cache_integrity_mismatch",
            cache_source_path=str(access_path),
            artifact_path=str(artifact_path),
        )
    try:
        payload = json.loads(raw)
    except ValueError:
        payload = {}
    pull_request = payload.get("pull_request") if isinstance(payload, dict) else {}
    pull_request = pull_request if isinstance(pull_request, dict) else {}
    observed_pr = pull_request.get("number")
    if (
        expected_pr_number not in (None, "")
        and str(observed_pr or "") != str(expected_pr_number)
    ):
        return _ci_health_unavailable(
            "",
            reason="typed_external_cache_pr_mismatch",
            expected_pr_number=expected_pr_number,
            pr_number=observed_pr,
            cache_source_path=str(access_path),
            artifact_path=str(artifact_path),
        )
    rollup = pull_request.get("statusCheckRollup")
    rollup = rollup if isinstance(rollup, list) else []
    failed = [
        item for item in rollup
        if isinstance(item, dict)
        and str(item.get("conclusion") or "").upper() not in {"", "SUCCESS", "NEUTRAL", "SKIPPED"}
    ]
    pending = [
        item for item in rollup
        if isinstance(item, dict)
        and str(item.get("status") or "").upper() not in {"", "COMPLETED"}
    ]
    status = "red" if failed else ("pending" if pending else "green")
    return {
        "status": status,
        "available": bool(payload.get("available") is True and observed_pr),
        "base_branch": pull_request.get("baseRefName") or "",
        "pr_number": observed_pr,
        "pr_state": pull_request.get("state") or "",
        "pr_head_oid": pull_request.get("headRefOid") or "",
        "merge_state": pull_request.get("mergeStateStatus") or "",
        "is_draft": pull_request.get("isDraft"),
        "failed_checks": failed,
        "pending_checks": pending,
        "checks": rollup,
        "evidence_source": "typed_l2_external_cache",
        "cache_source_path": str(access_path),
        "artifact_path": str(artifact_path),
        "artifact_sha256": expected_sha,
    }

def _candidate_engine_tree_roots(workspace_root, repo_root):
    candidates = [repo_root, workspace_root / ".megaplan" / "runtime" / "editable-engine"]
    deduped = []
    seen = set()
    for candidate in candidates:
        resolved = pathlib.Path(candidate).expanduser()
        key = str(resolved)
        if key in seen:
            continue
        seen.add(key)
        deduped.append(resolved)
    return deduped

def _collect_external_engine_tree(repo_root, workspace_root):
    if not repo_root.is_dir():
        return _engine_tree_unavailable(
            repo_root,
            workspace_root,
            reason="repo_context_unavailable",
        )
    try:
        payload = collect_engine_tree_evidence(
            repo_root,
            workspace_root=workspace_root,
            candidate_mirror_roots=_candidate_engine_tree_roots(workspace_root, repo_root),
        )
    except Exception as exc:
        return _engine_tree_unavailable(
            repo_root,
            workspace_root,
            reason="engine_tree_collection_failed",
            error=str(exc),
        )
    return _normalize_engine_tree_evidence(
        payload,
        repo_root=repo_root,
        workspace_root=workspace_root,
    )


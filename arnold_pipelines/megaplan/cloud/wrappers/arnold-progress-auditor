    user_action_context = _user_action_context(plan_dir, state)
    stale_state_evidence = _stale_state_evidence(
        plan_latest_failure,
        latest_failure,
        events_path,
        history,
        chain_log,
        chain_current,
        repair_data,
        run_kind,

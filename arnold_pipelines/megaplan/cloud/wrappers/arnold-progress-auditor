def _normalize_handoff(outcome, raw_handoff):
    allowed = {
        None,
        "immediate_repair.repair_attempt",
        "meta_repair.repair_attempt",
        "github_sync.publish",
        "six_hour_auditor.diagnosis",
    }
    if outcome == "auditor_human_escalation" or raw_handoff == "auditor_escalate_to_human":
        return None
    if raw_handoff in allowed:
        return raw_handoff
    if outcome == "recovered":
        return None
    return "six_hour_auditor.diagnosis"


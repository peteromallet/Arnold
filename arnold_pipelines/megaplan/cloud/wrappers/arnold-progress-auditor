import json
import subprocess
import sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud.github_sync import (
    GitHubSyncConfig,
    sync_persistent_problems,
)
from arnold_pipelines.megaplan.cloud.incident_bridge import (
    append_six_hour_auditor_audit_complete,
    append_six_hour_auditor_diagnosis,
)

findings_path = Path(sys.argv[1])
gather_dir = Path(sys.argv[2])
explicit_repo = sys.argv[3].strip()
explicit_repo_path = sys.argv[4].strip()

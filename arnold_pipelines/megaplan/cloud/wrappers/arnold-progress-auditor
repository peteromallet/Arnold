#!/usr/bin/env bash
# arnold-progress-auditor — periodic Codex-orchestrated DeepSeek-backed plan progress audit.
#
# Host-side systemd oneshot (megaplan-progress-audit.service, every 6h via
# megaplan-progress-audit.timer). When invoked on the host it docker-execs into
# the megaplan-cloud-agent container (mirroring ensure-megaplan-watchdog) and
# re-invokes itself there. When invoked inside the container it runs the audit.
#
# In-container loop:
#   * discover candidate workspaces/plans from markers, live tmux sessions, and
#     recent workspace activity inside the audit window
#   * gather the last AUDIT_WINDOW_HOURS (default 6h) of activity per plan
#     (plan_v*.md count/sizes, iteration/attempt progression, gate verdicts,
#     critique trend, events.ndjson growth, progress_stall flags from
#     /workspace/watchdog-report.json)
#   * for plans with suspicious signals, dispatch Codex as the top-level audit
#     orchestrator; Codex then reads the subagent-launcher skill and deploys
#     DeepSeek research subagents (provider=deepseek, model
#     deepseek:deepseek-v4-pro) via the existing subagent-launcher/megaplan
#     dispatch contract
#   * write /workspace/audit-reports/<ts>-audit.{json,md}, append one line to
#     /workspace/audit-report.log
#
# MODEL-JUDGED: for each suspicious plan, Codex subjectively decides whether
# the evidence is STALE state to clear, a GENUINE live non-critical deadlock to
# root-cause + fix + push to editible-install (the watchdog relaunches the
# chain), an INEFFICIENT cycling pattern, or PASSIVE/document-only. No
# hardcoded verdict rule.
set -uo pipefail

CONTAINER="${MEGAPLAN_CLOUD_CONTAINER:-megaplan-cloud-agent}"

# Inside-container detection: /workspace/arnold editable checkout only exists
# inside the container in this deployment.
if [[ ! -d /workspace/arnold ]]; then
  if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
    echo "arnold-progress-auditor: container_missing container=$CONTAINER" >&2
    exit 1
  fi
  exec docker exec \
    -e ARNOLD_AUTONOMY="${ARNOLD_AUTONOMY:-}" \
    -e ARNOLD_AUDIT_AUTOFIX_ENABLED="${ARNOLD_AUDIT_AUTOFIX_ENABLED:-}" \
    -e ARNOLD_AUDIT_AUTOFIX_COMMIT_ENABLED="${ARNOLD_AUDIT_AUTOFIX_COMMIT_ENABLED:-}" \
    -e ARNOLD_REPAIR_QUEUE_ROOT="${ARNOLD_REPAIR_QUEUE_ROOT:-/workspace/.megaplan/repair-queue}" \
    -e MEGAPLAN_AUDIT_WINDOW_HOURS="${MEGAPLAN_AUDIT_WINDOW_HOURS:-}" \
    "$CONTAINER" bash -lc '/usr/local/bin/arnold-progress-auditor "$@"' _ "$@"
fi

# Load the on-box source selection before the installed-wrapper trampoline.
# Otherwise the trampoline always re-execs /workspace/arnold and can silently
# discard a deployed corrective runtime selected by the watchdog hot env.
if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

# Keep the installed container entrypoint tiny and load-bearing only as a
# trampoline.  The editable checkout is the deployed recovery implementation
# and is what the watchdog already treats as its current source of truth.
AUDITOR_SOURCE_ROOT="${MEGAPLAN_AUDIT_ARNOLD_SRC:-${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}}"
SOURCE_AUDITOR="$AUDITOR_SOURCE_ROOT/arnold_pipelines/megaplan/cloud/wrappers/arnold-progress-auditor"
if [[ -x "$SOURCE_AUDITOR" ]]; then
  self_real="$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]:-$0}")"
  source_real="$(readlink -f "$SOURCE_AUDITOR" 2>/dev/null || printf '%s' "$SOURCE_AUDITOR")"
  if [[ "$self_real" != "$source_real" ]]; then
    exec "$SOURCE_AUDITOR" "$@"
  fi
fi

# ---- in-container audit -----------------------------------------------------

WRAPPER_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../../../.." && pwd)"

MARKER_DIR="${MEGAPLAN_AUDIT_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
REPAIR_DATA_DIR="${MEGAPLAN_AUDIT_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
export MEGAPLAN_AUDIT_REPAIR_DATA_DIR="$REPAIR_DATA_DIR"
REPAIR_QUEUE_ROOT="${ARNOLD_REPAIR_QUEUE_ROOT:-/workspace/.megaplan/repair-queue}"
export ARNOLD_REPAIR_QUEUE_ROOT="$REPAIR_QUEUE_ROOT"
REPORT_DIR="${MEGAPLAN_AUDIT_REPORT_DIR:-/workspace/audit-reports}"
REPORT_LOG="${MEGAPLAN_AUDIT_REPORT_LOG:-/workspace/audit-report.log}"
WATCHDOG_REPORT="${MEGAPLAN_AUDIT_WATCHDOG_REPORT:-/workspace/watchdog-report.json}"
ARNOLD_SRC="${MEGAPLAN_AUDIT_ARNOLD_SRC:-${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}}"
DISCOVER_BIN="${MEGAPLAN_AUDIT_DISCOVER_BIN:-$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-cloud-discover}"
LAUNCHER="${MEGAPLAN_AUDIT_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
AUDIT_WINDOW_HOURS="${MEGAPLAN_AUDIT_WINDOW_HOURS:-6}"
SUBAGENT_TIMEOUT="${MEGAPLAN_AUDIT_SUBAGENT_TIMEOUT_SECS:-900}"
SUBAGENT_MAX_TOKENS="${MEGAPLAN_AUDIT_SUBAGENT_MAX_TOKENS:-8192}"
SUBAGENT_PROFILE="${MEGAPLAN_AUDIT_SUBAGENT_PROFILE:-partnered-5}"
DEEPSEEK_MODEL="${MEGAPLAN_AUDIT_MODEL:-deepseek:deepseek-v4-pro}"
AUDIT_CODEX_MODEL="gpt-5.6-sol"
CODEX_TIMEOUT="${MEGAPLAN_AUDIT_CODEX_TIMEOUT_SECS:-1800}"
SUBAGENT_SKILL="${MEGAPLAN_AUDIT_SUBAGENT_SKILL:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/subagent-launcher/SKILL.md}"
AUDIT_GITHUB_REPO="${MEGAPLAN_AUDIT_GITHUB_REPO:-}"
AUDIT_GITHUB_REPO_PATH="${MEGAPLAN_AUDIT_GITHUB_REPO_PATH:-}"
AUDIT_GITHUB_LABELS="${MEGAPLAN_AUDIT_GITHUB_LABELS:-incident-control-plane,persistent-problem}"
RECOVERY_ENABLED="${MEGAPLAN_AUDIT_RECOVERY_ENABLED:-1}"
RECOVERY_SYNC_ENABLED="${MEGAPLAN_AUDIT_RECOVERY_SYNC_ENABLED:-0}"
WATCHDOG_BIN="${MEGAPLAN_AUDIT_WATCHDOG_BIN:-$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-watchdog}"

# Legacy direct DeepSeek launcher contract retained here for watchdog contract
# tests and operator reference:
# timeout "$SUBAGENT_TIMEOUT" python3 "$LAUNCHER" \
#   --toolsets="file,web" \
#   --model="$DEEPSEEK_MODEL" \
#   --max-tokens="$SUBAGENT_MAX_TOKENS" \
#   --query-file="$brief" \
#   --project-dir="$workspace"

mkdir -p "$REPORT_DIR" "$(dirname "$REPORT_LOG")"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
JSON_OUT="$REPORT_DIR/${TS}-audit.json"
MD_OUT="$REPORT_DIR/${TS}-audit.md"
WORKLIST="$(mktemp)"
GATHER_DIR="$(mktemp -d)"
RECOVERY_EVIDENCE="$GATHER_DIR/recovery-sweep.json"
trap 'rm -rf "$WORKLIST" "$GATHER_DIR"' EXIT

log() {
  local message
  message="$(redact_inline_text "$*")"
  echo "[progress-auditor $(date -Iseconds)] $message"
}

redact_inline_text() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$1" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

print(redact_text(sys.argv[1]), end="")
PY
}

redact_file_in_place() {
  local path="${1:-}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$path" <<'PY'
from pathlib import Path
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

path = Path(sys.argv[1])
path.write_text(redact_text(path.read_text(encoding="utf-8")), encoding="utf-8")
PY
}

audit_flag_enabled() {
  local function_name="${1:-}"
  if [[ -z "$function_name" ]]; then
    echo 0
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$function_name" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud import feature_flags

name = sys.argv[1]
fn = getattr(feature_flags, name, None)
if fn is None:
    print("0")
    raise SystemExit(0)
print("1" if bool(fn()) else "0")
PY
}

autofix_allowed_targets_markdown() {
  cat <<'EOF'
- No mutation targets. The six-hour auditor is an evaluator only.
- Findings must be handed to the validated central repair-request queue.
EOF
}

autofix_policy_markdown() {
  cat <<'EOF'
Auditor authority: READ-ONLY EVALUATOR.
- Do not edit source, run state, plan state, repair data, or project files.
- Do not apply patches, create claims, launch repair agents, commit, or push.
- Return evidence and a recommendation. The wrapper routes unhealthy findings
  through the validated central repair-request authority.
EOF
}

AUDIT_AUTOFIX_ENABLED_FLAG="$(audit_flag_enabled audit_autofix_enabled)"
AUDIT_MUTATION_AUTHORIZED_FLAG="$(audit_flag_enabled audit_autofix_mutation_authorized)"
AUDIT_AUTOFIX_COMMIT_ENABLED_FLAG="$(audit_flag_enabled audit_autofix_commit_enabled)"
AUDIT_LAUNCH_ATTEMPTED=0
export ARNOLD_META_REPAIR_ENABLED="${ARNOLD_META_REPAIR_ENABLED:-1}"
export ARNOLD_META_REPAIR_COMMIT_ENABLED="${ARNOLD_META_REPAIR_COMMIT_ENABLED:-1}"

reject_conflicting_audit_model_pins() {
  local name value
  for name in CODEX_MODEL MEGAPLAN_AUDIT_CODEX_MODEL CLOUD_WATCHDOG_CODEX_MODEL; do
    value="${!name:-}"
    if [[ -n "$value" && "$value" != "$AUDIT_CODEX_MODEL" ]]; then
      log "six-hour auditor model pin conflict: $name=$value required=$AUDIT_CODEX_MODEL"
      return 1
    fi
  done
}

if ! reject_conflicting_audit_model_pins; then
  exit 78
fi

capture_recovery_snapshot() {
  local output_path="$1"
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$output_path" <<'PY'
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.status_snapshot import build_cloud_status_snapshot

path = pathlib.Path(sys.argv[1])
path.write_text(json.dumps(build_cloud_status_snapshot(), indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

assemble_recovery_evidence() {
  local before_path="$1" after_path="$2" watchdog_rc="$3" enabled="$4"
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - \
    "$before_path" "$after_path" "$WATCHDOG_REPORT" "$RECOVERY_EVIDENCE" \
    "$watchdog_rc" "$enabled" "$AUDIT_CODEX_MODEL" <<'PY'
import datetime as dt
import json
import pathlib
import re
import sys

before_path, after_path, report_path, output_path, watchdog_rc, enabled, codex_model = sys.argv[1:]


def load(path: str) -> dict:
    try:
        value = json.loads(pathlib.Path(path).read_text(encoding="utf-8"))
    except Exception:
        return {}
    return value if isinstance(value, dict) else {}


before = load(before_path)
after = load(after_path)
report = load(report_path)
report_items: dict[str, list[dict]] = {}
for item in report.get("items") or []:
    if not isinstance(item, dict):
        continue
    session = str(item.get("session") or "")
    if session:
        report_items.setdefault(session, []).append(item)

provider_pattern = re.compile(
    r"usage[ _-]?limit|rate[ _-]?limit|capacity|quota|credit balance|"
    r"authentication|authorization|credential|login required|token expired",
    re.IGNORECASE,
)
decisions = []
for session_entry in after.get("sessions") or []:
    if not isinstance(session_entry, dict):
        continue
    session = str(session_entry.get("session") or "")
    workspace = pathlib.Path(str(session_entry.get("workspace") or ""))
    current_plan = str(session_entry.get("current_plan") or "")
    state_path = workspace / ".megaplan" / "plans" / current_plan / "state.json"
    state = load(str(state_path)) if current_plan else {}
    current_state = str(state.get("current_state") or "").strip().lower()
    latest_failure = state.get("latest_failure") if isinstance(state.get("latest_failure"), dict) else {}
    failure_kind = str(latest_failure.get("kind") or "")
    failure_text = " ".join(
        str(latest_failure.get(key) or "") for key in ("kind", "message", "phase")
    )
    provider_failure = bool(provider_pattern.search(failure_text))
    items = report_items.get(session, [])
    statuses = [str(item.get("status") or "") for item in items]
    evidence = session_entry.get("evidence") if isinstance(session_entry.get("evidence"), dict) else {}
    superseded_by = evidence.get("superseded_by")
    status = str(session_entry.get("status") or "")
    live = bool(session_entry.get("tmux") or session_entry.get("process"))
    should_run = bool(session_entry.get("should_run"))
    advancement = session_entry.get("advancement") if isinstance(session_entry.get("advancement"), dict) else {}
    advancement_action = str(advancement.get("action") or "")
    advancement_automatic = bool(advancement.get("automatic"))

    if superseded_by:
        disposition = "superseded"
        decision = "skip_superseded"
    elif status == "complete":
        disposition = "completed"
        decision = "skip_completed"
    elif current_state == "paused" or "paused" in statuses:
        disposition = "paused"
        decision = "skip_paused"
        should_run = False
    elif advancement_action == "await_human" or status == "blocked":
        disposition = "human_gated"
        decision = "await_human"
        should_run = False
    elif live:
        disposition = "running"
        decision = "preserve_live_no_duplicate"
    elif "restarted" in statuses:
        disposition = "eligible_missing_runner"
        decision = "relaunched"
    elif any(value in statuses for value in ("repair_dispatched", "repair_running")):
        disposition = "genuinely_failed"
        decision = "repair_dispatched"
    elif provider_failure and "provider_retry_selected" in statuses:
        disposition = "provider_transient_failure"
        decision = "provider_retry_selected"
    elif should_run and (latest_failure or "failed" in str(session_entry.get("operator_next") or "")):
        disposition = "genuinely_failed"
        decision = "eligible_but_not_recovered"
    elif should_run and advancement_automatic:
        disposition = "eligible_missing_runner"
        decision = advancement_action or "eligible_but_not_recovered"
    elif should_run:
        disposition = "eligible_missing_runner"
        decision = "eligible_but_not_recovered"
    else:
        disposition = "inactive"
        decision = "skip_inactive"

    decisions.append(
        {
            "session": session,
            "status_after": status,
            "should_run": should_run,
            "live_after": live,
            "disposition": disposition,
            "decision": decision,
            "provider_transient_failure": provider_failure,
            "failure_kind": failure_kind,
            "advancement": advancement,
            "watchdog_statuses": statuses,
            "evidence": {
                "marker": evidence.get("marker"),
                "plan_state": str(state_path) if current_plan else None,
                "watchdog_report": report_path,
                "superseded_by": superseded_by,
            },
        }
    )

payload = {
    "schema_version": 1,
    "timestamp_utc": dt.datetime.now(dt.timezone.utc).isoformat(),
    "enabled": enabled.strip().lower() not in {"0", "false", "no", "off"},
    "watchdog_exit_code": int(watchdog_rc),
    "watchdog_report_timestamp": report.get("timestamp_utc"),
    "before_generated_at": before.get("generated_at"),
    "after_generated_at": after.get("generated_at"),
    "sessions_discovered": len(decisions),
    "should_run_count": sum(1 for item in decisions if item["should_run"]),
    "codex_model": codex_model,
    "decisions": decisions,
}
pathlib.Path(output_path).write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

run_recovery_sweep() {
  local before_path="$GATHER_DIR/recovery-before.json"
  local after_path="$GATHER_DIR/recovery-after.json"
  local watchdog_rc=0
  capture_recovery_snapshot "$before_path"
  case "${RECOVERY_ENABLED,,}" in
    0|false|no|off)
      log "recovery sweep disabled by MEGAPLAN_AUDIT_RECOVERY_ENABLED"
      ;;
    *)
      if [[ ! -x "$WATCHDOG_BIN" ]]; then
        log "recovery sweep unavailable; watchdog binary missing path=$WATCHDOG_BIN"
        watchdog_rc=127
      else
        log "recovery sweep starting watchdog=$WATCHDOG_BIN provider_retry_once=1"
        CLOUD_WATCHDOG_SYNC_ENABLED="$RECOVERY_SYNC_ENABLED" \
        CLOUD_WATCHDOG_PROVIDER_RETRY_ONCE=1 \
          "$WATCHDOG_BIN" --audit-sweep || watchdog_rc=$?
        log "recovery sweep finished watchdog_exit_code=$watchdog_rc"
      fi
      ;;
  esac
  capture_recovery_snapshot "$after_path"
  assemble_recovery_evidence "$before_path" "$after_path" "$watchdog_rc" "$RECOVERY_ENABLED"
}

run_recovery_sweep

# Build the plan worklist from marker, tmux, and workspace-activity discovery.
python3 - "$MARKER_DIR" "$WORKLIST" "$AUDIT_WINDOW_HOURS" "$DISCOVER_BIN" "/workspace" "$ARNOLD_SRC" <<'PY'
import datetime as dt
import json
import os
import pathlib
import subprocess
import sys

marker_dir, out, window_h, discover_bin, workspace_root, arnold_src = sys.argv[1:7]
window = float(window_h)
cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(hours=window)
workspace_root_path = pathlib.Path(workspace_root)
arnold_src_path = pathlib.Path(arnold_src).resolve()


def _recent_mtime(path: pathlib.Path) -> bool:
    try:
        return dt.datetime.fromtimestamp(path.stat().st_mtime, tz=dt.timezone.utc) >= cutoff
    except OSError:
        return False


def _plan_dirs(workspace: pathlib.Path) -> list[pathlib.Path]:
    plans_root = workspace / ".megaplan" / "plans"
    try:
        if not plans_root.is_dir():
            return []
        return sorted(p for p in plans_root.iterdir() if p.is_dir())
    except OSError:
        return []


def _merge(
    entries: dict[tuple[str, str], dict],
    workspace: pathlib.Path,
    plan_dir: pathlib.Path,
    session: str,
    source: str,
    updated: str = "",
    marker_path: pathlib.Path | None = None,
    marker_payload: dict | None = None,
) -> None:
    key = (str(workspace), plan_dir.name)
    entry = entries.setdefault(
        key,
        {
            "workspace": str(workspace),
            "plan": plan_dir.name,
            "session": session or workspace.name,
            "updated": updated,
            "sources": [],
        },
    )
    if not entry.get("session") and session:
        entry["session"] = session
    if updated and not entry.get("updated"):
        entry["updated"] = updated
    if source not in entry["sources"]:
        entry["sources"].append(source)
    if marker_path is not None and not entry.get("marker_path"):
        entry["marker_path"] = str(marker_path)
    if marker_payload:
        for source_key, dest_key in (
            ("kind", "kind"),
            ("run_kind", "kind"),
            ("remote_spec", "remote_spec"),
            ("spec", "remote_spec"),
            ("launch_command", "launch_command"),
            ("log", "log"),
            ("created_at", "created_at"),
            ("started_at", "started_at"),
            ("updated_at", "updated_at"),
            ("plan_name", "plan_name"),
        ):
            value = marker_payload.get(source_key)
            if value and not entry.get(dest_key):
                entry[dest_key] = value


entries: dict[tuple[str, str], dict] = {}

# (a) Marker-discovered workspaces.
for marker_path in sorted(pathlib.Path(marker_dir).glob("*.json")):
    try:
        payload = json.loads(marker_path.read_text(encoding="utf-8"))
    except Exception:
        continue
    workspace_raw = payload.get("workspace") or payload.get("workspace_dir")
    if not workspace_raw:
        continue
    workspace = pathlib.Path(workspace_raw)
    if not workspace.is_dir():
        continue
    session = payload.get("session") or marker_path.stem
    updated = payload.get("updated_at") or payload.get("created_at") or ""
    marker_run_kind = str(payload.get("run_kind") or payload.get("kind") or "").strip().lower()
    marker_plan_name = str(payload.get("plan_name") or "").strip()
    if marker_run_kind == "plan" and marker_plan_name:
        marker_plan_dir = workspace / ".megaplan" / "plans" / marker_plan_name
        plan_dirs = [marker_plan_dir] if marker_plan_dir.is_dir() else []
    else:
        plan_dirs = _plan_dirs(workspace)
    for plan_dir in plan_dirs:
        _merge(entries, workspace, plan_dir, session, "marker", updated, marker_path, payload)

# (b) Tmux-discovered live marker-less workspaces.
try:
    discover_proc = subprocess.run(
        ["bash", discover_bin, "tmux-unmarked", "--marker-dir", marker_dir, "--src-dir", arnold_src],
        text=True,
        capture_output=True,
        check=False,
    )
except OSError:
    discover_proc = None

if discover_proc and discover_proc.returncode == 0:
    for raw in discover_proc.stdout.splitlines():
        if not raw.strip():
            continue
        try:
            session, workspace_raw, _remote_spec, _run_kind, _plan_name, _relaunch_command = raw.split("\t", 5)
        except ValueError:
            continue
        workspace = pathlib.Path(workspace_raw)
        if not workspace.is_dir():
            continue
        if _run_kind == "plan" and _plan_name:
            marker_plan_dir = workspace / ".megaplan" / "plans" / _plan_name
            plan_dirs = [marker_plan_dir] if marker_plan_dir.is_dir() else []
        else:
            plan_dirs = _plan_dirs(workspace)
        for plan_dir in plan_dirs:
            _merge(entries, workspace, plan_dir, session, "tmux")

# (c) Workspace-activity-discovered plans with recent state/events.
try:
    workspace_children = sorted(workspace_root_path.iterdir())
except OSError:
    workspace_children = []

for workspace in workspace_children:
    try:
        resolved = workspace.resolve()
    except OSError:
        continue
    if not workspace.is_dir() or workspace.name.startswith("."):
        continue
    if resolved == arnold_src_path:
        continue
    plans = _plan_dirs(workspace)
    if not plans:
        continue
    for plan_dir in plans:
        state_path = plan_dir / "state.json"
        events_path = plan_dir / "events.ndjson"
        if _recent_mtime(state_path) or _recent_mtime(events_path):
            _merge(entries, workspace, plan_dir, workspace.name, "workspace_activity")

with open(out, "w", encoding="utf-8") as handle:
    for entry in sorted(entries.values(), key=lambda item: (item["workspace"], item["plan"])):
        handle.write(json.dumps(entry, sort_keys=True) + "\n")
PY

log "auditing plans=$(wc -l < "$WORKLIST" | tr -d ' ') window_hours=$AUDIT_WINDOW_HOURS"

# Collect the watchdog progress_stall flags so the auditor can cite them.
stall_summary="none"
if [[ -f "$WATCHDOG_REPORT" ]]; then
  stall_summary="$(python3 - "$WATCHDOG_REPORT" <<'PY'
import json, sys
try:
    rep = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    print("unreadable"); raise SystemExit(0)
issues = rep.get("issues") or []
stalls = [i for i in issues if i.get("status") == "progress_stall"]
if not stalls:
    print("none"); raise SystemExit(0)
msgs = [i.get("message", "")[:200] for i in stalls]
print(" ; ".join(msgs))
PY
)"

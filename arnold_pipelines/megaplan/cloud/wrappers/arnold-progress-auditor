        session,
        workspace_root=workspace_path,
        repo_root=repo_root,
    )
    resolver_state = _resolve_resolver_state_payload(current_target)
    repair_custody = _repair_custody_summary(session, state, current_target)
    ci_health = _collect_external_ci_health(repo_root)
    engine_tree = _collect_external_engine_tree(repo_root, workspace_path)
    projection_input = audit_input.get("projection_input") if isinstance(audit_input.get("projection_input"), dict) else {}
    projection_input = {
        **projection_input,
        "brief": incident_brief,
        "incident": incident_projection,
        "problem": problem_projection,
        "current_target": current_target,
        "resolver_state": resolver_state,
        "ci_health": ci_health,

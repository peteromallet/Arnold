def _normalize_handoff(outcome, raw_handoff):
    allowed = {
        None,
        "immediate_repair.repair_attempt",
        "meta_repair.repair_attempt",
        "github_sync.publish",
        "six_hour_auditor.diagnosis",
    }
    if raw_handoff in allowed:
        return raw_handoff
    if outcome == "recovered":
        return None
    return "six_hour_auditor.diagnosis"

def _issue_repo_for_workspace(workspace):
    workspace_path = Path(workspace)
    repo_path = Path(explicit_repo_path) if explicit_repo_path else workspace_path
    if explicit_repo:
        return explicit_repo, repo_path
    try:
        proc = subprocess.run(
            ["git", "-C", str(repo_path), "remote", "get-url", "origin"],
            check=False,
            capture_output=True,
            text=True,
        )
    except OSError:
        return None, repo_path
    if proc.returncode != 0:
        return None, repo_path
    raw = proc.stdout.strip()
    if raw.startswith("git@github.com:"):
        raw = raw.split(":", 1)[1]
    elif "github.com/" in raw:
        raw = raw.split("github.com/", 1)[1]
    raw = raw.removesuffix(".git").strip("/")
    if raw.count("/") != 1:
        return None, repo_path
    return raw, repo_path

def _event_evidence(item):
    source_refs = item.get("source_refs") if isinstance(item.get("source_refs"), dict) else {}
    incident_brief = item.get("incident_brief") if isinstance(item.get("incident_brief"), dict) else {}
    evidence = [
        {
            "kind": "incident_summary",
            "path": source_refs.get("incident_summary_path"),
            "session_id": item.get("session"),
        },
        {
            "kind": "problem_summary",
            "path": source_refs.get("problem_summary_path"),
            "session_id": item.get("session"),
        },
    ]
    for key in ("audit_report_paths", "watchdog_report_paths", "meta_record_paths", "attempt_paths"):
        for path in source_refs.get(key) or []:
            evidence.append({"kind": key.rstrip("s"), "path": path, "session_id": item.get("session")})
    last_timestamp = incident_brief.get("last_timestamp")
    if last_timestamp:
        evidence.append({"kind": "incident_brief", "session_id": item.get("session"), "status": last_timestamp})
    return [entry for entry in evidence if entry.get("path") or entry.get("status")]

audited = {}
workspaces_for_sync = {}
for item in findings + green_checks:
    if not isinstance(item, dict):
        continue
    incident_audit = item.get("incident_audit") if isinstance(item.get("incident_audit"), dict) else {}
    incident_brief = item.get("incident_brief") if isinstance(item.get("incident_brief"), dict) else {}
    incident_projection = item.get("incident_projection") if isinstance(item.get("incident_projection"), dict) else {}
    problem_projection = item.get("problem_projection") if isinstance(item.get("problem_projection"), dict) else {}
    incident_id = incident_audit.get("incident_id") or incident_brief.get("incident_id")
    workspace = item.get("workspace")
    if not incident_id or not workspace:
        continue
    key = (workspace, incident_id)
    if key in audited:
        continue
    audited[key] = True
    session_id = item.get("session")
    problem_id = incident_audit.get("problem_id") or problem_projection.get("problem_id")
    diagnosis = incident_audit.get("diagnosis") if isinstance(incident_audit.get("diagnosis"), dict) else {}
    audit_complete = incident_audit.get("audit_complete") if isinstance(incident_audit.get("audit_complete"), dict) else {}
    raw_handoff = audit_complete.get("next_expected_event") or incident_audit.get("next_expected_event")
    normalized_handoff = _normalize_handoff(audit_complete.get("outcome"), raw_handoff)
    decision = {
        "reconciler_findings": incident_audit.get("findings") or [],
        "reconciler_next_expected_event": raw_handoff,
        "hypothesis": item.get("hypothesis") or "",
        "corroboration": item.get("corroboration") or [],
    }
    links = {
        "incident_summary": (item.get("source_refs") or {}).get("incident_summary_path"),
        "problem_summary": (item.get("source_refs") or {}).get("problem_summary_path"),
    }
    diagnosis_event = append_six_hour_auditor_diagnosis(
        incident_id=incident_id,
        summary=diagnosis.get("summary") or incident_brief.get("summary") or f"Reconciled incident {incident_id}",
        evidence=_event_evidence(item),
        session_id=session_id,
        problem_id=problem_id,
        deadline_ts=incident_brief.get("deadline_ts"),
        next_expected_event="six_hour_auditor.audit_complete",
        decision=decision,
        links=links,
        root=workspace,
    )
    append_six_hour_auditor_audit_complete(
        incident_id=incident_id,
        summary=audit_complete.get("summary") or diagnosis.get("summary") or f"Audit cycle recorded for {incident_id}",
        outcome=audit_complete.get("outcome") or "audit_cycle_complete",
        evidence=_event_evidence(item),
        session_id=session_id,
        problem_id=problem_id,
        parent_event_ids=[diagnosis_event["payload"]["event_id"]],
        deadline_ts=incident_brief.get("deadline_ts"),
        next_expected_event=normalized_handoff,
        decision=decision,
        links=links,
        root=workspace,
    )
    if raw_handoff == "github_sync.publish":
        workspaces_for_sync[workspace] = True

for workspace in sorted(workspaces_for_sync):
    repo, repo_path = _issue_repo_for_workspace(workspace)

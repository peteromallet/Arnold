def _seed_human_escalation_payload(item, incident_id, session_id, repair_payload):
    payload = dict(repair_payload) if isinstance(repair_payload, dict) else {}
    payload.setdefault("schema_version", 1)
    payload.setdefault("session", session_id)
    payload.setdefault("workspace", item.get("workspace") or "")
    payload.setdefault("run_kind", ((item.get("session_header") or {}).get("kind") or "chain"))
    payload.setdefault("spec", ((item.get("session_header") or {}).get("remote_spec") or ""))
    payload.setdefault("plan_name", item.get("plan") or "")
    payload.setdefault("incident_id", incident_id)
    target = payload.get("target") if isinstance(payload.get("target"), dict) else {}
    current_refs = target.get("current_refs") if isinstance(target.get("current_refs"), dict) else {}
    if item.get("plan"):
        current_refs.setdefault("current_plan_name", item.get("plan"))
    if current_refs:
        target["current_refs"] = current_refs
    target.setdefault("authoritative_source", "six_hour_auditor")
    payload["target"] = target
    iterations = payload.get("iterations")
    if not isinstance(iterations, list) or not iterations:
        incident_audit = item.get("incident_audit") if isinstance(item.get("incident_audit"), dict) else {}
        diagnosis = incident_audit.get("diagnosis") if isinstance(incident_audit.get("diagnosis"), dict) else {}
        audit_complete = incident_audit.get("audit_complete") if isinstance(incident_audit.get("audit_complete"), dict) else {}
        payload["iterations"] = [
            {
                "i": "l3-auditor",
                "mechanical_launch": "auditor_human_escalation",
                "why": audit_complete.get("summary")
                or diagnosis.get("summary")

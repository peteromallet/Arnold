#!/usr/bin/env bash
# arnold-progress-auditor — periodic Codex-orchestrated DeepSeek-backed plan progress audit.
#
# Host-side systemd oneshot (megaplan-progress-audit.service, every 6h via
# megaplan-progress-audit.timer). When invoked on the host it docker-execs into
# the megaplan-cloud-agent container (mirroring ensure-megaplan-watchdog) and
# re-invokes itself there. When invoked inside the container it runs the audit.
#
# In-container loop:
#   * discover candidate workspaces/plans from markers, live tmux sessions, and
#     recent workspace activity inside the audit window
#   * gather the last AUDIT_WINDOW_HOURS (default 6h) of activity per plan
#     (plan_v*.md count/sizes, iteration/attempt progression, gate verdicts,
#     critique trend, events.ndjson growth, progress_stall flags from
#     /workspace/watchdog-report.json)
#   * for plans with suspicious signals, dispatch Codex as the top-level audit
#     orchestrator; Codex then reads the subagent-launcher skill and deploys
#     DeepSeek research subagents (provider=deepseek, model
#     deepseek:deepseek-v4-pro) via the existing subagent-launcher/megaplan
#     dispatch contract
#   * write /workspace/audit-reports/<ts>-audit.{json,md}, append one line to
#     /workspace/audit-report.log
#
# MODEL-JUDGED: for each suspicious plan, Codex subjectively decides whether it's
# a GENUINE non-critical deadlock (stuck looping/retrying) -> root-cause + fix +
# push to editible-install (the watchdog relaunches the chain), or PASSIVE ->
# document only. No hardcoded fix-vs-report rule.
set -uo pipefail

CONTAINER="${MEGAPLAN_CLOUD_CONTAINER:-megaplan-cloud-agent}"

# Inside-container detection: /workspace/arnold editable checkout only exists
# inside the container in this deployment.
if [[ ! -d /workspace/arnold ]]; then
  if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
    echo "arnold-progress-auditor: container_missing container=$CONTAINER" >&2
    exit 1
  fi
  exec docker exec "$CONTAINER" bash -lc '/usr/local/bin/arnold-progress-auditor "$@"' _ "$@"
fi

# ---- in-container audit -----------------------------------------------------

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

MARKER_DIR="${MEGAPLAN_AUDIT_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
REPAIR_DATA_DIR="${MEGAPLAN_AUDIT_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
export MEGAPLAN_AUDIT_REPAIR_DATA_DIR="$REPAIR_DATA_DIR"
REPORT_DIR="${MEGAPLAN_AUDIT_REPORT_DIR:-/workspace/audit-reports}"
REPORT_LOG="${MEGAPLAN_AUDIT_REPORT_LOG:-/workspace/audit-report.log}"
WATCHDOG_REPORT="${MEGAPLAN_AUDIT_WATCHDOG_REPORT:-/workspace/watchdog-report.json}"
ARNOLD_SRC="${MEGAPLAN_AUDIT_ARNOLD_SRC:-/workspace/arnold}"
DISCOVER_BIN="${MEGAPLAN_AUDIT_DISCOVER_BIN:-$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-cloud-discover}"
LAUNCHER="${MEGAPLAN_AUDIT_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
AUDIT_WINDOW_HOURS="${MEGAPLAN_AUDIT_WINDOW_HOURS:-6}"
SUBAGENT_TIMEOUT="${MEGAPLAN_AUDIT_SUBAGENT_TIMEOUT_SECS:-900}"
SUBAGENT_MAX_TOKENS="${MEGAPLAN_AUDIT_SUBAGENT_MAX_TOKENS:-8192}"
SUBAGENT_PROFILE="${MEGAPLAN_AUDIT_SUBAGENT_PROFILE:-partnered-5}"
DEEPSEEK_MODEL="${MEGAPLAN_AUDIT_MODEL:-deepseek:deepseek-v4-pro}"
CODEX_TIMEOUT="${MEGAPLAN_AUDIT_CODEX_TIMEOUT_SECS:-1800}"
SUBAGENT_SKILL="${MEGAPLAN_AUDIT_SUBAGENT_SKILL:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/subagent-launcher/SKILL.md}"

# Legacy direct DeepSeek launcher contract retained here for watchdog contract
# tests and operator reference:
# timeout "$SUBAGENT_TIMEOUT" python3 "$LAUNCHER" \
#   --toolsets="file,web" \
#   --model="$DEEPSEEK_MODEL" \
#   --max-tokens="$SUBAGENT_MAX_TOKENS" \
#   --query-file="$brief" \
#   --project-dir="$workspace"

mkdir -p "$REPORT_DIR" "$(dirname "$REPORT_LOG")"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
JSON_OUT="$REPORT_DIR/${TS}-audit.json"
MD_OUT="$REPORT_DIR/${TS}-audit.md"
WORKLIST="$(mktemp)"
GATHER_DIR="$(mktemp -d)"
trap 'rm -rf "$WORKLIST" "$GATHER_DIR"' EXIT

log() {
  echo "[progress-auditor $(date -Iseconds)] $*"
}

# Build the plan worklist from marker, tmux, and workspace-activity discovery.
python3 - "$MARKER_DIR" "$WORKLIST" "$AUDIT_WINDOW_HOURS" "$DISCOVER_BIN" "/workspace" "$ARNOLD_SRC" <<'PY'
import datetime as dt
import json
import os
import pathlib
import subprocess
import sys

marker_dir, out, window_h, discover_bin, workspace_root, arnold_src = sys.argv[1:7]
window = float(window_h)
cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(hours=window)
workspace_root_path = pathlib.Path(workspace_root)
arnold_src_path = pathlib.Path(arnold_src).resolve()


def _recent_mtime(path: pathlib.Path) -> bool:
    try:
        return dt.datetime.fromtimestamp(path.stat().st_mtime, tz=dt.timezone.utc) >= cutoff
    except OSError:
        return False


def _plan_dirs(workspace: pathlib.Path) -> list[pathlib.Path]:
    plans_root = workspace / ".megaplan" / "plans"
    try:
        if not plans_root.is_dir():
            return []
        return sorted(p for p in plans_root.iterdir() if p.is_dir())
    except OSError:
        return []


def _merge(
    entries: dict[tuple[str, str], dict],
    workspace: pathlib.Path,
    plan_dir: pathlib.Path,
    session: str,
    source: str,
    updated: str = "",
    marker_path: pathlib.Path | None = None,
    marker_payload: dict | None = None,
) -> None:
    key = (str(workspace), plan_dir.name)
    entry = entries.setdefault(
        key,
        {
            "workspace": str(workspace),
            "plan": plan_dir.name,
            "session": session or workspace.name,
            "updated": updated,
            "sources": [],
        },
    )
    if not entry.get("session") and session:
        entry["session"] = session
    if updated and not entry.get("updated"):
        entry["updated"] = updated
    if source not in entry["sources"]:
        entry["sources"].append(source)
    if marker_path is not None and not entry.get("marker_path"):
        entry["marker_path"] = str(marker_path)
    if marker_payload:
        for source_key, dest_key in (
            ("kind", "kind"),
            ("run_kind", "kind"),
            ("remote_spec", "remote_spec"),
            ("spec", "remote_spec"),
            ("launch_command", "launch_command"),
            ("log", "log"),
            ("created_at", "created_at"),
            ("started_at", "started_at"),
            ("updated_at", "updated_at"),
        ):
            value = marker_payload.get(source_key)
            if value and not entry.get(dest_key):
                entry[dest_key] = value


entries: dict[tuple[str, str], dict] = {}

# (a) Marker-discovered workspaces.
for marker_path in sorted(pathlib.Path(marker_dir).glob("*.json")):
    try:
        payload = json.loads(marker_path.read_text(encoding="utf-8"))
    except Exception:
        continue
    workspace_raw = payload.get("workspace") or payload.get("workspace_dir")
    if not workspace_raw:
        continue
    workspace = pathlib.Path(workspace_raw)
    if not workspace.is_dir():
        continue
    session = payload.get("session") or marker_path.stem
    updated = payload.get("updated_at") or payload.get("created_at") or ""
    for plan_dir in _plan_dirs(workspace):
        _merge(entries, workspace, plan_dir, session, "marker", updated, marker_path, payload)

# (b) Tmux-discovered live marker-less workspaces.
try:
    discover_proc = subprocess.run(
        ["bash", discover_bin, "tmux-unmarked", "--marker-dir", marker_dir, "--src-dir", arnold_src],
        text=True,
        capture_output=True,
        check=False,
    )
except OSError:
    discover_proc = None

if discover_proc and discover_proc.returncode == 0:
    for raw in discover_proc.stdout.splitlines():
        if not raw.strip():
            continue
        try:
            session, workspace_raw, _remote_spec, _run_kind, _plan_name, _relaunch_command = raw.split("\t", 5)
        except ValueError:
            continue
        workspace = pathlib.Path(workspace_raw)
        if not workspace.is_dir():
            continue
        for plan_dir in _plan_dirs(workspace):
            _merge(entries, workspace, plan_dir, session, "tmux")

# (c) Workspace-activity-discovered plans with recent state/events.
try:
    workspace_children = sorted(workspace_root_path.iterdir())
except OSError:
    workspace_children = []

for workspace in workspace_children:
    try:
        resolved = workspace.resolve()
    except OSError:
        continue
    if not workspace.is_dir() or workspace.name.startswith("."):
        continue
    if resolved == arnold_src_path:
        continue
    plans = _plan_dirs(workspace)
    if not plans:
        continue
    for plan_dir in plans:
        state_path = plan_dir / "state.json"
        events_path = plan_dir / "events.ndjson"
        if _recent_mtime(state_path) or _recent_mtime(events_path):
            _merge(entries, workspace, plan_dir, workspace.name, "workspace_activity")

with open(out, "w", encoding="utf-8") as handle:
    for entry in sorted(entries.values(), key=lambda item: (item["workspace"], item["plan"])):
        handle.write(json.dumps(entry, sort_keys=True) + "\n")
PY

log "auditing plans=$(wc -l < "$WORKLIST" | tr -d ' ') window_hours=$AUDIT_WINDOW_HOURS"

# Collect the watchdog progress_stall flags so the auditor can cite them.
stall_summary="none"
if [[ -f "$WATCHDOG_REPORT" ]]; then
  stall_summary="$(python3 - "$WATCHDOG_REPORT" <<'PY'
import json, sys
try:
    rep = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    print("unreadable"); raise SystemExit(0)
issues = rep.get("issues") or []
stalls = [i for i in issues if i.get("status") == "progress_stall"]
if not stalls:
    print("none"); raise SystemExit(0)
msgs = [i.get("message", "")[:200] for i in stalls]
print(" ; ".join(msgs))
PY
)"
fi

# Build per-plan evidence + decide which need a research subagent.
python3 - "$WORKLIST" "$GATHER_DIR" "$AUDIT_WINDOW_HOURS" "$ARNOLD_SRC" "$stall_summary" <<'PY'
import datetime as dt
import json
import os
import pathlib
import sys

worklist, gather_dir, window_h, arnold_src, stall_summary = sys.argv[1:6]
window = float(window_h)
now = dt.datetime.now(dt.timezone.utc)
cutoff = now - dt.timedelta(hours=window)

plans = []
with open(worklist, encoding="utf-8") as h:
    for line in h:
        line = line.strip()
        if line:
            plans.append(json.loads(line))

def _recent_iso(ts_str):
    if not ts_str:
        return False
    try:
        when = dt.datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
    except Exception:
        return False
    return when >= cutoff

def _mtime(path):
    try:
        return path.stat().st_mtime
    except OSError:
        return 0

def _recent_path(path):
    mtime = _mtime(path)
    return bool(mtime) and dt.datetime.fromtimestamp(mtime, tz=dt.timezone.utc) >= cutoff

def _load_json(path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}

def _tail_with_line_numbers(path, lines=20):
    if path is None:
        return ""
    try:
        raw_lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return ""
    start = max(0, len(raw_lines) - lines)
    return "\n".join(f"L{idx + 1}: {line}" for idx, line in enumerate(raw_lines[start:], start=start))

def _chain_log_candidates(workspace, session, entry):
    candidates = []
    log_value = entry.get("log")
    if log_value:
        candidates.append(pathlib.Path(log_value))
    if session and session != "megaplan-chain":
        candidates.append(workspace / ".megaplan" / f"cloud-chain-{session}.log")
    candidates.append(workspace / ".megaplan" / "cloud-chain.log")
    if session == "megaplan-chain":
        candidates.append(workspace / ".megaplan" / f"cloud-chain-{session}.log")
    seen = set()
    unique = []
    for path in candidates:
        key = str(path)
        if key not in seen:
            seen.add(key)
            unique.append(path)
    return unique

def _normalize_stop_signature(line):
    lower = line.lower()
    if "awaiting_human" in lower:
        return "awaiting_human"
    if "pr #" in lower and "closed" in lower:
        return "pr_closed"
    if "terminal state reached" in lower:
        return "terminal_state_reached"
    if "status: stopped" in lower or '"status": "stopped"' in lower:
        return "status_stopped"
    if "repair loop exhausted" in lower:
        return "repair_loop_exhausted"
    if "all milestones complete" in lower:
        return "all_milestones_complete"
    return ""

def _chain_log_summary(workspace, session, entry):
    log_path = next((path for path in _chain_log_candidates(workspace, session, entry) if path.exists()), None)
    if log_path is None:
        return {
            "path": "",
            "mtime_age_min": None,
            "tail": "",
            "recent_milestone_starts": [],
            "recent_terminal_states": [],
            "recent_stops": [],
            "repetition_summary": [],
        }
    try:
        lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        lines = []
    milestone_starts = []
    terminal_states = []
    stops = []
    signatures = {}
    for idx, line in enumerate(lines, start=1):
        lower = line.lower()
        rendered = f"L{idx}: {line}"
        if "milestone" in lower and "starting" in lower:
            milestone_starts.append(rendered)
        if "terminal state reached" in lower:
            terminal_states.append(rendered)
        if (
            "status: stopped" in lower
            or '"status": "stopped"' in lower
            or "awaiting_human" in lower
            or ("pr #" in lower and "closed" in lower)
            or "repair loop exhausted" in lower
            or "all milestones complete" in lower
        ):
            stops.append(rendered)
            signature = _normalize_stop_signature(line)
            if signature:
                bucket = signatures.setdefault(signature, [])
                bucket.append((idx, line))
    repetition_summary = []
    for signature, occurrences in sorted(signatures.items()):
        if len(occurrences) < 2:
            continue
        repetition_summary.append(
            {
                "signature": signature,
                "count": len(occurrences),
                "first_line": occurrences[0][0],
                "last_line": occurrences[-1][0],
                "examples": [f"L{idx}: {line}" for idx, line in occurrences[-3:]],
            }
        )
    mtime = _mtime(log_path)
    return {
        "path": str(log_path),
        "mtime_age_min": int((now.timestamp() - mtime) // 60) if mtime else None,
        "tail": _tail_with_line_numbers(log_path, lines=20),
        "recent_milestone_starts": milestone_starts[-5:],
        "recent_terminal_states": terminal_states[-5:],
        "recent_stops": stops[-8:],
        "repetition_summary": repetition_summary[-8:],
    }

def _chain_state_paths(workspace):
    candidates = set()
    candidates.update((workspace / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(workspace.glob(".megaplan/briefs/*/.megaplan/plans/.chains/*.json"))
    candidates.update((workspace / ".megaplan").glob("**/chain_state.json"))
    ordered = []
    for path in candidates:
        if path.name == "full_suite_baseline.json":
            continue
        mtime = _mtime(path)
        if mtime:
            ordered.append((mtime, path))
    ordered.sort(reverse=True)
    return [path for _, path in ordered]

def _compact_backstop(backstop):
    if not isinstance(backstop, dict):
        return {}
    return {
        "mode": backstop.get("mode"),
        "status": backstop.get("status"),
        "blocks": backstop.get("blocks"),
        "failed": backstop.get("failed"),
        "delta_computed": backstop.get("delta_computed"),
    }

def _chain_state_summary(workspace, plan):
    summaries = []
    for path in _chain_state_paths(workspace)[:4]:
        data = _load_json(path)
        if not isinstance(data, dict):
            continue
        completed = data.get("completed")
        completed_items = completed if isinstance(completed, list) else []
        summary = {
            "path": str(path),
            "mtime_age_min": int((now.timestamp() - _mtime(path)) // 60) if _mtime(path) else None,
            "current_milestone_index": data.get("current_milestone_index"),
            "completed_count": len(completed_items),
            "current_plan_name": data.get("current_plan_name") or "",
            "current_state": data.get("current_state") or "",
            "last_state": data.get("last_state") or "",
            "pr_number": data.get("pr_number"),
            "pr_state": data.get("pr_state"),
            "reason": data.get("reason") or data.get("error") or "",
            "events": data.get("events")[-8:] if isinstance(data.get("events"), list) else [],
            "completed": [],
        }
        milestones = data.get("milestones")
        if isinstance(milestones, list):
            summary["total_milestones"] = len(milestones)
        for item in completed_items[-8:]:
            if not isinstance(item, dict):
                continue
            summary["completed"].append(
                {
                    "label": item.get("label"),
                    "plan": item.get("plan"),
                    "status": item.get("status"),
                    "pr_number": item.get("pr_number"),
                    "pr_state": item.get("pr_state"),
                    "full_suite_backstop": _compact_backstop(item.get("full_suite_backstop")),
                }
            )
        summaries.append(summary)
    current = next((item for item in summaries if item.get("current_plan_name") == plan), None)
    if current is None:
        current = summaries[0] if summaries else {}
    return {"current": current, "all": summaries}

def _metadata_excerpt(metadata):
    if not isinstance(metadata, dict):
        return {}
    excerpt = {}
    for key in (
        "stderr",
        "stdout",
        "output",
        "raw_output",
        "error",
        "message",
        "detail",
        "details",
        "reason",
        "command",
        "cmd",
        "args",
        "argv",
        "exit_code",
        "returncode",
        "return_code",
        "rc",
        "iteration",
        "provider",
        "provider_error_code",
        "status_code",
        "error_layer",
        "stall_timeout_s",
        "elapsed_s",
        "missing_base_ref",
        "max_iterations",
    ):
        value = metadata.get(key)
        if value not in (None, "", [], {}):
            excerpt[key] = value
    return excerpt

def _user_action_context(plan_dir, state):
    user_actions_path = plan_dir / "user_actions.md"
    resolutions_path = plan_dir / "user_action_resolutions.json"
    finalize_path = plan_dir / "finalize.json"
    user_actions_md = ""
    if user_actions_path.exists():
        try:
            user_actions_md = user_actions_path.read_text(encoding="utf-8", errors="replace")
        except Exception:
            user_actions_md = ""
    finalize = _load_json(finalize_path)
    user_actions = finalize.get("user_actions") if isinstance(finalize, dict) else []
    if not isinstance(user_actions, list):
        user_actions = []
    disk_resolutions = _load_json(resolutions_path)
    if not isinstance(disk_resolutions, dict):
        disk_resolutions = {}
    meta = state.get("meta") if isinstance(state, dict) else {}
    state_resolutions = meta.get("user_action_resolutions") if isinstance(meta, dict) else {}
    if not isinstance(state_resolutions, dict):
        state_resolutions = {}
    resolved_states = {"satisfied", "accepted_blocked", "waived", "resolved"}
    unresolved = []
    for action in user_actions:
        if not isinstance(action, dict):
            continue
        action_id = action.get("id")
        if not isinstance(action_id, str) or not action_id:
            continue
        disk_resolution = disk_resolutions.get(action_id)
        state_resolution = state_resolutions.get(action_id)
        resolution_state = ""
        for resolution in (disk_resolution, state_resolution):
            if isinstance(resolution, dict) and resolution.get("state"):
                resolution_state = str(resolution.get("state"))
                break
        if resolution_state not in resolved_states:
            unresolved.append(
                {
                    "id": action_id,
                    "phase": action.get("phase") or "",
                    "blocks_task_ids": action.get("blocks_task_ids") if isinstance(action.get("blocks_task_ids"), list) else [],
                    "resolution_state": resolution_state or "unresolved",
                    "summary": action.get("summary") or action.get("description") or action.get("question") or "",
                    "rationale": action.get("rationale") or action.get("reason") or "",
                    "has_disk_resolution": action_id in disk_resolutions,
                    "has_state_resolution": action_id in state_resolutions,
                }
            )
    return {
        "plan_dir": str(plan_dir),
        "finalize_path": str(finalize_path) if finalize_path.exists() else "",
        "user_actions_path": str(user_actions_path) if user_actions_path.exists() else "",
        "user_actions_md": user_actions_md[:12000],
        "user_actions_truncated": len(user_actions_md) > 12000,
        "resolutions_path": str(resolutions_path) if resolutions_path.exists() else "",
        "disk_resolutions": disk_resolutions,
        "state_resolutions": state_resolutions,
        "unresolved_user_actions": unresolved,
    }

def _repair_data_summary(session):
    repair_data_dir = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_REPAIR_DATA_DIR", "/workspace/.megaplan/cloud-sessions/repair-data"))
    path = repair_data_dir / f"{session}.repair-data.json"
    if not path.exists():
        return {"path": str(path), "exists": False}
    payload = _load_json(path)
    iterations = payload.get("iterations") if isinstance(payload, dict) else []
    if not isinstance(iterations, list):
        iterations = []
    summarized_iterations = []
    failure_signatures = {}
    for item in iterations[-8:]:
        if not isinstance(item, dict):
            continue
        chain_state = item.get("chain_state_summary") if isinstance(item.get("chain_state_summary"), dict) else {}
        failure = item.get("plan_latest_failure") if isinstance(item.get("plan_latest_failure"), dict) else {}
        stderr = ""
        metadata = failure.get("metadata") if isinstance(failure.get("metadata"), dict) else {}
        if isinstance(metadata, dict):
            stderr = str(metadata.get("stderr") or "")[:1200]
        signature = "|".join(
            str(value or "")
            for value in (
                chain_state.get("current_plan_name"),
                chain_state.get("last_state"),
                failure.get("kind"),
                failure.get("message"),
                stderr[:160],
            )
        )
        if signature.strip("|"):
            failure_signatures[signature] = failure_signatures.get(signature, 0) + 1
        summarized_iterations.append(
            {
                "i": item.get("i"),
                "mechanical_launch": item.get("mechanical_launch") or item.get("kimi_launch") or "",
                "mechanical_detail": item.get("mechanical_detail") or item.get("why") or "",
                "failure_classification": item.get("failure_classification") or "",
                "chain_last_state": chain_state.get("last_state") or "",
                "chain_current_plan": chain_state.get("current_plan_name") or "",
                "latest_failure_kind": failure.get("kind") or "",
                "latest_failure_message": failure.get("message") or "",
                "latest_failure_stderr": stderr,
                "dev_classification": (item.get("dev_report") or {}).get("classification") if isinstance(item.get("dev_report"), dict) else "",
                "kimi_classification": (item.get("kimi_report") or {}).get("classification") if isinstance(item.get("kimi_report"), dict) else "",
                "structural_pattern": item.get("structural_pattern") or "",
                "human_review_recommendation": item.get("human_review_recommendation") or "",
            }
        )
    repeated = [
        {"signature": signature[:400], "count": count}
        for signature, count in sorted(failure_signatures.items(), key=lambda pair: pair[1], reverse=True)
        if count >= 2
    ]
    return {
        "path": str(path),
        "exists": True,
        "mtime_age_min": int((now.timestamp() - _mtime(path)) // 60) if _mtime(path) else None,
        "outcome": payload.get("outcome") if isinstance(payload, dict) else "",
        "iteration_count": len(iterations),
        "iterations": summarized_iterations,
        "repeated_failure_signatures": repeated[:6],
    }

def _plan_evidence(entry):
    workspace = entry["workspace"]
    plan = entry["plan"]
    workspace_path = pathlib.Path(workspace)
    plan_dir = workspace_path / ".megaplan" / "plans" / plan
    state_path = plan_dir / "state.json"
    try:
        state = json.loads(state_path.read_text(encoding="utf-8"))
    except Exception:
        return None

    plan_v_files = sorted(plan_dir.glob("plan_v*.md"))
    recent_v = []
    for p in plan_v_files:
        try:
            if dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc) >= cutoff:
                recent_v.append(p)
        except OSError:
            continue

    try:
        state_mtime = dt.datetime.fromtimestamp(state_path.stat().st_mtime, tz=dt.timezone.utc)
    except OSError:
        state_mtime = None
    events_path = plan_dir / "events.ndjson"
    try:
        events_mtime = events_path.stat().st_mtime if events_path.exists() else 0
    except OSError:
        events_mtime = 0
    events_recent = bool(events_mtime) and dt.datetime.fromtimestamp(events_mtime, tz=dt.timezone.utc) >= cutoff

    session = entry.get("session") or workspace_path.name
    session_header = {
        "session": session,
        "workspace": workspace,
        "kind": entry.get("kind") or "",
        "remote_spec": entry.get("remote_spec") or "",
        "launch_command": entry.get("launch_command") or "",
        "log": entry.get("log") or "",
        "marker_path": entry.get("marker_path") or "",
        "created_at": entry.get("created_at") or "",
        "updated_at": entry.get("updated_at") or entry.get("updated") or "",
        "started_at": entry.get("started_at") or "",
        "sources": entry.get("sources") or [],
    }
    chain_log = _chain_log_summary(workspace_path, session, entry)
    chain_state = _chain_state_summary(workspace_path, plan)
    repair_data = _repair_data_summary(session)
    chain_recent = any(
        [
            chain_log.get("path") and chain_log.get("mtime_age_min") is not None and chain_log.get("mtime_age_min") <= window * 60,
            any(item.get("mtime_age_min") is not None and item.get("mtime_age_min") <= window * 60 for item in chain_state.get("all", [])),
            repair_data.get("exists") and repair_data.get("mtime_age_min") is not None and repair_data.get("mtime_age_min") <= window * 60,
        ]
    )

    if not recent_v and not _recent_iso(state.get("created_at")):
        if (state_mtime is None or state_mtime < cutoff) and not events_recent and not chain_recent:
            return None

    sizes = {}
    for p in plan_v_files:
        try:
            sizes[p.name] = p.stat().st_size
        except OSError:
            continue
    events_size = events_path.stat().st_size if events_path.exists() else 0
    last_gate = state.get("last_gate") or {}
    latest_failure = state.get("latest_failure") or {}
    latest_failure_metadata = latest_failure.get("metadata") if isinstance(latest_failure.get("metadata"), dict) else {}
    meta = state.get("meta") or {}
    scores = meta.get("weighted_scores") or []
    plan_deltas = meta.get("plan_deltas") or []
    counts = meta.get("significant_counts") or []
    active = state.get("active_step") or {}

    history = state.get("history") or []
    recent_history = []
    for item in history:
        ts = item.get("timestamp") or item.get("completed_at") or ""
        if _recent_iso(ts):
            recent_history.append({"step": item.get("step"), "result": item.get("result"), "ts": ts})
    gates = [h for h in recent_history if h.get("step") == "gate"]
    gate_iterate = sum(1 for g in gates if g.get("result") in ("iterate", "ITERATE", "blocked"))
    gate_total = len(gates)

    plan_latest_failure = {
        "plan_name": state.get("name") or plan_dir.name,
        "state_path": str(state_path),
        "current_state": state.get("current_state") or state.get("state") or "",
        "phase": latest_failure.get("phase") or state.get("phase") or "",
        "iteration": state.get("iteration"),
        "kind": latest_failure.get("kind") or "",
        "message": latest_failure.get("message") or "",
        "state": latest_failure.get("state") or "",
        "recorded_at": latest_failure.get("recorded_at") or "",
        "last_artifact": latest_failure.get("last_artifact") or "",
        "suggested_action": latest_failure.get("suggested_action") or "",
        "metadata": _metadata_excerpt(latest_failure_metadata),
    }
    user_action_context = _user_action_context(plan_dir, state)

    return {
        "plan": plan_dir.name,
        "workspace": workspace,
        "session": session,
        "sources": entry.get("sources") or [],
        "session_header": session_header,
        "chain_log": chain_log,
        "chain_state_summary": chain_state,
        "repair_data_summary": repair_data,
        "plan_latest_failure": plan_latest_failure,
        "user_action_context": user_action_context,
        "current_state": state.get("current_state"),
        "iteration": state.get("iteration"),
        "active_step_phase": active.get("phase"),
        "active_step_attempt": active.get("attempt"),
        "plan_v_count": len(plan_v_files),
        "plan_v_sizes": sizes,
        "events_size": events_size,
        "events_mtime_age_min": int((now.timestamp() - events_mtime) // 60) if events_mtime else None,
        "last_gate_recommendation": last_gate.get("recommendation"),
        "last_gate_score": scores[-1] if scores else None,
        "score_trajectory": scores,
        "plan_deltas": plan_deltas,
        "significant_counts": counts,
        "recent_gate_total": gate_total,
        "recent_gate_iterate": gate_iterate,
        "latest_failure_kind": latest_failure.get("kind"),
        "latest_failure_message": (latest_failure.get("message") or "")[:240],
        "latest_failure_metadata": _metadata_excerpt(latest_failure_metadata),
    }

findings = []
for entry in plans:
    ev = _plan_evidence(entry)
    if ev is None:
        continue
    # Suspicion heuristics — evidence-only, no auto-fix.
    reasons = []
    v_sizes = list(ev["plan_v_sizes"].values())
    if ev["plan_v_count"] >= 4 and len(set(v_sizes)) >= 3:
        reasons.append(f"plan_v refreshed {ev['plan_v_count']}x in {int(window)}h ({min(v_sizes)}->{max(v_sizes)} bytes)")
    if ev["recent_gate_iterate"] >= 3:
        reasons.append(f"gate=ITERATE/blocked {ev['recent_gate_iterate']}/{ev['recent_gate_total']} recent times")
    scores = ev["score_trajectory"]
    if len(scores) >= 3 and scores[-1] is not None and scores[-1] < scores[0] and scores[-1] <= 5:
        reasons.append(f"score regression {scores[0]}->{scores[-1]}")
    if ev["active_step_attempt"] and int(ev["active_step_attempt"]) >= 8:
        reasons.append(f"step on attempt {ev['active_step_attempt']}")
    if ev["latest_failure_kind"] in ("stalled", "phase_failed", "execution_blocked"):
        reasons.append(f"{ev['latest_failure_kind']}: {ev['latest_failure_message']}")
    chain_current = (ev.get("chain_state_summary") or {}).get("current") or {}
    chain_last_state = chain_current.get("last_state")
    if chain_last_state in ("awaiting_human", "pr_closed", "missing_base_ref", "blocked"):
        reasons.append(
            f"chain last_state={chain_last_state} current_plan={chain_current.get('current_plan_name') or 'unknown'}"
        )
    chain_repeats = (ev.get("chain_log") or {}).get("repetition_summary") or []
    repeated_attention = [
        item for item in chain_repeats
        if item.get("signature") not in ("all_milestones_complete",) and int(item.get("count") or 0) >= 2
    ]
    if repeated_attention:
        item = repeated_attention[-1]
        reasons.append(
            f"chain log repeats {item.get('signature')} {item.get('count')}x L{item.get('first_line')}..L{item.get('last_line')}"
        )
    repair_summary = ev.get("repair_data_summary") or {}
    repeated_failures = repair_summary.get("repeated_failure_signatures") or []
    if int(repair_summary.get("iteration_count") or 0) >= 2:
        reasons.append(f"repair data has {repair_summary.get('iteration_count')} repair iterations")
    if repeated_failures:
        reasons.append(f"repair data repeats same failure signature {repeated_failures[0].get('count')}x")
    unresolved_actions = (ev.get("user_action_context") or {}).get("unresolved_user_actions") or []
    if chain_last_state == "awaiting_human" and unresolved_actions:
        ids = ",".join(str(item.get("id")) for item in unresolved_actions[:5])
        reasons.append(f"awaiting_human with unresolved user actions: {ids}")
    if not reasons:
        continue
    ev["reasons"] = reasons
    findings.append(ev)

with open(os.path.join(gather_dir, "findings.json"), "w", encoding="utf-8") as h:
    json.dump({"window_hours": window, "stall_summary": stall_summary, "findings": findings}, h, indent=2, sort_keys=True)
print(len(findings))
PY

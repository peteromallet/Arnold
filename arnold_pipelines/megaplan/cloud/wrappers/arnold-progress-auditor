revalidate_audit_snapshot() {
  python3 - "$GATHER_DIR/findings.json" <<'PY'
import hashlib
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
payload = json.loads(path.read_text(encoding="utf-8"))
superseded = 0
for finding in payload.get("findings") or []:
    refs = []
    repair = finding.get("repair_data_summary") or {}
    if repair.get("path") and repair.get("sha256"):
        refs.append((repair["path"], repair["sha256"], "repair_data"))
    for item in (finding.get("meta_repair_summary") or {}).get("meta_run_refs") or []:
        if item.get("current_episode") and item.get("path") and item.get("sha256"):
            refs.append((item["path"], item["sha256"], "current_meta_run"))
    changed = []
    for raw_path, expected, kind in refs:
        artifact = pathlib.Path(raw_path)
        try:
            observed = hashlib.sha256(artifact.read_bytes()).hexdigest()
        except OSError:
            observed = "missing"
        if observed != expected:
            changed.append({"kind": kind, "path": raw_path, "expected_sha256": expected, "observed_sha256": observed})
    if not changed:
        finding["evidence_snapshot"] = {"status": "current", "revalidated_ref_count": len(refs)}
        continue
    superseded += 1
    finding["evidence_snapshot"] = {"status": "superseded", "changed_refs": changed}
    finding.setdefault("reasons", []).append(
        "evidence_snapshot_superseded: volatile repair/meta evidence changed after deterministic gather; dispatch fails closed until the next bounded gather"
    )
    superfixer = finding.get("deterministic_superfixer_evidence")
    if isinstance(superfixer, dict):
        superfixer["actionable"] = False
        superfixer["snapshot_superseded"] = True
path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(superseded)
PY
}


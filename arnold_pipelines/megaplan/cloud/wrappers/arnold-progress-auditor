            gc_gate = f" · gate `{gc.get('last_gate_recommendation')}` (score {gc.get('last_gate_score')})"
        lines.append(f"- **{gc.get('plan')}** (`{gc.get('session')}`) — {gc_state}{gc_gate}")
    lines.append("")
# Autonomous fix attempts section (always emitted with empty-state text).
lines.append("## 🔧 Autonomous fix attempts")
lines.append("")
if autonomous_fix_attempts:
    for af in autonomous_fix_attempts:
        commit_str = f" commit `{af.get('commit')}`" if af.get("commit") else ""
        lines.append(f"- **{af.get('plan')}** (`{af.get('session')}`) —{commit_str} {af.get('summary', '')[:120]}")
else:
    lines.append("_No autonomous fixes were attempted during this audit._")
lines.append("")
# Risky or deferred fixes section (always emitted with empty-state text).
lines.append("## ⚠️ Risky or deferred fixes")
lines.append("")
if risky_or_deferred_fixes:
    for rf in risky_or_deferred_fixes:
        lines.append(f"- **{rf.get('plan')}** (`{rf.get('session')}`) — verdict `{rf.get('verdict')}` — {rf.get('summary', '')[:120]}")
else:
    lines.append("_No risky or deferred fixes were identified during this audit._")
lines.append("")
with open(md_out, "w", encoding="utf-8") as h:
    h.write("\n".join(lines) + "\n")

# One-line log append (human-greppable).
summary_bits = [f.get("plan") for f in findings] or ["none"]
with open(log_path, "a", encoding="utf-8") as h:
    h.write(f"{now_iso}\tfindings={len(findings)}\tgreen={len(green_checks)}\tplans={','.join(summary_bits)}\tstall={data.get('stall_summary','')[:80]}\n")
print(json_out)

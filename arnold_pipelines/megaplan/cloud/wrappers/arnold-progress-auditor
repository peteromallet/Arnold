            "events": data.get("events")[-8:] if isinstance(data.get("events"), list) else [],
            "completed": [],
        }
        milestones = data.get("milestones")
        if isinstance(milestones, list):
            summary["total_milestones"] = len(milestones)
        for item in completed_items[-8:]:
            if not isinstance(item, dict):
                continue
            summary["completed"].append(
                {
                    "label": item.get("label"),
                    "plan": item.get("plan"),
                    "status": item.get("status"),
                    "pr_number": item.get("pr_number"),
                    "pr_state": item.get("pr_state"),
                    "full_suite_backstop": _compact_backstop(item.get("full_suite_backstop")),
                }
            )
        summaries.append(summary)
    current = next((item for item in summaries if item.get("current_plan_name") == plan), None)
    if current is None:
        current = next(
            (
                item
                for item in summaries
                if any(
                    isinstance(completed, dict) and completed.get("plan") == plan
                    for completed in item.get("completed") or []
                )
            ),
            None,
        )
    if current is None:
        current = {}
    return {"current": current, "all": summaries}

def _accepted_event_receipt(events_path):
    events = _load_events(events_path)
    accepted = None
    accepted_index = None
    recent_kind_counts = {}
    for index, event in enumerate(events, start=1):
        kind = str(event.get("kind") or event.get("event_type") or "").strip().lower()
        when = _event_timestamp(event)
        if when is not None and when >= cutoff:
            recent_kind_counts[kind or "unknown"] = recent_kind_counts.get(kind or "unknown", 0) + 1
        if kind == "plan_finished" or (kind == "phase_end" and _successful_event(event)):
            accepted = event
            accepted_index = index
    if not isinstance(accepted, dict):
        return {
            "present": False,
            "seq": None,
            "digest": "",
            "event": {},
            "age_min": None,
            "recent_kind_counts": recent_kind_counts,
        }
    seq = _event_seq(accepted)
    if seq is None:
        seq = accepted_index
    accepted_at = _event_timestamp(accepted)
    return {
        "present": True,
        "seq": seq,
        "digest": hashlib.sha256(
            json.dumps(accepted, sort_keys=True, separators=(",", ":"), default=str).encode("utf-8")
        ).hexdigest(),
        "event": _event_excerpt(accepted),
        "age_min": int((now - accepted_at).total_seconds() // 60) if accepted_at else None,
        "recent_kind_counts": recent_kind_counts,
    }


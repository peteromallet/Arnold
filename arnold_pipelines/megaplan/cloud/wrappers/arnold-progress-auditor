        return {
            "should_dispatch": False,
            "trigger": "",
            "rationale": ["repair-data only contains legacy attempt summaries; no active recurring repair context is present"],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": 0,
            "meta_run_refs": [],
            "missing_meta_run_evidence": False,
        }
    try:
        observed_plan_name = chain_current_plan if normalized_kind != "plan" else str(current_plan_name or "").strip()
        current_target_observation = {
            "authoritative_source": "chain_state" if normalized_kind != "plan" and chain_current else "plan_state",
            "current_refs": {
                "run_kind": normalized_kind,
                "current_plan_name": observed_plan_name,
                "chain_current_plan_name": chain_current_plan,
                "plan_current_state": normalized_state,
                "chain_last_state": chain_last_state,
            },
            "plan_state": {"present": bool(current_plan_name)},
            "chain_state": {"present": bool(chain_current)},
            "active_step_heartbeat": {
                "active": bool(str(active_step_phase or "").strip()),
                "worker_pid_alive": active_step_liveness.get("worker_pid_alive")
                if isinstance(active_step_liveness, dict)
                else None,
            },
            "stale_evidence": [],
        }
        classification, _ = evaluate_meta_repair_triggers(
            session,
            repair_data_dir=repair_root,
            repair_outcome=repair_outcome,
            attempt_outcomes=attempt_outcomes,
            failure_kinds=failure_kinds,
            repair_budget_exhausted=repair_outcome in {"repair_timeout", "repair_exhausted"},
            current_target_observation=current_target_observation,
            load_evidence=True,
        )
        should_dispatch = bool(classification.should_dispatch)
        trigger = classification.trigger_label
        rationale = [_redact_scalar(item) for item in classification.rationale]
    except Exception as exc:
        should_dispatch = False
        trigger = "classification_error"
        rationale = [_redact_scalar(exc)]
    if should_dispatch and terminal_success:
        should_dispatch = False
        trigger = ""
        rationale = [
            "current gathered target state already reached terminal success; "
            "stale repair-data recurrence does not require meta-repair dispatch"
        ]
    live_event_activity = isinstance(events_mtime_age_min, int) and events_mtime_age_min <= 5
    chain_log_age = None
    if isinstance(chain_log_summary, dict):
        chain_log_age = chain_log_summary.get("mtime_age_min")
    live_chain_activity = isinstance(chain_log_age, int) and chain_log_age <= 5
    active_step = active_step_liveness if isinstance(active_step_liveness, dict) else {}
    live_active_step_activity = bool(str(active_step_phase or "").strip()) and (
        live_event_activity or active_step.get("worker_pid_alive") is True
    )
    non_terminal_state = normalized_state not in {"done", "complete", "completed", "finalized"}
    live_target_activity = live_active_step_activity or (
        non_terminal_state and (
        live_event_activity or (normalized_kind == "chain" and live_chain_activity)
        )
    )
    if should_dispatch and trigger in {"persistent_recurring_retry", "partial_liveness_recurrence"} and live_target_activity:
        should_dispatch = False
        trigger = ""
        rationale = [
            "watchdog-corroborated live target activity supersedes recurring meta-repair dispatch: "
            f"events_mtime_age_min={events_mtime_age_min!r}, chain_log_mtime_age_min={chain_log_age!r}, "
            f"active_step_phase={active_step_phase!r}, worker_pid_alive={active_step.get('worker_pid_alive')!r}"
        ]
    watchdog_alive_refs = _watchdog_alive_refs(prior_watchdog_report_refs)
    if should_dispatch and trigger in {"persistent_recurring_retry", "partial_liveness_recurrence"} and watchdog_alive_refs:
        should_dispatch = False
        trigger = ""
        rationale = [
            "repeated watchdog reports already classified this session as alive, so stale recurring "
            f"repair sidecars do not prove an unhandled meta-repair dispatch gap (alive_refs={len(watchdog_alive_refs)})"
        ]
    failed_run_refs = [item for item in run_refs if item.get("launch_failure")]
    failed_meta_records = []
    for item in meta_refs or []:
        path = item.get("path") if isinstance(item, dict) else ""
        if path and _meta_record_is_launch_failure(pathlib.Path(str(path))):
            failed_meta_records.append(item)
    return {
        "should_dispatch": should_dispatch,
        "trigger": trigger,
        "rationale": rationale,
        "repair_outcome": _redact_scalar(repair_outcome),
        "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
        "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
        "meta_record_count": len(meta_refs or []),
        "meta_run_log_count": len(run_refs),
        "meta_run_refs": run_refs,
        "failed_meta_run_count": len(failed_run_refs),
        "failed_meta_record_count": len(failed_meta_records),
        "missing_meta_run_evidence": bool(should_dispatch and not meta_refs and not run_refs),
        "failed_meta_run_evidence": bool(should_dispatch and (failed_run_refs or failed_meta_records)),
    }

def _watchdog_alive_refs(refs):
    alive = []
    for item in refs or []:
        if not isinstance(item, dict):
            continue
        status = str(item.get("matched_status") or "").strip().lower()
        message = str(item.get("matched_message") or "").strip().lower()
        if status == "alive" or "session already alive" in message:
            alive.append(item)
    return alive

def _collect_watchdog_report_refs(session, plan, workspace):
    refs = []
    tokens = _match_tokens(session, plan, workspace.name)
    candidates = []
    if WATCHDOG_REPORT_PATH.exists():
        candidates.append(WATCHDOG_REPORT_PATH)
    if WATCHDOG_REPORT_ARCHIVE_DIR.exists():
        candidates.extend(sorted(WATCHDOG_REPORT_ARCHIVE_DIR.glob("*.json"), reverse=True)[:20])
    for path in candidates:
        payload = _load_json(path)
        if not isinstance(payload, dict):
            continue
        matched_items = []
        items = payload.get("items") if isinstance(payload.get("items"), list) else []
        issues = payload.get("issues") if isinstance(payload.get("issues"), list) else []
        for item in items + issues:
            if _watchdog_record_matches(item, session=session, plan=plan, workspace=workspace, tokens=tokens):
                matched_items.append(item)
        if matched_items:
            matched = matched_items[-1]
        elif _watchdog_record_matches(payload, session=session, plan=plan, workspace=workspace, tokens=tokens):
            matched = payload
        else:
            continue
        refs.append(
            {
                "report_id": _redact_scalar(path.stem),
                "path": _redact_scalar(path),
                "timestamp_utc": _redact_scalar(payload.get("timestamp_utc") or ""),
                "matched_status": _redact_scalar(matched.get("status") or matched.get("health") or ""),
                "matched_action": _redact_scalar(matched.get("action") or ""),
                "matched_message": _redact_scalar(matched.get("message") or matched.get("summary") or ""),
            }
        )
    return _bounded_refs(refs, key_fields=("report_id", "path"))

def _watchdog_record_matches(item, *, session, plan, workspace, tokens):
    if not isinstance(item, dict):
        return False
    session_text = str(session or "").strip()
    plan_text = str(plan or "").strip()
    workspace_text = str(workspace or "").strip()
    item_session = str(item.get("session") or "").strip()
    item_plan = str(item.get("plan") or item.get("current_plan_name") or "").strip()
    item_workspace = str(item.get("workspace") or "").strip()
    item_remote_spec = str(item.get("remote_spec") or "").strip()
    if session_text and item_session:
        return item_session == session_text
    if workspace_text and item_workspace and item_workspace == workspace_text:
        if plan_text and item_plan:
            return item_plan == plan_text
        return True
    if plan_text and item_plan:
        return item_plan == plan_text
    if item_session or item_plan or item_workspace or item_remote_spec:
        return False
    return _artifact_matches(item, tokens)

def _collect_audit_report_refs(session, plan):
    refs = []
    if not AUDIT_REPORT_DIR.exists():
        return refs
    for path in sorted(AUDIT_REPORT_DIR.glob("*-audit.json"), reverse=True)[:20]:
        payload = _load_json(path)
        if not isinstance(payload, dict):
            continue
        findings = payload.get("findings") if isinstance(payload.get("findings"), list) else []
        if not any(
            isinstance(item, dict)
            and str(item.get("session") or "") == session
            and str(item.get("plan") or "") == plan
            for item in findings
        ):
            continue
        refs.append(
            {
                "report_id": _redact_scalar(path.stem),
                "path": _redact_scalar(path),
                "timestamp_utc": _redact_scalar(payload.get("timestamp_utc") or ""),
            }
        )
    return _bounded_refs(refs, key_fields=("report_id", "path"))

def _collect_persistent_finding_refs(session, plan, incident_ids):
    if not PERSISTENT_FINDINGS_DOC.exists():
        return []
    refs = []
    wanted = _match_tokens(session, plan, *incident_ids)
    try:
        lines = PERSISTENT_FINDINGS_DOC.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return []
    for lineno, line in enumerate(lines, start=1):
        lower = line.lower()
        if not any(token in lower for token in wanted):
            continue
        refs.append(
            {
                "path": _redact_scalar(PERSISTENT_FINDINGS_DOC),
                "line": lineno,
                "excerpt": _redact_scalar(line[:200]),
            }
        )
    return _bounded_refs(refs, key_fields=("path", "line"))

def _collect_ticket_refs(workspace, session, plan, incident_ids):
    ticket_dir = workspace / ".megaplan" / "tickets"
    if not ticket_dir.exists():
        return []
    refs = []
    wanted = _match_tokens(session, plan, *incident_ids)
    for path in sorted(ticket_dir.glob("*.md"), reverse=True)[:20]:
        try:
            body = path.read_text(encoding="utf-8", errors="replace")
        except Exception:
            continue
        if not any(token in body.lower() for token in wanted):
            continue
        ticket_id = path.name.split("-", 1)[0]
        refs.append(
            {
                "ticket_id": _redact_scalar(ticket_id),
                "path": _redact_scalar(path),
            }
        )
    return _bounded_refs(refs, key_fields=("ticket_id", "path"))

def _collect_commit_refs():
    if not (COMMIT_SOURCE_DIR / ".git").exists():
        return []
    cmd = [
        "git",
        "-C",
        str(COMMIT_SOURCE_DIR),
        "log",
        "--max-count",
        str(MAX_COMMIT_REFS),
        "--pretty=format:%H%x09%s",
        "--",
        *COMMIT_SOURCE_PATHS,
    ]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    except OSError:
        return []
    if proc.returncode != 0:
        return []
    refs = []
    for line in proc.stdout.splitlines():
        sha, _, subject = line.partition("\t")
        sha = sha.strip()
        if not sha:
            continue
        refs.append(
            {
                "commit": _redact_scalar(sha[:12]),
                "subject": _redact_scalar(subject[:200]),
            }
        )
    return _bounded_refs(refs, key_fields=("commit",))

def _tail_with_line_numbers(path, lines=20):
    if path is None:
        return ""
    try:
        raw_lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return ""
    start = max(0, len(raw_lines) - lines)
    return "\n".join(f"L{idx + 1}: {line}" for idx, line in enumerate(raw_lines[start:], start=start))

def _chain_log_candidates(workspace, session, entry):
    candidates = []
    log_value = entry.get("log")
    if log_value:
        candidates.append(pathlib.Path(log_value))
    if session and session != "megaplan-chain":
        candidates.append(workspace / ".megaplan" / f"cloud-chain-{session}.log")
    candidates.append(workspace / ".megaplan" / "cloud-chain.log")
    if session == "megaplan-chain":
        candidates.append(workspace / ".megaplan" / f"cloud-chain-{session}.log")
    seen = set()
    unique = []
    for path in candidates:
        key = str(path)
        if key not in seen:
            seen.add(key)
            unique.append(path)
    return unique

_AWAITING_HUMAN_TOKEN = re.compile(r"(?<![A-Za-z0-9_])awaiting_human(?:_verify)?(?![A-Za-z0-9_])")

def _has_awaiting_human_token(line):
    return bool(_AWAITING_HUMAN_TOKEN.search(line.lower()))

def _normalize_stop_signature(line):
    lower = line.lower()
    if _has_awaiting_human_token(lower):
        return "awaiting_human"
    if "pr #" in lower and "closed" in lower:
        return "pr_closed"
    if "terminal state reached" in lower:
        return "terminal_state_reached"
    if "status: stopped" in lower or '"status": "stopped"' in lower:
        return "status_stopped"
    if "repair loop exhausted" in lower:
        return "repair_loop_exhausted"
    if "all milestones complete" in lower:
        return "all_milestones_complete"
    return ""

def _chain_log_summary(workspace, session, entry):
    log_path = next((path for path in _chain_log_candidates(workspace, session, entry) if path.exists()), None)
    if log_path is None:
        return {
            "path": "",
            "mtime_age_min": None,
            "tail": "",
            "recent_milestone_starts": [],
            "recent_terminal_states": [],
            "recent_stops": [],
            "repetition_summary": [],
            "one_milestone_stop_cycles": [],
        }
    try:
        lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        lines = []
    milestone_starts = []
    terminal_states = []
    stops = []
    signatures = {}
    cycles = []
    current_cycle = []
    for idx, line in enumerate(lines, start=1):
        lower = line.lower()
        rendered = f"L{idx}: {line}"
        if "milestone" in lower and "starting" in lower:
            milestone_starts.append(rendered)
            current_cycle.append((idx, line))
        if "terminal state reached" in lower:
            terminal_states.append(rendered)
        if (
            "status: stopped" in lower
            or '"status": "stopped"' in lower
            or _has_awaiting_human_token(lower)
            or ("pr #" in lower and "closed" in lower)
            or "repair loop exhausted" in lower
            or "all milestones complete" in lower
        ):
            stops.append(rendered)
            signature = _normalize_stop_signature(line)
            if signature:
                bucket = signatures.setdefault(signature, [])
                bucket.append((idx, line))
            milestone_lines = [
                (line_idx, text)
                for line_idx, text in current_cycle
                if "milestone" in text.lower() and "starting" in text.lower()
            ]
            if len(milestone_lines) == 1:
                cycles.append(
                    {
                        "start_line": milestone_lines[0][0],
                        "stop_line": idx,
                        "start": f"L{milestone_lines[0][0]}: {milestone_lines[0][1]}",
                        "stop": rendered,
                    }
                )
            current_cycle = []
    repetition_summary = []
    for signature, occurrences in sorted(signatures.items()):
        if len(occurrences) < 2:
            continue
        repetition_summary.append(
            {
                "signature": signature,
                "count": len(occurrences),
                "first_line": occurrences[0][0],
                "last_line": occurrences[-1][0],
                "examples": [f"L{idx}: {line}" for idx, line in occurrences[-3:]],
            }
        )
    mtime = _mtime(log_path)
    return {
        "path": str(log_path),
        "mtime_age_min": int((now.timestamp() - mtime) // 60) if mtime else None,
        "tail": _tail_with_line_numbers(log_path, lines=20),
        "recent_milestone_starts": milestone_starts[-5:],
        "recent_terminal_states": terminal_states[-5:],
        "recent_stops": stops[-8:],
        "repetition_summary": repetition_summary[-8:],
        "one_milestone_stop_cycles": cycles[-8:],
    }

def _chain_state_paths(workspace):
    candidates = set()
    candidates.update((workspace / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(workspace.glob(".megaplan/initiatives/*/.megaplan/plans/.chains/*.json"))
    candidates.update((workspace / ".megaplan").glob("**/chain_state.json"))
    ordered = []
    for path in candidates:
        if path.name == "full_suite_baseline.json":
            continue
        mtime = _mtime(path)
        if mtime:
            ordered.append((mtime, path))
    ordered.sort(reverse=True)
    return [path for _, path in ordered]

def _compact_backstop(backstop):
    if not isinstance(backstop, dict):
        return {}
    return {
        "mode": backstop.get("mode"),
        "status": backstop.get("status"),
        "blocks": backstop.get("blocks"),
        "failed": backstop.get("failed"),
        "delta_computed": backstop.get("delta_computed"),
    }

def _chain_state_summary(workspace, plan):
    summaries = []
    for path in _chain_state_paths(workspace)[:4]:
        data = _load_json(path)
        if not isinstance(data, dict):
            continue
        completed = data.get("completed")
        completed_items = completed if isinstance(completed, list) else []
        summary = {
            "path": str(path),
            "mtime_age_min": int((now.timestamp() - _mtime(path)) // 60) if _mtime(path) else None,
            "current_milestone_index": data.get("current_milestone_index"),
            "completed_count": len(completed_items),
            "current_plan_name": data.get("current_plan_name") or "",
            "current_state": data.get("current_state") or "",
            "last_state": data.get("last_state") or "",
            "chain_complete": data.get("chain_complete"),
            "pr_number": data.get("pr_number"),
            "pr_state": data.get("pr_state"),
            "reason": data.get("reason") or data.get("error") or "",
            "events": data.get("events")[-8:] if isinstance(data.get("events"), list) else [],
            "completed": [],
        }
        milestones = data.get("milestones")
        if isinstance(milestones, list):
            summary["total_milestones"] = len(milestones)
        for item in completed_items[-8:]:
            if not isinstance(item, dict):
                continue
            summary["completed"].append(
                {
                    "label": item.get("label"),
                    "plan": item.get("plan"),
                    "status": item.get("status"),
                    "pr_number": item.get("pr_number"),
                    "pr_state": item.get("pr_state"),
                    "full_suite_backstop": _compact_backstop(item.get("full_suite_backstop")),
                }
            )
        summaries.append(summary)
    current = next((item for item in summaries if item.get("current_plan_name") == plan), None)
    if current is None:
        current = summaries[0] if summaries else {}
    return {"current": current, "all": summaries}

def _metadata_excerpt(metadata):
    if not isinstance(metadata, dict):
        return {}
    excerpt = {}
    for key in (
        "stderr",
        "stdout",
        "output",
        "raw_output",
        "error",
        "message",
        "detail",
        "details",
        "reason",
        "command",
        "cmd",
        "args",
        "argv",
        "exit_code",
        "returncode",
        "return_code",
        "rc",
        "iteration",
        "provider",
        "provider_error_code",
        "status_code",
        "error_layer",
        "stall_timeout_s",
        "elapsed_s",
        "missing_base_ref",
        "max_iterations",
    ):
        value = metadata.get(key)
        if value not in (None, "", [], {}):
            excerpt[key] = value
    return excerpt

def _user_action_context(plan_dir, state):
    user_actions_path = plan_dir / "user_actions.md"
    resolutions_path = plan_dir / "user_action_resolutions.json"
    finalize_path = plan_dir / "finalize.json"
    user_actions_md = ""
    if user_actions_path.exists():
        try:
            user_actions_md = user_actions_path.read_text(encoding="utf-8", errors="replace")
        except Exception:
            user_actions_md = ""
    finalize = _load_json(finalize_path)
    user_actions = finalize.get("user_actions") if isinstance(finalize, dict) else []
    if not isinstance(user_actions, list):
        user_actions = []
    disk_resolutions = _load_json(resolutions_path)
    if not isinstance(disk_resolutions, dict):
        disk_resolutions = {}
    meta = state.get("meta") if isinstance(state, dict) else {}
    state_resolutions = meta.get("user_action_resolutions") if isinstance(meta, dict) else {}
    if not isinstance(state_resolutions, dict):
        state_resolutions = {}
    resolved_states = {"satisfied", "accepted_blocked", "waived", "resolved"}
    unresolved = []
    for action in user_actions:
        if not isinstance(action, dict):
            continue
        action_id = action.get("id")
        if not isinstance(action_id, str) or not action_id:
            continue
        disk_resolution = disk_resolutions.get(action_id)
        state_resolution = state_resolutions.get(action_id)
        resolution_state = ""
        for resolution in (disk_resolution, state_resolution):
            if isinstance(resolution, dict) and resolution.get("state"):
                resolution_state = str(resolution.get("state"))
                break
        if resolution_state not in resolved_states:
            unresolved.append(
                {
                    "id": action_id,
                    "phase": action.get("phase") or "",
                    "blocks_task_ids": action.get("blocks_task_ids") if isinstance(action.get("blocks_task_ids"), list) else [],
                    "resolution_state": resolution_state or "unresolved",
                    "summary": action.get("summary") or action.get("description") or action.get("question") or "",
                    "rationale": action.get("rationale") or action.get("reason") or "",
                    "has_disk_resolution": action_id in disk_resolutions,
                    "has_state_resolution": action_id in state_resolutions,
                }
            )
    return {
        "plan_dir": str(plan_dir),
        "finalize_path": str(finalize_path) if finalize_path.exists() else "",
        "user_actions_path": str(user_actions_path) if user_actions_path.exists() else "",
        "user_actions_md": user_actions_md[:12000],
        "user_actions_truncated": len(user_actions_md) > 12000,
        "resolutions_path": str(resolutions_path) if resolutions_path.exists() else "",
        "disk_resolutions": disk_resolutions,
        "state_resolutions": state_resolutions,
        "unresolved_user_actions": unresolved,
    }

def _repair_data_summary(session):
    repair_data_dir = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_REPAIR_DATA_DIR", "/workspace/.megaplan/cloud-sessions/repair-data"))
    path = repair_data_dir / f"{session}.repair-data.json"
    if not path.exists():
        return {"path": str(path), "exists": False}
    payload = _load_json(path)
    attempts = payload.get("attempts") if isinstance(payload, dict) else []
    if not isinstance(attempts, list):
        attempts = []
    iterations = payload.get("iterations") if isinstance(payload, dict) else []
    if not isinstance(iterations, list):
        iterations = []
    summarized_iterations = []
    failure_signatures = {}
    for item in iterations[-8:]:
        if not isinstance(item, dict):
            continue
        chain_state = item.get("chain_state_summary") if isinstance(item.get("chain_state_summary"), dict) else {}
        failure = item.get("plan_latest_failure") if isinstance(item.get("plan_latest_failure"), dict) else {}
        stderr = ""
        metadata = failure.get("metadata") if isinstance(failure.get("metadata"), dict) else {}
        if isinstance(metadata, dict):
            stderr = str(metadata.get("stderr") or "")[:1200]
        signature = "|".join(
            str(value or "")
            for value in (
                chain_state.get("current_plan_name"),
                chain_state.get("last_state"),
                failure.get("kind"),
                failure.get("message"),
                stderr[:160],
            )
        )
        if signature.strip("|"):
            failure_signatures[signature] = failure_signatures.get(signature, 0) + 1
        summarized_iterations.append(
            {
                "i": item.get("i"),
                "mechanical_launch": item.get("mechanical_launch") or item.get("kimi_launch") or "",
                "mechanical_detail": item.get("mechanical_detail") or item.get("why") or "",
                "failure_classification": item.get("failure_classification") or "",
                "chain_last_state": chain_state.get("last_state") or "",
                "chain_current_plan": chain_state.get("current_plan_name") or "",
                "chain_current_milestone_index": chain_state.get("current_milestone_index"),
                "chain_completed_count": chain_state.get("completed_count"),
                "latest_failure_kind": failure.get("kind") or "",
                "latest_failure_message": failure.get("message") or "",
                "latest_failure_stderr": stderr,
                "dev_classification": (item.get("dev_report") or {}).get("classification") if isinstance(item.get("dev_report"), dict) else "",
                "kimi_classification": (item.get("kimi_report") or {}).get("classification") if isinstance(item.get("kimi_report"), dict) else "",
                "structural_pattern": item.get("structural_pattern") or "",
                "human_review_recommendation": item.get("human_review_recommendation") or "",
            }
        )
    repeated = [
        {"signature": signature[:400], "count": count}
        for signature, count in sorted(failure_signatures.items(), key=lambda pair: pair[1], reverse=True)
        if count >= 2
    ]
    return {
        "path": str(path),
        "exists": True,
        "mtime_age_min": int((now.timestamp() - _mtime(path)) // 60) if _mtime(path) else None,
        "outcome": payload.get("outcome") if isinstance(payload, dict) else "",
        "current_attempt_id": payload.get("current_attempt_id") if isinstance(payload, dict) else "",
        "attempt_count": len(attempts),
        "attempt_ids": (
            [
                str(item.get("attempt_id") or item.get("id") or "").strip()
                for item in attempts[-8:]
                if isinstance(item, dict) and str(item.get("attempt_id") or item.get("id") or "").strip()
            ]
            or (payload.get("attempt_ids") if isinstance(payload, dict) and isinstance(payload.get("attempt_ids"), list) else [])
        ),
        "repair_run_count": payload.get("repair_run_count") if isinstance(payload, dict) else None,
        "iteration_count": len(iterations),
        "iterations": summarized_iterations,
        "repeated_failure_signatures": repeated[:6],
    }

def _repair_custody_summary(session, plan_state, current_target):
    repair_data_dir = pathlib.Path(
        os.environ.get(
            "MEGAPLAN_AUDIT_REPAIR_DATA_DIR",
            "/workspace/.megaplan/cloud-sessions/repair-data",
        )
    )
    target = dict(current_target) if isinstance(current_target, dict) else {}
    target.setdefault("session", session)
    target.setdefault("target_session", session)
    malformed_requests = [
        item
        for item in iter_repair_requests(REPAIR_QUEUE_ROOT, include_malformed=True)
        if item.get("kind") == "malformed_repair_request"
    ]
    malformed_decisions = [
        item
        for item in iter_repair_decisions(REPAIR_QUEUE_ROOT, include_malformed=True)
        if item.get("kind") == "malformed_repair_decision"
    ]
    if project_repair_custody is None or not repair_request_runtime_available:
        return {
            "queue_root": str(REPAIR_QUEUE_ROOT),
            "projection_error": "installed runtime lacks repair custody projection support",
            "malformed_request_count": len(malformed_requests),
            "malformed_decision_count": len(malformed_decisions),
        }
    try:
        projection = project_repair_custody(
            plan_state=plan_state if isinstance(plan_state, dict) else {},
            current_target=target,
            queue_root=REPAIR_QUEUE_ROOT,
            repair_data_dir=repair_data_dir,
        )
    except Exception as exc:
        return {
            "queue_root": str(REPAIR_QUEUE_ROOT),
            "projection_error": _redact_scalar(exc),
            "malformed_request_count": len(malformed_requests),
            "malformed_decision_count": len(malformed_decisions),
        }
    return {
        "queue_root": str(REPAIR_QUEUE_ROOT),
        "blocker_id": projection.get("blocker_id") or "",
        "active_request_ids": projection.get("active_request_ids") or [],
        "accepted_unclaimed_request_ids": projection.get("accepted_unclaimed_request_ids") or [],
        "request_status_counts": projection.get("request_status_counts") or {},
        "claim_count": projection.get("claim_count") or 0,
        "attempt_count": projection.get("attempt_count") or 0,
        "claim_retry_counts": projection.get("claim_retry_counts") or {},
        "claim_alert_request_ids": projection.get("claim_alert_request_ids") or [],
        "retry_budget": projection.get("retry_budget") or {},
        "terminal_outcomes": projection.get("terminal_outcomes") or [],
        "malformed_request_count": len(malformed_requests),
        "malformed_decision_count": len(malformed_decisions),
        "malformed_request_paths": [item.get("path") for item in malformed_requests[:3]],
        "malformed_decision_paths": [item.get("path") for item in malformed_decisions[:3]],
    }

def _load_events(events_path):
    events = []
    try:
        lines = events_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return events
    for line in lines:
        if not line.strip():
            continue
        try:
            event = json.loads(line)
        except Exception:
            continue
        if isinstance(event, dict):
            events.append(event)
    return events

def _event_timestamp(event):
    for key in ("ts_utc", "timestamp_utc", "timestamp", "recorded_at", "created_at"):
        when = _parse_iso(event.get(key))
        if when is not None:
            return when
    payload = event.get("payload")
    if isinstance(payload, dict):
        for key in ("ts_utc", "timestamp_utc", "timestamp", "recorded_at", "created_at"):
            when = _parse_iso(payload.get(key))
            if when is not None:
                return when
    return None

def _event_seq(event):
    for key in ("seq", "event_seq", "sequence"):
        value = event.get(key)
        try:
            if value is not None:
                return int(value)
        except (TypeError, ValueError):
            pass
    return None

def _failure_seq(latest_failure):
    if not isinstance(latest_failure, dict):
        return None
    candidates = [
        latest_failure.get("seq"),
        latest_failure.get("event_seq"),
        latest_failure.get("sequence"),
    ]
    metadata = latest_failure.get("metadata")
    if isinstance(metadata, dict):
        candidates.extend([metadata.get("seq"), metadata.get("event_seq"), metadata.get("sequence")])
    for value in candidates:
        try:
            if value is not None:
                return int(value)
        except (TypeError, ValueError):
            continue
    return None

def _success_value(value):
    return str(value or "").strip().lower() in {
        "success",
        "succeeded",
        "done",
        "proceed",
        "pass",
        "passed",
        "ok",
        "complete",
        "completed",
        "finished",
        "executed",
        "finalized",
    }

def _successful_event(event):
    kind = str(event.get("kind") or event.get("event_type") or "").strip().lower()
    payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
    phase = str(event.get("phase") or payload.get("phase") or "").strip().lower()
    if kind == "phase_end":
        return any(
            _success_value(event.get(key)) or _success_value(payload.get(key))
            for key in ("exit_kind", "status", "result", "state", "recommendation", "verdict")
        )
    if kind == "plan_finished":
        return True
    if kind in {"gate", "gate_result", "quality_gate", "phase_end"}:
        if _success_value(payload.get("recommendation") or event.get("recommendation")):
            return True
    if phase == "gate" and _success_value(payload.get("recommendation") or event.get("recommendation")):
        return True
    for key in ("exit_kind", "status", "result", "state", "recommendation", "verdict"):
        if _success_value(event.get(key)) or _success_value(payload.get(key)):
            return True
    return False

def _event_excerpt(event):
    payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
    return {
        "seq": _event_seq(event),
        "ts": (_event_timestamp(event).isoformat().replace("+00:00", "Z") if _event_timestamp(event) else ""),
        "kind": event.get("kind") or event.get("event_type") or "",
        "phase": event.get("phase") or payload.get("phase") or "",
        "status": event.get("status") or event.get("result") or payload.get("status") or payload.get("result") or payload.get("exit_kind") or "",
        "recommendation": event.get("recommendation") or payload.get("recommendation") or "",
    }


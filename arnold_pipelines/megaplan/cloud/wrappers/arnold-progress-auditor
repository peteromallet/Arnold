def _user_action_context(plan_dir, state):
    user_actions_path = plan_dir / "user_actions.md"
    resolutions_path = plan_dir / "user_action_resolutions.json"
    finalize_path = plan_dir / "finalize.json"
    user_actions_md = ""
    if user_actions_path.exists():
        try:
            user_actions_md = user_actions_path.read_text(encoding="utf-8", errors="replace")
        except Exception:
            user_actions_md = ""
    finalize = _load_json(finalize_path)
    user_actions = finalize.get("user_actions") if isinstance(finalize, dict) else []
    if not isinstance(user_actions, list):
        user_actions = []
    disk_resolutions = _load_json(resolutions_path)
    if not isinstance(disk_resolutions, dict):
        disk_resolutions = {}
    meta = state.get("meta") if isinstance(state, dict) else {}
    state_resolutions = meta.get("user_action_resolutions") if isinstance(meta, dict) else {}
    if not isinstance(state_resolutions, dict):
        state_resolutions = {}
    resolved_states = {"satisfied", "accepted_blocked", "waived", "resolved"}
    unresolved = []
    for action in user_actions:
        if not isinstance(action, dict):
            continue
        action_id = action.get("id")
        if not isinstance(action_id, str) or not action_id:
            continue
        disk_resolution = disk_resolutions.get(action_id)
        state_resolution = state_resolutions.get(action_id)
        resolution_state = ""
        for resolution in (disk_resolution, state_resolution):
            if isinstance(resolution, dict) and resolution.get("state"):
                resolution_state = str(resolution.get("state"))
                break
        if resolution_state not in resolved_states:
            unresolved.append(
                {
                    "id": action_id,
                    "phase": action.get("phase") or "",
                    "blocks_task_ids": action.get("blocks_task_ids") if isinstance(action.get("blocks_task_ids"), list) else [],
                    "resolution_state": resolution_state or "unresolved",
                    "summary": action.get("summary") or action.get("description") or action.get("question") or "",
                    "rationale": action.get("rationale") or action.get("reason") or "",
                    "has_disk_resolution": action_id in disk_resolutions,
                    "has_state_resolution": action_id in state_resolutions,
                }
            )
    return {
        "plan_dir": str(plan_dir),
        "finalize_path": str(finalize_path) if finalize_path.exists() else "",
        "user_actions_path": str(user_actions_path) if user_actions_path.exists() else "",
        "user_actions_md": user_actions_md[:12000],
        "user_actions_truncated": len(user_actions_md) > 12000,
        "resolutions_path": str(resolutions_path) if resolutions_path.exists() else "",
        "disk_resolutions": disk_resolutions,
        "state_resolutions": state_resolutions,
        "unresolved_user_actions": unresolved,
    }

def _repair_data_summary(session):
    repair_data_dir = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_REPAIR_DATA_DIR", "/workspace/.megaplan/cloud-sessions/repair-data"))
    path = repair_data_dir / f"{session}.repair-data.json"
    if not path.exists():
        return {"path": str(path), "exists": False}
    payload = _load_json(path)
    iterations = payload.get("iterations") if isinstance(payload, dict) else []
    if not isinstance(iterations, list):
        iterations = []
    summarized_iterations = []
    failure_signatures = {}
    for item in iterations[-8:]:
        if not isinstance(item, dict):
            continue
        chain_state = item.get("chain_state_summary") if isinstance(item.get("chain_state_summary"), dict) else {}
        failure = item.get("plan_latest_failure") if isinstance(item.get("plan_latest_failure"), dict) else {}
        stderr = ""
        metadata = failure.get("metadata") if isinstance(failure.get("metadata"), dict) else {}
        if isinstance(metadata, dict):
            stderr = str(metadata.get("stderr") or "")[:1200]
        signature = "|".join(
            str(value or "")
            for value in (
                chain_state.get("current_plan_name"),
                chain_state.get("last_state"),
                failure.get("kind"),
                failure.get("message"),
                stderr[:160],
            )
        )
        if signature.strip("|"):
            failure_signatures[signature] = failure_signatures.get(signature, 0) + 1
        summarized_iterations.append(
            {
                "i": item.get("i"),
                "mechanical_launch": item.get("mechanical_launch") or item.get("kimi_launch") or "",
                "mechanical_detail": item.get("mechanical_detail") or item.get("why") or "",
                "failure_classification": item.get("failure_classification") or "",
                "chain_last_state": chain_state.get("last_state") or "",
                "chain_current_plan": chain_state.get("current_plan_name") or "",
                "chain_current_milestone_index": chain_state.get("current_milestone_index"),
                "chain_completed_count": chain_state.get("completed_count"),
                "latest_failure_kind": failure.get("kind") or "",
                "latest_failure_message": failure.get("message") or "",
                "latest_failure_stderr": stderr,
                "dev_classification": (item.get("dev_report") or {}).get("classification") if isinstance(item.get("dev_report"), dict) else "",
                "kimi_classification": (item.get("kimi_report") or {}).get("classification") if isinstance(item.get("kimi_report"), dict) else "",
                "structural_pattern": item.get("structural_pattern") or "",
                "human_review_recommendation": item.get("human_review_recommendation") or "",
            }
        )
    repeated = [
        {"signature": signature[:400], "count": count}
        for signature, count in sorted(failure_signatures.items(), key=lambda pair: pair[1], reverse=True)
        if count >= 2
    ]
    return {
        "path": str(path),
        "exists": True,
        "mtime_age_min": int((now.timestamp() - _mtime(path)) // 60) if _mtime(path) else None,
        "outcome": payload.get("outcome") if isinstance(payload, dict) else "",
        "iteration_count": len(iterations),
        "iterations": summarized_iterations,
        "repeated_failure_signatures": repeated[:6],
    }

def _load_events(events_path):
    events = []
    try:
        lines = events_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return events
    for line in lines:
        if not line.strip():
            continue
        try:
            event = json.loads(line)
        except Exception:
            continue
        if isinstance(event, dict):
            events.append(event)
    return events

def _event_timestamp(event):
    for key in ("ts_utc", "timestamp_utc", "timestamp", "recorded_at", "created_at"):
        when = _parse_iso(event.get(key))
        if when is not None:
            return when
    payload = event.get("payload")
    if isinstance(payload, dict):
        for key in ("ts_utc", "timestamp_utc", "timestamp", "recorded_at", "created_at"):
            when = _parse_iso(payload.get(key))
            if when is not None:
                return when
    return None

def _event_seq(event):
    for key in ("seq", "event_seq", "sequence"):
        value = event.get(key)
        try:
            if value is not None:
                return int(value)
        except (TypeError, ValueError):
            pass
    return None

def _failure_seq(latest_failure):
    if not isinstance(latest_failure, dict):
        return None
    candidates = [
        latest_failure.get("seq"),
        latest_failure.get("event_seq"),
        latest_failure.get("sequence"),
    ]
    metadata = latest_failure.get("metadata")
    if isinstance(metadata, dict):
        candidates.extend([metadata.get("seq"), metadata.get("event_seq"), metadata.get("sequence")])
    for value in candidates:
        try:
            if value is not None:
                return int(value)
        except (TypeError, ValueError):
            continue
    return None

def _success_value(value):
    return str(value or "").strip().lower() in {
        "success",
        "succeeded",
        "done",
        "proceed",
        "pass",
        "passed",
        "ok",
        "complete",
        "completed",
        "finished",
        "executed",
        "finalized",
    }

def _successful_event(event):
    kind = str(event.get("kind") or event.get("event_type") or "").strip().lower()
    payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
    phase = str(event.get("phase") or payload.get("phase") or "").strip().lower()
    if kind == "phase_end":
        return any(
            _success_value(event.get(key)) or _success_value(payload.get(key))
            for key in ("exit_kind", "status", "result", "state", "recommendation", "verdict")
        )
    if kind == "plan_finished":
        return True
    if kind in {"gate", "gate_result", "quality_gate", "phase_end"}:
        if _success_value(payload.get("recommendation") or event.get("recommendation")):
            return True
    if phase == "gate" and _success_value(payload.get("recommendation") or event.get("recommendation")):
        return True
    for key in ("exit_kind", "status", "result", "state", "recommendation", "verdict"):
        if _success_value(event.get(key)) or _success_value(payload.get(key)):
            return True
    return False

def _event_excerpt(event):
    payload = event.get("payload") if isinstance(event.get("payload"), dict) else {}
    return {
        "seq": _event_seq(event),
        "ts": (_event_timestamp(event).isoformat().replace("+00:00", "Z") if _event_timestamp(event) else ""),
        "kind": event.get("kind") or event.get("event_type") or "",
        "phase": event.get("phase") or payload.get("phase") or "",
        "status": event.get("status") or event.get("result") or payload.get("status") or payload.get("result") or payload.get("exit_kind") or "",
        "recommendation": event.get("recommendation") or payload.get("recommendation") or "",
    }

def _latest_failure_staleness(latest_failure, events_path):
    if not isinstance(latest_failure, dict) or not latest_failure:
        return {
            "latest_failure_is_stale": False,
            "last_success_after_failure": "",
            "last_success_after_failure_event": {},
        }
    failure_ts = _parse_iso(latest_failure.get("recorded_at") or latest_failure.get("timestamp") or latest_failure.get("ts_utc"))
    failure_event_seq = _failure_seq(latest_failure)
    last_success = None
    for event in _load_events(events_path):
        if not _successful_event(event):
            continue
        event_ts = _event_timestamp(event)
        event_seq = _event_seq(event)
        after_by_ts = failure_ts is not None and event_ts is not None and event_ts > failure_ts
        after_by_seq = failure_event_seq is not None and event_seq is not None and event_seq > failure_event_seq
        if not after_by_ts and not after_by_seq:
            continue
        if last_success is None:
            last_success = event
            continue
        last_ts = _event_timestamp(last_success)
        last_seq = _event_seq(last_success)
        if event_ts is not None and (last_ts is None or event_ts > last_ts):
            last_success = event
        elif event_ts is None and event_seq is not None and (last_seq is None or event_seq > last_seq):
            last_success = event
    if last_success is None:
        return {
            "latest_failure_is_stale": False,
            "last_success_after_failure": "",
            "last_success_after_failure_event": {},
        }
    excerpt = _event_excerpt(last_success)
    return {
        "latest_failure_is_stale": True,
        "last_success_after_failure": excerpt.get("ts") or (str(excerpt.get("seq")) if excerpt.get("seq") is not None else ""),
        "last_success_after_failure_event": excerpt,
    }

def _blocked_history_entry(item):
    if not isinstance(item, dict):
        return False
    result = str(item.get("result") or item.get("status") or "").strip().lower()
    if "blocked" not in result:
        return False
    try:
        duration = int(item.get("duration_ms") or 0)
    except (TypeError, ValueError):
        return False
    return duration == 0 and bool(item.get("artifact_hash"))

def _stale_block_replay(history, chain_log, chain_state, run_kind):
    by_hash = {}
    for item in (history if isinstance(history, list) else []):
        if not _blocked_history_entry(item):
            continue
        artifact_hash = str(item.get("artifact_hash") or "")
        by_hash.setdefault(artifact_hash, []).append(item)
    repeated = []
    for artifact_hash, items in sorted(by_hash.items(), key=lambda pair: len(pair[1]), reverse=True):
        if len(items) < 2:
            continue
        repeated.append(
            {
                "artifact_hash": artifact_hash,
                "count": len(items),
                "timestamps": [
                    str(item.get("timestamp") or item.get("completed_at") or "")
                    for item in items[-5:]
                ],
                "step": items[-1].get("step") or "",
                "output_file": items[-1].get("output_file") or "",
            }
        )
    if run_kind == "plan":
        chain_exits = True
    else:
        chain_exits = bool((chain_log or {}).get("recent_stops")) or (chain_state or {}).get("last_state") in {
            "awaiting_human",
            "blocked",
            "stopped",
        }
    return {
        "stale_block_replay": bool(repeated and chain_exits),
        "stale_block_replay_hash": repeated[0]["artifact_hash"] if repeated else "",
        "stale_block_replay_count": repeated[0]["count"] if repeated else 0,
        "stale_block_replay_entries": repeated[:3],
    }

def _between_milestone_cycling(chain_log, chain_state, repair_data):
    current = chain_state or {}
    try:
        completed_count = int(current.get("completed_count") or 0)
    except (TypeError, ValueError):
        completed_count = 0
    cycles = (chain_log or {}).get("one_milestone_stop_cycles") or []
    repair_iterations = int((repair_data or {}).get("iteration_count") or 0)
    repair_completed = [
        item.get("chain_completed_count")
        for item in ((repair_data or {}).get("iterations") or [])
        if item.get("chain_completed_count") is not None
    ]
    one_step_repair_advances = 0
    for prev, cur in zip(repair_completed, repair_completed[1:]):
        try:
            if int(cur) - int(prev) == 1:
                one_step_repair_advances += 1
        except (TypeError, ValueError):
            continue
    repeated_relaunch = repair_iterations >= 2 or len((chain_log or {}).get("recent_stops") or []) >= 2
    cycling = completed_count >= 2 and repeated_relaunch and (len(cycles) >= 2 or one_step_repair_advances >= 1)
    return {
        "between_milestone_cycling": cycling,
        "one_milestone_stop_cycle_count": len(cycles),
        "one_milestone_stop_cycles": cycles[-4:],
        "repair_one_milestone_advances": one_step_repair_advances,
    }

def _stale_state_evidence(plan_latest_failure, latest_failure, events_path, history, chain_log, chain_state, repair_data, run_kind):
    evidence = _latest_failure_staleness(latest_failure, events_path)
    evidence.update(_stale_block_replay(history, chain_log, chain_state, run_kind))
    if run_kind == "chain":
        evidence.update(_between_milestone_cycling(chain_log, chain_state, repair_data))
    else:
        evidence.update(
            {
                "between_milestone_cycling": False,
                "one_milestone_stop_cycle_count": 0,
                "one_milestone_stop_cycles": [],
                "repair_one_milestone_advances": 0,
            }
        )
    clear_actions = []
    if evidence.get("latest_failure_is_stale"):
        clear_actions.append(f"set {plan_latest_failure.get('state_path')} latest_failure to null")
    if evidence.get("stale_block_replay"):
        clear_actions.append("clear or quarantine stale blocked phase/task artifacts before re-driving")
    if evidence.get("between_milestone_cycling"):
        clear_actions.append("fix/re-drive chain so it advances continuously instead of one milestone per relaunch")
    evidence["recommended_state_clear_actions"] = clear_actions
    return evidence

def _incident_live_snapshot(

        custody.get("claim_alert_request_ids")
    )
    stale_records = []
    for record in records if isinstance(records, list) else []:
        if not isinstance(record, dict):
            continue
        created_at = str(record.get("created_at") or "").strip()
        try:
            created = dt.datetime.fromisoformat(created_at.replace("Z", "+00:00"))
            age_min = int((now - created.astimezone(dt.timezone.utc)).total_seconds() // 60)
        except (TypeError, ValueError):
            age_min = None
        if custody_exhausted or age_min is None or age_min >= 5:
            stale_records.append((record, age_min))
    if stale_records:
        record, age_min = stale_records[0]
        return (
            "queue_coalesced_without_live_owner: duplicate repair request was coalesced "
            "onto an owner with no durable claim or nonterminal attempt "
            f"owner_request_id={record.get('related_request_id') or 'unknown'} "

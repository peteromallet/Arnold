def _normalize_stage_metric_phase(phase):
    token = (phase or "").strip().lower()
    if not token:
        return ""
    token = token.replace(".", "_").replace("-", "_").replace(" ", "_")
    while "__" in token:
        token = token.replace("__", "_")
    return token.strip("_")

def _map_phase_to_stage(phase):
    normalized = _normalize_stage_metric_phase(phase)
    if not normalized:
        return None
    stage = _STAGE_METRIC_PHASE_EXACT.get(normalized)
    if stage:
        return stage
    for prefix, candidate in _STAGE_METRIC_PHASE_PREFIXES:
        if normalized.startswith(prefix):
            return candidate
    return None

def _stage_metric_bucket():
    bucket = {}
    for counter in STAGE_METRIC_COUNTERS:
        bucket[counter] = 0
        bucket[f"{counter}_evidence"] = []
    return bucket

def _stage_metrics_template():
    return {
        **{stage: _stage_metric_bucket() for stage in STAGE_METRIC_STAGES},
        "unknown_phase_count": 0,
        "unknown_phase_evidence": [],
    }

def _stage_metric_ref(ref_type, value, **extra):
    ref = {"type": ref_type, "value": value}
    for key, extra_value in extra.items():
        if extra_value in (None, "", [], {}):
            continue
        ref[key] = extra_value
    return ref

def _unknown_stage_phase_refs(entry, phase):
    refs = []
    normalized = _normalize_stage_metric_phase(phase)
    if normalized:
        refs.append(_stage_metric_ref("phase_name", normalized, source="active_step_phase"))
    refs.append(_stage_metric_ref("plan", entry.get("plan") or ""))
    refs.append(_stage_metric_ref("workspace", entry.get("workspace") or ""))
    refs.append(_stage_metric_ref("session_id", entry.get("session") or ""))
    refs.append(_stage_metric_ref("file_path", entry.get("state_path") or ""))
    return [ref for ref in refs if ref.get("value")]

def _append_stage_metric(bucket, counter, amount, *refs):
    try:
        delta = int(amount or 0)
    except (TypeError, ValueError):
        delta = 0
    if delta <= 0:
        return
    bucket[counter] += delta
    evidence_key = f"{counter}_evidence"
    seen = {
        json.dumps(item, sort_keys=True)
        for item in bucket.get(evidence_key, [])
        if isinstance(item, dict)
    }
    for ref in refs:
        if not isinstance(ref, dict):
            continue
        marker = json.dumps(ref, sort_keys=True)
        if marker in seen:
            continue
        bucket[evidence_key].append(ref)
        seen.add(marker)

def _resolve_event_phase(events):
    """Walk events in reverse chronological order to find the most recent phase-bearing event.

    Returns (phase_name, kind, timestamp) or (\"\", \"\", None) when no phase event exists.
    ``llm_token_heartbeat`` events indicate active LLM work; they do not carry a phase
    name but are evidence that the most recent phase_start is still in-flight.
    """
    sorted_events = sorted(
        events, key=lambda e: _event_timestamp(e) or 0, reverse=True
    )
    last_heartbeat_ts = None
    for event in sorted_events:
        kind = str(event.get("kind") or event.get("event_type") or "").strip().lower()
        ts = _event_timestamp(event)
        if kind == "llm_token_heartbeat":
            if last_heartbeat_ts is None:
                last_heartbeat_ts = ts
            continue
        if kind in ("phase_start", "phase_end", "state_transition"):
            payload = event.get("payload") or {}
            phase = (payload.get("phase") or "").strip()
            if not phase:
                phase = (event.get("phase") or "").strip()
            if phase:
                return _normalize_stage_metric_phase(phase), kind, ts
        # Other event kinds that may carry phase info
        payload = event.get("payload") or {}
        phase = (payload.get("phase") or "").strip()
        if phase:
            return _normalize_stage_metric_phase(phase), kind, ts
    return "", "", None


def _build_stage_metrics(entries, stall_summary="none"):
    stage_metrics = _stage_metrics_template()
    events_cache = {}  # events_path_str -> list of events

    for entry in (entries if isinstance(entries, list) else []):
        if not isinstance(entry, dict):
            continue

        # ── derive events path from state_path ──────────────────────────
        state_path = entry.get("state_path") or ""
        events_path_str = ""
        events = []
        if state_path:
            try:
                events_path_obj = pathlib.Path(state_path).parent / "events.ndjson"
                events_path_str = str(events_path_obj)
            except Exception:
                pass

        # Load events once per plan (dedup by path)
        if events_path_str:
            if events_path_str not in events_cache:
                events_cache[events_path_str] = _load_events(pathlib.Path(events_path_str))
            events = events_cache.get(events_path_str, [])

        # ── active_event_phase from event telemetry ─────────────────────
        if events:
            active_phase, phase_kind, phase_ts = _resolve_event_phase(events)
            if active_phase:
                entry["active_event_phase"] = active_phase
                entry["active_event_phase_stage"] = _map_phase_to_stage(active_phase)
                entry["active_event_phase_kind"] = phase_kind
                if phase_ts is not None:
                    entry["active_event_phase_ts"] = phase_ts.isoformat() if isinstance(phase_ts, dt.datetime) else str(phase_ts)

        if not events:
            # No events file – fall back to state-based unknown detection
            phase = entry.get("active_step_phase")
            if phase:
                stage = _map_phase_to_stage(phase)
                if not stage:
                    stage_metrics["unknown_phase_count"] += 1
                    stage_metrics["unknown_phase_evidence"].append(
                        {
                            "phase": _normalize_stage_metric_phase(phase),
                            "refs": _unknown_stage_phase_refs(entry, phase),
                        }
                    )
        else:
            # ── collect phase_start / phase_end pairs ───────────────────────
            phase_starts = {}  # phase_name -> [(ts, event), ...]
            phase_ends = {}    # phase_name -> [(ts, event), ...]

            for event in events:
                kind = str(event.get("kind") or event.get("event_type") or "").strip().lower()
                if kind not in ("phase_start", "phase_end"):
                    continue
                payload = event.get("payload") or {}
                phase = (payload.get("phase") or "").strip()
                if not phase:
                    phase = (event.get("phase") or "").strip()
                if not phase:
                    continue
                ts = _event_timestamp(event)
                if kind == "phase_start":
                    phase_starts.setdefault(phase, []).append((ts, event))
                else:
                    phase_ends.setdefault(phase, []).append((ts, event))

            all_phases = set(list(phase_starts.keys()) + list(phase_ends.keys()))

            for phase_name in sorted(all_phases):
                starts = sorted(phase_starts.get(phase_name, []), key=lambda x: x[0] or 0)
                ends = sorted(phase_ends.get(phase_name, []), key=lambda x: x[0] or 0)

                stage = _map_phase_to_stage(phase_name)
                normalized_phase = _normalize_stage_metric_phase(phase_name)

                # Greedy pairing: each start matched with the next end after it
                paired = []
                end_idx = 0
                for start_ts, start_ev in starts:
                    if start_ts is None:
                        continue
                    while end_idx < len(ends):
                        end_ts, end_ev = ends[end_idx]
                        if end_ts is not None and end_ts >= start_ts:
                            paired.append((start_ts, start_ev, end_ts, end_ev))
                            end_idx += 1
                            break
                        end_idx += 1

                # ── durations from paired events ─────────────────────────
                for start_ts, start_ev, end_ts, end_ev in paired:
                    duration = max(0, int((end_ts - start_ts).total_seconds()))
                    start_iso = start_ts.isoformat() if isinstance(start_ts, dt.datetime) else str(start_ts)
                    end_iso = end_ts.isoformat() if isinstance(end_ts, dt.datetime) else str(end_ts)
                    if stage:
                        bucket = stage_metrics[stage]
                        bucket["duration_seconds"] += duration
                        bucket["duration_seconds_evidence"].append(
                            _stage_metric_ref(
                                "phase_duration",
                                normalized_phase,
                                duration_seconds=duration,
                                start_ts=start_iso,
                                end_ts=end_iso,
                                source="events.ndjson",
                            )
                        )
                    else:
                        stage_metrics["unknown_phase_count"] += 1
                        stage_metrics["unknown_phase_evidence"].append(
                            {
                                "phase": normalized_phase,
                                "duration_seconds": duration,
                                "refs": [
                                    _stage_metric_ref(
                                        "phase_duration",
                                        normalized_phase,
                                        duration_seconds=duration,
                                        start_ts=start_iso,
                                        end_ts=end_iso,
                                        source="events.ndjson",
                                    ),
                                    *_unknown_stage_phase_refs(entry, phase_name),
                                ],
                            }
                        )

                # ── unpaired phase_start (missing phase_end) ─────────────
                for i in range(len(paired), len(starts)):
                    start_ts, start_ev = starts[i]
                    start_iso = start_ts.isoformat() if isinstance(start_ts, dt.datetime) else str(start_ts) if start_ts else ""
                    ev_ref = _stage_metric_ref(
                        "unpaired_phase_start",
                        normalized_phase,
                        timestamp=start_iso,
                        source="events.ndjson",
                    )
                    if stage:
                        bucket = stage_metrics[stage]
                        bucket["missing_evidence"] += 1
                        bucket["missing_evidence_evidence"].append(ev_ref)
                    else:
                        stage_metrics["unknown_phase_count"] += 1
                        stage_metrics["unknown_phase_evidence"].append(
                            {
                                "phase": normalized_phase,
                                "refs": [ev_ref, *_unknown_stage_phase_refs(entry, phase_name)],
                            }
                        )

                # ── unpaired phase_end (missing phase_start) ─────────────
                for i in range(len(paired), len(ends)):
                    end_ts, end_ev = ends[i]
                    end_iso = end_ts.isoformat() if isinstance(end_ts, dt.datetime) else str(end_ts) if end_ts else ""
                    ev_ref = _stage_metric_ref(
                        "unpaired_phase_end",
                        normalized_phase,
                        timestamp=end_iso,
                        source="events.ndjson",
                    )
                    if stage:
                        bucket = stage_metrics[stage]
                        bucket["missing_evidence"] += 1
                        bucket["missing_evidence_evidence"].append(ev_ref)
                    else:
                        stage_metrics["unknown_phase_count"] += 1
                        stage_metrics["unknown_phase_evidence"].append(
                            {
                                "phase": normalized_phase,
                                "refs": [ev_ref, *_unknown_stage_phase_refs(entry, phase_name)],
                            }
                        )

        # ── state-based unknown phases (phases in state but not in events) ──
        phase = entry.get("active_step_phase")
        if phase:
            stage = _map_phase_to_stage(phase)
            if not stage:
                already_recorded = any(
                    e.get("phase") == _normalize_stage_metric_phase(phase)
                    for e in stage_metrics["unknown_phase_evidence"]
                )
                if not already_recorded:
                    stage_metrics["unknown_phase_count"] += 1
                    stage_metrics["unknown_phase_evidence"].append(
                        {
                            "phase": _normalize_stage_metric_phase(phase),
                            "refs": _unknown_stage_phase_refs(entry, phase),
                        }
                    )

        repair_summary = entry.get("repair_data_summary") if isinstance(entry.get("repair_data_summary"), dict) else {}
        repair_bucket = stage_metrics["repair"]
        repair_attempt_count = int(repair_summary.get("attempt_count") or 0)
        if repair_attempt_count > 0:
            _append_stage_metric(
                repair_bucket,
                "repair_attempts",
                repair_attempt_count,
                _stage_metric_ref(
                    "repair_data",
                    repair_summary.get("path") or "",
                    source="repair-data",
                    session_id=entry.get("session") or "",
                    attempt_count=repair_attempt_count,
                    attempt_ids=(repair_summary.get("attempt_ids") or [])[:5],
                ),
            )
        for item in (repair_summary.get("repeated_failure_signatures") or []):
            if not isinstance(item, dict):
                continue
            repeats = max(0, int(item.get("count") or 0) - 1)
            if repeats <= 0:
                continue
            _append_stage_metric(
                repair_bucket,
                "retries",
                repeats,
                _stage_metric_ref(
                    "repeated_failure_signature",
                    (item.get("signature") or "")[:160],
                    source="repair-data",
                    path=repair_summary.get("path") or "",
                    occurrences=int(item.get("count") or 0),
                ),
            )

        meta_summary = entry.get("meta_repair_summary") if isinstance(entry.get("meta_repair_summary"), dict) else {}
        meta_bucket = stage_metrics["meta_repair"]
        meta_record_count = int(meta_summary.get("meta_record_count") or 0)
        meta_run_count = int(meta_summary.get("meta_run_log_count") or 0)
        meta_attempt_count = max(meta_record_count, meta_run_count)
        if meta_attempt_count > 0:
            meta_refs = [
                item.get("path")
                for item in (entry.get("meta_repair_refs") or [])
                if isinstance(item, dict) and item.get("path")
            ]
            run_refs = [
                item.get("path")
                for item in (meta_summary.get("meta_run_refs") or [])
                if isinstance(item, dict) and item.get("path")
            ]
            _append_stage_metric(
                meta_bucket,
                "meta_repair_attempts",
                meta_attempt_count,
                _stage_metric_ref(
                    "meta_repair_artifacts",
                    entry.get("session") or "",
                    source="meta-repair",
                    meta_record_count=meta_record_count,
                    meta_run_log_count=meta_run_count,
                    meta_record_paths=meta_refs[:3],
                    meta_run_paths=run_refs[:3],
                ),
            )

        if int(entry.get("recent_gate_iterate") or 0) > 0:
            _append_stage_metric(
                stage_metrics["gate"],
                "retries",
                int(entry.get("recent_gate_iterate") or 0),
                _stage_metric_ref(
                    "recent_gate_history",
                    entry.get("plan") or "",
                    source="state.json",
                    state_path=entry.get("state_path") or "",
                    iterate_count=int(entry.get("recent_gate_iterate") or 0),
                    total=int(entry.get("recent_gate_total") or 0),
                ),
            )

        chain_log = entry.get("chain_log") if isinstance(entry.get("chain_log"), dict) else {}
        chain_bucket = stage_metrics["chain"]
        for item in (chain_log.get("repetition_summary") or []):
            if not isinstance(item, dict):
                continue
            count = int(item.get("count") or 0)
            if count < 2:
                continue
            signature = str(item.get("signature") or "").strip()
            _append_stage_metric(
                chain_bucket,
                "retries",
                count - 1,
                _stage_metric_ref(
                    "chain_log_repetition",
                    signature,
                    source="chain_log",
                    path=chain_log.get("path") or "",
                    occurrences=count,
                    first_line=item.get("first_line"),
                    last_line=item.get("last_line"),
                ),
            )
        stop_cycles = chain_log.get("one_milestone_stop_cycles") or []
        if stop_cycles:
            last_cycle = stop_cycles[-1] if isinstance(stop_cycles[-1], dict) else {}
            _append_stage_metric(
                chain_bucket,
                "no_op_loops",
                len(stop_cycles),
                _stage_metric_ref(
                    "one_milestone_stop_cycles",
                    entry.get("plan") or "",
                    source="chain_log",
                    path=chain_log.get("path") or "",
                    cycle_count=len(stop_cycles),
                    start_line=last_cycle.get("start_line"),
                    stop_line=last_cycle.get("stop_line"),
                ),
            )

        stale_state = entry.get("stale_state_evidence") if isinstance(entry.get("stale_state_evidence"), dict) else {}
        if stale_state.get("stale_block_replay"):
            _append_stage_metric(
                chain_bucket,
                "no_op_loops",
                1,
                _stage_metric_ref(
                    "stale_block_replay",
                    entry.get("plan") or "",
                    source="state.json",
                    state_path=entry.get("state_path") or "",
                ),
            )
        if stale_state.get("between_milestone_cycling"):
            _append_stage_metric(
                chain_bucket,
                "no_op_loops",
                1,
                _stage_metric_ref(
                    "between_milestone_cycling",
                    entry.get("plan") or "",
                    source="chain_log",
                    path=chain_log.get("path") or "",
                    cycle_count=stale_state.get("one_milestone_stop_cycle_count"),
                    repair_advances=stale_state.get("repair_one_milestone_advances"),
                ),
            )

        human_bucket = stage_metrics["human_pr_ci"]
        unresolved_actions = (entry.get("user_action_context") or {}).get("unresolved_user_actions") or []
        if unresolved_actions:
            _append_stage_metric(
                human_bucket,
                "human_waits",
                len(unresolved_actions),
                _stage_metric_ref(
                    "unresolved_user_actions",
                    entry.get("plan") or "",
                    source="finalize.json",
                    action_ids=[str(item.get("id")) for item in unresolved_actions[:5] if item.get("id")],
                    finalize_path=(entry.get("user_action_context") or {}).get("finalize_path") or "",
                ),
            )
        chain_current = ((entry.get("chain_state_summary") or {}).get("current") if isinstance(entry.get("chain_state_summary"), dict) else {}) or {}
        chain_last_state = str(chain_current.get("last_state") or "").strip().lower()
        if chain_last_state == "awaiting_human":
            _append_stage_metric(
                human_bucket,
                "human_waits",
                1,
                _stage_metric_ref(
                    "chain_last_state",
                    "awaiting_human",
                    source="chain_state",
                    path=chain_current.get("path") or "",
                ),
            )
        if chain_last_state == "pr_closed":
            _append_stage_metric(
                human_bucket,
                "ci_waits",
                1,
                _stage_metric_ref(
                    "chain_last_state",
                    "pr_closed",
                    source="chain_state",
                    path=chain_current.get("path") or "",
                ),
            )
        pr_closed_repeat = next(
            (
                item for item in (chain_log.get("repetition_summary") or [])
                if isinstance(item, dict) and item.get("signature") == "pr_closed"
            ),
            None,
        )
        if isinstance(pr_closed_repeat, dict) and int(pr_closed_repeat.get("count") or 0) >= 2:
            _append_stage_metric(
                human_bucket,
                "ci_waits",
                int(pr_closed_repeat.get("count") or 0) - 1,
                _stage_metric_ref(
                    "chain_log_repetition",
                    "pr_closed",
                    source="chain_log",
                    path=chain_log.get("path") or "",
                    occurrences=int(pr_closed_repeat.get("count") or 0),
                    first_line=pr_closed_repeat.get("first_line"),
                    last_line=pr_closed_repeat.get("last_line"),
                ),
            )

        incident_audit = entry.get("incident_audit") if isinstance(entry.get("incident_audit"), dict) else {}
        incident_brief = entry.get("incident_brief") if isinstance(entry.get("incident_brief"), dict) else {}
        expected_handoff = incident_audit.get("next_expected_event") or incident_brief.get("next_expected_event") or ""
        incident_handoff_gap_count = int(entry.get("incident_handoff_gap_count") or 0)
        if incident_handoff_gap_count > 0:
            _append_stage_metric(
                chain_bucket,
                "handoff_gaps",
                incident_handoff_gap_count,
                *((entry.get("incident_handoff_gap_refs") or [])[:3] if isinstance(entry.get("incident_handoff_gap_refs"), list) else []),
            )
        incident_dead_worker_count = int(entry.get("incident_dead_worker_count") or 0)
        if incident_dead_worker_count > 0:
            _append_stage_metric(
                stage_metrics["deployment_runtime"],
                "dead_workers",
                incident_dead_worker_count,
                *((entry.get("incident_dead_worker_refs") or [])[:3] if isinstance(entry.get("incident_dead_worker_refs"), list) else []),
            )
        for finding in (incident_audit.get("findings") or []):
            if not isinstance(finding, dict) or finding.get("status") == "ok":
                continue
            code = str(finding.get("code") or "").strip()
            layer = str(finding.get("layer") or "").strip()
            recommendation = str(finding.get("recommendation") or "").strip()
            if incident_handoff_gap_count <= 0 and (layer == "stale_claim" or code == "stale_claim_detected"):
                handoff_amount = len(finding.get("claim_ids") or []) if isinstance(finding.get("claim_ids"), list) and finding.get("claim_ids") else 1
                _append_stage_metric(
                    chain_bucket,
                    "handoff_gaps",
                    handoff_amount,
                    _stage_metric_ref(
                        "incident_audit",
                        code or layer or "stale_claim",
                        source="incident_audit",
                        incident_id=incident_audit.get("incident_id") or incident_brief.get("incident_id") or "",
                        claim_ids=(finding.get("claim_ids") or [])[:5] if isinstance(finding.get("claim_ids"), list) else [],
                        next_expected_event=expected_handoff,
                    ),
                )
            elif incident_dead_worker_count <= 0 and code == "live_process_absent":
                _append_stage_metric(
                    stage_metrics["deployment_runtime"],
                    "dead_workers",
                    1,
                    _stage_metric_ref(
                        "incident_audit",
                        code,
                        source="incident_audit",
                        incident_id=incident_audit.get("incident_id") or incident_brief.get("incident_id") or "",
                        next_expected_event=recommendation or expected_handoff,
                    ),
                )

    # ── watchdog stall evidence ──────────────────────────────────────────
    if stall_summary and stall_summary != "none":
        stall_messages = [msg.strip() for msg in stall_summary.split(" ; ") if msg.strip()]
        if stall_messages:
            # Map each stall message to any plan entry it mentions
            entry_plan_names = {
                e.get("plan", ""): e
                for e in (entries if isinstance(entries, list) else [])
                if isinstance(e, dict) and e.get("plan")
            }
            matched_stalls = []
            unmatched_stalls = []
            for msg in stall_messages:
                matched = False
                for plan_name, plan_entry in entry_plan_names.items():
                    if plan_name in msg:
                        matched_stalls.append((msg, plan_entry))
                        matched = True
                        break
                if not matched:
                    unmatched_stalls.append(msg)

            # Count matched stalls in the chain stage (stalls are chain-level signals)
            chain_bucket = stage_metrics.setdefault("chain", _stage_metric_bucket())
            for msg, plan_entry in matched_stalls:
                _append_stage_metric(
                    chain_bucket,
                    "stalls",
                    1,
                    _stage_metric_ref(
                        "watchdog_stall",
                        msg[:200],
                        source="watchdog-report.json",
                        plan=plan_entry.get("plan") or "",
                        workspace=plan_entry.get("workspace") or "",
                        session_id=plan_entry.get("session") or "",
                    ),
                )

            # Unmatched stalls still go to chain stage
            for msg in unmatched_stalls:
                _append_stage_metric(
                    chain_bucket,
                    "stalls",
                    1,
                    _stage_metric_ref(
                        "watchdog_stall_unmatched",
                        msg[:200],
                        source="watchdog-report.json",
                    ),
                )

    # ── populate unknowns from unknown phase evidence ───────────────────
    unknown_count = stage_metrics.get("unknown_phase_count", 0)
    if unknown_count > 0:
        for stage_name in STAGE_METRIC_STAGES:
            bucket = stage_metrics.get(stage_name, {})
            if isinstance(bucket, dict) and "unknowns" in bucket:
                bucket["unknowns"] = max(bucket.get("unknowns", 0), unknown_count)

    return stage_metrics

def _latest_failure_staleness(latest_failure, events_path):
    if not isinstance(latest_failure, dict) or not latest_failure:
        return {
            "latest_failure_is_stale": False,
            "last_success_after_failure": "",
            "last_success_after_failure_event": {},
        }
    failure_ts = _parse_iso(latest_failure.get("recorded_at") or latest_failure.get("timestamp") or latest_failure.get("ts_utc"))
    failure_event_seq = _failure_seq(latest_failure)
    last_success = None
    for event in _load_events(events_path):
        if not _successful_event(event):
            continue
        event_ts = _event_timestamp(event)
        event_seq = _event_seq(event)
        after_by_ts = failure_ts is not None and event_ts is not None and event_ts > failure_ts
        after_by_seq = failure_event_seq is not None and event_seq is not None and event_seq > failure_event_seq
        if not after_by_ts and not after_by_seq:
            continue
        if last_success is None:
            last_success = event
            continue
        last_ts = _event_timestamp(last_success)
        last_seq = _event_seq(last_success)
        if event_ts is not None and (last_ts is None or event_ts > last_ts):
            last_success = event
        elif event_ts is None and event_seq is not None and (last_seq is None or event_seq > last_seq):
            last_success = event
    if last_success is None:
        return {
            "latest_failure_is_stale": False,
            "last_success_after_failure": "",
            "last_success_after_failure_event": {},
        }
    excerpt = _event_excerpt(last_success)
    return {
        "latest_failure_is_stale": True,
        "last_success_after_failure": excerpt.get("ts") or (str(excerpt.get("seq")) if excerpt.get("seq") is not None else ""),
        "last_success_after_failure_event": excerpt,
    }

def _blocked_history_entry(item):
    if not isinstance(item, dict):
        return False
    result = str(item.get("result") or item.get("status") or "").strip().lower()
    if "blocked" not in result:
        return False
    try:
        duration = int(item.get("duration_ms") or 0)
    except (TypeError, ValueError):
        return False
    return duration == 0 and bool(item.get("artifact_hash"))

def _stale_block_replay(history, chain_log, chain_state, run_kind):
    by_hash = {}
    for item in (history if isinstance(history, list) else []):
        if not _blocked_history_entry(item):
            continue
        artifact_hash = str(item.get("artifact_hash") or "")
        by_hash.setdefault(artifact_hash, []).append(item)
    repeated = []
    for artifact_hash, items in sorted(by_hash.items(), key=lambda pair: len(pair[1]), reverse=True):
        if len(items) < 2:
            continue
        repeated.append(
            {
                "artifact_hash": artifact_hash,
                "count": len(items),
                "timestamps": [
                    str(item.get("timestamp") or item.get("completed_at") or "")
                    for item in items[-5:]
                ],
                "step": items[-1].get("step") or "",
                "output_file": items[-1].get("output_file") or "",
            }
        )
    if run_kind == "plan":
        chain_exits = True
    else:
        chain_exits = bool((chain_log or {}).get("recent_stops")) or (chain_state or {}).get("last_state") in {
            "awaiting_human",
            "blocked",
            "stopped",
        }
    return {
        "stale_block_replay": bool(repeated and chain_exits),
        "stale_block_replay_hash": repeated[0]["artifact_hash"] if repeated else "",
        "stale_block_replay_count": repeated[0]["count"] if repeated else 0,
        "stale_block_replay_entries": repeated[:3],
    }

def _between_milestone_cycling(chain_log, chain_state, repair_data):
    current = chain_state or {}
    try:
        completed_count = int(current.get("completed_count") or 0)
    except (TypeError, ValueError):
        completed_count = 0
    cycles = (chain_log or {}).get("one_milestone_stop_cycles") or []
    repair_iterations = int((repair_data or {}).get("iteration_count") or 0)
    repair_completed = [
        item.get("chain_completed_count")
        for item in ((repair_data or {}).get("iterations") or [])
        if item.get("chain_completed_count") is not None
    ]
    one_step_repair_advances = 0
    for prev, cur in zip(repair_completed, repair_completed[1:]):
        try:
            if int(cur) - int(prev) == 1:
                one_step_repair_advances += 1
        except (TypeError, ValueError):
            continue
    repeated_relaunch = repair_iterations >= 2 or len((chain_log or {}).get("recent_stops") or []) >= 2
    cycling = completed_count >= 2 and repeated_relaunch and (len(cycles) >= 2 or one_step_repair_advances >= 1)
    return {
        "between_milestone_cycling": cycling,
        "one_milestone_stop_cycle_count": len(cycles),
        "one_milestone_stop_cycles": cycles[-4:],
        "repair_one_milestone_advances": one_step_repair_advances,
    }

def _stale_state_evidence(plan_latest_failure, latest_failure, events_path, history, chain_log, chain_state, repair_data, run_kind):
    evidence = _latest_failure_staleness(latest_failure, events_path)
    evidence.update(_stale_block_replay(history, chain_log, chain_state, run_kind))
    if run_kind == "chain":
        evidence.update(_between_milestone_cycling(chain_log, chain_state, repair_data))
    else:
        evidence.update(
            {
                "between_milestone_cycling": False,
                "one_milestone_stop_cycle_count": 0,
                "one_milestone_stop_cycles": [],
                "repair_one_milestone_advances": 0,
            }
        )
    clear_actions = []
    if evidence.get("latest_failure_is_stale"):
        clear_actions.append(f"set {plan_latest_failure.get('state_path')} latest_failure to null")
    if evidence.get("stale_block_replay"):
        clear_actions.append("clear or quarantine stale blocked phase/task artifacts before re-driving")
    if evidence.get("between_milestone_cycling"):
        clear_actions.append("fix/re-drive chain so it advances continuously instead of one milestone per relaunch")
    evidence["recommended_state_clear_actions"] = clear_actions
    return evidence

def _incident_live_snapshot(
    *,
    session,
    incident,
    problem,
    repair_data,
    prior_watchdog_report_refs,
    meta_repair_refs,
    attempt_refs,
    current_target=None,
    active_step_liveness=None,
):
    incident_session_ids = incident.get("session_ids") if isinstance(incident, dict) else []
    if not isinstance(incident_session_ids, list) or not incident_session_ids:
        incident_session_ids = [session]
    process_session_id = next((str(item) for item in incident_session_ids if item), session)
    processes = []
    tmux_process = current_target.get("tmux_process") if isinstance(current_target, dict) else {}
    if not isinstance(tmux_process, dict):
        tmux_process = {}
    tmux_pid = tmux_process.get("pid")
    if not isinstance(tmux_pid, int):
        tmux_pid = None
    tmux_evidence = {
        "session": tmux_process.get("session") or process_session_id,
        "pid": tmux_pid,
        "pid_live": tmux_process.get("pid_live") if isinstance(tmux_process.get("pid_live"), bool) else None,
        "session_live": tmux_process.get("session_live") if isinstance(tmux_process.get("session_live"), bool) else None,
        "live_status": str(tmux_process.get("live_status") or "").strip().lower(),
    }
    active_step_evidence = dict(active_step_liveness) if isinstance(active_step_liveness, dict) else {"present": False}
    live_evidence_sources = []
    if active_step_evidence.get("worker_pid_alive") is True:
        live_evidence_sources.append("active_step_pid")
    if tmux_evidence.get("pid_live") is True:
        live_evidence_sources.append("tmux_pid")
    if tmux_evidence.get("session_live") is True or tmux_evidence.get("live_status") == "alive":
        live_evidence_sources.append("tmux_session")
    if attempt_refs and live_evidence_sources:
        latest_attempt = attempt_refs[-1]
        processes.append(
            {
                "actor": "immediate_repair",
                "session_id": process_session_id,
                "started_at": latest_attempt.get("updated_at") or latest_attempt.get("created_at") or incident.get("last_timestamp"),
                "worker_pid": active_step_evidence.get("worker_pid") or tmux_pid,
                "live_evidence_sources": live_evidence_sources,
            }
        )
    snapshot = {
        "now": _now_iso(),
        "watchdog": {
            "last_reported_at": next(
                (item.get("timestamp_utc") for item in reversed(prior_watchdog_report_refs) if item.get("timestamp_utc")),
                None,
            ),
        },
        "github_sync": {
            "last_attempt_at": _publication_attempt_ts(incident, problem),
        },
        "immediate_repair": {
            "active_step_liveness": active_step_evidence,
            "tmux_process": tmux_evidence,
            "evidence_refs": attempt_refs,
        },
        "meta_repair": {
            "evidence_refs": meta_repair_refs,
        },
        "processes": processes,
        "corroboration": {
            "repair_iteration_count": repair_data.get("iteration_count"),
            "watchdog_report_count": len(prior_watchdog_report_refs),
            "attempt_ref_count": len(attempt_refs),
            "meta_repair_ref_count": len(meta_repair_refs),
        },
    }
    return snapshot

def _reconciler_reasons(incident_audit):
    findings = incident_audit.get("findings") if isinstance(incident_audit, dict) else []
    reasons = []
    for finding in findings if isinstance(findings, list) else []:
        if not isinstance(finding, dict):
            continue
        if finding.get("status") == "ok":
            continue
        if str(finding.get("code") or "").strip() == "DRIFT_DETECTED":
            drift_reason = str(finding.get("drift_reason") or "").strip()
            if drift_reason:
                reasons.append(drift_reason)
            else:
                reasons.append(
                    f"{finding.get('source_pair') or 'unknown_source_pair'}:"
                    f"{finding.get('contradiction') or 'unspecified_contradiction'}"
                )
            continue
        reasons.append(f"reconciler {finding.get('layer')}={finding.get('code')}: {finding.get('message')}")
    return reasons

def _chain_state_looks_terminal(chain_current):
    if not isinstance(chain_current, dict) or not chain_current:
        return False
    last_state = str(chain_current.get("last_state") or "").strip().lower()
    pr_state = str(chain_current.get("pr_state") or "").strip().lower()
    chain_complete = chain_current.get("chain_complete")
    if chain_complete is True:
        return True
    if last_state in {"done", "complete", "completed"} and pr_state in {"", "merged", "closed"}:
        total = chain_current.get("total_milestones")
        completed = chain_current.get("completed_count")
        if total in (None, "", 0) or completed in (None, ""):
            return True
        try:
            return int(completed) >= int(total)
        except (TypeError, ValueError):
            return True
    return False

def _chain_state_looks_nonterminal(chain_current):
    if not isinstance(chain_current, dict) or not chain_current:
        return False
    if _chain_state_looks_terminal(chain_current):
        return False
    if chain_current.get("chain_complete") is False:
        return True
    last_state = str(chain_current.get("last_state") or "").strip().lower()
    pr_state = str(chain_current.get("pr_state") or "").strip().lower()
    if pr_state in {"open", "draft"}:
        return True
    if last_state and last_state not in {"done", "complete", "completed"}:
        return True
    total = chain_current.get("total_milestones")
    completed = chain_current.get("completed_count")
    try:
        return total not in (None, "", 0) and int(completed or 0) < int(total)
    except (TypeError, ValueError):
        return False

def _watchdog_chain_health_disagreement_reason(ev):
    refs = ev.get("prior_watchdog_report_refs") if isinstance(ev, dict) else []
    refs = refs if isinstance(refs, list) else []
    latest = next((item for item in refs if isinstance(item, dict) and item.get("matched_status")), {})
    if not latest:
        return ""
    watchdog_status = str(latest.get("matched_status") or "").strip().lower()
    chain_current = (ev.get("chain_state_summary") or {}).get("current") if isinstance(ev.get("chain_state_summary"), dict) else {}
    if watchdog_status == "complete" and _chain_state_looks_nonterminal(chain_current):
        return (
            "watchdog_chain_health_disagreement: watchdog reports complete but "
            f"chain state is last_state={chain_current.get('last_state') or 'unknown'} "
            f"chain_complete={chain_current.get('chain_complete')} "
            f"pr_state={chain_current.get('pr_state') or 'unknown'} "
            f"completed={chain_current.get('completed_count')}/{chain_current.get('total_milestones') or '?'}"
        )
    if watchdog_status == "awaiting_pr_merge" and _chain_state_looks_terminal(chain_current):
        return (
            "watchdog_chain_health_disagreement: watchdog reports awaiting_pr_merge but "
            f"chain state is terminal last_state={chain_current.get('last_state') or 'unknown'} "
            f"chain_complete={chain_current.get('chain_complete')} "
            f"pr_state={chain_current.get('pr_state') or 'unknown'}"
        )
    return ""

def _repair_data_ghost_running_reason(ev):
    repair = ev.get("repair_data_summary") if isinstance(ev, dict) else {}
    if not isinstance(repair, dict) or not repair.get("exists"):
        return ""
    outcome = str(repair.get("outcome") or "").strip().lower()
    if outcome not in {"running", "repairing", "in_progress", "active"}:
        return ""
    has_attempt = bool(repair.get("current_attempt_id") or repair.get("attempt_ids"))
    iteration_count = int(repair.get("iteration_count") or 0)
    chain_current = (ev.get("chain_state_summary") or {}).get("current") if isinstance(ev.get("chain_state_summary"), dict) else {}
    if not has_attempt and iteration_count == 0 and (_chain_state_looks_terminal(chain_current) or _chain_state_looks_nonterminal(chain_current)):
        return (
            "repair_data_ghost_running: repair-data outcome is running with no current attempt "
            f"and zero iterations while chain state is last_state={chain_current.get('last_state') or 'unknown'} "
            f"chain_complete={chain_current.get('chain_complete')}"
        )
    return ""

def _repair_complete_incomplete_chain_reason(ev):
    """Surface the L1 false-success shape as a deterministic L3 finding."""
    repair = ev.get("repair_data_summary") if isinstance(ev, dict) else {}
    if not isinstance(repair, dict) or not repair.get("exists"):
        return ""
    outcome = str(repair.get("outcome") or "").strip().lower()
    if outcome not in {"complete", "completed", "progressed"}:
        return ""
    chain_current = (ev.get("chain_state_summary") or {}).get("current") if isinstance(ev.get("chain_state_summary"), dict) else {}
    if not isinstance(chain_current, dict) or not chain_current:
        return ""
    total = chain_current.get("total_milestones")
    completed = chain_current.get("completed_count")
    try:
        total_int = int(total)
        completed_int = int(completed or 0)
    except (TypeError, ValueError):
        return ""
    if total_int <= 0 or completed_int >= total_int:
        return ""
    return (
        "repair_complete_incomplete_chain: repair-data outcome="
        f"{outcome} but chain remains incomplete ({completed_int}/{total_int})"
    )

def _green_with_recent_repair_churn_reason(ev):
    repair = ev.get("repair_data_summary") if isinstance(ev, dict) else {}
    if not isinstance(repair, dict) or not repair.get("exists"):
        return ""
    recent_repair = repair.get("mtime_age_min") is not None and int(repair.get("mtime_age_min") or 0) <= int(window) * 60
    has_churn = int(repair.get("iteration_count") or 0) > 0 or bool(ev.get("meta_repair_refs")) or bool(ev.get("attempt_refs"))
    chain_current = (ev.get("chain_state_summary") or {}).get("current") if isinstance(ev.get("chain_state_summary"), dict) else {}
    chain_last_state = str(chain_current.get("last_state") or "").strip().lower()
    human_gate_states = {"awaiting_human", "awaiting_human_verify", "human_prerequisite"}
    if recent_repair and has_churn and chain_last_state not in human_gate_states and _chain_state_looks_nonterminal(chain_current):
        return (
            "green_with_recent_repair_churn: recent repair/meta-repair artifacts exist "
            f"while chain state is non-terminal last_state={chain_current.get('last_state') or 'unknown'}"
        )
    return ""

def _active_step_liveness(active):
    if not isinstance(active, dict) or not active:
        return {"present": False}
    raw_pid = active.get("worker_pid")
    result = {
        "present": bool(active.get("phase") or raw_pid),
        "phase": active.get("phase") or active.get("step") or "",
        "attempt": active.get("attempt"),
        "worker_pid": str(raw_pid) if raw_pid not in (None, "") else "",
        "worker_pid_alive": None,
    }
    if raw_pid in (None, ""):
        return result
    try:
        pid = int(raw_pid)
    except (TypeError, ValueError):
        result["worker_pid_alive"] = False
        return result
    if pid <= 0:
        result["worker_pid_alive"] = False
        return result
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        result["worker_pid_alive"] = False
    except PermissionError:
        result["worker_pid_alive"] = True
    except OSError:
        result["worker_pid_alive"] = False
    else:
        result["worker_pid_alive"] = True
    return result

def _active_step_ghost_worker_reason(ev):
    liveness = ev.get("active_step_liveness") if isinstance(ev, dict) else {}
    if not isinstance(liveness, dict) or not liveness.get("present"):
        return ""
    pid = liveness.get("worker_pid") or ""
    if not pid or liveness.get("worker_pid_alive") is not False:
        return ""
    return (
        "plan_active_step_ghost_worker: "
        f"phase={liveness.get('phase') or 'unknown'} worker_pid={pid} is not live"
    )

def _workflow_cursor_mismatch_reason(ev):
    failure = ev.get("plan_latest_failure") if isinstance(ev, dict) else {}
    if not isinstance(failure, dict):
        return ""
    haystack = " ".join(
        str(failure.get(key) or "") for key in ("kind", "message", "state")
    ).lower()
    if "workflow_cursor_mismatch" not in haystack and "workflow cursor mismatch" not in haystack:
        return ""
    return (
        "workflow_cursor_mismatch: plan control projection disagrees with the "
        "recorded workflow cursor; retryable state-machine contradiction, not completion"
    )

def _superfixer_cycle_evidence(ev):
    resolver = ev.get("resolver_state") if isinstance(ev, dict) else {}
    resolver = resolver if isinstance(resolver, dict) else {}
    canonical_state = str(resolver.get("canonical_state") or "UNKNOWN").strip().upper()
    if canonical_state == "HUMAN_ACTION_REQUIRED":
        return {
            "actionable": False,
            "excluded_typed_human_gate": True,
            "canonical_state": canonical_state,
        }

    custody = ev.get("repair_custody_summary") if isinstance(ev, dict) else {}
    custody = custody if isinstance(custody, dict) else {}
    repair = ev.get("repair_data_summary") if isinstance(ev, dict) else {}
    repair = repair if isinstance(repair, dict) else {}
    meta = ev.get("meta_repair_summary") if isinstance(ev, dict) else {}
    meta = meta if isinstance(meta, dict) else {}
    target = ev.get("current_target") if isinstance(ev, dict) else {}
    target = target if isinstance(target, dict) else {}
    chain_current = (ev.get("chain_state_summary") or {}).get("current") if isinstance(ev, dict) else {}
    chain_current = chain_current if isinstance(chain_current, dict) else {}

    accepted_unclaimed = custody.get("accepted_unclaimed_request_ids") or []
    accepted_unclaimed = accepted_unclaimed if isinstance(accepted_unclaimed, list) else []
    retry_budget = custody.get("retry_budget") if isinstance(custody.get("retry_budget"), dict) else {}
    repair_outcome = str(repair.get("outcome") or "").strip().lower()
    repair_age = repair.get("mtime_age_min")
    stale_l1 = (
        repair_outcome in {"repair_timeout", "repair_exhausted"}
        or (
            repair.get("exists")
            and isinstance(repair_age, int)
            and repair_age > 60
            and repair_outcome not in {"complete", "completed", "progressed", "live_with_fresh_activity"}
        )
    )
    malformed_count = int(custody.get("malformed_request_count") or 0) + int(
        custody.get("malformed_decision_count") or 0
    )
    unknown_evidence = bool(custody.get("projection_error") or malformed_count)
    l1_failed = bool(accepted_unclaimed or stale_l1)

    active = ev.get("active_step_liveness") if isinstance(ev, dict) else {}
    active = active if isinstance(active, dict) else {}
    tmux_process = target.get("tmux_process") if isinstance(target.get("tmux_process"), dict) else {}
    tmux_live = (
        tmux_process.get("pid_live") is True
        or tmux_process.get("session_live") is True
        or str(tmux_process.get("live_status") or "").strip().lower() == "alive"
    )
    dead_active_step = active.get("present") is True and active.get("worker_pid_alive") is False
    explicit_stopped = str(tmux_process.get("live_status") or "").strip().lower() in {
        "dead", "missing", "stopped", "unavailable"
    }
    watchdog_refs = ev.get("prior_watchdog_report_refs") if isinstance(ev, dict) else []
    watchdog_refs = watchdog_refs if isinstance(watchdog_refs, list) else []
    watchdog_stopped = any(
        str(item.get("matched_status") or "").strip().lower()
        in {"stopped", "dead", "progress_stall", "broken_superfixer"}
        for item in watchdog_refs
        if isinstance(item, dict)
    )
    runner_dead = bool(not tmux_live and (dead_active_step or explicit_stopped or watchdog_stopped))
    incomplete_chain = _chain_state_looks_nonterminal(chain_current)

    meta_ages = [
        item.get("mtime_age_min")
        for item in (ev.get("meta_repair_refs") or [])
        if isinstance(item, dict) and isinstance(item.get("mtime_age_min"), int)
    ]
    meta_ages.extend(
        item.get("mtime_age_min")
        for item in (meta.get("meta_run_refs") or [])
        if isinstance(item, dict) and isinstance(item.get("mtime_age_min"), int)
    )
    failed_l2 = bool(meta.get("failed_meta_run_count") or meta.get("failed_meta_record_count"))
    current_l2 = bool(meta_ages and min(meta_ages) <= 60 and not failed_l2)
    absent_or_stale_l2 = not current_l2

    actionable = bool(
        l1_failed
        and runner_dead
        and incomplete_chain
        and absent_or_stale_l2
        and not unknown_evidence
    )
    return {
        "actionable": actionable,
        "excluded_typed_human_gate": False,
        "canonical_state": canonical_state,
        "accepted_unclaimed_count": len(accepted_unclaimed),
        "accepted_unclaimed_request_ids": accepted_unclaimed[:5],
        "request_status_counts": custody.get("request_status_counts") or {},
        "claim_count": custody.get("claim_count") or 0,
        "attempt_count": custody.get("attempt_count") or 0,
        "claim_retry_counts": custody.get("claim_retry_counts") or {},
        "claim_alert_request_ids": custody.get("claim_alert_request_ids") or [],
        "retry_budget": retry_budget,
        "repair_outcome": repair_outcome,
        "repair_age_min": repair_age,
        "runner_dead": runner_dead,
        "dead_active_step": dead_active_step,
        "tmux_live_status": tmux_process.get("live_status"),
        "chain_incomplete": incomplete_chain,
        "chain_last_state": chain_current.get("last_state"),
        "chain_completed_count": chain_current.get("completed_count"),
        "chain_total_milestones": chain_current.get("total_milestones"),
        "meta_record_count": meta.get("meta_record_count") or 0,
        "meta_run_log_count": meta.get("meta_run_log_count") or 0,
        "latest_meta_age_min": min(meta_ages) if meta_ages else None,
        "failed_l2_evidence": failed_l2,
        "absent_or_stale_l2": absent_or_stale_l2,
        "malformed_request_count": custody.get("malformed_request_count") or 0,
        "malformed_decision_count": custody.get("malformed_decision_count") or 0,
        "projection_error": custody.get("projection_error") or "",
        "unknown_evidence": unknown_evidence,
    }

def _stale_l1_l2_cycle_reason(ev):
    evidence = _superfixer_cycle_evidence(ev)
    ev["deterministic_superfixer_evidence"] = evidence
    if evidence.get("unknown_evidence") and evidence.get("runner_dead") and evidence.get("chain_incomplete"):
        return (
            "broken_superfixer_unknown_evidence: runner is stopped and chain is incomplete, "
            "but malformed or unavailable custody projection evidence forbids automatic repair; "
            f"projection_error={evidence.get('projection_error') or 'none'} "
            f"malformed_requests={evidence.get('malformed_request_count')} "
            f"malformed_decisions={evidence.get('malformed_decision_count')}"
        )
    if not evidence.get("actionable"):
        return ""
    return (
        "stale_l1_l2_cycle: incomplete chain has a stopped/dead runner and "
        "accepted-unclaimed, exhausted, stale, or malformed L1 custody with no current L2 evidence; "
        f"accepted_unclaimed={evidence.get('accepted_unclaimed_count')} "
        f"claim_count={evidence.get('claim_count')} attempt_count={evidence.get('attempt_count')} "
        f"repair_outcome={evidence.get('repair_outcome') or 'unknown'} "
        f"repair_age_min={evidence.get('repair_age_min')} "
        f"retry_budget={evidence.get('retry_budget')} "
        f"claim_alerts={len(evidence.get('claim_alert_request_ids') or [])} "
        f"latest_meta_age_min={evidence.get('latest_meta_age_min')}"
    )

def _meta_repair_gap_is_primary(incident_brief, incident_projection, incident_audit):
    findings = incident_audit.get("findings") if isinstance(incident_audit, dict) else []
    for finding in findings if isinstance(findings, list) else []:
        if not isinstance(finding, dict):
            continue
        if str(finding.get("layer") or "").strip() != "meta_repair":
            continue
        if str(finding.get("status") or "").strip() != "ok":
            return True

    for expected in (
        incident_audit.get("next_expected_event") if isinstance(incident_audit, dict) else "",
        incident_brief.get("next_expected_event") if isinstance(incident_brief, dict) else "",
        incident_projection.get("next_expected_event") if isinstance(incident_projection, dict) else "",
    ):
        if str(expected or "").strip() == "meta_repair.repair_attempt":
            return True
    return False

def _ci_health_unavailable(repo_root, *, reason, **extra):
    payload = {
        "status": "unavailable",
        "available": False,
        "base_branch": "main",
        "repo_root": str(repo_root),
        "reason": reason,
    }
    payload.update(extra)
    return payload

def _engine_tree_unavailable(repo_root, workspace_root, *, reason, **extra):
    payload = {
        "status": "unavailable",
        "available": False,
        "repo_root": str(repo_root),
        "workspace_root": str(workspace_root),
        "reason": reason,
        "import_consumers": [],
    }
    payload.update(extra)
    return payload

def _normalize_engine_tree_evidence(value, *, repo_root, workspace_root):
    if not isinstance(value, dict):
        return _engine_tree_unavailable(
            repo_root,
            workspace_root,
            reason="engine_tree_invalid_payload",
        )
    normalized = dict(value)
    if not isinstance(normalized.get("import_consumers"), list):
        impacted_consumers = normalized.get("impacted_consumers")
        normalized["import_consumers"] = impacted_consumers if isinstance(impacted_consumers, list) else []
    return normalized

def _collect_external_ci_health(repo_root):
    if not repo_root.is_dir():
        return _ci_health_unavailable(repo_root, reason="repo_context_unavailable")
    try:
        payload = collect_ci_health(repo_root, base_branch="main")
    except Exception as exc:
        return _ci_health_unavailable(
            repo_root,
            reason="ci_health_collection_failed",
            error=str(exc),
        )
    if not isinstance(payload, dict):
        return _ci_health_unavailable(repo_root, reason="ci_health_invalid_payload")
    return dict(payload)

def _candidate_engine_tree_roots(workspace_root, repo_root):
    candidates = [repo_root, workspace_root / ".megaplan" / "runtime" / "editable-engine"]
    deduped = []
    seen = set()
    for candidate in candidates:
        resolved = pathlib.Path(candidate).expanduser()
        key = str(resolved)
        if key in seen:
            continue
        seen.add(key)
        deduped.append(resolved)
    return deduped

def _collect_external_engine_tree(repo_root, workspace_root):
    if not repo_root.is_dir():
        return _engine_tree_unavailable(
            repo_root,
            workspace_root,
            reason="repo_context_unavailable",
        )
    try:
        payload = collect_engine_tree_evidence(
            repo_root,
            workspace_root=workspace_root,
            candidate_mirror_roots=_candidate_engine_tree_roots(workspace_root, repo_root),
        )
    except Exception as exc:
        return _engine_tree_unavailable(
            repo_root,
            workspace_root,
            reason="engine_tree_collection_failed",
            error=str(exc),
        )
    return _normalize_engine_tree_evidence(
        payload,
        repo_root=repo_root,
        workspace_root=workspace_root,
    )

def _current_target_fallback(session, *, repo_root, reason, **extra):
    payload = {
        "schema_version": 1,
        "session": session,
        "target_id": f"{session}:unknown",
        "authoritative_source": "current_target_unavailable",
        "current_refs": {},
        "stale_evidence": [],
        "rationale": [reason],
        "ci_health": _ci_health_unavailable(repo_root, reason=reason),
    }
    payload.update(extra)
    return payload

def _resolve_current_target_evidence(session, *, workspace_root, repo_root):
    marker_dir = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_MARKER_DIR", "/workspace/.megaplan/cloud-sessions"))
    repair_data_dir = pathlib.Path(
        os.environ.get("MEGAPLAN_AUDIT_REPAIR_DATA_DIR", str(marker_dir / "repair-data"))
    )
    try:
        payload = resolve_current_target(
            session,
            marker_dir=marker_dir,
            repair_data_dir=repair_data_dir,
            repo_root=repo_root,
            base_branch="main",
        )
    except Exception as exc:
        return _current_target_fallback(
            session,
            repo_root=repo_root,
            reason="current_target_collection_failed",
            error=str(exc),
        )
    if not isinstance(payload, dict):
        return _current_target_fallback(
            session,
            repo_root=repo_root,
            reason="current_target_invalid_payload",
        )
    normalized = dict(payload)
    normalized.setdefault("session", session)
    normalized.setdefault("ci_health", _ci_health_unavailable(repo_root, reason="current_target_missing_ci_health"))
    return normalized

def _resolve_resolver_state_payload(current_target):
    try:
        resolved = resolve_run_state(current_target)
    except Exception as exc:
        return {
            "canonical_state": "UNKNOWN",
            "confidence": "low",
            "next_action": "auditor_escalate_to_human",
            "stale_sources": [],
            "reason": str(exc),
        }
    if hasattr(resolved, "to_dict"):
        resolved = resolved.to_dict()
    return dict(resolved) if isinstance(resolved, dict) else {}

def _plan_evidence(entry):
    workspace = entry["workspace"]
    plan = entry["plan"]
    workspace_path = pathlib.Path(workspace)
    plan_dir = workspace_path / ".megaplan" / "plans" / plan
    state_path = plan_dir / "state.json"
    try:
        state = json.loads(state_path.read_text(encoding="utf-8"))
    except Exception:
        return None

    plan_v_files = sorted(plan_dir.glob("plan_v*.md"))
    recent_v = []
    for p in plan_v_files:
        try:
            if dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc) >= cutoff:
                recent_v.append(p)
        except OSError:
            continue

    try:
        state_mtime = dt.datetime.fromtimestamp(state_path.stat().st_mtime, tz=dt.timezone.utc)
    except OSError:
        state_mtime = None
    events_path = plan_dir / "events.ndjson"
    try:
        events_mtime = events_path.stat().st_mtime if events_path.exists() else 0
    except OSError:
        events_mtime = 0
    events_recent = bool(events_mtime) and dt.datetime.fromtimestamp(events_mtime, tz=dt.timezone.utc) >= cutoff

    session = entry.get("session") or workspace_path.name
    run_kind = str(entry.get("kind") or "").strip().lower()
    if run_kind not in {"chain", "plan"}:
        run_kind = "chain"
    session_header = {
        "session": session,
        "workspace": workspace,
        "kind": run_kind,
        "remote_spec": entry.get("remote_spec") or "",
        "launch_command": entry.get("launch_command") or "",
        "log": entry.get("log") or "",
        "marker_path": entry.get("marker_path") or "",
        "created_at": entry.get("created_at") or "",
        "updated_at": entry.get("updated_at") or entry.get("updated") or "",
        "started_at": entry.get("started_at") or "",
        "sources": entry.get("sources") or [],
    }
    chain_log = _chain_log_summary(workspace_path, session, entry)
    chain_state = _chain_state_summary(workspace_path, plan)
    repair_data = _repair_data_summary(session)
    cross_refs = _collect_related_artifact_refs(workspace_path, plan, session, repair_data)
    active = state.get("active_step") or {}
    active_liveness = _active_step_liveness(active)
    prior_incident_ids = [item.get("incident_id") for item in cross_refs.get("prior_incident_refs", []) if item.get("incident_id")]
    prior_watchdog_report_refs = _collect_watchdog_report_refs(session, plan, workspace_path)
    meta_repair_summary = _meta_repair_summary(
        session,
        repair_data,
        cross_refs.get("meta_repair_refs") or [],
        run_kind=run_kind,
        current_plan_name=plan,
        current_state=state.get("current_state") or "",
        active_step_phase=active.get("phase") or "",
        active_step_liveness=active_liveness,
        chain_state_summary=chain_state,
        chain_log_summary=chain_log,
        events_mtime_age_min=int((now.timestamp() - events_mtime) // 60) if events_mtime else None,
        prior_watchdog_report_refs=prior_watchdog_report_refs,
    )
    prior_audit_refs = _collect_audit_report_refs(session, plan)
    persistent_finding_refs = _collect_persistent_finding_refs(session, plan, prior_incident_ids)
    ticket_refs = _collect_ticket_refs(workspace_path, session, plan, prior_incident_ids)
    commit_refs = _collect_commit_refs()
    chain_current = (chain_state or {}).get("current") or {}
    chain_recent = any(
        [
            chain_log.get("path") and chain_log.get("mtime_age_min") is not None and chain_log.get("mtime_age_min") <= window * 60,
            any(item.get("mtime_age_min") is not None and item.get("mtime_age_min") <= window * 60 for item in chain_state.get("all", [])),
            repair_data.get("exists") and repair_data.get("mtime_age_min") is not None and repair_data.get("mtime_age_min") <= window * 60,
        ]
    )

    if not recent_v and not _recent_iso(state.get("created_at")):
        if (state_mtime is None or state_mtime < cutoff) and not events_recent and not chain_recent:
            return None

    sizes = {}
    for p in plan_v_files:
        try:
            sizes[p.name] = p.stat().st_size
        except OSError:
            continue
    events_size = events_path.stat().st_size if events_path.exists() else 0
    last_gate = state.get("last_gate") or {}
    latest_failure = state.get("latest_failure") or {}
    latest_failure_metadata = latest_failure.get("metadata") if isinstance(latest_failure.get("metadata"), dict) else {}
    meta = state.get("meta") or {}
    scores = meta.get("weighted_scores") or []
    plan_deltas = meta.get("plan_deltas") or []
    counts = meta.get("significant_counts") or []

    history = state.get("history") or []
    recent_history = []
    for item in history:
        ts = item.get("timestamp") or item.get("completed_at") or ""
        if _recent_iso(ts):
            recent_history.append({"step": item.get("step"), "result": item.get("result"), "ts": ts})
    gates = [h for h in recent_history if h.get("step") == "gate"]
    gate_iterate = sum(1 for g in gates if g.get("result") in ("iterate", "ITERATE", "blocked"))
    gate_total = len(gates)

    plan_latest_failure = {
        "plan_name": state.get("name") or plan_dir.name,
        "state_path": str(state_path),
        "current_state": state.get("current_state") or state.get("state") or "",
        "phase": latest_failure.get("phase") or state.get("phase") or "",
        "iteration": state.get("iteration"),
        "kind": latest_failure.get("kind") or "",
        "message": latest_failure.get("message") or "",
        "state": latest_failure.get("state") or "",
        "recorded_at": latest_failure.get("recorded_at") or "",
        "last_artifact": latest_failure.get("last_artifact") or "",
        "suggested_action": latest_failure.get("suggested_action") or "",
        "metadata": _metadata_excerpt(latest_failure_metadata),

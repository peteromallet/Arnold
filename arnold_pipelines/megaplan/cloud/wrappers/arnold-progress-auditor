    except Exception:
        return None

    plan_v_files = sorted(plan_dir.glob("plan_v*.md"))
    recent_v = []
    for p in plan_v_files:
        try:
            if dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc) >= cutoff:
                recent_v.append(p)
        except OSError:
            continue

    try:
        state_mtime = dt.datetime.fromtimestamp(state_path.stat().st_mtime, tz=dt.timezone.utc)
    except OSError:
        state_mtime = None
    events_path = plan_dir / "events.ndjson"
    try:

    audit_input = six_hour_auditor.build_audit_input(session, root=workspace_path, now=_now_iso())
    incident_brief = audit_input.get("brief") if isinstance(audit_input.get("brief"), dict) else {}
    incident_projection = audit_input.get("incident") if isinstance(audit_input.get("incident"), dict) else {}
    problem_projection = audit_input.get("problem") if isinstance(audit_input.get("problem"), dict) else {}
    repo_root = COMMIT_SOURCE_DIR.expanduser().resolve()

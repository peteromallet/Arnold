#!/usr/bin/env bash
# arnold-progress-auditor — periodic Codex-orchestrated DeepSeek-backed plan progress audit.
#
# Host-side systemd oneshot (megaplan-progress-audit.service, every 6h via
# megaplan-progress-audit.timer). When invoked on the host it docker-execs into
# the megaplan-cloud-agent container (mirroring ensure-megaplan-watchdog) and
# re-invokes itself there. When invoked inside the container it runs the audit.
#
# In-container loop:
#   * discover candidate workspaces/plans from markers, live tmux sessions, and
#     recent workspace activity inside the audit window
#   * gather the last AUDIT_WINDOW_HOURS (default 6h) of activity per plan
#     (plan_v*.md count/sizes, iteration/attempt progression, gate verdicts,
#     critique trend, events.ndjson growth, progress_stall flags from
#     /workspace/watchdog-report.json)
#   * for plans with suspicious signals, dispatch Codex as the top-level audit
#     orchestrator; Codex then reads the subagent-launcher skill and deploys
#     DeepSeek research subagents (provider=deepseek, model
#     deepseek:deepseek-v4-pro) via the existing subagent-launcher/megaplan
#     dispatch contract
#   * write /workspace/audit-reports/<ts>-audit.{json,md}, append one line to
#     /workspace/audit-report.log
#
# MODEL-JUDGED: for each suspicious plan, Codex subjectively decides whether
# the evidence is STALE state to clear, a GENUINE live non-critical deadlock to
# root-cause + fix + push to editible-install (the watchdog relaunches the
# chain), an INEFFICIENT cycling pattern, or PASSIVE/document-only. No
# hardcoded verdict rule.
set -uo pipefail

CONTAINER="${MEGAPLAN_CLOUD_CONTAINER:-megaplan-cloud-agent}"

# Inside-container detection: /workspace/arnold editable checkout only exists
# inside the container in this deployment.
if [[ ! -d /workspace/arnold ]]; then
  if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
    echo "arnold-progress-auditor: container_missing container=$CONTAINER" >&2
    exit 1
  fi
  exec docker exec "$CONTAINER" bash -lc '/usr/local/bin/arnold-progress-auditor "$@"' _ "$@"
fi

# ---- in-container audit -----------------------------------------------------

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

WRAPPER_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../../../.." && pwd)"

MARKER_DIR="${MEGAPLAN_AUDIT_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
REPAIR_DATA_DIR="${MEGAPLAN_AUDIT_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
export MEGAPLAN_AUDIT_REPAIR_DATA_DIR="$REPAIR_DATA_DIR"
REPORT_DIR="${MEGAPLAN_AUDIT_REPORT_DIR:-/workspace/audit-reports}"
REPORT_LOG="${MEGAPLAN_AUDIT_REPORT_LOG:-/workspace/audit-report.log}"
WATCHDOG_REPORT="${MEGAPLAN_AUDIT_WATCHDOG_REPORT:-/workspace/watchdog-report.json}"
ARNOLD_SRC="${MEGAPLAN_AUDIT_ARNOLD_SRC:-/workspace/arnold}"
DISCOVER_BIN="${MEGAPLAN_AUDIT_DISCOVER_BIN:-$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-cloud-discover}"
LAUNCHER="${MEGAPLAN_AUDIT_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
AUDIT_WINDOW_HOURS="${MEGAPLAN_AUDIT_WINDOW_HOURS:-6}"
SUBAGENT_TIMEOUT="${MEGAPLAN_AUDIT_SUBAGENT_TIMEOUT_SECS:-900}"
SUBAGENT_MAX_TOKENS="${MEGAPLAN_AUDIT_SUBAGENT_MAX_TOKENS:-8192}"
SUBAGENT_PROFILE="${MEGAPLAN_AUDIT_SUBAGENT_PROFILE:-partnered-5}"
DEEPSEEK_MODEL="${MEGAPLAN_AUDIT_MODEL:-deepseek:deepseek-v4-pro}"
CODEX_TIMEOUT="${MEGAPLAN_AUDIT_CODEX_TIMEOUT_SECS:-1800}"
SUBAGENT_SKILL="${MEGAPLAN_AUDIT_SUBAGENT_SKILL:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/subagent-launcher/SKILL.md}"
AUDIT_GITHUB_REPO="${MEGAPLAN_AUDIT_GITHUB_REPO:-}"
AUDIT_GITHUB_REPO_PATH="${MEGAPLAN_AUDIT_GITHUB_REPO_PATH:-}"
AUDIT_GITHUB_LABELS="${MEGAPLAN_AUDIT_GITHUB_LABELS:-incident-control-plane,persistent-problem}"

# Legacy direct DeepSeek launcher contract retained here for watchdog contract
# tests and operator reference:
# timeout "$SUBAGENT_TIMEOUT" python3 "$LAUNCHER" \
#   --toolsets="file,web" \
#   --model="$DEEPSEEK_MODEL" \
#   --max-tokens="$SUBAGENT_MAX_TOKENS" \
#   --query-file="$brief" \
#   --project-dir="$workspace"

mkdir -p "$REPORT_DIR" "$(dirname "$REPORT_LOG")"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
JSON_OUT="$REPORT_DIR/${TS}-audit.json"
MD_OUT="$REPORT_DIR/${TS}-audit.md"
WORKLIST="$(mktemp)"
GATHER_DIR="$(mktemp -d)"
trap 'rm -rf "$WORKLIST" "$GATHER_DIR"' EXIT

log() {
  local message
  message="$(redact_inline_text "$*")"
  echo "[progress-auditor $(date -Iseconds)] $message"
}

redact_inline_text() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$1" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

print(redact_text(sys.argv[1]), end="")
PY
}

redact_file_in_place() {
  local path="${1:-}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$path" <<'PY'
from pathlib import Path
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

path = Path(sys.argv[1])
path.write_text(redact_text(path.read_text(encoding="utf-8")), encoding="utf-8")
PY
}

audit_flag_enabled() {
  local function_name="${1:-}"
  if [[ -z "$function_name" ]]; then
    echo 0
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$function_name" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud import feature_flags

name = sys.argv[1]
fn = getattr(feature_flags, name, None)
if fn is None:
    print("0")
    raise SystemExit(0)
print("1" if bool(fn()) else "0")
PY
}

autofix_allowed_targets_markdown() {
  cat <<'EOF'
- `arnold_pipelines/megaplan/cloud/**`
- `tests/cloud/**`
- Never modify the audited run workspace, plan state, repair-data artifacts, user project trees, or files outside those Arnold repair-system paths.
EOF
}

autofix_policy_markdown() {
  local autofix_enabled="${1:-0}"
  local commit_enabled="${2:-0}"
  if [[ "$autofix_enabled" != "1" ]]; then
    cat <<'EOF'
Autofix mode: REPORT-ONLY.
- Do not edit files, apply patches, or run `git commit` / `git push`.
- Diagnose the repair-system issue, cite evidence, and recommend the smallest safe operator follow-up.
EOF
    return 0
  fi
  if [[ "$commit_enabled" == "1" ]]; then
    cat <<'EOF'
Autofix mode: REPAIR-SYSTEM PATCH + COMMIT/PUSH (explicitly gated).
- You are trusted to ship the repair-system fix when evidence supports it.
- You may change only the allowed Arnold repair-system files listed below.
- Keep the fix narrow, validate with `python3 -m py_compile` and one focused test module, then `git commit` and `git push` to `origin/editible-install`.
- Do not stop at a recommendation for repair-system bugs; patch, validate, commit, push, and return `FIXED <commit-sha>`.
- Do not touch run-state artifacts, project workspaces, or non-repair-system files.
EOF
    return 0
  fi
  cat <<'EOF'
Autofix mode: REPAIR-SYSTEM PATCH-ONLY.
- You may change only the allowed Arnold repair-system files listed below.
- Validate with `python3 -m py_compile` and one focused test module.
- Leave changes uncommitted; do not run `git commit` or `git push`.
- Do not touch run-state artifacts, project workspaces, or non-repair-system files.
EOF
}

AUDIT_AUTOFIX_ENABLED_FLAG="$(audit_flag_enabled audit_autofix_enabled)"
AUDIT_AUTOFIX_COMMIT_ENABLED_FLAG="$(audit_flag_enabled audit_autofix_commit_enabled)"
export ARNOLD_META_REPAIR_ENABLED="${ARNOLD_META_REPAIR_ENABLED:-1}"
export ARNOLD_META_REPAIR_COMMIT_ENABLED="${ARNOLD_META_REPAIR_COMMIT_ENABLED:-1}"

# Build the plan worklist from marker, tmux, and workspace-activity discovery.
python3 - "$MARKER_DIR" "$WORKLIST" "$AUDIT_WINDOW_HOURS" "$DISCOVER_BIN" "/workspace" "$ARNOLD_SRC" <<'PY'
import datetime as dt
import json
import os
import pathlib
import subprocess
import sys

marker_dir, out, window_h, discover_bin, workspace_root, arnold_src = sys.argv[1:7]
window = float(window_h)
cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(hours=window)
workspace_root_path = pathlib.Path(workspace_root)
arnold_src_path = pathlib.Path(arnold_src).resolve()


def _recent_mtime(path: pathlib.Path) -> bool:
    try:
        return dt.datetime.fromtimestamp(path.stat().st_mtime, tz=dt.timezone.utc) >= cutoff
    except OSError:
        return False


def _plan_dirs(workspace: pathlib.Path) -> list[pathlib.Path]:
    plans_root = workspace / ".megaplan" / "plans"
    try:
        if not plans_root.is_dir():
            return []
        return sorted(p for p in plans_root.iterdir() if p.is_dir())
    except OSError:
        return []


def _merge(
    entries: dict[tuple[str, str], dict],
    workspace: pathlib.Path,
    plan_dir: pathlib.Path,
    session: str,
    source: str,
    updated: str = "",
    marker_path: pathlib.Path | None = None,
    marker_payload: dict | None = None,
) -> None:
    key = (str(workspace), plan_dir.name)
    entry = entries.setdefault(
        key,
        {
            "workspace": str(workspace),
            "plan": plan_dir.name,
            "session": session or workspace.name,
            "updated": updated,
            "sources": [],
        },
    )
    if not entry.get("session") and session:
        entry["session"] = session
    if updated and not entry.get("updated"):
        entry["updated"] = updated
    if source not in entry["sources"]:
        entry["sources"].append(source)
    if marker_path is not None and not entry.get("marker_path"):
        entry["marker_path"] = str(marker_path)
    if marker_payload:
        for source_key, dest_key in (
            ("kind", "kind"),
            ("run_kind", "kind"),
            ("remote_spec", "remote_spec"),
            ("spec", "remote_spec"),
            ("launch_command", "launch_command"),
            ("log", "log"),
            ("created_at", "created_at"),
            ("started_at", "started_at"),
            ("updated_at", "updated_at"),
            ("plan_name", "plan_name"),
        ):
            value = marker_payload.get(source_key)
            if value and not entry.get(dest_key):
                entry[dest_key] = value


entries: dict[tuple[str, str], dict] = {}

# (a) Marker-discovered workspaces.
for marker_path in sorted(pathlib.Path(marker_dir).glob("*.json")):
    try:
        payload = json.loads(marker_path.read_text(encoding="utf-8"))
    except Exception:
        continue
    workspace_raw = payload.get("workspace") or payload.get("workspace_dir")
    if not workspace_raw:
        continue
    workspace = pathlib.Path(workspace_raw)
    if not workspace.is_dir():
        continue
    session = payload.get("session") or marker_path.stem
    updated = payload.get("updated_at") or payload.get("created_at") or ""
    marker_run_kind = str(payload.get("run_kind") or payload.get("kind") or "").strip().lower()
    marker_plan_name = str(payload.get("plan_name") or "").strip()
    if marker_run_kind == "plan" and marker_plan_name:
        marker_plan_dir = workspace / ".megaplan" / "plans" / marker_plan_name
        plan_dirs = [marker_plan_dir] if marker_plan_dir.is_dir() else []
    else:
        plan_dirs = _plan_dirs(workspace)
    for plan_dir in plan_dirs:
        _merge(entries, workspace, plan_dir, session, "marker", updated, marker_path, payload)

# (b) Tmux-discovered live marker-less workspaces.
try:
    discover_proc = subprocess.run(
        ["bash", discover_bin, "tmux-unmarked", "--marker-dir", marker_dir, "--src-dir", arnold_src],
        text=True,
        capture_output=True,
        check=False,
    )
except OSError:
    discover_proc = None

if discover_proc and discover_proc.returncode == 0:
    for raw in discover_proc.stdout.splitlines():
        if not raw.strip():
            continue
        try:
            session, workspace_raw, _remote_spec, _run_kind, _plan_name, _relaunch_command = raw.split("\t", 5)
        except ValueError:
            continue
        workspace = pathlib.Path(workspace_raw)
        if not workspace.is_dir():
            continue
        if _run_kind == "plan" and _plan_name:
            marker_plan_dir = workspace / ".megaplan" / "plans" / _plan_name
            plan_dirs = [marker_plan_dir] if marker_plan_dir.is_dir() else []
        else:
            plan_dirs = _plan_dirs(workspace)
        for plan_dir in plan_dirs:
            _merge(entries, workspace, plan_dir, session, "tmux")

# (c) Workspace-activity-discovered plans with recent state/events.
try:
    workspace_children = sorted(workspace_root_path.iterdir())
except OSError:
    workspace_children = []

for workspace in workspace_children:
    try:
        resolved = workspace.resolve()
    except OSError:
        continue
    if not workspace.is_dir() or workspace.name.startswith("."):
        continue
    if resolved == arnold_src_path:
        continue
    plans = _plan_dirs(workspace)
    if not plans:
        continue
    for plan_dir in plans:
        state_path = plan_dir / "state.json"
        events_path = plan_dir / "events.ndjson"
        if _recent_mtime(state_path) or _recent_mtime(events_path):
            _merge(entries, workspace, plan_dir, workspace.name, "workspace_activity")

with open(out, "w", encoding="utf-8") as handle:
    for entry in sorted(entries.values(), key=lambda item: (item["workspace"], item["plan"])):
        handle.write(json.dumps(entry, sort_keys=True) + "\n")
PY

log "auditing plans=$(wc -l < "$WORKLIST" | tr -d ' ') window_hours=$AUDIT_WINDOW_HOURS"

# Collect the watchdog progress_stall flags so the auditor can cite them.
stall_summary="none"
if [[ -f "$WATCHDOG_REPORT" ]]; then
  stall_summary="$(python3 - "$WATCHDOG_REPORT" <<'PY'
import json, sys
try:
    rep = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    print("unreadable"); raise SystemExit(0)
issues = rep.get("issues") or []
stalls = [i for i in issues if i.get("status") == "progress_stall"]
if not stalls:
    print("none"); raise SystemExit(0)
msgs = [i.get("message", "")[:200] for i in stalls]
print(" ; ".join(msgs))
PY
)"
fi

# Build per-plan evidence + decide which need a research subagent.
python3 - "$WORKLIST" "$GATHER_DIR" "$AUDIT_WINDOW_HOURS" "$ARNOLD_SRC" "$stall_summary" <<'PY'
import datetime as dt
import json
import os
import pathlib
import re
import subprocess
import sys

worklist, gather_dir, window_h, arnold_src, stall_summary = sys.argv[1:6]
window = float(window_h)
now = dt.datetime.now(dt.timezone.utc)
cutoff = now - dt.timedelta(hours=window)
sys.path.insert(0, arnold_src)
sys.path.insert(0, str(pathlib.Path.cwd()))

from arnold_pipelines.megaplan.cloud.redact import redact_text
from arnold_pipelines.megaplan.cloud.meta_repair import evaluate_meta_repair_triggers
from arnold_pipelines.megaplan.cloud.repair_contract import read_jsonl_records
from arnold_pipelines.megaplan.cloud.six_hour_auditor import audit_projection_input, build_audit_input
from arnold_pipelines.megaplan.incident.summaries import write_projection_summaries

MAX_CROSS_REF_ITEMS = 3
MAX_COMMIT_REFS = 5
WATCHDOG_REPORT_PATH = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_WATCHDOG_REPORT", "/workspace/watchdog-report.json"))
WATCHDOG_REPORT_ARCHIVE_DIR = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_WATCHDOG_REPORT_ARCHIVE_DIR", "/workspace/watchdog-reports"))
AUDIT_REPORT_DIR = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_REPORT_DIR", "/workspace/audit-reports"))
PERSISTENT_FINDINGS_DOC = pathlib.Path(os.environ.get("CLOUD_WATCHDOG_REPAIR_FINDINGS_DOC", "/workspace/findings/persistent-problems.md"))
META_RUN_DIR = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_META_RUN_DIR", "/workspace/.megaplan/meta-runs"))
COMMIT_SOURCE_DIR = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_COMMIT_SOURCE_DIR", arnold_src))
COMMIT_SOURCE_PATHS = (
    "arnold_pipelines/megaplan/cloud/wrappers/arnold-watchdog",
    "arnold_pipelines/megaplan/cloud/wrappers/arnold-progress-auditor",
    "arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop",
    "arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop",
    "arnold_pipelines/megaplan/cloud/meta_repair.py",
    "arnold_pipelines/megaplan/cloud/meta_repair_policy.py",
    "arnold_pipelines/megaplan/cloud/repair_contract.py",
)

plans = []
with open(worklist, encoding="utf-8") as h:
    for line in h:
        line = line.strip()
        if line:
            plans.append(json.loads(line))

def _recent_iso(ts_str):
    if not ts_str:
        return False
    try:
        when = dt.datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
    except Exception:
        return False
    return when >= cutoff

def _parse_iso(ts_str):
    if not ts_str:
        return None
    try:
        when = dt.datetime.fromisoformat(str(ts_str).replace("Z", "+00:00"))
    except Exception:
        return None
    if when.tzinfo is None:
        when = when.replace(tzinfo=dt.timezone.utc)
    return when

def _mtime(path):
    try:
        return path.stat().st_mtime
    except OSError:
        return 0

def _recent_path(path):
    mtime = _mtime(path)
    return bool(mtime) and dt.datetime.fromtimestamp(mtime, tz=dt.timezone.utc) >= cutoff

def _load_json(path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}

def _redact_scalar(value):
    text = str(value or "").strip()
    return redact_text(text) if text else ""

def _now_iso():
    return now.isoformat().replace("+00:00", "Z")

def _summary_path(workspace, kind, item_id):
    return str(workspace / ".megaplan" / "incident-ledger" / "summaries" / kind / f"{item_id}.json")

def _publication_attempt_ts(incident, problem):
    timestamps = []
    if isinstance(incident, dict) and incident.get("latest_actor") == "github_sync":
        timestamps.append(incident.get("last_timestamp"))
    evidence_refs = incident.get("evidence_refs") if isinstance(incident, dict) else []
    for ref in evidence_refs if isinstance(evidence_refs, list) else []:
        if not isinstance(ref, dict):
            continue
        if str(ref.get("kind") or "").startswith("github_issue"):
            for key in ("ts", "recorded_at", "created_at", "timestamp_utc"):
                value = ref.get(key)
                if value:
                    timestamps.append(value)
                    break
    fix_commits = problem.get("fix_commits") if isinstance(problem, dict) else []
    if timestamps:
        return sorted(str(value) for value in timestamps if value)[-1]
    if fix_commits:
        return incident.get("last_timestamp") if isinstance(incident, dict) else None
    return None

def _dedupe_refs(items, *, key_fields):
    seen = set()
    deduped = []
    for item in items:
        if not isinstance(item, dict):
            continue
        key = tuple(item.get(field) for field in key_fields)
        if key in seen:
            continue
        seen.add(key)
        deduped.append(item)
    return deduped

def _bounded_refs(items, *, key_fields):
    return _dedupe_refs(items, key_fields=key_fields)[:MAX_CROSS_REF_ITEMS]

def _match_tokens(*values):
    tokens = set()
    for value in values:
        text = str(value or "").strip().lower()
        if text:
            tokens.add(text)
    return tokens

def _artifact_matches(payload, tokens):
    haystacks = []
    if isinstance(payload, dict):
        for key in ("session", "plan", "plan_name", "workspace", "incident_id", "meta_repair_id", "escalation_id"):
            value = payload.get(key)
            if value not in (None, ""):
                haystacks.append(str(value).lower())
        target = payload.get("target")
        if isinstance(target, dict):
            for key in ("target_id", "plan_name", "session"):
                value = target.get(key)
                if value not in (None, ""):
                    haystacks.append(str(value).lower())
    return any(token in hay for token in tokens for hay in haystacks)

def _load_json_records(paths):
    records = []
    for path in paths:
        payload = _load_json(path)
        if isinstance(payload, dict):
            records.append((path, payload))
    return records

def _collect_related_artifact_refs(workspace, plan, session, repair_data):
    repair_root = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_REPAIR_DATA_DIR", "/workspace/.megaplan/cloud-sessions/repair-data"))
    sidecar_root = repair_root.with_name(f"{repair_root.name}.d")
    repair_snapshot = _load_json(repair_root / f"{session}.repair-data.json")
    if not isinstance(repair_snapshot, dict):
        repair_snapshot = {}
    tokens = _match_tokens(session, plan, workspace.name, repair_snapshot.get("incident_id"), repair_data.get("incident_id"))
    incident_refs = []
    related_prior_incidents = []
    attempt_refs = []
    meta_refs = []
    escalation_refs = []
    current_incident_id = str(repair_snapshot.get("incident_id") or repair_data.get("incident_id") or "").strip()
    known_prior_refs = repair_snapshot.get("known_prior_issue_refs") if isinstance(repair_snapshot.get("known_prior_issue_refs"), list) else []
    known_prior_ids = {str(item.get("incident_id") or "").strip() for item in known_prior_refs if isinstance(item, dict)}
    known_prior_ids.discard("")
    incident_dir = repair_root / "incidents"
    for path, payload in _load_json_records(sorted(incident_dir.glob("*.json"), reverse=True)[:50]):
        incident_id = str(payload.get("incident_id") or path.stem).strip()
        if not incident_id:
            continue
        if incident_id != current_incident_id and incident_id not in known_prior_ids and not _artifact_matches(payload, tokens):
            continue
        ref = {
            "incident_id": _redact_scalar(incident_id),
            "path": _redact_scalar(path),
            "session": _redact_scalar(payload.get("session") or payload.get("target", {}).get("session") or ""),
            "state": _redact_scalar(payload.get("state") or payload.get("status") or ""),
            "source": "incident_record",
        }
        incident_refs.append(ref)
        if incident_id != current_incident_id:
            related_prior_incidents.append(ref)
    attempt_dir = repair_root / "attempts"
    attempt_ids = {str(item).strip() for item in (repair_snapshot.get("attempt_ids") or []) if str(item).strip()}
    current_attempt_id = str(repair_snapshot.get("current_attempt_id") or "").strip()
    if current_attempt_id:
        attempt_ids.add(current_attempt_id)
    for path, payload in _load_json_records(sorted(attempt_dir.glob("*.json"), reverse=True)[:50]):
        attempt_id = str(payload.get("attempt_id") or path.stem).strip()
        if not attempt_id:
            continue
        if attempt_id not in attempt_ids and not _artifact_matches(payload, tokens):
            continue
        attempt_refs.append(
            {
                "attempt_id": _redact_scalar(attempt_id),
                "incident_id": _redact_scalar(payload.get("incident_id") or ""),
                "path": _redact_scalar(path),
                "source": "attempt_record",
            }
        )
    meta_dir = repair_root / "meta"
    for path, payload in _load_json_records(sorted(meta_dir.glob("*.json"), reverse=True)[:50]):
        meta_id = str(payload.get("meta_repair_id") or path.stem).strip()
        if not meta_id or not _artifact_matches(payload, tokens):
            continue
        meta_refs.append(
            {
                "meta_repair_id": _redact_scalar(meta_id),
                "incident_id": _redact_scalar(payload.get("incident_id") or ""),
                "path": _redact_scalar(path),
                "source": "meta_record",
            }
        )
    escalation_path = sidecar_root / "escalations" / "escalations.jsonl"
    if escalation_path.exists():
        for record in read_jsonl_records(escalation_path, skip_parse_errors=True)[-50:]:
            if not isinstance(record, dict) or not _artifact_matches(record, tokens):
                continue
            escalation_refs.append(
                {
                    "escalation_id": _redact_scalar(record.get("escalation_id") or ""),
                    "incident_id": _redact_scalar(record.get("incident_id") or ""),
                    "path": _redact_scalar(escalation_path),
                    "sequence": record.get("_sequence"),
                    "source": "escalation_sidecar",
                }
            )
    source_refs = {
        "repair_data_path": _redact_scalar(repair_root / f"{session}.repair-data.json"),
        "repair_index_path": _redact_scalar(repair_root / "index.json"),
        "incident_paths": [item["path"] for item in _bounded_refs(incident_refs, key_fields=("incident_id", "path"))],
        "attempt_paths": [item["path"] for item in _bounded_refs(attempt_refs, key_fields=("attempt_id", "path"))],
        "meta_record_paths": [item["path"] for item in _bounded_refs(meta_refs, key_fields=("meta_repair_id", "path"))],
        "escalation_paths": [item["path"] for item in _bounded_refs(escalation_refs, key_fields=("escalation_id", "path", "sequence"))],
    }
    return {
        "related_prior_incidents": _bounded_refs(related_prior_incidents, key_fields=("incident_id", "path")),
        "prior_incident_refs": _bounded_refs(incident_refs, key_fields=("incident_id", "path")),
        "attempt_refs": _bounded_refs(attempt_refs, key_fields=("attempt_id", "path")),
        "meta_repair_refs": _bounded_refs(meta_refs, key_fields=("meta_repair_id", "path")),
        "escalation_refs": _bounded_refs(escalation_refs, key_fields=("escalation_id", "path", "sequence")),
        "source_refs": source_refs,
    }

def _collect_meta_run_refs(session):
    refs = []
    if not META_RUN_DIR.exists():
        return refs
    safe_session = "".join(ch if ch.isalnum() or ch in "_.-" else "-" for ch in str(session))
    candidates = list(META_RUN_DIR.glob(f"*{safe_session}*")) + list(META_RUN_DIR.glob(f"*{session}*"))
    seen = set()
    ordered = []
    for path in candidates:
        key = str(path)
        if key in seen or not path.is_file():
            continue
        seen.add(key)
        ordered.append((_mtime(path), path))
    ordered.sort(reverse=True)
    for mtime, path in ordered[:5]:
        tail = _tail_with_line_numbers(path, lines=12)
        launch_failure = _text_has_meta_launch_failure(tail)
        refs.append(
            {
                "path": _redact_scalar(path),
                "mtime_age_min": int((now.timestamp() - mtime) // 60) if mtime else None,
                "tail": _redact_scalar(tail),
                "launch_failure": launch_failure,
            }
        )
    return refs

def _text_has_meta_launch_failure(text):
    if not isinstance(text, str):
        return False
    needles = (
        "Codex meta-repair orchestrator returned no output",
        "Codex meta-repair prompt exceeded input limit",
        "Not inside a trusted directory",
        "--skip-git-repo-check was not specified",
        "codex CLI missing; no automated meta-repair",
        "failed to launch DeepSeek/Hermes subagents",
        "Input exceeds the maximum length",
        "input_too_large",
    )
    return any(needle in text for needle in needles)

def _meta_record_is_launch_failure(path):
    payload = _load_json(path)
    if not isinstance(payload, dict):
        return False
    outcome = str(payload.get("outcome") or "")
    if outcome and outcome not in {"UNKNOWN", "NO_FIX"} and not outcome.startswith("Codex meta-repair orchestrator returned no output"):
        return False
    haystacks = [
        str(payload.get("diagnosis") or ""),
        str(payload.get("reason") or ""),
    ]
    subagent_results = payload.get("subagent_results")
    if isinstance(subagent_results, dict):
        haystacks.extend(str(value or "") for value in subagent_results.values())
    return _text_has_meta_launch_failure("\n".join(haystacks))

def _repair_attempt_signals(repair_payload):
    attempts = repair_payload.get("attempts") if isinstance(repair_payload, dict) else []
    iterations = repair_payload.get("iterations") if isinstance(repair_payload, dict) else []
    if not isinstance(attempts, list):
        attempts = []
    if not isinstance(iterations, list):
        iterations = []
    recent_attempts = [item for item in attempts[-5:] if isinstance(item, dict)]
    recent_iterations = [item for item in iterations[-5:] if isinstance(item, dict)]
    failure_kinds = []
    for item in recent_attempts + recent_iterations:
        for candidate in (
            item.get("failure_classification"),
            (item.get("failure_context") or {}).get("failure_classification") if isinstance(item.get("failure_context"), dict) else None,
            (item.get("post_launch_failure_context") or {}).get("failure_classification") if isinstance(item.get("post_launch_failure_context"), dict) else None,
            (item.get("plan_latest_failure") or {}).get("kind") if isinstance(item.get("plan_latest_failure"), dict) else None,
            item.get("latest_failure_kind"),
        ):
            if isinstance(candidate, str) and candidate.strip():
                failure_kinds.append(candidate.strip())
                break
    repair_outcome = str(repair_payload.get("outcome") or "") if isinstance(repair_payload, dict) else ""
    attempt_outcomes = [
        str(item.get("outcome") or repair_outcome or "").strip()
        for item in recent_attempts + recent_iterations
        if isinstance(item, dict)
    ]
    return repair_outcome, [item for item in attempt_outcomes if item], failure_kinds

def _attempt_has_runtime_context(item):
    if not isinstance(item, dict):
        return False
    for key in ("recorded_at", "started_at", "finished_at", "dispatched_at", "run_dir", "outcome"):
        if str(item.get(key) or "").strip():
            return True
    for key in ("resolver_output", "target", "verification"):
        if isinstance(item.get(key), dict) and item.get(key):
            return True
    return False

def _meta_repair_summary(
    session,
    repair_data,
    meta_refs,
    *,
    run_kind="",
    current_state="",
    chain_state_summary=None,
    chain_log_summary=None,
    events_mtime_age_min=None,
):
    repair_root = pathlib.Path(os.environ.get("MEGAPLAN_AUDIT_REPAIR_DATA_DIR", "/workspace/.megaplan/cloud-sessions/repair-data"))
    repair_payload = _load_json(repair_root / f"{session}.repair-data.json")
    if not isinstance(repair_payload, dict):
        repair_payload = {}
    run_refs = _collect_meta_run_refs(session)
    repair_outcome, attempt_outcomes, failure_kinds = _repair_attempt_signals(repair_payload)
    recent_attempts = [
        item
        for item in (repair_payload.get("attempts") if isinstance(repair_payload.get("attempts"), list) else [])[-5:]
        if isinstance(item, dict)
    ]
    recent_iterations = [
        item
        for item in (repair_payload.get("iterations") if isinstance(repair_payload.get("iterations"), list) else [])[-5:]
        if isinstance(item, dict)
    ]
    current_attempt_id = str(repair_payload.get("current_attempt_id") or "").strip()
    current_recurrence = repair_payload.get("current_recurrence") if isinstance(repair_payload.get("current_recurrence"), dict) else {}
    current_signature = repair_payload.get("current_signature") if isinstance(repair_payload.get("current_signature"), dict) else {}
    terminal_success = False
    if isinstance(repair_data, dict) and not repair_data.get("exists"):
        normalized_kind = str(run_kind or "").strip().lower()
        normalized_state = str(current_state or "").strip().lower()
        if normalized_kind == "plan":
            terminal_success = normalized_state in {"done", "complete", "completed", "finalized"}
        else:
            chain_current = (chain_state_summary or {}).get("current") if isinstance(chain_state_summary, dict) else {}
            chain_last_state = str((chain_current or {}).get("last_state") or "").strip().lower()
            chain_current_plan = str((chain_current or {}).get("current_plan_name") or "").strip()
            terminal_success = chain_last_state in {"done", "complete", "completed"} and not chain_current_plan
    if terminal_success and not meta_refs and not run_refs:
        return {
            "should_dispatch": False,
            "trigger": "",
            "rationale": [
                "session already reached terminal success and has no repair-data or meta-repair artifacts; "
                "partial-liveness sidecars alone are not operative meta-repair evidence"
            ],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": 0,
            "meta_run_refs": [],
            "missing_meta_run_evidence": False,
        }
    if (
        repair_outcome == "running"
        and not current_attempt_id
        and not current_recurrence
        and not current_signature
        and not recent_iterations
        and not recent_attempts
    ):
        run_refs = _collect_meta_run_refs(session)
        return {
            "should_dispatch": True,
            "trigger": "repair_running_without_attempt_context",
            "rationale": [
                "repair-data reports running but has no current attempt id, recurrence, "
                "signature, attempts, or iterations; this is an artifact-quality gap, "
                "not proof that ordinary repair is active"
            ],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": len(run_refs),
            "meta_run_refs": run_refs,
            "missing_meta_run_evidence": bool(not meta_refs and not run_refs),
        }
    if (
        repair_outcome == "running"
        and not current_attempt_id
        and not current_recurrence
        and not current_signature
        and not recent_iterations
        and recent_attempts
    ):
        return {
            "should_dispatch": False,
            "trigger": "",
            "rationale": [
                "repair-data reports running but no active attempt/iteration context is present; "
                "historical attempts alone are insufficient to demand meta-repair"
            ],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": 0,
            "meta_run_refs": [],
            "missing_meta_run_evidence": False,
        }
    if (
        not current_attempt_id
        and not current_recurrence
        and not current_signature
        and recent_attempts
        and not any(_attempt_has_runtime_context(item) for item in recent_attempts)
        and repair_outcome not in {"repair_timeout", "repair_exhausted"}
    ):
        return {
            "should_dispatch": False,
            "trigger": "",
            "rationale": ["repair-data only contains legacy attempt summaries; no active recurring repair context is present"],
            "repair_outcome": _redact_scalar(repair_outcome),
            "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
            "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
            "meta_record_count": len(meta_refs or []),
            "meta_run_log_count": 0,
            "meta_run_refs": [],
            "missing_meta_run_evidence": False,
        }
    try:
        classification, _ = evaluate_meta_repair_triggers(
            session,
            repair_data_dir=repair_root,
            repair_outcome=repair_outcome,
            attempt_outcomes=attempt_outcomes,
            failure_kinds=failure_kinds,
            repair_budget_exhausted=repair_outcome in {"repair_timeout", "repair_exhausted"},
            load_evidence=True,
        )
        should_dispatch = bool(classification.should_dispatch)
        trigger = classification.trigger_label
        rationale = [_redact_scalar(item) for item in classification.rationale]
    except Exception as exc:
        should_dispatch = False
        trigger = "classification_error"
        rationale = [_redact_scalar(exc)]
    normalized_kind = str(run_kind or "").strip().lower()
    normalized_state = str(current_state or "").strip().lower()
    live_event_activity = isinstance(events_mtime_age_min, int) and events_mtime_age_min <= 5
    chain_log_age = None
    if isinstance(chain_log_summary, dict):
        chain_log_age = chain_log_summary.get("mtime_age_min")
    live_chain_activity = isinstance(chain_log_age, int) and chain_log_age <= 5
    non_terminal_state = normalized_state not in {"done", "complete", "completed", "finalized"}
    live_target_activity = non_terminal_state and (
        live_event_activity or (normalized_kind == "chain" and live_chain_activity)
    )
    if should_dispatch and trigger in {"persistent_recurring_retry", "partial_liveness_recurrence"} and live_target_activity:
        should_dispatch = False
        trigger = ""
        rationale = [
            "watchdog-corroborated live target activity supersedes recurring meta-repair dispatch: "
            f"events_mtime_age_min={events_mtime_age_min!r}, chain_log_mtime_age_min={chain_log_age!r}"
        ]
    failed_run_refs = [item for item in run_refs if item.get("launch_failure")]
    failed_meta_records = []
    for item in meta_refs or []:
        path = item.get("path") if isinstance(item, dict) else ""
        if path and _meta_record_is_launch_failure(pathlib.Path(str(path))):
            failed_meta_records.append(item)
    return {
        "should_dispatch": should_dispatch,
        "trigger": trigger,
        "rationale": rationale,
        "repair_outcome": _redact_scalar(repair_outcome),
        "attempt_outcomes": [_redact_scalar(item) for item in attempt_outcomes[-5:]],
        "failure_kinds": [_redact_scalar(item) for item in failure_kinds[-5:]],
        "meta_record_count": len(meta_refs or []),
        "meta_run_log_count": len(run_refs),
        "meta_run_refs": run_refs,
        "failed_meta_run_count": len(failed_run_refs),
        "failed_meta_record_count": len(failed_meta_records),
        "missing_meta_run_evidence": bool(should_dispatch and not meta_refs and not run_refs),
        "failed_meta_run_evidence": bool(should_dispatch and (failed_run_refs or failed_meta_records)),
    }

def _collect_watchdog_report_refs(session, plan, workspace):
    refs = []
    tokens = _match_tokens(session, plan, workspace.name)
    candidates = []
    if WATCHDOG_REPORT_PATH.exists():
        candidates.append(WATCHDOG_REPORT_PATH)
    if WATCHDOG_REPORT_ARCHIVE_DIR.exists():
        candidates.extend(sorted(WATCHDOG_REPORT_ARCHIVE_DIR.glob("*.json"), reverse=True)[:20])
    for path in candidates:
        payload = _load_json(path)
        if not isinstance(payload, dict):
            continue
        if not _artifact_matches(payload, tokens):
            items = payload.get("items") if isinstance(payload.get("items"), list) else []
            issues = payload.get("issues") if isinstance(payload.get("issues"), list) else []
            if not any(_artifact_matches(item, tokens) for item in items + issues if isinstance(item, dict)):
                continue
        refs.append(
            {
                "report_id": _redact_scalar(path.stem),
                "path": _redact_scalar(path),
                "timestamp_utc": _redact_scalar(payload.get("timestamp_utc") or ""),
            }
        )
    return _bounded_refs(refs, key_fields=("report_id", "path"))

def _collect_audit_report_refs(session, plan):
    refs = []
    if not AUDIT_REPORT_DIR.exists():
        return refs
    for path in sorted(AUDIT_REPORT_DIR.glob("*-audit.json"), reverse=True)[:20]:
        payload = _load_json(path)
        if not isinstance(payload, dict):
            continue
        findings = payload.get("findings") if isinstance(payload.get("findings"), list) else []
        if not any(
            isinstance(item, dict)
            and str(item.get("session") or "") == session
            and str(item.get("plan") or "") == plan
            for item in findings
        ):
            continue
        refs.append(
            {
                "report_id": _redact_scalar(path.stem),
                "path": _redact_scalar(path),
                "timestamp_utc": _redact_scalar(payload.get("timestamp_utc") or ""),
            }
        )
    return _bounded_refs(refs, key_fields=("report_id", "path"))

def _collect_persistent_finding_refs(session, plan, incident_ids):
    if not PERSISTENT_FINDINGS_DOC.exists():
        return []
    refs = []
    wanted = _match_tokens(session, plan, *incident_ids)
    try:
        lines = PERSISTENT_FINDINGS_DOC.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return []
    for lineno, line in enumerate(lines, start=1):
        lower = line.lower()
        if not any(token in lower for token in wanted):
            continue
        refs.append(
            {
                "path": _redact_scalar(PERSISTENT_FINDINGS_DOC),
                "line": lineno,
                "excerpt": _redact_scalar(line[:200]),
            }
        )
    return _bounded_refs(refs, key_fields=("path", "line"))

def _collect_ticket_refs(workspace, session, plan, incident_ids):
    ticket_dir = workspace / ".megaplan" / "tickets"
    if not ticket_dir.exists():
        return []
    refs = []
    wanted = _match_tokens(session, plan, *incident_ids)
    for path in sorted(ticket_dir.glob("*.md"), reverse=True)[:20]:
        try:
            body = path.read_text(encoding="utf-8", errors="replace")
        except Exception:
            continue
        if not any(token in body.lower() for token in wanted):
            continue
        ticket_id = path.name.split("-", 1)[0]
        refs.append(
            {
                "ticket_id": _redact_scalar(ticket_id),
                "path": _redact_scalar(path),
            }
        )
    return _bounded_refs(refs, key_fields=("ticket_id", "path"))

def _collect_commit_refs():
    if not (COMMIT_SOURCE_DIR / ".git").exists():
        return []
    cmd = [
        "git",
        "-C",
        str(COMMIT_SOURCE_DIR),
        "log",
        "--max-count",
        str(MAX_COMMIT_REFS),
        "--pretty=format:%H%x09%s",
        "--",
        *COMMIT_SOURCE_PATHS,
    ]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    except OSError:
        return []
    if proc.returncode != 0:
        return []
    refs = []
    for line in proc.stdout.splitlines():
        sha, _, subject = line.partition("\t")
        sha = sha.strip()
        if not sha:
            continue
        refs.append(
            {
                "commit": _redact_scalar(sha[:12]),
                "subject": _redact_scalar(subject[:200]),
            }
        )
    return _bounded_refs(refs, key_fields=("commit",))

def _tail_with_line_numbers(path, lines=20):
    if path is None:
        return ""
    try:
        raw_lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return ""
    start = max(0, len(raw_lines) - lines)
    return "\n".join(f"L{idx + 1}: {line}" for idx, line in enumerate(raw_lines[start:], start=start))

def _chain_log_candidates(workspace, session, entry):
    candidates = []
    log_value = entry.get("log")
    if log_value:
        candidates.append(pathlib.Path(log_value))
    if session and session != "megaplan-chain":
        candidates.append(workspace / ".megaplan" / f"cloud-chain-{session}.log")
    candidates.append(workspace / ".megaplan" / "cloud-chain.log")
    if session == "megaplan-chain":
        candidates.append(workspace / ".megaplan" / f"cloud-chain-{session}.log")
    seen = set()
    unique = []
    for path in candidates:
        key = str(path)
        if key not in seen:
            seen.add(key)
            unique.append(path)
    return unique

_AWAITING_HUMAN_TOKEN = re.compile(r"(?<![A-Za-z0-9_])awaiting_human(?:_verify)?(?![A-Za-z0-9_])")

def _has_awaiting_human_token(line):
    return bool(_AWAITING_HUMAN_TOKEN.search(line.lower()))

def _normalize_stop_signature(line):
    lower = line.lower()
    if _has_awaiting_human_token(lower):
        return "awaiting_human"
    if "pr #" in lower and "closed" in lower:
        return "pr_closed"
    if "terminal state reached" in lower:
        return "terminal_state_reached"
    if "status: stopped" in lower or '"status": "stopped"' in lower:
        return "status_stopped"
    if "repair loop exhausted" in lower:
        return "repair_loop_exhausted"
    if "all milestones complete" in lower:
        return "all_milestones_complete"
    return ""

def _chain_log_summary(workspace, session, entry):
    log_path = next((path for path in _chain_log_candidates(workspace, session, entry) if path.exists()), None)
    if log_path is None:
        return {
            "path": "",
            "mtime_age_min": None,
            "tail": "",
            "recent_milestone_starts": [],
            "recent_terminal_states": [],
            "recent_stops": [],
            "repetition_summary": [],
            "one_milestone_stop_cycles": [],
        }
    try:
        lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        lines = []
    milestone_starts = []
    terminal_states = []
    stops = []
    signatures = {}
    cycles = []
    current_cycle = []
    for idx, line in enumerate(lines, start=1):
        lower = line.lower()
        rendered = f"L{idx}: {line}"
        if "milestone" in lower and "starting" in lower:
            milestone_starts.append(rendered)
            current_cycle.append((idx, line))
        if "terminal state reached" in lower:
            terminal_states.append(rendered)
        if (
            "status: stopped" in lower
            or '"status": "stopped"' in lower
            or _has_awaiting_human_token(lower)
            or ("pr #" in lower and "closed" in lower)
            or "repair loop exhausted" in lower
            or "all milestones complete" in lower
        ):
            stops.append(rendered)
            signature = _normalize_stop_signature(line)
            if signature:
                bucket = signatures.setdefault(signature, [])
                bucket.append((idx, line))
            milestone_lines = [
                (line_idx, text)
                for line_idx, text in current_cycle
                if "milestone" in text.lower() and "starting" in text.lower()
            ]
            if len(milestone_lines) == 1:
                cycles.append(
                    {
                        "start_line": milestone_lines[0][0],
                        "stop_line": idx,
                        "start": f"L{milestone_lines[0][0]}: {milestone_lines[0][1]}",
                        "stop": rendered,
                    }
                )
            current_cycle = []
    repetition_summary = []
    for signature, occurrences in sorted(signatures.items()):
        if len(occurrences) < 2:
            continue
        repetition_summary.append(
            {
                "signature": signature,
                "count": len(occurrences),
                "first_line": occurrences[0][0],
                "last_line": occurrences[-1][0],
                "examples": [f"L{idx}: {line}" for idx, line in occurrences[-3:]],
            }
        )
    mtime = _mtime(log_path)
    return {
        "path": str(log_path),
        "mtime_age_min": int((now.timestamp() - mtime) // 60) if mtime else None,
        "tail": _tail_with_line_numbers(log_path, lines=20),
        "recent_milestone_starts": milestone_starts[-5:],
        "recent_terminal_states": terminal_states[-5:],
        "recent_stops": stops[-8:],
        "repetition_summary": repetition_summary[-8:],
        "one_milestone_stop_cycles": cycles[-8:],
    }

def _chain_state_paths(workspace):
    candidates = set()
    candidates.update((workspace / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(workspace.glob(".megaplan/initiatives/*/.megaplan/plans/.chains/*.json"))
    candidates.update((workspace / ".megaplan").glob("**/chain_state.json"))
    ordered = []
    for path in candidates:
        if path.name == "full_suite_baseline.json":
            continue
        mtime = _mtime(path)
        if mtime:
            ordered.append((mtime, path))
    ordered.sort(reverse=True)
    return [path for _, path in ordered]

def _compact_backstop(backstop):
    if not isinstance(backstop, dict):
        return {}
    return {
        "mode": backstop.get("mode"),
        "status": backstop.get("status"),
        "blocks": backstop.get("blocks"),
        "failed": backstop.get("failed"),
        "delta_computed": backstop.get("delta_computed"),
    }

def _chain_state_summary(workspace, plan):
    summaries = []
    for path in _chain_state_paths(workspace)[:4]:
        data = _load_json(path)
        if not isinstance(data, dict):
            continue
        completed = data.get("completed")
        completed_items = completed if isinstance(completed, list) else []
        summary = {
            "path": str(path),
            "mtime_age_min": int((now.timestamp() - _mtime(path)) // 60) if _mtime(path) else None,
            "current_milestone_index": data.get("current_milestone_index"),
            "completed_count": len(completed_items),
            "current_plan_name": data.get("current_plan_name") or "",
            "current_state": data.get("current_state") or "",
            "last_state": data.get("last_state") or "",
            "pr_number": data.get("pr_number"),
            "pr_state": data.get("pr_state"),
            "reason": data.get("reason") or data.get("error") or "",
            "events": data.get("events")[-8:] if isinstance(data.get("events"), list) else [],
            "completed": [],
        }
        milestones = data.get("milestones")
        if isinstance(milestones, list):
            summary["total_milestones"] = len(milestones)
        for item in completed_items[-8:]:
            if not isinstance(item, dict):
                continue
            summary["completed"].append(
                {
                    "label": item.get("label"),
                    "plan": item.get("plan"),
                    "status": item.get("status"),
                    "pr_number": item.get("pr_number"),
                    "pr_state": item.get("pr_state"),
                    "full_suite_backstop": _compact_backstop(item.get("full_suite_backstop")),
                }
            )
        summaries.append(summary)
    current = next((item for item in summaries if item.get("current_plan_name") == plan), None)
    if current is None:
        current = summaries[0] if summaries else {}
    return {"current": current, "all": summaries}


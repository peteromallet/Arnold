def _canonical_launch_disagreement_reason(ev):
    repair = ev.get("repair_data_summary") if isinstance(ev, dict) else {}
    custody = ev.get("repair_custody_summary") if isinstance(ev, dict) else {}
    repair = repair if isinstance(repair, dict) else {}
    custody = custody if isinstance(custody, dict) else {}
    watchdog_refs = ev.get("prior_watchdog_report_refs") if isinstance(ev, dict) else []
    watchdog_statuses = {
        str(item.get("matched_status") or "").strip().lower()
        for item in (watchdog_refs if isinstance(watchdog_refs, list) else [])
        if isinstance(item, dict)
    }
    active_claim = (
        str(repair.get("outcome") or "").strip().lower()
        in {"running", "repairing", "in_progress", "active"}
        or bool(watchdog_statuses & {"repair_dispatched", "repair_running", "meta_repair"})
        or str(custody.get("custody_bucket") or "") == "repairing"
    )
    attempts = custody.get("attempts") if isinstance(custody.get("attempts"), list) else []
    queue_attempts = [
        item for item in attempts
        if isinstance(item, dict) and item.get("source") == "repair_queue_dispatch_attempt"
    ]
    references = []
    for item in queue_attempts:
        raw = item.get("raw") if isinstance(item.get("raw"), dict) else {}
        references.append(
            {
                "request_id": item.get("request_id") or raw.get("request_id"),
                "blocker_id": item.get("blocker_id") or raw.get("blocker_id"),
                "run_id": raw.get("managed_run_id"),
                "manifest_path": raw.get("managed_manifest_path"),
                "attempt_path": item.get("path"),
            }
        )
    if active_claim and not references:
        return "agent_claim_without_canonical_manifest: repair/dispatched label has no linked queue attempt"
    for ref in references:
        if not ref["run_id"] or not ref["manifest_path"]:
            return (
                "legacy_direct_agent_launch: repair attempt lacks managed run/manifest linkage "
                f"attempt={ref.get('attempt_path') or 'unknown'}"
            )
        manifest = _load_json(pathlib.Path(str(ref["manifest_path"])))
        try:
            provenance = normalize_machine_origin_provenance(manifest.get("launch_provenance") or {})
        except Exception:
            return (
                "managed_run_link_disagreement: managed manifest has missing/invalid machine origin "
                f"run={ref['run_id']} manifest={ref['manifest_path']}"
            )
        links = manifest.get("links") if isinstance(manifest.get("links"), dict) else {}
        if (
            not is_managed_manifest(manifest)
            or manifest.get("run_id") != ref["run_id"]
            or links.get("repair_request_id") != ref["request_id"]
            or links.get("blocker_id") != ref["blocker_id"]
            or provenance.get("transport") != "automatic_system"
        ):
            return (
                "managed_run_link_disagreement: attempt, manifest, request, blocker, or origin disagree "
                f"run={ref['run_id']} manifest={ref['manifest_path']}"
            )
        if manifest.get("status") in {"completed", "failed", "interrupted", "cancelled", "superseded", "unknown"} and active_claim:
            return (
                "managed_run_lifecycle_disagreement: repair label is active but canonical run is terminal "
                f"run={ref['run_id']} status={manifest.get('status')}"
            )
    return ""


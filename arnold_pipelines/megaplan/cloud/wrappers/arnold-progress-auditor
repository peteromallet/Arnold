  log "autofix observed but mutation blocked; skipping Codex dispatch for findings=$N_FINDINGS"
fi

record_incident_audits "$GATHER_DIR/findings.json"

# Final report assembly: JSON + Markdown + one-line log append.
python3 - "$GATHER_DIR/findings.json" "$JSON_OUT" "$MD_OUT" "$REPORT_LOG" "$TS" "$AUDIT_MUTATION_AUTHORIZED_FLAG" "$AUDIT_LAUNCH_ATTEMPTED" "$RECOVERY_EVIDENCE" "$AUDIT_CODEX_MODEL" <<'PY'
import datetime as dt
import glob
import json
import os
import pathlib
import sys

findings_path, json_out, md_out, log_path, ts = sys.argv[1:6]
autofix_authorized = len(sys.argv) > 6 and sys.argv[6] == "1"
launch_attempted = len(sys.argv) > 7 and sys.argv[7] == "1"
recovery_evidence_path = sys.argv[8]
codex_model = sys.argv[9]
data = json.load(open(findings_path, encoding="utf-8"))
try:
    recovery_sweep = json.load(open(recovery_evidence_path, encoding="utf-8"))
except Exception:
    recovery_sweep = {
        "enabled": False,
        "watchdog_exit_code": 127,
        "sessions_discovered": 0,
        "should_run_count": 0,
        "decisions": [],
    }

# Merge the per-finding subagent responses back in.
findings = data.get("findings") or []
for i, f in enumerate(findings):
    resp_path = os.path.join(os.path.dirname(findings_path), f"finding-{i}.json")
    if os.path.exists(resp_path):
        f.update(json.load(open(resp_path, encoding="utf-8")))
launch_attempted = launch_attempted or any(
    bool(f.get("codex_launch_attempted")) for f in findings if isinstance(f, dict)
)
dispatch_receipts = []
for finding in findings:
    if not isinstance(finding, dict):
        continue
    receipt_root = finding.get("dispatch_receipt_root")
    dispatch_id = finding.get("dispatch_id")
    if not receipt_root or not dispatch_id:
        continue
    receipt_path = pathlib.Path(receipt_root) / "dispatch_receipts" / f"{dispatch_id}.json"
    try:
        receipt = json.loads(receipt_path.read_text(encoding="utf-8"))
    except Exception:
        continue
    dispatch_receipts.append(receipt)
    launch_attempted = launch_attempted or receipt.get("subprocess_started") is True
resolved_models = sorted({
    str(receipt.get("resolved_runtime_model"))
    for receipt in dispatch_receipts
    if receipt.get("subprocess_started") is True and receipt.get("resolved_runtime_model")
})
resolved_runtime_model = resolved_models[0] if len(resolved_models) == 1 else None

now_iso = dt.datetime.now(dt.timezone.utc).isoformat()
green_checks = data.get("green_checks") or []
green_checks = [
    {
        key: item.get(key)
        for key in (
            "plan",
            "workspace",
            "session",
            "sources",
            "current_state",
            "iteration",
            "active_step_phase",
            "plan_v_count",
            "last_gate_recommendation",
            "last_gate_score",
        )
    }
    for item in green_checks
    if isinstance(item, dict)
]
related_prior_incidents = []
for finding in findings:
    for item in finding.get("related_prior_incidents") or []:
        if isinstance(item, dict):
            related_prior_incidents.append(item)
seen_prior = set()
deduped_prior = []
for item in related_prior_incidents:
    key = (item.get("incident_id"), item.get("path"))
    if key in seen_prior:
        continue
    seen_prior.add(key)
    deduped_prior.append(item)
# Collect autonomous fix attempts and risky/deferred fixes from findings.
autonomous_fix_attempts = []
risky_or_deferred_fixes = []
for f in findings:
    hypothesis = (f.get("hypothesis") or "").strip()
    if not hypothesis:
        continue
    first_line = hypothesis.split("\n")[0].strip()
    plan = f.get("plan")
    session = f.get("session")
    if first_line.startswith("FIXED"):
        risky_or_deferred_fixes.append(
            {
                "plan": plan,
                "session": session,
                "verdict": "INVALID_MUTATION_CLAIM",
                "summary": hypothesis[:200],
            }
        )
    elif first_line.startswith("ESCALATE"):
        risky_or_deferred_fixes.append(
            {
                "plan": plan,
                "session": session,
                "verdict": "ESCALATE",
                "summary": hypothesis[:200],
            }
        )
# ── stage_metrics, coverage, data_quality, dispatch_summary ──────────
stage_metrics_data = data.get("stage_metrics") or {}
STAGE_NAMES = [
    "prep", "plan", "critique", "gate", "revise", "finalize",
    "execute", "review", "feedback", "chain", "repair",
    "meta_repair", "human_pr_ci", "deployment_runtime",
]
STAGE_COUNTERS = [
    "stalls", "retries", "repair_attempts", "meta_repair_attempts",
    "human_waits", "ci_waits", "handoff_gaps", "no_op_loops",
    "dead_workers", "duration_seconds", "unknowns", "missing_evidence",
]

# coverage block ── deterministic summary of which stages have data
coverage = {
    "total_stages": len(STAGE_NAMES),
    "stages_with_data": [],
    "stages_without_data": [],
    "stages_not_checked": [],
}
for stage in STAGE_NAMES:
    bucket = stage_metrics_data.get(stage)
    if not isinstance(bucket, dict) or not bucket:
        coverage["stages_not_checked"].append(stage)
        continue
    has_data = any(
        bucket.get(counter, 0) > 0
        for counter in STAGE_COUNTERS
    )
    if has_data:
        coverage["stages_with_data"].append(stage)
    else:
        coverage["stages_without_data"].append(stage)

# data_quality block ── explicit missing/unknown/not_checked states
data_quality = {
    "unknown_phases": stage_metrics_data.get("unknown_phase_count", 0),
    "unknown_phase_evidence": stage_metrics_data.get("unknown_phase_evidence") or [],
    "stages_with_missing_evidence": [],
    "missing_inputs": [],
    "data_sources": {
        "stage_metrics_available": bool(stage_metrics_data),
        "findings_available": bool(findings),
        "green_checks_available": bool(green_checks),
    },
}
for stage in STAGE_NAMES:
    bucket = stage_metrics_data.get(stage)
    if isinstance(bucket, dict) and bucket.get("missing_evidence", 0) > 0:
        data_quality["stages_with_missing_evidence"].append(stage)
    if not isinstance(stage_metrics_data.get(stage), dict):
        data_quality["missing_inputs"].append(
            {"stage": stage, "status": "not_checked", "reason": "stage bucket not present in stage_metrics"}
        )

# A launch attempt permanently falsifies report-only, even when exec/timeout
# failed and no response was produced.
dispatch_summary = {
    "mode": "autofix_attempted" if launch_attempted else "report_only",
    "autofix_enabled": autofix_authorized,
    "repair_dispatched": False,
    "model_dispatched": launch_attempted,
    "deepseek_dispatched": False,
    "meta_repair_dispatched": False,
    "codex_dispatched": launch_attempted,
    "resolved_runtime_model": resolved_runtime_model,
    "dispatch_receipt_count": len(dispatch_receipts),
    "git_commit_performed": False,
    "file_edit_performed": False,
    "rationale": (
        "A Codex launch was attempted; report-only is false regardless of launch outcome."
        if launch_attempted
        else "Autofix mutation blocked; report-only mode confirmed. No repair, model, "
        "meta-repair, git commit, or file-edit dispatch occurred."
    ),
}

payload = {
    "schema_version": 1,
    "timestamp_utc": now_iso,
    "window_hours": data.get("window_hours"),
    "stall_summary": data.get("stall_summary"),
    "finding_count": len(findings),
    "green_checks_count": len(green_checks),
    "deepseek_model": findings[0].get("deepseek_model") if findings else None,
    "codex_model": codex_model,
    "recovery_sweep": recovery_sweep,
    "findings": findings,
    "green_checks": green_checks,
    "related_prior_incidents": deduped_prior,
    "stage_metrics": stage_metrics_data,
    "coverage": coverage,
    "data_quality": data_quality,
    "dispatch_summary": dispatch_summary,
    "dispatch_receipts": dispatch_receipts,
    "root_cause_patterns": data.get("root_cause_patterns") or {
        "repeated_failure_signatures": [],
        "chain_log_repetitions": [],
        "stale_state_patterns": [],
    },
    "autonomous_fix_attempts": autonomous_fix_attempts,
    "risky_or_deferred_fixes": risky_or_deferred_fixes,
}
pathlib.Path(os.path.dirname(json_out)).mkdir(parents=True, exist_ok=True)
with open(json_out, "w", encoding="utf-8") as h:
    json.dump(payload, h, indent=2, sort_keys=True)
    h.write("\n")

lines = [
    f"# Progress audit — {ts}",
    "",
    f"Window: {payload['window_hours']}h · findings: {payload['finding_count']} · green: {len(green_checks)} · watchdog stall flags: {payload['stall_summary']}",
    f"DeepSeek model: {payload.get('deepseek_model') or 'n/a'}",
    f"Codex model: {payload.get('codex_model') or 'n/a'}",
    "",
]
recovery = payload.get("recovery_sweep") or {}
lines.extend(
    [
        "## Recovery sweep",
        "",
        (
            f"Watchdog exit: `{recovery.get('watchdog_exit_code')}` · "
            f"sessions discovered: `{recovery.get('sessions_discovered')}` · "
            f"should run after sweep: `{recovery.get('should_run_count')}`"
        ),
        "",
    ]
)
for item in recovery.get("decisions") or []:
    lines.append(
        f"- **{item.get('session')}** — `{item.get('disposition')}` → "
        f"`{item.get('decision')}` · watchdog `{','.join(item.get('watchdog_statuses') or []) or 'none'}`"
    )
lines.append("")
if not findings and not green_checks:
    lines.append("_No plans detected in the audit window._")
elif not findings:
    lines.append("_No suspicious plans detected in the audit window._")
# ── Stage metrics ────────────────────────────────────────────────────
lines.append("## Stage metrics")
lines.append("")
nonzero_stages = []
for stage in STAGE_NAMES:
    bucket = stage_metrics_data.get(stage)
    if not isinstance(bucket, dict):
        continue
    has_nonzero = any(bucket.get(c, 0) > 0 for c in STAGE_COUNTERS)
    if not has_nonzero:
        continue
    nonzero_stages.append(stage)
    counter_parts = []
    for c in STAGE_COUNTERS:
        val = bucket.get(c, 0)
        if val > 0:
            counter_parts.append(f"{c}={val}")
    counter_str = ", ".join(counter_parts) if counter_parts else "none"
    duration = bucket.get("duration_seconds", 0)
    unknowns = bucket.get("unknowns", 0)
    missing = bucket.get("missing_evidence", 0)
    evidence_bits = []
    for c in STAGE_COUNTERS:
        ev_list = bucket.get(f"{c}_evidence", [])
        for ref in ev_list[:1]:
            ref_type = ref.get("type", "")
            ref_value = str(ref.get("value", ""))[:50]
            if ref_value:
                evidence_bits.append(f"{ref_type}:{ref_value}")
    ev_str = " · ".join(evidence_bits[:5]) if evidence_bits else ""
    extra = []
    if unknowns > 0:
        extra.append(f"unknowns={unknowns}")
    if missing > 0:
        extra.append(f"missing_evidence={missing}")
    extra_str = " · ".join(extra) if extra else ""
    line = f"- **{stage}**: {counter_str}"
    if duration > 0:
        line += f" · duration={duration}s"
    if extra_str:
        line += f" · {extra_str}"
    if ev_str:
        line += f" · [{ev_str}]"
    lines.append(line)
unknown_phases = stage_metrics_data.get("unknown_phase_count", 0)
if unknown_phases > 0:
    lines.append(f"- **unknown phases**: {unknown_phases} phase(s) could not be mapped to a stage")
if not nonzero_stages and unknown_phases == 0:
    lines.append("_No stage metric data available._")
lines.append("")
for f in findings:
    lines.append(f"## {f.get('plan')} — `{f.get('session')}`")
    lines.append(f"- workspace: `{f.get('workspace')}`")
    lines.append(f"- state: `{f.get('current_state')}` · iteration `{f.get('iteration')}` · last gate `{f.get('last_gate_recommendation')}` (score {f.get('last_gate_score')})")
    lines.append(f"- plan_v: {f.get('plan_v_count')} versions · recent gates ITERATE/blocked {f.get('recent_gate_iterate')}/{f.get('recent_gate_total')}")
    reasons = "; ".join(f.get("reasons", []))
    lines.append(f"- signals: {reasons}")
    chain_current = (f.get("chain_state_summary") or {}).get("current") or {}
    chain_log = f.get("chain_log") or {}
    if chain_current or chain_log.get("path"):
        lines.append(
            f"- chain: last_state `{chain_current.get('last_state') or 'unknown'}` · "
            f"current_plan `{chain_current.get('current_plan_name') or 'unknown'}` · "
            f"milestone_index `{chain_current.get('current_milestone_index')}` · "
            f"completed `{chain_current.get('completed_count')}` · log `{chain_log.get('path') or 'n/a'}`"
        )
    repeats = chain_log.get("repetition_summary") or []
    if repeats:
        rendered = "; ".join(
            f"{item.get('signature')}={item.get('count')}x L{item.get('first_line')}..L{item.get('last_line')}"
            for item in repeats[:4]
        )
        lines.append(f"- chain repeats: {rendered}")
    repair = f.get("repair_data_summary") or {}
    if repair.get("exists"):
        lines.append(f"- repair-data: `{repair.get('path')}` · iterations `{repair.get('iteration_count')}` · outcome `{repair.get('outcome')}`")
    user_actions = f.get("user_action_context") or {}
    unresolved = user_actions.get("unresolved_user_actions") or []
    if user_actions.get("user_actions_path") or unresolved:
        ids = ", ".join(str(item.get("id")) for item in unresolved[:5]) or "none"
        lines.append(f"- user actions: `{user_actions.get('user_actions_path') or 'n/a'}` · unresolved `{ids}`")
    if f.get("related_prior_incidents"):
        rendered = "; ".join(
            f"{item.get('incident_id')} ({item.get('path')})"
            for item in (f.get("related_prior_incidents") or [])[:3]
            if isinstance(item, dict)
        )
        lines.append(f"- related prior incidents: {rendered}")
    source_refs = f.get("source_refs") or {}
    if source_refs:
        bits = []
        for key in ("audit_report_paths", "watchdog_report_paths", "persistent_finding_paths", "ticket_paths", "meta_record_paths", "meta_run_log_paths"):
            value = source_refs.get(key)
            if isinstance(value, list) and value:
                bits.append(f"{key}={', '.join(str(item) for item in value[:2])}")
        if bits:
            lines.append(f"- source refs: {'; '.join(bits)}")
    meta_summary = f.get("meta_repair_summary") or {}
    if meta_summary:
        lines.append(
            f"- meta-repair: trigger `{meta_summary.get('trigger')}` · "
            f"should_dispatch `{meta_summary.get('should_dispatch')}` · "
            f"records `{meta_summary.get('meta_record_count')}` · "
            f"run_logs `{meta_summary.get('meta_run_log_count')}`"
        )
    if f.get("latest_failure_message"):
        lines.append(f"- latest_failure: {f.get('latest_failure_kind')} — {f.get('latest_failure_message')}")
    stale = f.get("stale_state_evidence") or {}
    stale_bits = []
    if stale.get("latest_failure_is_stale"):
        stale_bits.append(f"latest_failure_is_stale last_success_after_failure={stale.get('last_success_after_failure')}")
    if stale.get("stale_block_replay"):
        stale_bits.append(f"stale_block_replay count={stale.get('stale_block_replay_count')} hash={stale.get('stale_block_replay_hash')}")
    if stale.get("between_milestone_cycling"):
        stale_bits.append(f"between_milestone_cycling cycles={stale.get('one_milestone_stop_cycle_count')}")
    if stale_bits:
        lines.append(f"- stale/cycling evidence: {'; '.join(stale_bits)}")
    clear_actions = stale.get("recommended_state_clear_actions") or []
    if clear_actions:
        lines.append(f"- stale-state clear actions: {'; '.join(clear_actions)}")
    stderr = (((f.get("plan_latest_failure") or {}).get("metadata") or {}).get("stderr") or "")
    if stderr:
        stderr_line = " ".join(str(stderr).split())[:260]
        lines.append(f"- latest_failure.stderr: `{stderr_line}`")
    lines.append("")
    lines.append("**DeepSeek hypothesis / recommendation:**")
    lines.append("")
    resp = (f.get("hypothesis") or "").strip() or "_(no response)_"
    lines.append(resp)
    lines.append("")
rcp = payload.get("root_cause_patterns") or {}
rcp_sections = []
rep_sigs = rcp.get("repeated_failure_signatures") or []
if rep_sigs:
    rcp_sections.append("### Repeated failure signatures across plans")
    for item in rep_sigs[:6]:
        plans = ", ".join(item.get("affected_plans") or [])
        sessions = ", ".join(item.get("affected_sessions") or [])
        rcp_sections.append(
            f"- `{item.get('signature', '')[:120]}` × {item.get('total_occurrences')} "
            f"· plans: {plans} · sessions: {sessions}"
        )
    rcp_sections.append("")
chain_reps = rcp.get("chain_log_repetitions") or []
if chain_reps:
    rcp_sections.append("### Chain-log repetition patterns across plans")
    for item in chain_reps[:6]:
        plans = ", ".join(item.get("affected_plans") or [])
        sessions = ", ".join(item.get("affected_sessions") or [])
        rcp_sections.append(
            f"- `{item.get('signature')}` × {item.get('total_occurrences')} "
            f"· plans: {plans} · sessions: {sessions}"
        )
    rcp_sections.append("")
stale_pats = rcp.get("stale_state_patterns") or []
if stale_pats:
    rcp_sections.append("### Stale-state patterns across plans")
    for item in stale_pats[:6]:
        plans = ", ".join(item.get("affected_plans") or [])
        sessions = ", ".join(item.get("affected_sessions") or [])
        rcp_sections.append(
            f"- `{item.get('pattern')}` in {item.get('plan_count')} plans "
            f"· plans: {plans} · sessions: {sessions}"
        )
    rcp_sections.append("")
if rcp_sections:
    lines.append("## 🔁 Root-cause patterns (cross-plan)")
    lines.append("")
    lines.extend(rcp_sections)
if green_checks:
    lines.append("## ✅ Healthy plans (inspected, no suspicious signals)")
    lines.append("")
    for gc in green_checks:
        gc_state = f"state `{gc.get('current_state')}` · iteration `{gc.get('iteration')}`"
        gc_gate = ""
        if gc.get("last_gate_recommendation"):
            gc_gate = f" · gate `{gc.get('last_gate_recommendation')}` (score {gc.get('last_gate_score')})"
        lines.append(f"- **{gc.get('plan')}** (`{gc.get('session')}`) — {gc_state}{gc_gate}")
    lines.append("")
# Autonomous fix attempts section (always emitted with empty-state text).
lines.append("## 🔧 Autonomous fix attempts")
lines.append("")
if autonomous_fix_attempts:
    for af in autonomous_fix_attempts:
        commit_str = f" commit `{af.get('commit')}`" if af.get("commit") else ""
        lines.append(f"- **{af.get('plan')}** (`{af.get('session')}`) —{commit_str} {af.get('summary', '')[:120]}")
else:
    lines.append("_No autonomous fixes were attempted during this audit._")
lines.append("")
# Risky or deferred fixes section (always emitted with empty-state text).
lines.append("## ⚠️ Risky or deferred fixes")
lines.append("")
if risky_or_deferred_fixes:
    for rf in risky_or_deferred_fixes:
        lines.append(f"- **{rf.get('plan')}** (`{rf.get('session')}`) — verdict `{rf.get('verdict')}` — {rf.get('summary', '')[:120]}")
else:
    lines.append("_No risky or deferred fixes were identified during this audit._")
lines.append("")
with open(md_out, "w", encoding="utf-8") as h:
    h.write("\n".join(lines) + "\n")

# One-line log append (human-greppable).
summary_bits = [f.get("plan") for f in findings] or ["none"]
with open(log_path, "a", encoding="utf-8") as h:
    h.write(f"{now_iso}\tfindings={len(findings)}\tgreen={len(green_checks)}\tplans={','.join(summary_bits)}\tstall={data.get('stall_summary','')[:80]}\n")
print(json_out)
PY

log "report written to $JSON_OUT (findings=$FINDING_COUNT)"

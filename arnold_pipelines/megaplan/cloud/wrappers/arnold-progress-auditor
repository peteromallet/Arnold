def _issue_repo_for_workspace(workspace):
    workspace_path = Path(workspace)
    repo_path = Path(explicit_repo_path) if explicit_repo_path else workspace_path
    if explicit_repo:
        return explicit_repo, repo_path
    try:
        proc = subprocess.run(
            ["git", "-C", str(repo_path), "remote", "get-url", "origin"],
            check=False,
            capture_output=True,
            text=True,
        )
    except OSError:
        return None, repo_path
    if proc.returncode != 0:
        return None, repo_path
    raw = proc.stdout.strip()
    if raw.startswith("git@github.com:"):
        raw = raw.split(":", 1)[1]
    elif "github.com/" in raw:
        raw = raw.split("github.com/", 1)[1]
    raw = raw.removesuffix(".git").strip("/")
    if raw.count("/") != 1:
        return None, repo_path
    return raw, repo_path


def _event_evidence(item):
    source_refs = item.get("source_refs") if isinstance(item.get("source_refs"), dict) else {}
    incident_brief = item.get("incident_brief") if isinstance(item.get("incident_brief"), dict) else {}
    evidence = [
        {
            "kind": "incident_summary",
            "path": source_refs.get("incident_summary_path"),
            "session_id": item.get("session"),
        },
        {
            "kind": "problem_summary",
            "path": source_refs.get("problem_summary_path"),
            "session_id": item.get("session"),
        },
    ]
    for key in ("audit_report_paths", "watchdog_report_paths", "meta_record_paths", "attempt_paths"):
        for path in source_refs.get(key) or []:
            evidence.append({"kind": key.rstrip("s"), "path": path, "session_id": item.get("session")})
    last_timestamp = incident_brief.get("last_timestamp")
    if last_timestamp:
        evidence.append({"kind": "incident_brief", "session_id": item.get("session"), "status": last_timestamp})
    return [entry for entry in evidence if entry.get("path") or entry.get("status")]


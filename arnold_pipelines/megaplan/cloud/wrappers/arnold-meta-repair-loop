session, trigger_raw, verdict, resp_path, brief_path, repair_data_dir, worker_run_id, worker_manifest, blocker_id = sys.argv[1:10]

trigger = None
try:
    trigger = MetaRepairTrigger(trigger_raw)
except ValueError:
    pass

resp_text = ""
try:
    resp_text = Path(resp_path).read_text(encoding="utf-8")
except Exception:
    pass

brief_text = ""
try:
    brief_text = Path(brief_path).read_text(encoding="utf-8")
except Exception:
    pass

meta_repair_id = str(uuid.uuid4())

install_sync_raw = os.environ.get("INSTALL_SYNC_JSON", "{}")
install_sync_info = {}
try:
    install_sync_info = json.loads(install_sync_raw)
except Exception:
    pass

verification_raw = os.environ.get(
    "META_REPAIR_VERIFICATION_JSON",
    os.environ.get("POST_RETRIGGER_VERIFICATION_JSON", "{}"),
)
verification_info = {}
try:
    verification_info = json.loads(verification_raw)
except Exception:
    pass

post_retrigger_verification = {"verdict": verdict}
try:
    post_retrigger_verification["commit_custody"] = json.loads(
        os.environ.get("COMMIT_CUSTODY_JSON", "{}")
    )
except Exception:
    post_retrigger_verification["commit_custody"] = {
        "accepted": False,
        "outcome": "commit_custody_failed",
    }
if install_sync_info:
    post_retrigger_verification["install_sync"] = install_sync_info
if isinstance(verification_info, dict) and verification_info:
    post_retrigger_verification.update(verification_info)

effective_outcome = derive_meta_repair_effective_outcome(
    verdict=verdict,
    install_sync_status=str(install_sync_info.get("status") or ""),
    post_retrigger_verification=post_retrigger_verification,
)

record = MetaRepairRecord(
    meta_repair_id=meta_repair_id,
    session=session,
    trigger=trigger,
    blocker_id=blocker_id,
    diagnosis=redact_text(resp_text[:4000]),
    subagent_results={
        "codex_response": redact_text(resp_text[:4000]),
        "managed_agent_run_id": worker_run_id,
        "managed_agent_manifest": worker_manifest,
        "parent_managed_agent_run_id": str(os.environ.get("ARNOLD_MANAGED_AGENT_RUN_ID") or ""),
    },
    changes=[],
    tests=[],
    retrigger_command=redact_text(str(post_retrigger_verification.get("retrigger_command") or "")),
    post_retrigger_verification=post_retrigger_verification,
    outcome=effective_outcome,
)

# Build the meta-repair verdict following the same discipline as ordinary repair
meta_verdict = build_meta_repair_verdict(
    record=record,
    verdict=verdict,
    session=session,
    failure_reasons=(
        f"trigger={trigger_raw}" if trigger_raw else "no_trigger",
    ),
    retrigger_command_evidence=(
        os.environ.get("META_REPAIR_VERIFICATION_JSON", "{}")
    ),
)

record_path = persist_meta_repair_record(
    record,
    repair_data_dir=repair_data_dir,
    verdict=meta_verdict,
)
outcome_path = str(os.environ.get("ARNOLD_L3_REPAIR_OUTCOME_PATH") or "").strip()
if outcome_path:
    marker = lambda name: any(
        line.strip().lower() == f"{name.lower()}=true"
        for line in resp_text.splitlines()
    )
    guard_false = any(
        line.strip().lower() == "guard_weakened=false"
        for line in resp_text.splitlines()
    )
    accepted = verification_info.get("accepted") is True
    outcome = {
        "schema_version": "arnold-l3-repair-outcome-v1",
        "audit_escalation_id": str(os.environ.get("ARNOLD_L3_ESCALATION_ID") or ""),
        "repair_request_id": str(os.environ.get("CLOUD_WATCHDOG_REPAIR_REQUEST_ID") or ""),
        "root_managed_run_id": str(os.environ.get("ARNOLD_MANAGED_AGENT_RUN_ID") or ""),
        "worker_managed_run_id": worker_run_id,
        "worker_managed_manifest_path": worker_manifest,
        "meta_repair_record_path": str(record_path),
        "fixer_fixed": bool(verdict.startswith("FIXED") and marker("FIXER_FIXED") and accepted),
        "backstop_fixed": bool(verdict.startswith("FIXED") and marker("BACKSTOP_FIXED") and accepted),
        "guard_weakened": not guard_false,
        "guard_changes": [] if guard_false else ["missing_explicit_no-guard-weakening_receipt"],
        "ordinary_retrigger_run_id": str(verification_info.get("ordinary_retrigger_run_id") or ""),
        "ordinary_retrigger_manifest_path": str(verification_info.get("ordinary_retrigger_manifest_path") or ""),
        "ordinary_retrigger_verification": verification_info,
        "verdict": verdict,
    }
    destination = Path(outcome_path)
    destination.parent.mkdir(parents=True, exist_ok=True)
    temporary = destination.with_suffix(destination.suffix + ".tmp")
    temporary.write_text(json.dumps(outcome, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    temporary.replace(destination)
print(f"RECORD_PATH={record_path}")
print(f"META_REPAIR_ID={meta_repair_id}")
print(f"VERDICT_KIND={meta_verdict.verdict_kind}")
PY
}

    session_id=session,
    parent_event_ids=parent_ids if parent_ids else None,
    root=workspace_root,
)
print(f"RETRIGGER_EVENT_ID={retrigger_event.get('event_id', '')}")

# Retrigger ordinary repair
retrigger_command = [repair_loop_bin, session]
try:
    marker = json.loads((marker_dir / f"{session}.json").read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    marker = {}
workspace = str(marker.get("workspace") or "").strip()
remote_spec = str(marker.get("remote_spec") or "").strip()
if workspace:
    retrigger_command.append(workspace)
    if remote_spec:
        retrigger_command.append(remote_spec)
parent_run_id = str(os.environ.get("ARNOLD_MANAGED_AGENT_RUN_ID") or "").strip() or None
request_id = str(os.environ.get("CLOUD_WATCHDOG_REPAIR_REQUEST_ID") or "").strip()
blocker_id = str(os.environ.get("CLOUD_WATCHDOG_REPAIR_BLOCKER_ID") or "").strip()
identity_key = f"meta-retrigger:{session}:{parent_run_id or install_sync_event_id}"
managed_project = Path(workspace).resolve() if workspace else workspace_root.resolve()
spec = ManagedCommandSpec(
    run_kind="automatic_repair_retry",
    identity_key=identity_key,
    project_dir=managed_project,
    argv=tuple(retrigger_command),
    task_kind="autonomous",
    difficulty=8,
    model="control-plane",
    reasoning_effort="bounded",
    route_class="meta_repair_retrigger",
    backend="repair-loop",
    command_display=f"meta-repair ordinary repair retrigger {session}",
    launch_provenance=machine_origin_provenance(
        origin_kind="meta_repair_retrigger",
        origin_id=session,
        component="arnold-meta-repair-loop",
        trigger_id=parent_run_id or install_sync_event_id or session,
    ),
    links={
        "repair_request_id": request_id,
        "blocker_id": blocker_id,
        "incident_id": incident_id,
        "cloud_session": session,
        "chain": remote_spec,
        "phase": "meta_repair_retrigger",
    },
    parent_run_id=parent_run_id,
    lineage_key=f"repair-retrigger:{request_id or session}",
    tee_output=False,
)
managed_returncode = run_managed_command(spec)
run_id = stable_managed_run_id(spec.run_kind, spec.identity_key)
managed_root = managed_project / ".megaplan" / "plans" / "resident-subagents" / run_id
managed_log = managed_root / "run.log"
try:
    managed_stdout = managed_log.read_text(encoding="utf-8", errors="replace")
except OSError:
    managed_stdout = ""
completed = SimpleNamespace(
    returncode=managed_returncode,
    stdout=managed_stdout,
    stderr="",
)

# Verify retrigger result from the authoritative session repair-data artifact,
# not from subprocess liveness alone.
lookup_error = ""
post_retrigger_verification = {}
try:
    post_retrigger_verification = load_authoritative_post_retrigger_verification(
        session,
        repair_data_path,
    )
except Exception as exc:
    lookup_error = f"{type(exc).__name__}: {exc}"

retrigger_result = RetriggerExecutionResult(
    command=tuple(retrigger_command),
    returncode=int(completed.returncode),
    stdout=str(completed.stdout or ""),
    stderr=str(completed.stderr or ""),
    lock_released=False,
)
verification = verify_retrigger_success(
    retriggered=True,
    retrigger_result=retrigger_result,
    post_retrigger_verification=post_retrigger_verification,
)
verification["ordinary_retrigger_run_id"] = run_id
verification["ordinary_retrigger_manifest_path"] = str(managed_root / "manifest.json")
if lookup_error:
    verification["authoritative_repair_data_error"] = lookup_error
    if retrigger_result.returncode == 0:
        verification["accepted"] = False
        verification["rejection_reason"] = (
            "authoritative post-retrigger repair-data outcome unavailable: "
            f"{lookup_error}"
        )

accepted = bool(verification.get("accepted"))
effective_returncode = retrigger_result.returncode
if not accepted and effective_returncode == 0:
    effective_returncode = VERIFIER_REJECTION_RETURNCODE

verification_event_id = ""
if accepted:
    verification_event = append_verified_recovered(
        incident_id=incident_id,
        summary=(
            "Ordinary repair retrigger verified success "
            f"outcome={verification.get('outcome', '')} "
            f"returncode={retrigger_result.returncode}"

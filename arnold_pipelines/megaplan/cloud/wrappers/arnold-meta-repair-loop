#!/usr/bin/env bash
# arnold-meta-repair-loop — diagnose and fix repair-system failures when
# ordinary repair has failed.
#
# Invoked by the cloud watchdog after ordinary repair failure classification
# identifies one of the six meta-repair trigger conditions.  This wrapper:
#   1. Loads env (cloud-hot-env), redaction helpers.
#   2. Classifies the failure via Python handoff to meta_repair.py and
#      builds a redacted diagnosis prompt.
#   3. Checks feature flags and recursion guard — exits early when
#      META_REPAIR_ENABLED is explicitly off or recursion is detected.
#   4. Dispatches Codex as the top-level orchestrator with
#      --sandbox danger-full-access.  Codex is instructed to read the
#      subagent-launcher skill and delegate DeepSeek/Hermes research
#      subagents (provider=deepseek, model=deepseek:deepseek-v4-pro,
#      profile=partnered-5) for broad mapping, log/history review,
#      independent root-cause probes, and bounded fix investigations.
#   5. May commit and push by default where policy permits; operators can
#      explicitly disable this with META_REPAIR_COMMIT_ENABLED=0.
#   6. Retriggers the ordinary repair loop for the same session after
#      applying any fix, then verifies terminal success.
#   7. Persists a redacted meta-repair record under repair-data/meta/.
set -uo pipefail

TERMINAL_AUDIT_MODE=0
if [[ "${1:-}" == "--terminal-audit" ]]; then
  TERMINAL_AUDIT_MODE=1
  shift
fi

if [[ $# -lt 1 ]]; then
  echo "usage: arnold-meta-repair-loop [--terminal-audit] <session> [trigger]" >&2
  exit 64
fi

SESSION="$1"
WATCHDOG_TRIGGER="${2:-}"

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

MARKER_DIR="${MEGAPLAN_META_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
REPAIR_DATA_DIR="${MEGAPLAN_META_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
ARNOLD_SRC="${MEGAPLAN_META_ARNOLD_SRC:-/workspace/arnold}"
SELF_PATH="${MEGAPLAN_META_SELF_PATH:-${BASH_SOURCE[0]:-$0}}"
if command -v readlink >/dev/null 2>&1; then
  SELF_PATH="$(readlink -f "$SELF_PATH" 2>/dev/null || printf '%s' "$SELF_PATH")"
fi
WRAPPER_REPO_ROOT="$(cd "$(dirname "$SELF_PATH")/../../../.." 2>/dev/null && pwd || printf '%s' /)"
if [[ ! -f "$WRAPPER_REPO_ROOT/arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop" ]] \
  && [[ -f "$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop" ]]; then
  WRAPPER_REPO_ROOT="$ARNOLD_SRC"
fi
LAUNCHER="${MEGAPLAN_META_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
SUBAGENT_SKILL="${MEGAPLAN_META_SUBAGENT_SKILL:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/subagent-launcher/SKILL.md}"
DEEPSEEK_MODEL="${MEGAPLAN_META_MODEL:-deepseek:deepseek-v4-pro}"
SUBAGENT_PROFILE="${MEGAPLAN_META_SUBAGENT_PROFILE:-partnered-5}"
SUBAGENT_TIMEOUT="${MEGAPLAN_META_SUBAGENT_TIMEOUT_SECS:-900}"
CODEX_TIMEOUT="${MEGAPLAN_META_CODEX_TIMEOUT_SECS:-5400}"
META_REPAIR_BUDGET="${MEGAPLAN_META_BUDGET_SECS:-7200}"
META_REPAIR_ENABLED_VAR="${ARNOLD_META_REPAIR_ENABLED:-1}"
META_REPAIR_COMMIT_ENABLED_VAR="${ARNOLD_META_REPAIR_COMMIT_ENABLED:-1}"
SYNC_BRANCH="${MEGAPLAN_META_SYNC_BRANCH:-editible-install}"
REPAIR_LOOP_BIN="${MEGAPLAN_META_REPAIR_LOOP_BIN:-$WRAPPER_REPO_ROOT/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop}"
REPAIR_LOOP_FALLBACK="$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop"
if [[ ! -f "$REPAIR_LOOP_BIN" && -f "$REPAIR_LOOP_FALLBACK" ]]; then
  REPAIR_LOOP_BIN="$REPAIR_LOOP_FALLBACK"
fi
REPAIR_DATA_PATH="$REPAIR_DATA_DIR/${SESSION}.repair-data.json"
RUN_DIR="${MEGAPLAN_META_RUN_DIR:-/workspace/.megaplan/meta-runs}"
BRIEF_PREFLIGHT_MAX_CHARS="${MEGAPLAN_META_BRIEF_PREFLIGHT_MAX_CHARS:-900000}"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
SAFE_SESSION="$(printf '%s' "$SESSION" | tr -c 'A-Za-z0-9_.-' '-')"
RUN_LOG="$RUN_DIR/${TS}-${SAFE_SESSION}.log"

mkdir -p "$RUN_DIR" "$REPAIR_DATA_DIR"

# No-model closeout: invoke L1 once only after strict terminal preflight.
if [[ "$TERMINAL_AUDIT_MODE" == 1 ]]; then
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 -m arnold_pipelines.megaplan.cloud.terminal_audit "$SESSION" --repair-loop-bin "$REPAIR_LOOP_BIN" --marker-dir "$MARKER_DIR" --repair-data-dir "$REPAIR_DATA_DIR"
  exit $?
fi

log() {
  local message
  message="$(redact_inline_text "$*")"
  echo "[meta-repair $(date -Iseconds)] $message" | tee -a "$RUN_LOG"
}

redact_inline_text() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$1" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

print(redact_text(sys.argv[1]), end="")
PY
}

redact_file_in_place() {
  local path="${1:-}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$path" <<'PY'
from pathlib import Path
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

path = Path(sys.argv[1])
path.write_text(redact_text(path.read_text(encoding="utf-8")), encoding="utf-8")
PY
}

l2_mutation_authorized() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 -c \
    'from arnold_pipelines.megaplan.cloud.feature_flags import MUTATION_PATH_L2, mutation_authorized; raise SystemExit(0 if mutation_authorized(MUTATION_PATH_L2) else 1)'
}

# ---- early gate: feature flag -----------------------------------------------
case "$META_REPAIR_ENABLED_VAR" in
  0|false|False|FALSE|no|No|NO|off|Off|OFF)
  log "meta-repair disabled (ARNOLD_META_REPAIR_ENABLED=$META_REPAIR_ENABLED_VAR); exiting"
  exit 0
  ;;
esac

log "meta-repair starting session=$SESSION"

# ---- early gate: recursion guard --------------------------------------------
recursion_check() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.meta_repair_policy import check_meta_repair_recursion

session, repair_data_dir = sys.argv[1:3]
result = check_meta_repair_recursion(session, repair_data_dir=repair_data_dir)
if result.recursing:
    print(f"RECURSION:{result.recommendation}")
    sys.exit(1)
print(f"OK:{result.recommendation}")
PY
}

RECURSION_OUTPUT="$(recursion_check 2>&1)" || true
if [[ "$RECURSION_OUTPUT" == RECURSION:* ]]; then
  log "recursion guard: $RECURSION_OUTPUT"
  log "escalating to NEEDS_HUMAN instead of recursing"

  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" "$RECURSION_OUTPUT" <<'PY'
import json, sys, uuid
from datetime import datetime, timezone
from pathlib import Path

from arnold_pipelines.megaplan.cloud.repair_contract import atomic_write_json, NEEDS_HUMAN
from arnold_pipelines.megaplan.cloud.redact import redact_text

session, repair_data_dir, recursion_output = sys.argv[1:4]
needs_human = {
    "session": session,
    "outcome": NEEDS_HUMAN,
    "reason": redact_text(recursion_output),
    "recorded_at": datetime.now(timezone.utc).isoformat(),
    "escalation_id": str(uuid.uuid4()),
}
meta_dir = Path(repair_data_dir) / "meta"
meta_dir.mkdir(parents=True, exist_ok=True)
needs_path = meta_dir / f"needs-human-{session}.json"
atomic_write_json(needs_path, needs_human)
print(f"escalation persisted: {needs_path}")
PY
  exit 1
fi
log "recursion guard: $RECURSION_OUTPUT"

# ---- classify failure + build redacted prompt via Python handoff -------------
classification_and_prompt() {
  local force_emergency="${1:-0}"
  FORCE_EMERGENCY="$force_emergency" PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" "$REPAIR_DATA_PATH" "$MARKER_DIR" "$META_REPAIR_ENABLED_VAR" "$WATCHDOG_TRIGGER" <<'PY'
import json, os, sys

from arnold_pipelines.megaplan.cloud.current_target import resolve_current_target
from arnold_pipelines.megaplan.cloud.meta_repair import (
    MetaRepairClassification,
    MetaRepairTrigger,
    build_meta_repair_prompt,
    evaluate_meta_repair_triggers,
    load_redacted_evidence,
)

session, repair_data_dir, repair_data_path, marker_dir, enabled, watchdog_trigger = sys.argv[1:7]
force_emergency = os.environ.get("FORCE_EMERGENCY") == "1"

# Evaluate triggers without loading full evidence initially;
# the wrapper provides the trigger context.
trigger = None
if watchdog_trigger:
    try:
        trigger = MetaRepairTrigger(watchdog_trigger)
    except ValueError:
        trigger = None

if trigger is not None:
    evidence = load_redacted_evidence(session, repair_data_dir=repair_data_dir)
    current_target_observation = resolve_current_target(
        session,
        marker_dir=marker_dir,
        repair_data_dir=repair_data_dir,
    )
    evidence["current_target_corroboration"] = current_target_observation
    classification = MetaRepairClassification(
        session=session,
        trigger=trigger,
        rationale=(
            f"watchdog preclassified trigger={trigger.value}; "
            "meta loop preserves bounded trigger custody and treats live target discovery as corroboration",
        ),
        evidence=evidence,
    )
    prompt = build_meta_repair_prompt(
        classification,
        repair_data_dir=repair_data_dir,
        force_emergency=force_emergency,
    )
else:
    classification, prompt = evaluate_meta_repair_triggers(
        session,
        repair_data_dir=repair_data_dir,
        load_evidence=True,
    )
    if classification.should_dispatch:
        prompt = build_meta_repair_prompt(
            classification,
            repair_data_dir=repair_data_dir,
            force_emergency=force_emergency,
        )

if not classification.should_dispatch:
    print("NO_TRIGGER")
    sys.exit(0)

print("TRIGGER:" + (classification.trigger.value if classification.trigger else "unknown"))
print("PROMPT_START")
print(prompt)
print("PROMPT_END")
PY
}

CLASSIFICATION_RESULT="$(classification_and_prompt 2>&1)" || true
if [[ "$CLASSIFICATION_RESULT" == NO_TRIGGER* ]]; then
  log "no meta-repair trigger matched; exiting"
  exit 0
fi

TRIGGER_TYPE="$(echo "$CLASSIFICATION_RESULT" | sed -n 's/^TRIGGER://p')"
log "trigger=$TRIGGER_TYPE"

# Extract the prompt (between PROMPT_START and PROMPT_END markers)
PROMPT="$(echo "$CLASSIFICATION_RESULT" | sed -n '/^PROMPT_START$/,/^PROMPT_END$/{//!p}')"
if [[ -z "$PROMPT" ]]; then
  log "prompt assembly produced empty output; exiting"
  exit 1
fi

# Write the prompt to a file for Codex dispatch + redact it
BRIEF_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-brief.md"
{
  echo "# Meta-Repair Diagnosis: $SESSION"
  echo
  echo "**Trigger:** \`$TRIGGER_TYPE\`"
  echo "**Session:** \`$SESSION\`"
  echo "**Repair Data Directory:** \`$REPAIR_DATA_DIR\`"
  echo
  echo "$PROMPT"
  echo
  cat <<'PROMPT_POLICY'
## Meta-Repair Policy

You are diagnosing and repairing a failure in the Arnold repair system itself
— NOT the end-user project.  Your job is to fix the repair tooling so that
ordinary repair can succeed.

### Scope and authority
- You have `danger-full-access` sandbox scope.
- You may read, patch, and test files in the Arnold checkout
  (`$ARNOLD_SRC` on the `editible-install` branch).
- You may inspect the repair data, watchdog reports, chain state, session
  markers, and audit reports as evidence.
- You MUST delegate broad mapping, log/history review, independent
  root-cause probes, and bounded fix investigations to DeepSeek/Hermes
  research subagents wherever practical.

### Subagent dispatch
- Read the subagent-launcher skill at the path stored in
  `SUBAGENT_SKILL` for the exact dispatch contract.
- Use provider=deepseek, model=deepseek:deepseek-v4-pro,
  profile=partnered-5, max-tokens=92192.
- Each subagent gets a focused query, project directory, and a bounded
  scope.

### Commit/push policy
- You may commit and push fixes when ARNOLD_META_REPAIR_COMMIT_ENABLED is not
  explicitly disabled.
- Do not commit or push when ARNOLD_META_REPAIR_COMMIT_ENABLED=0/false/no/off.
- Pushes require the same gate as commits.

### Fix constraints
- Fix only Arnold repair-system code (wrappers, Python modules under
  arnold_pipelines/megaplan/cloud/, tests, contracts).
- Do NOT modify the running workspace/project tree.
- Keep fixes narrow, testable, and bounded.
- Validate fixes with `python3 -m py_compile` and focused tests.

### Retrigger
- After applying any fix, retrigger the ordinary repair loop for
  session `$SESSION` using the command stored in REPAIR_LOOP_BIN.
- Verify that the retriggered ordinary repair reaches a terminal
  SUCCESS outcome.
- Do NOT claim success without a verified ordinary repair retrigger —
  partial_liveness and "repairing" are not terminal success.

### Output format
Start with a verdict on its own line: FIXED, ESCALATE, or NO_FIX.
Then cite specific evidence, the root cause, the change(s) made
(if any), and the retrigger verification result.  Keep under 400 words.
PROMPT_POLICY
} > "$BRIEF_PATH"
redact_file_in_place "$BRIEF_PATH"
BRIEF_SIZE="$(wc -c < "$BRIEF_PATH" | tr -d ' ')"
if [[ "$BRIEF_SIZE" =~ ^[0-9]+$ ]] && (( BRIEF_SIZE > BRIEF_PREFLIGHT_MAX_CHARS )); then
  log "meta-repair brief exceeded preflight char budget; rebuilding emergency brief chars=$BRIEF_SIZE limit=$BRIEF_PREFLIGHT_MAX_CHARS"
  CLASSIFICATION_RESULT="$(classification_and_prompt 1 2>&1)" || true
  if [[ "$CLASSIFICATION_RESULT" == NO_TRIGGER* ]]; then
    log "emergency prompt rebuild returned no trigger; exiting"
    exit 0
  fi
  TRIGGER_TYPE="$(echo "$CLASSIFICATION_RESULT" | sed -n 's/^TRIGGER://p')"
  PROMPT="$(echo "$CLASSIFICATION_RESULT" | sed -n '/^PROMPT_START$/,/^PROMPT_END$/{//!p}')"
  if [[ -z "$PROMPT" ]]; then
    log "emergency prompt assembly produced empty output; exiting"
    exit 1
  fi
  {
    echo "# Meta-Repair Diagnosis: $SESSION"
    echo
    echo "**Trigger:** \`$TRIGGER_TYPE\`"
    echo "**Session:** \`$SESSION\`"
    echo "**Repair Data Directory:** \`$REPAIR_DATA_DIR\`"
    echo
    echo "$PROMPT"
    echo
    cat <<'PROMPT_POLICY'
## Meta-Repair Policy

You are diagnosing and repairing a failure in the Arnold repair system itself
— NOT the end-user project.  Your job is to fix the repair tooling so that
ordinary repair can succeed.

### Scope and authority
- You have `danger-full-access` sandbox scope.
- You may read, patch, and test files in the Arnold checkout
  (`$ARNOLD_SRC` on the `editible-install` branch).
- You may inspect the repair data, watchdog reports, chain state, session
  markers, and audit reports as evidence.
- You MUST delegate broad mapping, log/history review, independent
  root-cause probes, and bounded fix investigations to DeepSeek/Hermes
  research subagents wherever practical.

### Subagent dispatch
- Read the subagent-launcher skill at the path stored in
  `SUBAGENT_SKILL` for the exact dispatch contract.
- Use provider=deepseek, model=deepseek:deepseek-v4-pro,
  profile=partnered-5, max-tokens=92192.
- Each subagent gets a focused query, project directory, and a bounded
  scope.

### Commit/push policy
- You may commit and push fixes when ARNOLD_META_REPAIR_COMMIT_ENABLED is not
  explicitly disabled.
- Do not commit or push when ARNOLD_META_REPAIR_COMMIT_ENABLED=0/false/no/off.
- Pushes require the same gate as commits.

### Fix constraints
- Fix only Arnold repair-system code (wrappers, Python modules under
  arnold_pipelines/megaplan/cloud/, tests, contracts).
- Do NOT modify the running workspace/project tree.
- Keep fixes narrow, testable, and bounded.
- Validate fixes with `python3 -m py_compile` and focused tests.

### Retrigger
- After applying any fix, retrigger the ordinary repair loop for
  session `$SESSION` using the command stored in REPAIR_LOOP_BIN.
- Verify that the retriggered ordinary repair reaches a terminal
  SUCCESS outcome.
- Do NOT claim success without a verified ordinary repair retrigger —
  partial_liveness and "repairing" are not terminal success.

### Output format
Start with a verdict on its own line: FIXED, ESCALATE, or NO_FIX.
Then cite specific evidence, the root cause, the change(s) made
(if any), and the retrigger verification result.  Keep under 400 words.
PROMPT_POLICY
  } > "$BRIEF_PATH"
  redact_file_in_place "$BRIEF_PATH"
  BRIEF_SIZE="$(wc -c < "$BRIEF_PATH" | tr -d ' ')"
  log "emergency brief rebuilt chars=$BRIEF_SIZE"
fi

# ---- commit gate check ------------------------------------------------------
commit_gate_check() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.meta_repair_policy import can_commit_changes, can_push_changes

session = sys.argv[1]
commit_result = can_commit_changes(session=session)
push_result = can_push_changes(session=session)
print(f"COMMIT_ALLOWED={commit_result.allowed}")
print(f"PUSH_ALLOWED={push_result.allowed}")
print(f"COMMIT_REASON={commit_result.reason}")
PY
}

COMMIT_GATE="$(commit_gate_check 2>&1)" || true
COMMIT_ALLOWED="$(echo "$COMMIT_GATE" | sed -n 's/^COMMIT_ALLOWED=//p')"
PUSH_ALLOWED="$(echo "$COMMIT_GATE" | sed -n 's/^PUSH_ALLOWED=//p')"
log "commit_allowed=$COMMIT_ALLOWED push_allowed=$PUSH_ALLOWED"
SOURCE_BASELINE_HEAD="$(git -C "$ARNOLD_SRC" rev-parse HEAD 2>/dev/null || true)"
log "captured pre-dispatch source HEAD=${SOURCE_BASELINE_HEAD:-unavailable}"

# ---- Codex dispatch ---------------------------------------------------------
RESP_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-resp.txt"
ERR_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-resp.err"
FALLBACK_BRIEF_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-direct-hermes-brief.md"
FALLBACK_RESP_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-direct-hermes-resp.txt"

has_recordable_verdict() {
  local response_path="${1:-}"
  local first_line=""
  if [[ -f "$response_path" ]]; then
    first_line="$(head -1 "$response_path" | tr -d '\r\n')"
  fi
  [[ "$first_line" == FIXED* || "$first_line" == ESCALATE* || "$first_line" == NO_FIX* ]]
}

run_direct_hermes_fallback() {
  if [[ ! -f "$LAUNCHER" ]]; then
    log "direct Hermes fallback unavailable launcher=$LAUNCHER"
    return 1
  fi

  {
    cat <<EOF
# Direct Hermes Meta-Repair Fallback

The Codex orchestration path failed before producing a recordable verdict.
You are the direct repair agent now. Work on the Arnold source checkout at
\`$ARNOLD_SRC\`; do not modify the audited project workspace. Perform the
bounded investigation and repair yourself without launching another Codex
or Hermes agent. Preserve the output contract in the brief below.

EOF
    cat "$BRIEF_PATH"
  } > "$FALLBACK_BRIEF_PATH"
  redact_file_in_place "$FALLBACK_BRIEF_PATH"

  log "dispatching direct Hermes fallback session=$SESSION model=$DEEPSEEK_MODEL"
  (
    if [[ -f /workspace/.cloud-hot-env ]]; then
      set -a
      # shellcheck disable=SC1091
      . /workspace/.cloud-hot-env
      set +a
    fi
    export PYENV_VERSION=3.11.11
    export ARNOLD_PATH="$ARNOLD_SRC"
    export ARNOLD_SRC="$ARNOLD_SRC"
    export ARNOLD_META_REPAIR_COMMIT_ENABLED="$META_REPAIR_COMMIT_ENABLED_VAR"
    # Import the launcher from a neutral directory.  A source checkout may
    # contain a product-local `megaplan` package that shadows Hermes runtime
    # discovery before the agent starts.
    cd /workspace || exit 1
    timeout "$SUBAGENT_TIMEOUT" python3 -c '
import runpy
import sys
import types

# Some source checkouts contain a product-local ``megaplan`` namespace but
# not the legacy ``megaplan.agent`` package.  Older installed launchers treat
# that partial namespace as a fatal import instead of falling through to the
# current Arnold runtime.  Preload only the missing probe module so the
# launcher reaches its supported Arnold fallback without patching the
# separately installed skill in place.
try:
    import megaplan
except ModuleNotFoundError:
    megaplan = types.ModuleType("megaplan")
    megaplan.__path__ = []
    sys.modules["megaplan"] = megaplan
agent_probe = types.ModuleType("megaplan.agent")
sys.modules["megaplan.agent"] = agent_probe
setattr(megaplan, "agent", agent_probe)

launcher = sys.argv[1]
sys.argv = [launcher, *sys.argv[2:]]
runpy.run_path(launcher, run_name="__main__")
' "$LAUNCHER" \
      --model "$DEEPSEEK_MODEL" \
      --toolsets "file,web,terminal" \
      --query-file "$FALLBACK_BRIEF_PATH" \
      --project-dir /workspace
  ) > "$FALLBACK_RESP_PATH" 2>> "$ERR_PATH" || true
  redact_file_in_place "$FALLBACK_RESP_PATH"
  redact_file_in_place "$ERR_PATH"

  if ! has_recordable_verdict "$FALLBACK_RESP_PATH"; then
    log "direct Hermes fallback produced no recordable verdict"
    return 1
  fi
  cp "$FALLBACK_RESP_PATH" "$RESP_PATH"
  log "direct Hermes fallback produced a recordable verdict"
}

persist_unrecordable_launch_failure() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - \
    "$SESSION" "$TRIGGER_TYPE" "$REPAIR_DATA_DIR" "$RESP_PATH" "$ERR_PATH" <<'PY'
import sys
import uuid
from pathlib import Path

from arnold_pipelines.megaplan.cloud.meta_repair import (
    MetaRepairRecord,
    MetaRepairTrigger,
    persist_meta_repair_record,
)
from arnold_pipelines.megaplan.cloud.redact import redact_text

session, trigger_raw, repair_data_dir, response_path, error_path = sys.argv[1:6]
try:
    trigger = MetaRepairTrigger(trigger_raw)
except ValueError:
    trigger = None

response = Path(response_path).read_text(encoding="utf-8") if Path(response_path).exists() else ""
error = Path(error_path).read_text(encoding="utf-8") if Path(error_path).exists() else ""
diagnosis = (
    "Codex meta-repair orchestrator returned no output and direct Hermes "
    "fallback produced no recordable verdict."
)
record = MetaRepairRecord(
    meta_repair_id=str(uuid.uuid4()),
    session=session,
    trigger=trigger,
    diagnosis=diagnosis,
    subagent_results={
        "orchestrator_response": redact_text(response[:2000]),
        "launch_error": redact_text(error[-2000:]),
    },
    outcome="model_tool_launch_failure",
)
path = persist_meta_repair_record(record, repair_data_dir=repair_data_dir)
print(f"RECORD_PATH={path}")
PY
}

if ! l2_mutation_authorized; then
  log "observed: L2 Codex dispatch blocked (requires ARNOLD_AUTONOMY and ARNOLD_META_REPAIR_ENABLED)"
  printf '%s\n' \
    "NO_FIX" \
    "Meta-repair trigger observed; mutation blocked by the master-plus-path authorization gate." \
    > "$RESP_PATH"
  : > "$ERR_PATH"
elif command -v codex >/dev/null 2>&1; then
  log "dispatching Codex meta-repair session=$SESSION deepseek_model=$DEEPSEEK_MODEL profile=$SUBAGENT_PROFILE"
  (
    if [[ -f /workspace/.cloud-hot-env ]]; then
      set -a
      # shellcheck disable=SC1091
      . /workspace/.cloud-hot-env
      set +a
    fi
    export PYENV_VERSION=3.11.11
    export MEGAPLAN_DEFAULT_PROFILE="$SUBAGENT_PROFILE"
    export MEGAPLAN_REPAIR_PROFILE="$SUBAGENT_PROFILE"
    export ARNOLD_META_REPAIR_COMMIT_ENABLED="$META_REPAIR_COMMIT_ENABLED_VAR"
    export ARNOLD_SRC="$ARNOLD_SRC"
    cd "$ARNOLD_SRC" || exit 1
    timeout "$CODEX_TIMEOUT" codex exec --skip-git-repo-check --sandbox danger-full-access - < "$BRIEF_PATH"
  ) > "$RESP_PATH" 2>"$ERR_PATH" || true
  redact_file_in_place "$RESP_PATH"
  redact_file_in_place "$ERR_PATH"
  if [[ ! -s "$RESP_PATH" ]]; then
    if grep -qE 'Input exceeds the maximum length|input_too_large' "$ERR_PATH" 2>/dev/null; then
      echo "Codex meta-repair prompt exceeded input limit; see meta-repair log." > "$RESP_PATH"
    else
      echo "Codex meta-repair orchestrator returned no output (timed out or failed to launch DeepSeek/Hermes subagents); see meta-repair log." > "$RESP_PATH"
    fi
  fi
else
  log "codex CLI missing; trying direct Hermes fallback"
  echo "codex CLI missing; no automated meta-repair." > "$RESP_PATH"
fi

if ! has_recordable_verdict "$RESP_PATH"; then
  run_direct_hermes_fallback || true
fi

RESP_TEXT="$(cat "$RESP_PATH")"
log "codex response $(wc -l <<<"$RESP_TEXT" | tr -d ' ') lines"

# ---- parse verdict from response -------------------------------------------
VERDICT="$(echo "$RESP_TEXT" | head -1 | tr -d '\r\n')"

if ! has_recordable_verdict "$RESP_PATH"; then
  FAILURE_RECORD_INFO="$(persist_unrecordable_launch_failure 2>&1)" || true
  FAILURE_RECORD_PATH="$(echo "$FAILURE_RECORD_INFO" | sed -n 's/^RECORD_PATH=//p')"
  log "all meta-repair launch paths failed before a recordable verdict; negative evidence persisted path=$FAILURE_RECORD_PATH and recursion guard remains unpoisoned"
  exit 1
fi

if [[ "$VERDICT" == FIXED* ]]; then
  log "verdict=FIXED"
elif [[ "$VERDICT" == ESCALATE* ]]; then
  log "verdict=ESCALATE"
elif [[ "$VERDICT" == NO_FIX* ]]; then
  log "verdict=NO_FIX"
else
  log "verdict=UNKNOWN (first line: ${VERDICT:0:80})"
fi

# Prove that model-authored source changes have durable branch custody before
# install sync, retrigger, or a successful meta-repair record can proceed.
COMMIT_CUSTODY_JSON="$(PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$ARNOLD_SRC" "$SOURCE_BASELINE_HEAD" "$VERDICT" "$PUSH_ALLOWED" <<'PY'
import json, sys

from arnold_pipelines.megaplan.cloud.meta_repair import verify_meta_repair_commit_custody

repo, baseline, verdict, push_allowed = sys.argv[1:5]
result = verify_meta_repair_commit_custody(
    repo,
    baseline_head=baseline,
    verdict=verdict,
    push_required=push_allowed.strip().lower() == "true",
)
print(json.dumps(result, sort_keys=True))
PY
)" || COMMIT_CUSTODY_JSON='{"accepted":false,"outcome":"commit_custody_failed","reason":"commit custody verifier failed"}'
export COMMIT_CUSTODY_JSON
COMMIT_CUSTODY_ACCEPTED="$(python3 -c 'import json,os; print(str(bool(json.loads(os.environ["COMMIT_CUSTODY_JSON"]).get("accepted"))).lower())' 2>/dev/null || echo false)"
COMMIT_CUSTODY_REASON="$(python3 -c 'import json,os; print(json.loads(os.environ["COMMIT_CUSTODY_JSON"]).get("reason", ""))' 2>/dev/null || true)"
log "commit custody accepted=$COMMIT_CUSTODY_ACCEPTED reason=$COMMIT_CUSTODY_REASON"

# ---- install sync after FIXED verdict with source commit --------------------
INSTALL_SYNC_STATUS=""
INSTALL_SYNC_EVENT_ID=""
INSTALL_SYNC_EVENT_TYPE=""
export INSTALL_SYNC_JSON="{}"

if [[ "$VERDICT" == FIXED* ]]; then
  log "verdict=FIXED; checking for source commits before install sync"

  if [[ "$COMMIT_CUSTODY_ACCEPTED" != "true" ]]; then
    INSTALL_SYNC_STATUS="commit_custody_failed"
    export INSTALL_SYNC_JSON="$(python3 -c 'import json,os; print(json.dumps({"status":"commit_custody_failed","verification":json.loads(os.environ["COMMIT_CUSTODY_JSON"])}))')"
    log "commit custody FAILED; will NOT install sync or retrigger ordinary repair"
  else

    INSTALL_SYNC_RESULT="$(PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$ARNOLD_SRC" "$WRAPPER_REPO_ROOT" <<'PY'
import json, sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud.install_sync import apply_install_sync

session = sys.argv[1]
arnold_src = Path(sys.argv[2])
workspace_root = Path(sys.argv[3])

incident_id = f"inc-{session}"

result = apply_install_sync(
    source_root=arnold_src,
    incident_id=incident_id,
    session_id=session,
    root=workspace_root,
)

event = result.get("event", {})
print(f"STATUS={result['status']}")
print(f"EVENT_ID={event.get('event_id', '')}")
print(f"EVENT_TYPE={event.get('type', '')}")
print(f"RETURNCODE={result['returncode']}")
print("INSTALL_SYNC_JSON=" + json.dumps({
    "status": result["status"],
    "command": result["command_text"],
    "returncode": result["returncode"],
    "verification": result.get("verification", {}),
    "event_id": event.get("event_id", ""),
    "event_type": event.get("type", ""),
}, default=str))
PY
)" || true

    INSTALL_SYNC_STATUS="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^STATUS=//p')"
    INSTALL_SYNC_EVENT_ID="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^EVENT_ID=//p')"
    INSTALL_SYNC_EVENT_TYPE="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^EVENT_TYPE=//p')"
    export INSTALL_SYNC_JSON="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^INSTALL_SYNC_JSON=//p')"

    if [[ "$INSTALL_SYNC_STATUS" == "failed" ]]; then
      log "install sync FAILED event_id=$INSTALL_SYNC_EVENT_ID; will NOT retrigger ordinary repair"
    elif [[ "$INSTALL_SYNC_STATUS" == "applied" ]]; then
      log "install sync applied successfully event_id=$INSTALL_SYNC_EVENT_ID"
    fi
  fi
else
  export INSTALL_SYNC_JSON="{}"
fi

# ---- persist meta-repair record ---------------------------------------------
persist_record() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$TRIGGER_TYPE" "$VERDICT" "$RESP_PATH" "$BRIEF_PATH" "$REPAIR_DATA_DIR" <<'PY'
import json, os, sys, uuid
from pathlib import Path

from arnold_pipelines.megaplan.cloud.meta_repair import (
    derive_meta_repair_effective_outcome,
    extract_reported_repair_custody,
    MetaRepairRecord,
    MetaRepairTrigger,
    persist_meta_repair_record,
)
from arnold_pipelines.megaplan.cloud.redact import redact_text

session, trigger_raw, verdict, resp_path, brief_path, repair_data_dir = sys.argv[1:7]

trigger = None
try:
    trigger = MetaRepairTrigger(trigger_raw)
except ValueError:
    pass

resp_text = ""
try:
    resp_text = Path(resp_path).read_text(encoding="utf-8")
except Exception:
    pass

brief_text = ""
try:
    brief_text = Path(brief_path).read_text(encoding="utf-8")
except Exception:
    pass

meta_repair_id = str(uuid.uuid4())

install_sync_raw = os.environ.get("INSTALL_SYNC_JSON", "{}")
install_sync_info = {}
try:
    install_sync_info = json.loads(install_sync_raw)
except Exception:
    pass

verification_raw = os.environ.get(
    "META_REPAIR_VERIFICATION_JSON",
    os.environ.get("POST_RETRIGGER_VERIFICATION_JSON", "{}"),
)
verification_info = {}
try:
    verification_info = json.loads(verification_raw)
except Exception:
    pass

post_retrigger_verification = {"verdict": verdict}
commit_custody_raw = os.environ.get("COMMIT_CUSTODY_JSON", "{}")
try:
    post_retrigger_verification["commit_custody"] = json.loads(commit_custody_raw)
except Exception:
    post_retrigger_verification["commit_custody"] = {
        "accepted": False,
        "outcome": "commit_custody_failed",
        "reason": "commit custody evidence was invalid",
    }
if install_sync_info:
    post_retrigger_verification["install_sync"] = install_sync_info
if isinstance(verification_info, dict) and verification_info:
    post_retrigger_verification.update(verification_info)

effective_outcome = derive_meta_repair_effective_outcome(
    verdict=verdict,
    install_sync_status=str(install_sync_info.get("status") or ""),
    post_retrigger_verification=post_retrigger_verification,
)
reported_changes, reported_tests = extract_reported_repair_custody(resp_text)

record = MetaRepairRecord(
    meta_repair_id=meta_repair_id,
    session=session,
    trigger=trigger,
    diagnosis=redact_text(resp_text[:4000]),
    subagent_results={"codex_response": redact_text(resp_text[:4000])},
    changes=reported_changes,
    tests=reported_tests,
    retrigger_command=redact_text(str(post_retrigger_verification.get("retrigger_command") or "")),
    post_retrigger_verification=post_retrigger_verification,
    outcome=effective_outcome,
)
record_path = persist_meta_repair_record(record, repair_data_dir=repair_data_dir)
print(f"RECORD_PATH={record_path}")
print(f"META_REPAIR_ID={meta_repair_id}")
PY
}
export META_REPAIR_VERIFICATION_JSON='{}'

# ---- retrigger ordinary repair after successful install sync ----------------
if [[ "$VERDICT" == FIXED* ]]; then
  if [[ "$INSTALL_SYNC_STATUS" == "failed" || "$INSTALL_SYNC_STATUS" == "commit_custody_failed" ]]; then
    log "skipping retrigger: install sync or commit custody failed"
  else
    log "emitting repair_retriggered and retriggering ordinary repair session=$SESSION"

    RETRIGGER_RESULT="$(PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_LOOP_BIN" "$WRAPPER_REPO_ROOT" "$INSTALL_SYNC_EVENT_ID" "$REPAIR_DATA_PATH" "$MARKER_DIR" <<'PY'
import datetime as dt
import json, os, subprocess, sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud import feature_flags
from arnold_pipelines.megaplan.cloud.incident_bridge import (
    append_repair_retriggered,
    append_verified_recovered,
)
from arnold_pipelines.megaplan.cloud.meta_repair import (
    RetriggerExecutionResult,
    verify_retrigger_success,
)
from arnold_pipelines.megaplan.cloud.repair_contract import validate_repair_data

session = sys.argv[1]
repair_loop_bin = sys.argv[2]
workspace_root = Path(sys.argv[3])
install_sync_event_id = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] else ""
repair_data_path = Path(sys.argv[5])
marker_dir = Path(sys.argv[6]) if len(sys.argv) > 6 else repair_data_path.parent.parent

VERIFIER_REJECTION_RETURNCODE = 73


def load_authoritative_post_retrigger_verification(
    session_id: str,
    repair_data_path: Path,
) -> dict[str, object]:
    """Read outcome plus a fresh, ground-truth post-retrigger snapshot."""

    payload = validate_repair_data(repair_data_path)
    payload_session = str(payload.get("session") or "").strip()
    if payload_session and payload_session != session_id:
        raise ValueError(
            "authoritative repair-data session mismatch: "
            f"expected {session_id!r}, found {payload_session!r}"
        )
    outcome = str(payload.get("outcome") or "").strip().lower()
    if not outcome:
        raise ValueError("authoritative repair-data outcome missing")
    marker = {}
    marker_path = marker_dir / f"{session_id}.json"
    if marker_path.exists():
        try:
            marker = json.loads(marker_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as exc:
            raise ValueError(f"session marker unreadable: {exc}") from exc
    workspace = Path(str(marker.get("workspace") or ""))
    if not workspace.exists():
        raise ValueError("session workspace unavailable for authoritative snapshot")
    chain_candidates = sorted(
        (workspace / ".megaplan" / "plans" / ".chains").glob("*.json"),
        key=lambda item: item.stat().st_mtime,
    )
    if not chain_candidates:
        raise ValueError("chain state unavailable for authoritative snapshot")
    try:
        chain = json.loads(chain_candidates[-1].read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise ValueError(f"chain state unreadable: {exc}") from exc
    plan_name = str(chain.get("current_plan_name") or "").strip()
    plan_path = workspace / ".megaplan" / "plans" / plan_name / "state.json"
    if not plan_name or not plan_path.exists():
        plan_candidates = sorted(
            (workspace / ".megaplan" / "plans").glob("*/state.json"),
            key=lambda item: item.stat().st_mtime,
        )
        if not plan_candidates:
            raise ValueError("current plan state unavailable for authoritative snapshot")
        plan_path = plan_candidates[-1]
    try:
        plan = json.loads(plan_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise ValueError(f"current plan state unreadable: {exc}") from exc
    milestones = chain.get("milestones") if isinstance(chain.get("milestones"), list) else []
    completed = chain.get("completed") if isinstance(chain.get("completed"), list) else []
    active_step = plan.get("active_step") if isinstance(plan.get("active_step"), dict) else {}
    worker_pid = active_step.get("worker_pid")
    worker_pid_alive = None
    if worker_pid not in (None, ""):
        try:
            os.kill(int(worker_pid), 0)
        except (OSError, ValueError):
            worker_pid_alive = False
        else:
            worker_pid_alive = True
    snapshot = {
        "captured_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "workspace": str(workspace),
        "chain_path": str(chain_candidates[-1]),
        "plan_path": str(plan_path),
        "milestone_total": len(milestones),
        "completed_count": len(completed),
        "chain_last_state": str(chain.get("last_state") or "").strip().lower(),
        "plan_current_state": str(plan.get("current_state") or plan.get("state") or "").strip().lower(),
        "active_step_present": bool(active_step),
        "worker_pid": worker_pid,
        "worker_pid_alive": worker_pid_alive,
    }
    return {"outcome": outcome, "post_snapshot": snapshot}

incident_id = f"inc-{session}"

if not feature_flags.mutation_authorized(feature_flags.MUTATION_PATH_L2):
    raise SystemExit(
        "L2 retrigger blocked: ARNOLD_AUTONOMY and ARNOLD_META_REPAIR_ENABLED are required"
    )

# Emit repair_retriggered
parent_ids = []
if install_sync_event_id:
    parent_ids.append(install_sync_event_id)

retrigger_event = append_repair_retriggered(
    incident_id=incident_id,
    summary=f"Meta-repair retriggering ordinary repair for session={session}",
    session_id=session,
    parent_event_ids=parent_ids if parent_ids else None,
    root=workspace_root,
)
print(f"RETRIGGER_EVENT_ID={retrigger_event.get('event_id', '')}")

# Retrigger ordinary repair
retrigger_command = [repair_loop_bin, session]
try:
    marker = json.loads((marker_dir / f"{session}.json").read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    marker = {}
workspace = str(marker.get("workspace") or "").strip()
remote_spec = str(marker.get("remote_spec") or "").strip()
if workspace:
    retrigger_command.append(workspace)
    if remote_spec:
        retrigger_command.append(remote_spec)
completed = subprocess.run(
    retrigger_command,
    cwd=str(workspace_root),
    capture_output=True, text=True, check=False,
    timeout=3600,
)

# Verify retrigger result from the authoritative session repair-data artifact,
# not from subprocess liveness alone.
lookup_error = ""
post_retrigger_verification = {}
try:
    post_retrigger_verification = load_authoritative_post_retrigger_verification(
        session,
        repair_data_path,
    )
except Exception as exc:
    lookup_error = f"{type(exc).__name__}: {exc}"

retrigger_result = RetriggerExecutionResult(
    command=tuple(retrigger_command),
    returncode=int(completed.returncode),
    stdout=str(completed.stdout or ""),
    stderr=str(completed.stderr or ""),
    lock_released=False,
)
verification = verify_retrigger_success(
    retriggered=True,
    retrigger_result=retrigger_result,
    post_retrigger_verification=post_retrigger_verification,
)
if lookup_error:
    verification["authoritative_repair_data_error"] = lookup_error
    if retrigger_result.returncode == 0:
        verification["accepted"] = False
        verification["rejection_reason"] = (
            "authoritative post-retrigger repair-data outcome unavailable: "
            f"{lookup_error}"
        )

accepted = bool(verification.get("accepted"))
effective_returncode = retrigger_result.returncode
if not accepted and effective_returncode == 0:
    effective_returncode = VERIFIER_REJECTION_RETURNCODE

verification_event_id = ""
if accepted:
    verification_event = append_verified_recovered(
        incident_id=incident_id,
        summary=(
            "Ordinary repair retrigger verified success "
            f"outcome={verification.get('outcome', '')} "
            f"returncode={retrigger_result.returncode}"
        ),
        recovery_verification=verification,
        evidence=[
            {
                "kind": "retrigger_result",
                "returncode": retrigger_result.returncode,
            },
            {
                "kind": "verification_record",
                "data": verification,
            },
        ],
        session_id=session,
        parent_event_ids=[retrigger_event.get("event_id", "")],
        root=workspace_root,
    )
    verification_event_id = str(verification_event.get("event_id", ""))

print(f"VERIFICATION_EVENT_ID={verification_event_id}")
print(f"VERIFICATION_ACCEPTED={'true' if accepted else 'false'}")
print(f"VERIFICATION_REJECTION_REASON={verification.get('rejection_reason', '')}")
print("VERIFICATION_JSON=" + json.dumps(verification, sort_keys=True))
print(f"RETRIGGER_RETURNCODE={effective_returncode}")
print(f"RETRIGGER_RAW_RETURNCODE={retrigger_result.returncode}")
PY
)" || true

    RETRIGGER_EVENT_ID="$(echo "$RETRIGGER_RESULT" | sed -n 's/^RETRIGGER_EVENT_ID=//p')"
    VERIFICATION_EVENT_ID="$(echo "$RETRIGGER_RESULT" | sed -n 's/^VERIFICATION_EVENT_ID=//p')"
    VERIFICATION_ACCEPTED="$(echo "$RETRIGGER_RESULT" | sed -n 's/^VERIFICATION_ACCEPTED=//p')"
    VERIFICATION_REJECTION_REASON="$(echo "$RETRIGGER_RESULT" | sed -n 's/^VERIFICATION_REJECTION_REASON=//p')"
    META_REPAIR_VERIFICATION_JSON="$(echo "$RETRIGGER_RESULT" | sed -n 's/^VERIFICATION_JSON=//p')"
    RETRIGGER_RETURNCODE="$(echo "$RETRIGGER_RESULT" | sed -n 's/^RETRIGGER_RETURNCODE=//p')"

    log "retrigger complete returncode=$RETRIGGER_RETURNCODE accepted=${VERIFICATION_ACCEPTED:-false} rejection_reason=${VERIFICATION_REJECTION_REASON:-} retrigger_event_id=$RETRIGGER_EVENT_ID verification_event_id=$VERIFICATION_EVENT_ID"
  fi
fi

RECORD_INFO="$(persist_record 2>&1)" || true
RECORD_PATH="$(echo "$RECORD_INFO" | sed -n 's/^RECORD_PATH=//p')"
META_REPAIR_ID="$(echo "$RECORD_INFO" | sed -n 's/^META_REPAIR_ID=//p')"
log "record persisted meta_repair_id=$META_REPAIR_ID path=$RECORD_PATH"

log "meta-repair complete session=$SESSION verdict=$VERDICT"

validated = validate_investigator_receipt(
    json.loads(Path(receipt_path).read_text(encoding="utf-8")), expected_context_digest=digest
)
recomputed = hashlib.sha256(json.dumps(
    {key: value for key, value in context.items() if key != "context_digest"},
    sort_keys=True, separators=(",", ":"), default=str,
).encode("utf-8")).hexdigest()
if context.get("context_digest") != digest or recomputed != digest or validated.get("target_kind") != "l2_repair_system":
    raise SystemExit("L2 investigation/context custody mismatch")
source = context.get("source_custody") or {}
root = str(source.get("path") or context.get("arnold_src") or "")
head = subprocess.run(
    ["git", "-C", root, "rev-parse", "HEAD"], check=False, capture_output=True, text=True
).stdout.strip()
status = subprocess.run(
    ["git", "-C", root, "status", "--porcelain", "--untracked-files=no"],
    check=False, capture_output=True, text=True,
).stdout.strip()
if head != str(source.get("head") or "") or bool(status) != source.get("dirty"):
    raise SystemExit("Arnold source custody changed after L2 investigation")
if validated.get("recommended_action") != "repair_source":
    raise SystemExit("L2 investigation did not authorize source mutation")
if (validated.get("safe_repair_target") or {}).get("kind") not in {"arnold_source", "repair_custody"}:
    raise SystemExit("L2 investigation did not name a safe repair-system target")
print(validated.get("receipt_digest"))
PY
}


#!/usr/bin/env bash
# arnold-meta-repair-loop — diagnose and fix repair-system failures when
# ordinary repair has failed.
#
# Invoked by the cloud watchdog after ordinary repair failure classification
# identifies one of the six meta-repair trigger conditions.  This wrapper:
#   1. Loads env (cloud-hot-env), redaction helpers.
#   2. Classifies the failure via Python handoff to meta_repair.py and
#      builds a redacted diagnosis prompt.
#   3. Checks feature flags and recursion guard — exits early when
#      META_REPAIR_ENABLED is explicitly off or recursion is detected.
#   4. Dispatches Codex as the top-level orchestrator with
#      --sandbox danger-full-access.  Codex is instructed to read the
#      subagent-launcher skill and delegate DeepSeek/Hermes research
#      subagents (provider=deepseek, model=deepseek:deepseek-v4-pro,
#      profile=partnered-5) for broad mapping, log/history review,
#      independent root-cause probes, and bounded fix investigations.
#   5. May commit and push by default where policy permits; operators can
#      explicitly disable this with META_REPAIR_COMMIT_ENABLED=0.
#   6. Retriggers the ordinary repair loop for the same session after
#      applying any fix, then verifies terminal success.
#   7. Persists a redacted meta-repair record under repair-data/meta/.
set -uo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: arnold-meta-repair-loop <session> [trigger]" >&2
  exit 64
fi

SESSION="$1"
WATCHDOG_TRIGGER="${2:-}"

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

MARKER_DIR="${MEGAPLAN_META_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
REPAIR_DATA_DIR="${MEGAPLAN_META_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
ARNOLD_SRC="${MEGAPLAN_META_ARNOLD_SRC:-/workspace/arnold}"
SELF_PATH="${MEGAPLAN_META_SELF_PATH:-${BASH_SOURCE[0]:-$0}}"
if command -v readlink >/dev/null 2>&1; then
  SELF_PATH="$(readlink -f "$SELF_PATH" 2>/dev/null || printf '%s' "$SELF_PATH")"
fi
WRAPPER_REPO_ROOT="$(cd "$(dirname "$SELF_PATH")/../../../.." 2>/dev/null && pwd || printf '%s' /)"
if [[ ! -f "$WRAPPER_REPO_ROOT/arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop" ]] \
  && [[ -f "$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop" ]]; then
  WRAPPER_REPO_ROOT="$ARNOLD_SRC"
fi
LAUNCHER="${MEGAPLAN_META_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
SUBAGENT_SKILL="${MEGAPLAN_META_SUBAGENT_SKILL:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/subagent-launcher/SKILL.md}"
DEEPSEEK_MODEL="${MEGAPLAN_META_MODEL:-deepseek:deepseek-v4-pro}"
SUBAGENT_PROFILE="${MEGAPLAN_META_SUBAGENT_PROFILE:-partnered-5}"
SUBAGENT_TIMEOUT="${MEGAPLAN_META_SUBAGENT_TIMEOUT_SECS:-900}"
CODEX_TIMEOUT="${MEGAPLAN_META_CODEX_TIMEOUT_SECS:-5400}"
META_REPAIR_BUDGET="${MEGAPLAN_META_BUDGET_SECS:-7200}"
META_REPAIR_ENABLED_VAR="${ARNOLD_META_REPAIR_ENABLED:-1}"
META_REPAIR_COMMIT_ENABLED_VAR="${ARNOLD_META_REPAIR_COMMIT_ENABLED:-1}"
SYNC_BRANCH="${MEGAPLAN_META_SYNC_BRANCH:-editible-install}"
REPAIR_LOOP_BIN="${MEGAPLAN_META_REPAIR_LOOP_BIN:-$WRAPPER_REPO_ROOT/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop}"
REPAIR_LOOP_FALLBACK="$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop"
if [[ ! -f "$REPAIR_LOOP_BIN" && -f "$REPAIR_LOOP_FALLBACK" ]]; then
  REPAIR_LOOP_BIN="$REPAIR_LOOP_FALLBACK"
fi
REPAIR_DATA_PATH="$REPAIR_DATA_DIR/${SESSION}.repair-data.json"
RUN_DIR="${MEGAPLAN_META_RUN_DIR:-/workspace/.megaplan/meta-runs}"
BRIEF_PREFLIGHT_MAX_CHARS="${MEGAPLAN_META_BRIEF_PREFLIGHT_MAX_CHARS:-900000}"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
SAFE_SESSION="$(printf '%s' "$SESSION" | tr -c 'A-Za-z0-9_.-' '-')"
RUN_LOG="$RUN_DIR/${TS}-${SAFE_SESSION}.log"

mkdir -p "$RUN_DIR" "$REPAIR_DATA_DIR"

log() {
  local message
  message="$(redact_inline_text "$*")"
  echo "[meta-repair $(date -Iseconds)] $message" | tee -a "$RUN_LOG"
}

redact_inline_text() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$1" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

print(redact_text(sys.argv[1]), end="")
PY
}

redact_file_in_place() {
  local path="${1:-}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$path" <<'PY'
from pathlib import Path
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

path = Path(sys.argv[1])
path.write_text(redact_text(path.read_text(encoding="utf-8")), encoding="utf-8")
PY
}

# ---- early gate: feature flag -----------------------------------------------
case "$META_REPAIR_ENABLED_VAR" in
  0|false|False|FALSE|no|No|NO|off|Off|OFF)
  log "meta-repair disabled (ARNOLD_META_REPAIR_ENABLED=$META_REPAIR_ENABLED_VAR); exiting"
  exit 0
  ;;
esac

log "meta-repair starting session=$SESSION"

# ---- early gate: recursion guard --------------------------------------------
recursion_check() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.meta_repair_policy import check_meta_repair_recursion

session, repair_data_dir = sys.argv[1:3]
result = check_meta_repair_recursion(session, repair_data_dir=repair_data_dir)
if result.recursing:
    print(f"RECURSION:{result.recommendation}")
    sys.exit(1)
print(f"OK:{result.recommendation}")
PY
}

RECURSION_OUTPUT="$(recursion_check 2>&1)" || true
if [[ "$RECURSION_OUTPUT" == RECURSION:* ]]; then
  log "recursion guard: $RECURSION_OUTPUT"
  log "escalating to NEEDS_HUMAN instead of recursing"

  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" "$RECURSION_OUTPUT" <<'PY'
import json, sys, uuid
from datetime import datetime, timezone
from pathlib import Path

from arnold_pipelines.megaplan.cloud.repair_contract import atomic_write_json, NEEDS_HUMAN
from arnold_pipelines.megaplan.cloud.redact import redact_text

session, repair_data_dir, recursion_output = sys.argv[1:4]
needs_human = {
    "session": session,
    "outcome": NEEDS_HUMAN,
    "reason": redact_text(recursion_output),
    "recorded_at": datetime.now(timezone.utc).isoformat(),
    "escalation_id": str(uuid.uuid4()),
}
meta_dir = Path(repair_data_dir) / "meta"
meta_dir.mkdir(parents=True, exist_ok=True)
needs_path = meta_dir / f"needs-human-{session}.json"
atomic_write_json(needs_path, needs_human)
print(f"escalation persisted: {needs_path}")
PY
  exit 1
fi
log "recursion guard: $RECURSION_OUTPUT"

# ---- classify failure + build redacted prompt via Python handoff -------------
classification_and_prompt() {
  local force_emergency="${1:-0}"
  FORCE_EMERGENCY="$force_emergency" PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" "$REPAIR_DATA_PATH" "$MARKER_DIR" "$META_REPAIR_ENABLED_VAR" "$WATCHDOG_TRIGGER" <<'PY'
import json, os, sys

from arnold_pipelines.megaplan.cloud.current_target import resolve_current_target
from arnold_pipelines.megaplan.cloud.meta_repair import (
    MetaRepairClassification,
    MetaRepairTrigger,
    build_meta_repair_prompt,
    evaluate_meta_repair_triggers,
    load_redacted_evidence,
    stale_repair_evidence_reason,
)

session, repair_data_dir, repair_data_path, marker_dir, enabled, watchdog_trigger = sys.argv[1:7]
force_emergency = os.environ.get("FORCE_EMERGENCY") == "1"

# Evaluate triggers without loading full evidence initially;
# the wrapper provides the trigger context.
trigger = None
if watchdog_trigger:
    try:
        trigger = MetaRepairTrigger(watchdog_trigger)
    except ValueError:
        trigger = None

if trigger is not None:
    evidence = load_redacted_evidence(session, repair_data_dir=repair_data_dir)
    current_target_observation = resolve_current_target(
        session,
        marker_dir=marker_dir,
        repair_data_dir=repair_data_dir,
    )
    stale_reason = stale_repair_evidence_reason(
        evidence=evidence,
        current_target_observation=current_target_observation,
    )
    if stale_reason:
        classification = MetaRepairClassification(
            session=session,
            trigger=None,
            rationale=(stale_reason,),
            evidence=evidence,
        )
    else:
        classification = MetaRepairClassification(
            session=session,
            trigger=trigger,
            rationale=(f"watchdog preclassified trigger={trigger.value}; meta loop must not reclassify stale evidence",),
            evidence=evidence,
        )
        prompt = build_meta_repair_prompt(
            classification,
            repair_data_dir=repair_data_dir,
            force_emergency=force_emergency,
        )
else:
    classification, prompt = evaluate_meta_repair_triggers(
        session,
        repair_data_dir=repair_data_dir,
        load_evidence=True,
    )
    if classification.should_dispatch:
        prompt = build_meta_repair_prompt(
            classification,
            repair_data_dir=repair_data_dir,
            force_emergency=force_emergency,
        )

if not classification.should_dispatch:
    print("NO_TRIGGER")
    sys.exit(0)

print("TRIGGER:" + (classification.trigger.value if classification.trigger else "unknown"))
print("PROMPT_START")
print(prompt)
print("PROMPT_END")
PY
}

CLASSIFICATION_RESULT="$(classification_and_prompt 2>&1)" || true
if [[ "$CLASSIFICATION_RESULT" == NO_TRIGGER* ]]; then
  log "no meta-repair trigger matched; exiting"
  exit 0
fi

TRIGGER_TYPE="$(echo "$CLASSIFICATION_RESULT" | sed -n 's/^TRIGGER://p')"
log "trigger=$TRIGGER_TYPE"

# Extract the prompt (between PROMPT_START and PROMPT_END markers)
PROMPT="$(echo "$CLASSIFICATION_RESULT" | sed -n '/^PROMPT_START$/,/^PROMPT_END$/{//!p}')"
if [[ -z "$PROMPT" ]]; then
  log "prompt assembly produced empty output; exiting"
  exit 1
fi

# Write the prompt to a file for Codex dispatch + redact it
BRIEF_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-brief.md"
{
  echo "# Meta-Repair Diagnosis: $SESSION"
  echo
  echo "**Trigger:** \`$TRIGGER_TYPE\`"
  echo "**Session:** \`$SESSION\`"
  echo "**Repair Data Directory:** \`$REPAIR_DATA_DIR\`"
  echo
  echo "$PROMPT"
  echo
  cat <<'PROMPT_POLICY'
## Meta-Repair Policy

You are diagnosing and repairing a failure in the Arnold repair system itself
— NOT the end-user project.  Your job is to fix the repair tooling so that
ordinary repair can succeed.

### Scope and authority
- You have `danger-full-access` sandbox scope.
- You may read, patch, and test files in the Arnold checkout
  (`$ARNOLD_SRC` on the `editible-install` branch).
- You may inspect the repair data, watchdog reports, chain state, session
  markers, and audit reports as evidence.
- You MUST delegate broad mapping, log/history review, independent
  root-cause probes, and bounded fix investigations to DeepSeek/Hermes
  research subagents wherever practical.

### Subagent dispatch
- Read the subagent-launcher skill at the path stored in
  `SUBAGENT_SKILL` for the exact dispatch contract.
- Use provider=deepseek, model=deepseek:deepseek-v4-pro,
  profile=partnered-5, max-tokens=92192.
- Each subagent gets a focused query, project directory, and a bounded
  scope.

### Commit/push policy
- You may commit and push fixes when ARNOLD_META_REPAIR_COMMIT_ENABLED is not
  explicitly disabled.
- Do not commit or push when ARNOLD_META_REPAIR_COMMIT_ENABLED=0/false/no/off.
- Pushes require the same gate as commits.

### Fix constraints
- Fix only Arnold repair-system code (wrappers, Python modules under
  arnold_pipelines/megaplan/cloud/, tests, contracts).
- Do NOT modify the running workspace/project tree.
- Keep fixes narrow, testable, and bounded.
- Validate fixes with `python3 -m py_compile` and focused tests.

### Retrigger
- After applying any fix, retrigger the ordinary repair loop for
  session `$SESSION` using the command stored in REPAIR_LOOP_BIN.
- Verify that the retriggered ordinary repair reaches a terminal
  SUCCESS outcome.
- Do NOT claim success without a verified ordinary repair retrigger —
  partial_liveness and "repairing" are not terminal success.

### Output format
Start with a verdict on its own line: FIXED, ESCALATE, or NO_FIX.
Then cite specific evidence, the root cause, the change(s) made
(if any), and the retrigger verification result.  Keep under 400 words.
PROMPT_POLICY
} > "$BRIEF_PATH"
redact_file_in_place "$BRIEF_PATH"
BRIEF_SIZE="$(wc -c < "$BRIEF_PATH" | tr -d ' ')"
if [[ "$BRIEF_SIZE" =~ ^[0-9]+$ ]] && (( BRIEF_SIZE > BRIEF_PREFLIGHT_MAX_CHARS )); then
  log "meta-repair brief exceeded preflight char budget; rebuilding emergency brief chars=$BRIEF_SIZE limit=$BRIEF_PREFLIGHT_MAX_CHARS"
  CLASSIFICATION_RESULT="$(classification_and_prompt 1 2>&1)" || true
  if [[ "$CLASSIFICATION_RESULT" == NO_TRIGGER* ]]; then
    log "emergency prompt rebuild returned no trigger; exiting"
    exit 0
  fi
  TRIGGER_TYPE="$(echo "$CLASSIFICATION_RESULT" | sed -n 's/^TRIGGER://p')"
  PROMPT="$(echo "$CLASSIFICATION_RESULT" | sed -n '/^PROMPT_START$/,/^PROMPT_END$/{//!p}')"
  if [[ -z "$PROMPT" ]]; then
    log "emergency prompt assembly produced empty output; exiting"
    exit 1
  fi
  {
    echo "# Meta-Repair Diagnosis: $SESSION"
    echo
    echo "**Trigger:** \`$TRIGGER_TYPE\`"
    echo "**Session:** \`$SESSION\`"
    echo "**Repair Data Directory:** \`$REPAIR_DATA_DIR\`"
    echo
    echo "$PROMPT"
    echo
    cat <<'PROMPT_POLICY'
## Meta-Repair Policy

You are diagnosing and repairing a failure in the Arnold repair system itself
— NOT the end-user project.  Your job is to fix the repair tooling so that
ordinary repair can succeed.

### Scope and authority
- You have `danger-full-access` sandbox scope.
- You may read, patch, and test files in the Arnold checkout
  (`$ARNOLD_SRC` on the `editible-install` branch).
- You may inspect the repair data, watchdog reports, chain state, session
  markers, and audit reports as evidence.
- You MUST delegate broad mapping, log/history review, independent
  root-cause probes, and bounded fix investigations to DeepSeek/Hermes
  research subagents wherever practical.

### Subagent dispatch
- Read the subagent-launcher skill at the path stored in
  `SUBAGENT_SKILL` for the exact dispatch contract.
- Use provider=deepseek, model=deepseek:deepseek-v4-pro,
  profile=partnered-5, max-tokens=92192.
- Each subagent gets a focused query, project directory, and a bounded
  scope.

### Commit/push policy
- You may commit and push fixes when ARNOLD_META_REPAIR_COMMIT_ENABLED is not
  explicitly disabled.
- Do not commit or push when ARNOLD_META_REPAIR_COMMIT_ENABLED=0/false/no/off.
- Pushes require the same gate as commits.

### Fix constraints
- Fix only Arnold repair-system code (wrappers, Python modules under
  arnold_pipelines/megaplan/cloud/, tests, contracts).
- Do NOT modify the running workspace/project tree.
- Keep fixes narrow, testable, and bounded.
- Validate fixes with `python3 -m py_compile` and focused tests.

### Retrigger
- After applying any fix, retrigger the ordinary repair loop for
  session `$SESSION` using the command stored in REPAIR_LOOP_BIN.
- Verify that the retriggered ordinary repair reaches a terminal
  SUCCESS outcome.
- Do NOT claim success without a verified ordinary repair retrigger —
  partial_liveness and "repairing" are not terminal success.

### Output format
Start with a verdict on its own line: FIXED, ESCALATE, or NO_FIX.
Then cite specific evidence, the root cause, the change(s) made
(if any), and the retrigger verification result.  Keep under 400 words.
PROMPT_POLICY
  } > "$BRIEF_PATH"
  redact_file_in_place "$BRIEF_PATH"
  BRIEF_SIZE="$(wc -c < "$BRIEF_PATH" | tr -d ' ')"
  log "emergency brief rebuilt chars=$BRIEF_SIZE"
fi

# ---- commit gate check ------------------------------------------------------
commit_gate_check() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.meta_repair_policy import can_commit_changes, can_push_changes

session = sys.argv[1]
commit_result = can_commit_changes(session=session)
push_result = can_push_changes(session=session)
print(f"COMMIT_ALLOWED={commit_result.allowed}")
print(f"PUSH_ALLOWED={push_result.allowed}")
print(f"COMMIT_REASON={commit_result.reason}")
PY
}

COMMIT_GATE="$(commit_gate_check 2>&1)" || true
COMMIT_ALLOWED="$(echo "$COMMIT_GATE" | sed -n 's/^COMMIT_ALLOWED=//p')"
PUSH_ALLOWED="$(echo "$COMMIT_GATE" | sed -n 's/^PUSH_ALLOWED=//p')"
log "commit_allowed=$COMMIT_ALLOWED push_allowed=$PUSH_ALLOWED"

# ---- Codex dispatch ---------------------------------------------------------
RESP_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-resp.txt"
ERR_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-resp.err"

if command -v codex >/dev/null 2>&1; then
  log "dispatching Codex meta-repair session=$SESSION deepseek_model=$DEEPSEEK_MODEL profile=$SUBAGENT_PROFILE"
  (
    if [[ -f /workspace/.cloud-hot-env ]]; then
      set -a
      # shellcheck disable=SC1091
      . /workspace/.cloud-hot-env
      set +a
    fi
    export PYENV_VERSION=3.11.11
    export MEGAPLAN_DEFAULT_PROFILE="$SUBAGENT_PROFILE"
    export MEGAPLAN_REPAIR_PROFILE="$SUBAGENT_PROFILE"
    export ARNOLD_META_REPAIR_COMMIT_ENABLED="$META_REPAIR_COMMIT_ENABLED_VAR"
    export ARNOLD_SRC="$ARNOLD_SRC"
    cd "$ARNOLD_SRC" || exit 1
    timeout "$CODEX_TIMEOUT" codex exec --skip-git-repo-check --sandbox danger-full-access - < "$BRIEF_PATH"
  ) > "$RESP_PATH" 2>"$ERR_PATH" || true
  redact_file_in_place "$RESP_PATH"
  redact_file_in_place "$ERR_PATH"
  if [[ ! -s "$RESP_PATH" ]]; then
    if grep -qE 'Input exceeds the maximum length|input_too_large' "$ERR_PATH" 2>/dev/null; then
      echo "Codex meta-repair prompt exceeded input limit; see meta-repair log." > "$RESP_PATH"
    else
      echo "Codex meta-repair orchestrator returned no output (timed out or failed to launch DeepSeek/Hermes subagents); see meta-repair log." > "$RESP_PATH"
    fi
  fi
else
  log "codex CLI missing; cannot dispatch meta-repair"
  echo "codex CLI missing; no automated meta-repair." > "$RESP_PATH"
  exit 1
fi

RESP_TEXT="$(cat "$RESP_PATH")"
log "codex response $(wc -l <<<"$RESP_TEXT" | tr -d ' ') lines"

# ---- parse verdict from response -------------------------------------------
VERDICT="$(echo "$RESP_TEXT" | head -1 | tr -d '\r\n')"

if [[ "$VERDICT" != FIXED* && "$VERDICT" != ESCALATE* && "$VERDICT" != NO_FIX* ]] && grep -qE 'Codex meta-repair orchestrator returned no output|Codex meta-repair prompt exceeded input limit|Not inside a trusted directory|--skip-git-repo-check was not specified|Input exceeds the maximum length|input_too_large' "$RESP_PATH" "$ERR_PATH" 2>/dev/null; then
  log "codex launch failed before producing a recordable meta-repair response; leaving recursion guard unpoisoned"
  exit 1
fi

if [[ "$VERDICT" == FIXED* ]]; then
  log "verdict=FIXED"
elif [[ "$VERDICT" == ESCALATE* ]]; then
  log "verdict=ESCALATE"
elif [[ "$VERDICT" == NO_FIX* ]]; then
  log "verdict=NO_FIX"
else
  log "verdict=UNKNOWN (first line: ${VERDICT:0:80})"
fi

# ---- install sync after FIXED verdict with source commit --------------------
INSTALL_SYNC_STATUS=""
INSTALL_SYNC_EVENT_ID=""
INSTALL_SYNC_EVENT_TYPE=""
export INSTALL_SYNC_JSON="{}"

if [[ "$VERDICT" == FIXED* ]]; then
  log "verdict=FIXED; checking for source commits before install sync"

  INSTALL_SYNC_RESULT="$(PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$ARNOLD_SRC" "$WRAPPER_REPO_ROOT" <<'PY'
import json, subprocess, sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud.install_sync import apply_install_sync

session = sys.argv[1]
arnold_src = Path(sys.argv[2])
workspace_root = Path(sys.argv[3])

incident_id = f"inc-{session}"

# Check for recent commits (verify Codex actually made changes)
has_commits = False
try:
    git_log = subprocess.run(
        ["git", "log", "--oneline", "-1"],
        cwd=str(arnold_src),
        capture_output=True, text=True, check=False,
    )
    has_commits = git_log.returncode == 0 and bool(git_log.stdout.strip())
except Exception:
    pass

if not has_commits:
    print("NO_SOURCE_COMMIT")
    sys.exit(0)

result = apply_install_sync(
    source_root=arnold_src,
    incident_id=incident_id,
    session_id=session,
    root=workspace_root,
)

event = result.get("event", {})
print(f"STATUS={result['status']}")
print(f"EVENT_ID={event.get('event_id', '')}")
print(f"EVENT_TYPE={event.get('type', '')}")
print(f"RETURNCODE={result['returncode']}")
print("INSTALL_SYNC_JSON=" + json.dumps({
    "status": result["status"],
    "command": result["command_text"],
    "returncode": result["returncode"],
    "verification": result.get("verification", {}),
    "event_id": event.get("event_id", ""),
    "event_type": event.get("type", ""),
}, default=str))
PY
)" || true

  if [[ "$INSTALL_SYNC_RESULT" == NO_SOURCE_COMMIT* ]]; then
    log "no source commit detected; skipping install sync"
    INSTALL_SYNC_STATUS="no_source_commit"
    export INSTALL_SYNC_JSON="{}"
  else
    INSTALL_SYNC_STATUS="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^STATUS=//p')"
    INSTALL_SYNC_EVENT_ID="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^EVENT_ID=//p')"
    INSTALL_SYNC_EVENT_TYPE="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^EVENT_TYPE=//p')"
    export INSTALL_SYNC_JSON="$(echo "$INSTALL_SYNC_RESULT" | sed -n 's/^INSTALL_SYNC_JSON=//p')"

    if [[ "$INSTALL_SYNC_STATUS" == "failed" ]]; then
      log "install sync FAILED event_id=$INSTALL_SYNC_EVENT_ID; will NOT retrigger ordinary repair"
    elif [[ "$INSTALL_SYNC_STATUS" == "applied" ]]; then
      log "install sync applied successfully event_id=$INSTALL_SYNC_EVENT_ID"
    fi
  fi
else
  export INSTALL_SYNC_JSON="{}"
fi

# ---- persist meta-repair record ---------------------------------------------
persist_record() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$TRIGGER_TYPE" "$VERDICT" "$RESP_PATH" "$BRIEF_PATH" "$REPAIR_DATA_DIR" <<'PY'
import json, os, sys, uuid
from pathlib import Path

from arnold_pipelines.megaplan.cloud.meta_repair import (
    MetaRepairRecord,
    MetaRepairTrigger,
    persist_meta_repair_record,
)
from arnold_pipelines.megaplan.cloud.redact import redact_text

session, trigger_raw, verdict, resp_path, brief_path, repair_data_dir = sys.argv[1:7]

trigger = None
try:
    trigger = MetaRepairTrigger(trigger_raw)
except ValueError:
    pass

resp_text = ""
try:

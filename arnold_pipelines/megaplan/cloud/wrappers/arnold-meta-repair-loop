        recovery_verification=verification,
        evidence=[
            {
                "kind": "retrigger_result",
                "returncode": retrigger_result.returncode,
            },
            {
                "kind": "verification_record",
                "data": verification,
            },
        ],
        session_id=session,
        parent_event_ids=[retrigger_event.get("event_id", "")],
        root=workspace_root,
    )
    verification_event_id = str(verification_event.get("event_id", ""))

print(f"VERIFICATION_EVENT_ID={verification_event_id}")
print(f"VERIFICATION_ACCEPTED={'true' if accepted else 'false'}")
print(f"VERIFICATION_REJECTION_REASON={verification.get('rejection_reason', '')}")
print("VERIFICATION_JSON=" + json.dumps(verification, sort_keys=True))
print(f"RETRIGGER_RETURNCODE={effective_returncode}")
print(f"RETRIGGER_RAW_RETURNCODE={retrigger_result.returncode}")

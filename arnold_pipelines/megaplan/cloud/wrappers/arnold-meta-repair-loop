#!/usr/bin/env bash
# arnold-meta-repair-loop — diagnose and fix repair-system failures when
# ordinary repair has failed.
#
# Invoked by the cloud watchdog after ordinary repair failure classification
# identifies one of the six meta-repair trigger conditions.  This wrapper:
#   1. Loads env (cloud-hot-env), redaction helpers.
#   2. Classifies the failure via Python handoff to meta_repair.py and
#      builds a redacted diagnosis prompt.
#   3. Checks feature flags and recursion guard — exits early when
#      META_REPAIR_ENABLED is explicitly off or recursion is detected.
#   4. Dispatches Codex as the top-level orchestrator with
#      --sandbox danger-full-access.  Codex is instructed to read the
#      subagent-launcher skill and delegate DeepSeek/Hermes research
#      subagents (provider=deepseek, model=deepseek:deepseek-v4-pro,
#      profile=partnered-5) for broad mapping, log/history review,
#      independent root-cause probes, and bounded fix investigations.
#   5. May commit where policy permits. Pushes require independent, explicit
#      META_REPAIR_PUSH_ENABLED authority and default off.
#   6. Retriggers the ordinary repair loop for the same session after
#      applying any fix, then verifies terminal success.
#   7. Persists a redacted meta-repair record under repair-data/meta/.
set -uo pipefail

# Long L2 runs must not resume through a wrapper that activation rewrote while
# Bash was waiting on a child.  Pin a syntax-checked per-invocation snapshot;
# keep the original path only for repository and sibling discovery.
ARNOLD_META_REPAIR_LOOP_ORIGIN="${ARNOLD_META_REPAIR_LOOP_ORIGIN:-${BASH_SOURCE[0]:-$0}}"
if [[ "${ARNOLD_META_REPAIR_LOOP_SNAPSHOT_ACTIVE:-0}" != "1" ]]; then
  meta_repair_loop_snapshot="$(mktemp "${TMPDIR:-/tmp}/arnold-meta-repair-loop.XXXXXXXX")"
  if ! cp -- "$ARNOLD_META_REPAIR_LOOP_ORIGIN" "$meta_repair_loop_snapshot" \
    || ! bash -n "$meta_repair_loop_snapshot"; then
    rm -f -- "$meta_repair_loop_snapshot"
    echo "arnold-meta-repair-loop: immutable wrapper snapshot failed validation" >&2
    exit 78
  fi
  export ARNOLD_META_REPAIR_LOOP_ORIGIN
  export ARNOLD_META_REPAIR_LOOP_SNAPSHOT_ACTIVE=1
  exec bash "$meta_repair_loop_snapshot" "$@"
fi
trap 'rm -f -- "${BASH_SOURCE[0]:-$0}"' EXIT

if [[ $# -lt 1 ]]; then
  echo "usage: arnold-meta-repair-loop <session> [trigger]" >&2
  exit 64
fi

SESSION="$1"
WATCHDOG_TRIGGER="${2:-}"

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

MARKER_DIR="${MEGAPLAN_META_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
REPAIR_DATA_DIR="${MEGAPLAN_META_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
ARNOLD_SRC="${MEGAPLAN_META_ARNOLD_SRC:-${MEGAPLAN_RUNTIME_SRC:-/workspace/arnold}}"
SELF_PATH="${MEGAPLAN_META_SELF_PATH:-$ARNOLD_META_REPAIR_LOOP_ORIGIN}"
if command -v readlink >/dev/null 2>&1; then
  SELF_PATH="$(readlink -f "$SELF_PATH" 2>/dev/null || printf '%s' "$SELF_PATH")"
fi
WRAPPER_REPO_ROOT="$(cd "$(dirname "$SELF_PATH")/../../../.." 2>/dev/null && pwd || printf '%s' /)"
if [[ ! -f "$WRAPPER_REPO_ROOT/arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop" ]] \
  && [[ -f "$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-meta-repair-loop" ]]; then
  WRAPPER_REPO_ROOT="$ARNOLD_SRC"
fi
SUPERVISOR_RUNTIME_LIB="$(dirname "$ARNOLD_META_REPAIR_LOOP_ORIGIN")/arnold-supervisor-runtime-lib"
if [[ ! -f "$SUPERVISOR_RUNTIME_LIB" ]]; then
  SUPERVISOR_RUNTIME_LIB="$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-supervisor-runtime-lib"
fi
if [[ ! -f "$SUPERVISOR_RUNTIME_LIB" ]]; then
  SUPERVISOR_RUNTIME_LIB="/usr/local/bin/arnold-supervisor-runtime-lib"
fi
# shellcheck disable=SC1090
. "$SUPERVISOR_RUNTIME_LIB"
arnold_supervisor_stdlib_init meta-repair-loop || exit $?
SAFE_SESSION="$(printf '%s' "$SESSION" | tr -c 'A-Za-z0-9_.-' '-')"
SUPERVISOR_GAP_SCAN="${MEGAPLAN_SUPERVISOR_GAP_SCAN:-$(dirname "$ARNOLD_META_REPAIR_LOOP_ORIGIN")/arnold-supervisor-gap-scan}"
if [[ ! -x "$SUPERVISOR_GAP_SCAN" ]]; then
  SUPERVISOR_GAP_SCAN="/usr/local/bin/arnold-supervisor-gap-scan"
fi
SUPERVISOR_GAP_EVIDENCE="$REPAIR_DATA_DIR/${SAFE_SESSION}.supervisor-gap.json"
if [[ -x "$SUPERVISOR_GAP_SCAN" ]]; then
  "$MEGAPLAN_SUPERVISOR_STDLIB_PYTHON" -P "$SUPERVISOR_GAP_SCAN" \
    --marker-dir "$MARKER_DIR" --session "$SESSION" \
    --output "$SUPERVISOR_GAP_EVIDENCE" >/dev/null 2>&1 || true
fi
arnold_supervisor_runtime_init meta-repair-loop "$ARNOLD_SRC" || exit $?
LAUNCHER="${MEGAPLAN_META_LAUNCHER:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/subagent-launcher/launch_hermes_agent.py}"
SUBAGENT_SKILL="${MEGAPLAN_META_SUBAGENT_SKILL:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/subagent-launcher/SKILL.md}"
export LAUNCHER SUBAGENT_SKILL
DEEPSEEK_MODEL="${MEGAPLAN_META_MODEL:-deepseek:deepseek-v4-pro}"
SUBAGENT_PROFILE="${MEGAPLAN_META_SUBAGENT_PROFILE:-partnered-5}"
SUBAGENT_TIMEOUT="${MEGAPLAN_META_SUBAGENT_TIMEOUT_SECS:-900}"
CODEX_TIMEOUT="${MEGAPLAN_META_CODEX_TIMEOUT_SECS:-5400}"
META_CODEX_MODEL="${MEGAPLAN_META_CODEX_MODEL:-gpt-5.6-sol}"
META_REPAIR_DIFFICULTY="${ARNOLD_META_REPAIR_DIFFICULTY:-10}"
META_REPAIR_CHILD_DIFFICULTY_CEILING="${ARNOLD_META_REPAIR_CHILD_DIFFICULTY_CEILING:-$META_REPAIR_DIFFICULTY}"
SUPERFIXER_SKILL="${MEGAPLAN_SUPERFIXER_SKILL:-$ARNOLD_SRC/arnold_pipelines/megaplan/skills/superfixer-debug/SKILL.md}"
META_REPAIR_BUDGET="${MEGAPLAN_META_BUDGET_SECS:-7200}"
META_REPAIR_ENABLED_VAR="${ARNOLD_META_REPAIR_ENABLED:-1}"
META_REPAIR_COMMIT_ENABLED_VAR="${ARNOLD_META_REPAIR_COMMIT_ENABLED:-1}"
SYNC_BRANCH="${MEGAPLAN_META_SYNC_BRANCH:-editible-install}"
REPAIR_LOOP_BIN="${MEGAPLAN_META_REPAIR_LOOP_BIN:-$WRAPPER_REPO_ROOT/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop}"
REPAIR_LOOP_FALLBACK="$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-repair-loop"
if [[ ! -f "$REPAIR_LOOP_BIN" && -f "$REPAIR_LOOP_FALLBACK" ]]; then
  REPAIR_LOOP_BIN="$REPAIR_LOOP_FALLBACK"
fi
REPAIR_DATA_PATH="$REPAIR_DATA_DIR/${SESSION}.repair-data.json"
RUN_DIR="${MEGAPLAN_META_RUN_DIR:-/workspace/.megaplan/meta-runs}"
BRIEF_PREFLIGHT_MAX_CHARS="${MEGAPLAN_META_BRIEF_PREFLIGHT_MAX_CHARS:-900000}"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
RUN_LOG="$RUN_DIR/${TS}-${SAFE_SESSION}.log"
META_INVESTIGATION_CONTEXT_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-investigation-context.json"
META_INVESTIGATION_PROMPT_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-investigator-prompt.md"
META_INVESTIGATION_RECEIPT_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-investigator-receipt.json"
META_INVESTIGATION_OBSERVATION_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-investigator-observations.json"
META_INVESTIGATION_RUN_ID_PATH="$RUN_DIR/${TS}-${SAFE_SESSION}-investigator-run-id"
META_INVESTIGATION_CONTEXT_DIGEST=""
META_INVESTIGATION_RUN_ID=""
META_INVESTIGATION_MAX_BYTES=65536

load_resident_delegation_context() {
  local marker_path encoded rc
  marker_path="$MARKER_DIR/$SESSION.json"
  encoded="$(PYTHONSAFEPATH=1 PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 -P - "$marker_path" <<'PY'
import json
import os
import sys
from pathlib import Path

from arnold_pipelines.megaplan.resident.provenance import (
    DELEGATION_CONTEXT_ENV,
    encoded_provenance,
    normalize_delegation_provenance,
)

raw = os.environ.get(DELEGATION_CONTEXT_ENV)
if raw:
    try:
        print(encoded_provenance(normalize_delegation_provenance(json.loads(raw))), end="")
    except Exception as exc:
        print(f"invalid inherited resident delegation provenance: {exc}", file=sys.stderr)
        raise SystemExit(65)
    raise SystemExit(0)
try:
    marker = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except (OSError, ValueError, TypeError):
    raise SystemExit(3)
payload = marker.get("resident_delegation") if isinstance(marker, dict) else None
if payload is None:
    raise SystemExit(3)
try:
    print(encoded_provenance(normalize_delegation_provenance(payload)), end="")
except Exception as exc:
    print(f"invalid marker resident delegation provenance: {exc}", file=sys.stderr)
    raise SystemExit(65)
PY
)"
  rc=$?
  if [[ "$rc" == "3" ]]; then
    return 0
  fi
  if [[ "$rc" != "0" ]]; then
    echo "meta-repair launch refused: resident delegation provenance validation failed" >&2
    return "$rc"
  fi
  if [[ -n "$encoded" ]]; then
    export ARNOLD_RESIDENT_DELEGATION_CONTEXT="$encoded"
  fi
}

l2_mutation_authorized() {
  PYTHONSAFEPATH=1 PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 -P -c \
    'from arnold_pipelines.megaplan.cloud.feature_flags import MUTATION_PATH_L2, mutation_authorized; raise SystemExit(0 if mutation_authorized(MUTATION_PATH_L2) else 1)'
}

load_resident_delegation_context || exit $?

if PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$MARKER_DIR/$SESSION.json" <<'PY'
import json
import subprocess
import sys
from pathlib import Path
from arnold_pipelines.megaplan.chain.operator_pause import is_paused
from arnold_pipelines.megaplan.chain.spec import load_chain_state

try:
    marker = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
    remote_spec = Path(str(marker.get("remote_spec") or marker.get("spec") or ""))
    paused = bool(str(remote_spec)) and is_paused(load_chain_state(remote_spec))
except Exception:
    paused = False
raise SystemExit(0 if paused else 1)
PY
then
  echo "[meta-repair] durable operator pause active; superfixer skipped session=$SESSION" >&2
  exit 0
fi

mkdir -p "$RUN_DIR" "$REPAIR_DATA_DIR"

log() {
  local message
  message="$(redact_inline_text "$*")"
  echo "[meta-repair $(date -Iseconds)] $message" | tee -a "$RUN_LOG"
}

redact_inline_text() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$1" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

print(redact_text(sys.argv[1]), end="")
PY
}

redact_file_in_place() {
  local path="${1:-}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$path" <<'PY'
from pathlib import Path
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

path = Path(sys.argv[1])
path.write_text(redact_text(path.read_text(encoding="utf-8")), encoding="utf-8")
PY
}

# ---- early gate: feature flag -----------------------------------------------
case "$META_REPAIR_ENABLED_VAR" in
  0|false|False|FALSE|no|No|NO|off|Off|OFF)
  log "meta-repair disabled (ARNOLD_META_REPAIR_ENABLED=$META_REPAIR_ENABLED_VAR); exiting"
  exit 0
  ;;
esac

log "meta-repair starting session=$SESSION"

# Freeze blocker identity from authoritative repair custody.  The inherited
# dispatch token is provenance, not authority, and may describe an older
# blocker episode in the same long-lived session.
SUPPLIED_BLOCKER_ID="${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}"
if ! BLOCKER_RESOLUTION="$(PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 -P - "$SESSION" "$REPAIR_DATA_DIR" "$SUPPLIED_BLOCKER_ID" <<'PY'
import sys
from arnold_pipelines.megaplan.cloud.meta_repair_policy import resolve_authoritative_blocker_id
blocker, drift = resolve_authoritative_blocker_id(
    sys.argv[1], repair_data_dir=sys.argv[2], supplied_blocker_id=sys.argv[3]
)
print(blocker)
print("drift" if drift else "matched")
PY
)"; then
  log "authoritative blocker identity unavailable; refusing meta-repair"
  exit 1
fi
export CLOUD_WATCHDOG_REPAIR_BLOCKER_ID="$(printf '%s\n' "$BLOCKER_RESOLUTION" | sed -n '1p')"
BLOCKER_IDENTITY_STATUS="$(printf '%s\n' "$BLOCKER_RESOLUTION" | sed -n '2p')"
if [[ "$BLOCKER_IDENTITY_STATUS" == "drift" ]]; then
  log "blocker identity drift corrected supplied=$SUPPLIED_BLOCKER_ID authoritative=$CLOUD_WATCHDOG_REPAIR_BLOCKER_ID"
fi

# ---- early gate: recursion guard --------------------------------------------
recursion_check() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" "${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.meta_repair_policy import (
    check_meta_repair_recursion,
    resolve_authoritative_blocker_id,
)

session, repair_data_dir, blocker_id = sys.argv[1:4]
blocker_id, _ = resolve_authoritative_blocker_id(
    session, repair_data_dir=repair_data_dir, supplied_blocker_id=blocker_id
)
result = check_meta_repair_recursion(
    session,
    repair_data_dir=repair_data_dir,
    blocker_id=blocker_id,
)
if result.recursing:
    print(f"RECURSION:{result.recommendation}")
    sys.exit(1)
print(f"OK:{result.recommendation}")
PY
}

RECURSION_OUTPUT="$(recursion_check 2>&1)" || true
if [[ "$RECURSION_OUTPUT" == RECURSION:* ]]; then
  log "recursion guard: $RECURSION_OUTPUT"
  log "escalating to NEEDS_HUMAN instead of recursing"

  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" "$RECURSION_OUTPUT" "${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}" <<'PY'
import json, sys, uuid
from datetime import datetime, timezone
from pathlib import Path

from arnold_pipelines.megaplan.cloud.repair_contract import atomic_write_json, NEEDS_HUMAN
from arnold_pipelines.megaplan.cloud.redact import redact_text

session, repair_data_dir, recursion_output, blocker_id = sys.argv[1:5]
needs_human = {
    "session": session,
    "outcome": NEEDS_HUMAN,
    "reason": redact_text(recursion_output),
    "blocker_id": blocker_id,
    "recorded_at": datetime.now(timezone.utc).isoformat(),
    "escalation_id": str(uuid.uuid4()),
}
meta_dir = Path(repair_data_dir) / "meta"
meta_dir.mkdir(parents=True, exist_ok=True)
needs_path = meta_dir / f"needs-human-{session}.json"
atomic_write_json(needs_path, needs_human)
print(f"escalation persisted: {needs_path}")
PY
  exit 1
fi
log "recursion guard: $RECURSION_OUTPUT"

# A literal L3 trigger is not launch authority. Validate the bounded auditor
# context against its queued request and immutable resident provenance before
# trigger classification. The same check runs again when the prompt pointer is
# assembled, so a changed artifact fails closed before model dispatch.
validate_l3_dispatch_context() {
  PYTHONSAFEPATH=1 PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 -P - \
    "$SESSION" \
    "${ARNOLD_L3_REPAIR_CONTEXT_PATH:-}" \
    "${ARNOLD_L3_REPAIR_CONTEXT_DIGEST:-}" \
    "${ARNOLD_L3_ESCALATION_ID:-}" \
    "${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}" \
    "${ARNOLD_REPAIR_QUEUE_ROOT:-}" \
    "${ARNOLD_L3_REPAIR_OUTCOME_PATH:-}" <<'PY'
import json
import sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud.progress_auditor_escalation import (
    validate_l3_repair_dispatch_context,
)
from arnold_pipelines.megaplan.cloud.repair_requests import requests_dir

session, context_path, digest, escalation_id, request_id, queue_root, outcome_path = sys.argv[1:]
try:
    if not queue_root or not request_id:
        raise ValueError("L3 repair queue identity is incomplete")
    request_path = requests_dir(queue_root) / f"{request_id}.json"
    pointer = validate_l3_repair_dispatch_context(
        context_path=context_path,
        request_path=request_path,
        expected_session=session,
        expected_context_digest=digest,
        expected_escalation_id=escalation_id,
        expected_request_id=request_id,
    )
    expected_outcome = Path(context_path).resolve(strict=True).with_name(
        "repair-outcome.json"
    )
    if not outcome_path or Path(outcome_path).resolve(strict=False) != expected_outcome:
        raise ValueError("L3 repair outcome pointer disagrees with its context")
    pointer["outcome_path"] = str(expected_outcome)
except (OSError, ValueError) as exc:
    print(f"L3 dispatch validation failed: {exc}", file=sys.stderr)
    raise SystemExit(65)
print(json.dumps(pointer, sort_keys=True, separators=(",", ":")))
PY
}

L3_REPAIR_POINTER_JSON=""
if [[ "$WATCHDOG_TRIGGER" == "l3_progress_auditor" ]]; then
  if [[ "${ARNOLD_L3_DEEP_REPAIR:-0}" != "1" ]]; then
    log "L3 trigger missing explicit deep-repair authorization; refusing dispatch"
    exit 65
  fi
  if ! L3_REPAIR_POINTER_JSON="$(validate_l3_dispatch_context 2>&1)"; then
    log "$L3_REPAIR_POINTER_JSON"
    exit 65
  fi
  export L3_REPAIR_POINTER_JSON
  log "validated typed L3 repair request request_id=${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-} escalation_id=${ARNOLD_L3_ESCALATION_ID:-}"
elif [[ "${ARNOLD_L3_DEEP_REPAIR:-0}" == "1" ]]; then
  log "deep-repair authorization supplied without the L3 trigger; refusing dispatch"
  exit 65
fi

# ---- classify failure + build redacted prompt via Python handoff -------------
classification_and_prompt() {
  local force_emergency="${1:-0}"
  FORCE_EMERGENCY="$force_emergency" PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$REPAIR_DATA_DIR" "$REPAIR_DATA_PATH" "$MARKER_DIR" "$META_REPAIR_ENABLED_VAR" "$WATCHDOG_TRIGGER" <<'PY'
import json, os, sys

from arnold_pipelines.megaplan.cloud.current_target import resolve_current_target
from arnold_pipelines.megaplan.cloud.meta_repair import (
    MetaRepairClassification,
    MetaRepairTrigger,
    build_meta_repair_prompt,
    evaluate_meta_repair_triggers,
    load_redacted_evidence,
)

session, repair_data_dir, repair_data_path, marker_dir, enabled, watchdog_trigger = sys.argv[1:7]
force_emergency = os.environ.get("FORCE_EMERGENCY") == "1"

# Evaluate triggers without loading full evidence initially;
# the wrapper provides the trigger context.
trigger = None
if watchdog_trigger:
    try:
        trigger = MetaRepairTrigger(watchdog_trigger)
    except ValueError:
        trigger = None

if trigger is not None:
    evidence = load_redacted_evidence(session, repair_data_dir=repair_data_dir)
    current_target_observation = resolve_current_target(
        session,
        marker_dir=marker_dir,
        repair_data_dir=repair_data_dir,
    )
    evidence["current_target_corroboration"] = current_target_observation
    classification = MetaRepairClassification(
        session=session,
        trigger=trigger,
        rationale=(
            f"watchdog preclassified trigger={trigger.value}; "
            "meta loop preserves bounded trigger custody and treats live target discovery as corroboration",
        ),
        evidence=evidence,
    )
    prompt = build_meta_repair_prompt(
        classification,
        repair_data_dir=repair_data_dir,
        force_emergency=force_emergency,
    )
else:
    classification, prompt = evaluate_meta_repair_triggers(
        session,
        repair_data_dir=repair_data_dir,
        load_evidence=True,
    )
    if classification.should_dispatch:
        prompt = build_meta_repair_prompt(
            classification,
            repair_data_dir=repair_data_dir,
            force_emergency=force_emergency,
        )

if not classification.should_dispatch:
    print("NO_TRIGGER")
    sys.exit(0)

print("TRIGGER:" + (classification.trigger.value if classification.trigger else "unknown"))
print("PROMPT_START")
print(prompt)
print("PROMPT_END")
PY
}

CLASSIFICATION_RESULT="$(classification_and_prompt 2>&1)" || true
if [[ "$CLASSIFICATION_RESULT" == NO_TRIGGER* ]]; then
  log "no meta-repair trigger matched; exiting"
  exit 0
fi

TRIGGER_TYPE="$(echo "$CLASSIFICATION_RESULT" | sed -n 's/^TRIGGER://p')"
log "trigger=$TRIGGER_TYPE"

run_meta_repair_investigation() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" "$MEGAPLAN_SUPERVISOR_PYTHON" -P -m \
    arnold_pipelines.megaplan.cloud.repair_investigation build-meta \
    --session "$SESSION" --trigger "$TRIGGER_TYPE" \
    --repair-data-dir "$REPAIR_DATA_DIR" --marker-dir "$MARKER_DIR" \
    --arnold-src "$ARNOLD_SRC" \
    --request-id "${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}" \
    --blocker-id "${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}" \
    --output "$META_INVESTIGATION_CONTEXT_PATH" >>"$RUN_LOG" 2>&1 || return 1
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" "$MEGAPLAN_SUPERVISOR_PYTHON" -P -m \
    arnold_pipelines.megaplan.cloud.repair_investigation observe-meta \
    --context "$META_INVESTIGATION_CONTEXT_PATH" \
    --output "$META_INVESTIGATION_OBSERVATION_PATH" >>"$RUN_LOG" 2>&1 || return 1
  META_INVESTIGATION_CONTEXT_DIGEST="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["context_digest"])' "$META_INVESTIGATION_CONTEXT_PATH")"
  {
    cat <<EOF
You are the read-only L2 investigator for broken automatic repair session $SESSION.
Read the minimal envelope and its typed authoritative artifact references. Its digest is $META_INVESTIGATION_CONTEXT_DIGEST.

<meta_repair_investigation_envelope>
EOF
    cat "$META_INVESTIGATION_CONTEXT_PATH"
    cat <<EOF
</meta_repair_investigation_envelope>

The trusted local broker verified every referenced size and SHA-256 and emitted
these bounded observations. Treat them as read-only observations of the named
authoritative paths; do not infer access beyond them.

<verified_bounded_observations>
EOF
    cat "$META_INVESTIGATION_OBSERVATION_PATH"
    cat <<EOF
</verified_bounded_observations>

Follow the objective and authorization in the envelope. Return only one JSON object matching the referenced arnold-repair-investigator-receipt-v2 contract, with no markdown fence or commentary.
Populate every required field, including a non-empty safe_repair_target.scope and
the complete intended_recovery object. A historical needs_human artifact,
manual_review retry strategy, or absent target worker is not by itself a human

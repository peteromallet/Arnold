#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

def _resolve_root() -> Path:
    here = Path(__file__).resolve()
    for parent in here.parents:
        if (parent / "arnold_pipelines" / "megaplan" / "discord_dm.py").exists():
            return parent
    return Path(os.environ.get("MEGAPLAN_DISCORD_DM_ARNOLD_SRC", "/workspace/arnold"))


ROOT = _resolve_root()
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from arnold_pipelines.megaplan.discord_dm import send_discord_dm


def main() -> int:
    try:
        payload = json.load(sys.stdin)
    except Exception as exc:
        result = {
            "ok": False,
            "reason": "invalid_payload",
            "error": str(exc),
        }
    else:
        result = send_discord_dm(payload)
    json.dump(result, sys.stdout, sort_keys=True)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

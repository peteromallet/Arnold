#!/usr/bin/env bash
set -euo pipefail
SPEC="$1"
ONE_FLAG="${2:-}"
CANONICAL_LOG=".megaplan/cloud-chain.log"
PROJECT_DIR="${MEGAPLAN_PROJECT_DIR:-$(pwd)}"
ENGINE_DIR="${MEGAPLAN_ENGINE_DIR:-/workspace/arnold}"
if [ "$ONE_FLAG" = "--one" ]; then
    exec bash -lc "cd \"\$0\" && MEGAPLAN_TRUSTED_CONTAINER=1 python -m arnold_pipelines.megaplan chain start --spec \"\$1\" --project-dir \"\$2\" --one >> \"\$2/$CANONICAL_LOG\" 2>&1" "$ENGINE_DIR" "$SPEC" "$PROJECT_DIR"
else
    exec bash -lc "cd \"\$0\" && MEGAPLAN_TRUSTED_CONTAINER=1 python -m arnold_pipelines.megaplan chain start --spec \"\$1\" --project-dir \"\$2\" >> \"\$2/$CANONICAL_LOG\" 2>&1" "$ENGINE_DIR" "$SPEC" "$PROJECT_DIR"
fi

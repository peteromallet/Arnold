session_health_status() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local wait_status
  if ! tmux has-session -t "$session" 2>/dev/null; then
    if [[ "$run_kind" == "chain" ]]; then
      if chain_process_is_alive "$remote_spec" || plan_process_is_alive "$plan_name" || resolver_active_step_is_alive "$session"; then
        echo "alive"
        return 0
      fi
      wait_status="$(chain_wait_status "$workspace")"
      if [[ "$wait_status" != "none" ]]; then
        echo "$wait_status"
        return 0
      fi
    elif [[ -n "$plan_name" ]] && { plan_process_is_alive "$plan_name" || resolver_active_step_is_alive "$session"; }; then
      echo "alive"
      return 0
    fi
    echo "stopped"
    return 0
  fi

  local pane log_path
  pane="$(tmux capture-pane -pt "$session" -S -120 2>/dev/null || true)"
  if printf '%s\n' "$pane" | grep -Eq 'cmd exited rc=[1-9]|error retry [0-9]+/[0-9]+'; then
    echo "retrying_failure"
    return 0
  fi

  if [[ "$run_kind" == "chain" ]]; then
    if [[ "$session" == "megaplan-chain" ]]; then
      log_path="$workspace/.megaplan/cloud-chain.log"
    else
      log_path="$workspace/.megaplan/cloud-chain-${session}.log"
    fi
    if [[ -f "$log_path" ]] && tail -80 "$log_path" 2>/dev/null | grep -Eq '"error": "invalid_spec"|invalid_spec|"error": "git_refresh_failed"|git_refresh_failed|fatal: couldn'\''t find remote ref'; then
      echo "chain_log_failure"
      return 0
    fi
    if chain_process_is_alive "$remote_spec"; then
      echo "alive"
      return 0
    fi
    if plan_process_is_alive "$plan_name" || resolver_active_step_is_alive "$session"; then
      echo "alive"
      return 0
    fi
    wait_status="$(chain_wait_status "$workspace")"
    if [[ "$wait_status" != "none" ]]; then
      echo "$wait_status"
      return 0
    fi
  elif [[ -n "$plan_name" ]]; then
    if plan_process_is_alive "$plan_name" || resolver_active_step_is_alive "$session"; then
      echo "alive"
      return 0
    fi
  fi

  echo "stopped"
}


entry["human_review_recommendation"] = report.get("human_review_recommendation") or ""
entry["findings_doc_path"] = report.get("findings_doc_path") or ""
entry["findings_doc_appended"] = bool(report.get("findings_doc_appended"))
entry["problem_signature"] = payload.get("current_signature") or {}

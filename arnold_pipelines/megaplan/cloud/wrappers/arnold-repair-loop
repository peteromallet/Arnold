entry["plan_latest_failure"] = (payload.get("current_failure_context") or {}).get("plan_latest_failure", {})
entry["chain_state_summary"] = (payload.get("current_failure_context") or {}).get("chain_state_summary", {})
entry["plan_runtime_state"] = (payload.get("current_failure_context") or {}).get("plan_runtime_state", {})
entry["last_gate"] = (payload.get("current_failure_context") or {}).get("last_gate", {})
entry["user_action_context"] = (payload.get("current_failure_context") or {}).get("user_action_context", {})
entry["execute_attempt_context"] = (payload.get("current_failure_context") or {}).get("execute_attempt_context", {})
entry["resolver_output"] = (payload.get("current_failure_context") or {}).get("resolver_output", {})

attempts = payload.setdefault("attempts", [])
attempt = None
for item in attempts:
    if isinstance(item, dict) and int(item.get("attempt_id") or 0) == attempt_id:
        attempt = item
        break
if attempt is None:

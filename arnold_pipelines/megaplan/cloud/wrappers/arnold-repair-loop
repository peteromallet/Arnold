repair_agent_workdir() {
  # The repair target is the cloud session workspace. Most live
  # execution_blocked incidents are target-repo task failures, and launching the
  # agent from /workspace/arnold biases it into an engine-only repair. Arnold
  # engine/superfixer fixes remain available via the explicit $ARNOLD_SRC
  # prompt contract and PYTHONPATH below.
  if [[ -d "$WORKSPACE" ]]; then
    printf '%s\n' "$WORKSPACE"
  else
    printf '%s\n' "$ARNOLD_SRC"
  fi
}

run_dev_fix_turn() {
  require_repair_lock_held
  local iteration="$1"
  local attempt_id="$2"
  local recurring="$3"
  local requested_model="$4"
  local dispatch_model="$5"
  local dispatch_kind="$6"
  local fallback_reason="$7"
  local prompt_path report_path before_sha after_sha rc dev_timeout reasoning_effort repair_workdir
  prompt_path="$RUN_DIR/iter${iteration}-dev-fix-prompt.md"
  report_path="$RUN_DIR/iter${iteration}-dev-fix-report.json"
  write_dev_prompt "$prompt_path" "$requested_model" "$dispatch_model" "$report_path" "$recurring"
  repair_workdir="$(repair_agent_workdir)"
  before_sha="$(cd "$repair_workdir" && git rev-parse HEAD 2>/dev/null || true)"
  dev_timeout="$DEV_TIMEOUT"
  reasoning_effort="$CODEX_REASONING_EFFORT"
  if [[ "$recurring" == "1" ]]; then
    dev_timeout="$DEV_ROOT_CAUSE_TIMEOUT"
    reasoning_effort="$ROOT_CAUSE_REASONING_EFFORT"
  fi
  dev_timeout="$(cap_timeout_to_repair_budget "$dev_timeout" "dev-dispatch-$iteration")"
  log "iteration=$iteration dev-fix model=$dispatch_model requested=$requested_model recurring=$recurring timeout=$dev_timeout reasoning=$reasoning_effort workdir=$repair_workdir"
  prepare_repair_agent_exec_env
  if [[ "$dispatch_kind" == "hermes" ]]; then
    (
      cd "$repair_workdir" &&
      timeout "$dev_timeout" env PYENV_VERSION="${PYENV_VERSION:-3.11.11}" PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python "$HERMES_LAUNCHER" \
        --model="$dispatch_model" \
        --toolsets="file,web,terminal" \
        --query_file="$prompt_path" \
        --project_dir="$repair_workdir"
    ) >> "$LOG" 2>&1 &
  else
    (
      cd "$repair_workdir" &&
      timeout "$dev_timeout" env PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" codex exec \
        --sandbox danger-full-access \
        -c model="$dispatch_model" \
        -c model_reasoning_effort="$reasoning_effort" \
        - < "$prompt_path"
    ) >> "$LOG" 2>&1 &
  fi
  local child_pid=$!
  CHILD_PIDS+=("$child_pid")
  if wait "$child_pid"; then
    rc=0
  else
    rc=$?
  fi
  after_sha="$(cd "$repair_workdir" && git rev-parse HEAD 2>/dev/null || true)"
  repair_data_record_dev "$iteration" "$attempt_id" "$requested_model" "$dispatch_model" "$fallback_reason" "$report_path" "$rc" "$before_sha" "$after_sha"
  append_repair_finding_if_reported "$iteration" "$report_path" "$dispatch_model"
}

run_kimi_launch_turn() {

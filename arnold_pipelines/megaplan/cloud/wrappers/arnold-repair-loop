signature = repair_recurrence.build_problem_signature(failure_context)
advancement = repair_recurrence.build_advancement_snapshot(
    failure_context,
    run_kind=str(payload.get("run_kind") or ""),
    workspace=str(payload.get("workspace") or failure_context.get("workspace") or ""),
    logger=lambda message: print(f"repair_recurrence: {message}", file=sys.stderr),
)
session_snapshot = repair_recurrence.update_session_repair_snapshot(
    progress_payload,
    advancement,
    dispatched_at=dispatched_at,
    min_dispatches=min_dispatches,
    window_seconds=window_seconds,
)
recurrence = repair_recurrence.evaluate_recurrence(
    signature,
    payload.get("attempts") if isinstance(payload.get("attempts"), list) else [],
    session_snapshot,
)
attempt_id = int(payload.get("attempt_counter") or 0) + 1
payload["attempt_counter"] = attempt_id
payload["current_attempt_id"] = attempt_id
payload["current_failure_context"] = failure_context
payload["current_signature"] = signature
payload["current_advancement_snapshot"] = advancement
dispatch_request_id = str(request_id or payload.get("request_id") or "").strip()
dispatch_blocker_id = str(blocker_id or payload.get("blocker_id") or "").strip()
payload["request_id"] = dispatch_request_id or payload.get("request_id")
payload["blocker_id"] = dispatch_blocker_id or payload.get("blocker_id")
payload["current_recurrence"] = {
    **recurrence,
    "attempt_id": attempt_id,
    "iteration": iteration,
    "requested_model": requested_model,
    "dispatch_model": dispatch_model,
    "dispatched_at": dispatched_at,
    "root_cause_mode": bool(recurrence.get("detected")),
    "request_id": dispatch_request_id,
    "blocker_id": dispatch_blocker_id,
}
payload["run_recurrence_detected"] = bool(payload.get("run_recurrence_detected")) or bool(recurrence.get("detected"))
repair_recurrence.atomic_write_json(data_path, payload)
repair_recurrence.atomic_write_json(progress_path, session_snapshot)
breaker = 1 if recurrence.get("deterministic_failure_breaker") else 0
print(f"{attempt_id}\t{1 if recurrence.get('detected') else 0}\t{breaker}")
PY
  rc=$?
  rm -f "$failure_context_file"
  return "$rc"
}

render_recurrence_block() {
  python3 - "$DATA_FILE" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
payload = json.loads(path.read_text(encoding="utf-8"))
recurrence = payload.get("current_recurrence") or {}
if not recurrence.get("detected"):
    raise SystemExit(0)
attempts = payload.get("attempts") if isinstance(payload.get("attempts"), list) else []
matching_ids = {
    int(item)
    for item in (recurrence.get("layer1") or {}).get("matching_attempt_ids") or []
    if str(item).strip()
}
if matching_ids:
    relevant = [
        item
        for item in attempts
        if isinstance(item, dict) and int(item.get("attempt_id") or 0) in matching_ids
    ]
else:
    take = max(int((recurrence.get("layer2") or {}).get("no_advance_dispatch_count") or 1) - 1, 1)
    relevant = [item for item in attempts if isinstance(item, dict)][-take:]
signature = recurrence.get("problem_signature") or {}
signature_bits = []
for key in (
    "failure_kind",
    "current_state",
    "phase_or_step",
    "milestone_or_plan",
    "gate_recommendation",
    "blocked_task_id",
):
    value = str(signature.get(key) or "").strip() or "-"
    signature_bits.append(f"{key}={value}")
print("## RECURRENCE EVIDENCE")
print(
    "- This is attempt "
    f"{recurrence.get('attempt_number')} for the same controlled-field symptom (recurrence detected)."
)
layer1 = recurrence.get("layer1") or {}
layer2 = recurrence.get("layer2") or {}
if layer1.get("detected"):
    print(
        "- Layer 1 fired: the same controlled-field problem signature returned after "
        f"{layer1.get('repeat_count')} prior repair dispatch(es)."
    )
if layer2.get("detected"):
    print(
        "- Layer 2 fired: the session absorbed "
        f"{layer2.get('no_advance_dispatch_count')} repair dispatches within "
        f"{layer2.get('window_seconds')} seconds with no milestone/state advancement."
    )
print("- The symptom came back despite these prior fixes:")
print("- Recurrence means the prior attempts may have treated symptoms, not the cause.")
print(f"- Controlled signature: `({' ; '.join(signature_bits)})`")
print("- Prior fixes for this problem:")
if not relevant:
    print("- none captured")
for item in relevant[-4:]:
    model = item.get("dev_model") or item.get("dev_model_requested") or "n/a"
    attempted = item.get("dev_summary") or "n/a"
    dev_report = item.get("dev_report") if isinstance(item.get("dev_report"), dict) else {}
    if attempted == "n/a" and dev_report:
        attempted = dev_report.get("what_tried") or dev_report.get("fix_summary") or "n/a"
    commit = item.get("dev_fix_sha") or "none"
    conclusion = item.get("dev_hypothesis") or item.get("why") or item.get("kimi_diagnosis") or "n/a"
    print(
        f"- attempt {item.get('attempt_id') or item.get('i') or '?'}: "
        f"model={model} what_tried={attempted} commit={commit} conclusion={conclusion}"
    )
PY
}


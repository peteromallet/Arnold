    attempts.append(attempt)
attempt["attempt_id"] = attempt_id
attempt["repair_run_count"] = payload.get("repair_run_count")
attempt["iteration"] = iteration
attempt["dispatched_at"] = (payload.get("current_recurrence") or {}).get("dispatched_at") or ""
attempt["problem_signature"] = payload.get("current_signature") or {}
attempt["advancement_snapshot"] = payload.get("current_advancement_snapshot") or {}
attempt["recurrence"] = payload.get("current_recurrence") or {}
attempt["request_id"] = payload.get("request_id") or (payload.get("current_recurrence") or {}).get("request_id") or ""
attempt["blocker_id"] = payload.get("blocker_id") or (payload.get("current_recurrence") or {}).get("blocker_id") or ""
attempt["failure_context"] = payload.get("current_failure_context") or {}
attempt["failure_classification"] = entry["failure_classification"]
attempt["raw_failure_signals"] = entry["raw_failure_signals"]
attempt["plan_latest_failure"] = entry["plan_latest_failure"]
attempt["chain_state_summary"] = entry["chain_state_summary"]
attempt["plan_runtime_state"] = entry["plan_runtime_state"]
attempt["last_gate"] = entry["last_gate"]
attempt["user_action_context"] = entry["user_action_context"]
attempt["execute_attempt_context"] = entry["execute_attempt_context"]
attempt["resolver_output"] = entry["resolver_output"]
attempt["dev_model_requested"] = requested_model
attempt["dev_model"] = dispatch_model
if fallback_reason:
    attempt["dev_model_fallback"] = fallback_reason
attempt["dev_turn_rc"] = int(turn_rc)
attempt["dev_fix_sha"] = entry["dev_fix_sha"]

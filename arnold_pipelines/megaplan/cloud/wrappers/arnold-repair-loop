verify_started_and_holding() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="$4"
  local plan_name="$5"
  local initial_secs="$6"
  local hold_secs="$7"
  local health first_health second_health

  sleep "$initial_secs"
  first_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$first_health" != "alive" ]]; then
    echo "$first_health"
    return 1
  fi
  sleep "$hold_secs"
  second_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$second_health" == "alive" ]]; then
    echo "alive"
    return 0
  fi
  echo "$second_health"
  return 1
}

kill_tmux_session_if_present() {
  local session="$1"
  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session" 2>/dev/null || true
    for _ in 1 2 3 4 5; do
      tmux has-session -t "$session" 2>/dev/null || break
      sleep 0.2
    done
  fi
}

mechanical_launch_step() {
  local iteration="$1"
  local session="$2"
  local workspace="$3"
  local remote_spec="$4"
  local run_kind="$5"
  local plan_name="$6"
  local relaunch_command="$7"
  local quoted_command launch_script safe detail health

  quoted_command="$(resolve_relaunch_command "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name" "$relaunch_command")" || {
    echo "failed:missing_relaunch_command"
    return 1
  }
  kill_tmux_session_if_present "$session"
  safe="$(safe_name "$session")"
  launch_script="$(mktemp)"
  cat > "$launch_script" <<EOF
#!/usr/bin/env bash
set -euo pipefail
cd $(printf '%q' "$workspace")
exec /usr/local/bin/arnold-supervise "watchdog-$safe" bash -lc "$quoted_command"
EOF
  chmod +x "$launch_script"
  if ! tmux new-session -d -s "$session" -c "$workspace" "bash '$launch_script'"; then
    rm -f "$launch_script"
    echo "failed:tmux_launch_failed"
    return 1
  fi
  rm -f "$launch_script"
  health="$(verify_started_and_holding "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name" "$MECHANICAL_VERIFY_INITIAL_SECS" "$MECHANICAL_VERIFY_HOLD_SECS")" || {
    detail="$health"
    kill_tmux_session_if_present "$session"
    echo "failed:$detail"
    return 1
  }
  echo "running"
}

write_dev_prompt() {
  local prompt_path="$1"
  local requested_model="$2"
  local dispatch_model="$3"
  local report_path="$4"
  local failure_summary
  failure_summary="$(render_failure_summary "$DATA_FILE")"
  cat > "$prompt_path" <<EOF
You are the watchdog repair-loop dev-fix agent for a stopped Arnold cloud session.

$failure_summary

Full accumulated repair data: $DATA_FILE

Session: $SESSION
Workspace: $WORKSPACE
Chain spec: $REMOTE_SPEC
Editable Arnold source: $ARNOLD_SRC
Editable source branch: $SYNC_BRANCH
Repair data file (read this first): $DATA_FILE
JSON report path (write this before exiting): $report_path
Requested model label for this iteration: $requested_model
Actual dispatch model: $dispatch_model

Task:
1. Read the accumulated repair data JSON and gather only the freshest facts needed on the current stop.
2. Apply the narrowest safe root-cause fix in $ARNOLD_SRC on branch $SYNC_BRANCH.
3. Validate minimally: py_compile for touched python files and/or the smallest relevant focused test.
4. If source changes pass validation, commit and push them.
5. Do not relaunch the chain yourself. The wrapper will do the mechanical launch next.
6. Keep the turn short. Pick the most likely fix from the accumulated evidence instead of broad exploration.
7. Write a concise JSON report to $report_path with keys:
   classification, hypothesis, what_tried, validation, pushed_commit, remaining_blockers.

Constraints:
- Work only in $ARNOLD_SRC for source fixes.
- Do not ask for user input.
- End the turn as soon as you have either a narrow fix or a concrete blocker.
EOF
}

write_kimi_prompt() {
  local prompt_path="$1"
  local relaunch_command="$2"
  local report_path="$3"
  local failure_summary
  failure_summary="$(render_failure_summary "$DATA_FILE")"
  cat > "$prompt_path" <<EOF
You are the focused Kimi launch/diagnosis turn in the watchdog repair loop.

$failure_summary

Full accumulated repair data: $DATA_FILE

Session: $SESSION
Workspace: $WORKSPACE
Chain spec: $REMOTE_SPEC
Editable Arnold source: $ARNOLD_SRC
Repair data file (read this first): $DATA_FILE
JSON report path (write this before exiting): $report_path
Relaunch command: $relaunch_command

Task:

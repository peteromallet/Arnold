kill_matching_runner_processes() {
  require_repair_lock_held
  local session="$1"
  local remote_spec="$2"
  local run_kind="${3:-chain}"
  local plan_name="${4:-}"
  python3 - "$$" "$session" "$remote_spec" "$run_kind" "$plan_name" <<'PY' 2>>"$LOG" || true
import os
import signal
import subprocess
import sys
import time

own_pid = int(sys.argv[1])
session = sys.argv[2]
remote_spec = sys.argv[3]
run_kind = sys.argv[4]
plan_name = sys.argv[5]

try:
    proc = subprocess.run(
        ["ps", "-eww", "-o", "pid=", "-o", "pgid=", "-o", "args="],
        check=False,
        capture_output=True,
        text=True,
    )
except Exception:
    raise SystemExit(0)
if proc.returncode != 0:
    raise SystemExit(0)

needles: list[str] = []
if run_kind == "chain" and remote_spec:
    needles.append("arnold_pipelines.megaplan chain start")
elif run_kind == "epic_chain" and remote_spec:
    needles.append("arnold_pipelines.megaplan epic-chain start")
elif plan_name:
    needles.append("arnold_pipelines.megaplan auto")

targets: set[int] = set()
ignored = {os.getpid(), os.getppid(), own_pid}
for line in proc.stdout.splitlines():
    stripped = line.strip()
    if not stripped:
        continue
    try:
        pid_text, pgid_text, args = stripped.split(None, 2)
        pid = int(pid_text)
        pgid = int(pgid_text)
    except Exception:
        continue
    if pid in ignored:
        continue
    if session and f"arnold-repair-loop {session}" in args:
        continue
    if remote_spec and any(needle in args for needle in needles) and "--spec" in args and remote_spec in args:
        targets.add(pgid if pgid > 0 else pid)
    elif plan_name and any(needle in args for needle in needles) and f"--plan {plan_name}" in args:
        targets.add(pgid if pgid > 0 else pid)

for pgid in sorted(targets):
    try:
        os.killpg(pgid, signal.SIGTERM)
        print(f"killed stale runner process group pgid={pgid}", file=sys.stderr)
    except ProcessLookupError:
        pass
    except Exception as exc:
        print(f"failed SIGTERM stale runner pgid={pgid}: {exc}", file=sys.stderr)

if targets:
    time.sleep(2)
for pgid in sorted(targets):
    try:
        os.killpg(pgid, signal.SIGKILL)
        print(f"force-killed stale runner process group pgid={pgid}", file=sys.stderr)
    except ProcessLookupError:
        pass
    except Exception:
        pass
PY
}


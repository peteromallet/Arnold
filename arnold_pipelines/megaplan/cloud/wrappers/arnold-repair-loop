render_chain_health_block() {
  # Read the chain-health artifact the watchdog writes when it detects a
  # chain-level cycle / stuck-state / completion-guard rejection, and render the
  # evidence block for the dev-fix prompt. Returns empty when no chain-level
  # issue is flagged (so plan-level prompts are unchanged).
  local artifact
  artifact="$(dirname "$DATA_FILE")/${SESSION}.chain-health.json"
  [[ -f "$artifact" ]] || return 0
  python3 - "$artifact" <<'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
if not d or d.get("status") == "ok":
    sys.exit(0)
md = d.get("evidence_markdown") or ""
if md:
    print(md)
    sys.exit(0)
issue = d.get("issue_kind") or d.get("status") or "chain-level issue"
summary = (d.get("summary") or "").strip()
print("## CHAIN HEALTH EVIDENCE")
print(f"- Issue: {issue}")
if summary:
    print(f"- Summary: {summary}")
print("- This is a CHAIN-DRIVER issue (completion guard / state progression), not a plan bug.")
print("- Investigate: arnold_pipelines/megaplan/chain/__init__.py and arnold_pipelines/megaplan/chain/status.py")
PY
}

write_dev_prompt() {
  local prompt_path="$1"
  local requested_model="$2"
  local dispatch_model="$3"
  local report_path="$4"
  local recurrence_mode="${5:-0}"
  local failure_summary chain_health_block recurrence_block mode_tasks
  failure_summary="$(render_failure_summary "$DATA_FILE")"
  chain_health_block="$(render_chain_health_block)"
  recurrence_block="$(render_recurrence_block)"
  if [[ "$recurrence_mode" == "1" ]]; then
    mode_tasks="$(cat <<EOF
9. This is a recurring problem. Do NOT pick the likely fix. Do NOT repeat the prior approaches listed above.
10. Trace the actual mechanism end-to-end: inspect the real stderr/exit code, the actual SHAs, prompt contents, chain/plan state, and any worker inputs the run received versus what it should have received.
11. Do not stop at a status label. Name the precise mechanism that recreates the symptom before you propose a fix.
12. Use the extra time in this root-cause attempt; depth matters more than turn-shortness here.
13. Write a concise JSON report to $report_path with keys:
    classification, hypothesis, what_tried, validation, pushed_commit, remaining_blockers,
    structural_pattern, other_instantiations, human_review_recommendation,
    findings_doc_path, findings_doc_appended.
EOF
)"
  else
    mode_tasks="$(cat <<EOF
9. Use the raw failure signal, run narrative, and prior-attempt history to avoid repeating failed ideas.
10. Keep the turn short. Pick the most likely fix from the current evidence instead of broad exploration.
11. Write a concise JSON report to $report_path with keys:
    classification, hypothesis, what_tried, validation, pushed_commit, remaining_blockers,
    structural_pattern, other_instantiations, human_review_recommendation,
    findings_doc_path, findings_doc_appended.
EOF
)"
  fi
  cat > "$prompt_path" <<EOF
You are the watchdog repair-loop dev-fix agent for a stopped Arnold cloud session.

$failure_summary
$chain_health_block
$recurrence_block

**IF A "CHAIN HEALTH EVIDENCE" BLOCK IS PRESENT ABOVE: the root cause is a CHAIN-DRIVER code bug (completion guard / state progression / authority_divergence cycle) in arnold_pipelines/megaplan/chain/, NOT a plan bug. Read the recurring chain-log lines and the completion-guard verdict in that block, then fix the chain driver there. Do NOT chase the plan's latest_failure -- for a chain-level cycle the plan is a victim, not the cause.**
**IF A "RECURRENCE EVIDENCE" BLOCK IS PRESENT ABOVE: recurrence means the symptom came back after prior fixes. Do NOT reuse those approaches. Move into root-cause mode and trace the precise mechanism that regenerates the stop.**

Session: $SESSION
Workspace: $WORKSPACE
Run kind: $RUN_KIND
Run input: $REMOTE_SPEC
Plan name: ${PLAN_NAME:-}
Editable Arnold source: $ARNOLD_SRC
Editable source branch: $SYNC_BRANCH
Repair data file: $DATA_FILE
Persistent findings doc: $FINDINGS_DOC
JSON report path (write this before exiting): $report_path
Requested model label for this iteration: $requested_model
Actual dispatch model: $dispatch_model

Task:
1. Start from the inline incident snapshot above. Read the repair data JSON and pointed files only if you need deeper evidence.
   Read the LAST EXECUTE ATTEMPT summary first. The root cause might be in the Arnold SOURCE (a code bug) OR in the PLAN STATE (a deferred task, a missing baseline, stale tests for deleted modules). If a task was deferred or blocked rather than failed, investigate the task-level deferral reason; the fix might be to clear or resolve the deferral/state, not to change source code.
   Classification guide:
   - LIVE FAILURE: The latest_failure is recent (no success since it was recorded). Fix the root cause in the Arnold source.
   - STALE STATE: The latest_failure predates a successful run or the current block is a 0ms same-hash replay. CLEAR latest_failure to null in the plan's state.json, clear stale blocks, and re-drive the run. Do NOT try to fix a source bug; the issue was already addressed.
   For run_kind=plan, use the named plan's state.json, events.ndjson, plan log, and user-action artifacts. Missing chain state, chain logs, chain.yaml, milestones, and base refs are expected and not evidence of a bug.
   For run_kind=chain, use chain state/logs/milestones when present.
2. If the incident is awaiting_human or the User Action Gate section lists unresolved actions, ATTEMPT to resolve those user actions before treating this as a human stop. Read user_actions.md plus user_action_resolutions.json, inspect the referenced evidence/artifacts/code, make the best defensible judgment call, and record each decision with the CLI instead of hand-writing JSON. Use:
   cd "$WORKSPACE" && MEGAPLAN_ACTOR_ID=repair-loop-dev-fix PYTHONPATH="$ARNOLD_SRC:\${PYTHONPATH:-}" python3 -P -m arnold_pipelines.megaplan user-action resolve --plan "${PLAN_NAME:-<PLAN_NAME_FROM_SNAPSHOT>}" --action-id <ACTION_ID> --resolution <satisfied|accepted_blocked|waived|manual_required|rejected> --reason "..." --instructions "..." --tasks "<TASK_ID,...>"
   Prefer satisfied when the evidence clearly answers the action. Use accepted_blocked or waived only when the action itself permits a fallback. Leave unresolved or mark manual_required only when the decision is genuinely ambiguous, unusually difficult, or requires human-only judgment.
3. Go to the deepest structural level you can reach in this bounded turn. Do not just fix the one symptom that caused this stop; find the underlying pattern and check whether it has other instantiations.
4. Apply the narrowest safe root-cause fix in $ARNOLD_SRC on branch $SYNC_BRANCH, but prefer a general engine fix over a workflow-specific patch when the evidence supports it.
5. If you spot a structural pattern with other instantiations you cannot fix in this turn, append it to the findings doc at $FINDINGS_DOC so it can be reviewed. Capture what you fixed, the deeper pattern, the other instantiations you could not fix, and a recommendation for what a human should review.
6. Validate minimally: py_compile for touched python files and/or the smallest relevant focused test.
7. If source changes pass validation, commit and push them.
8. Do not relaunch the run yourself. The wrapper will do the mechanical launch next using the marker's run-kind-aware command.
$mode_tasks

Constraints:
- Work only in $ARNOLD_SRC for source fixes. You may update the active plan's user_action_resolutions.json and state metadata only through the user-action CLI above.
- Do not hardcode a workflow-specific workaround when a general engine fix is appropriate.
- Do not escalate awaiting_human just because a user action exists. Escalate only after you have reviewed the evidence and cannot make a confident decision.
- If you find a pattern such as flags positioned wrong across multiple dispatch sites or stale recovery logic duplicated in several places, fix what you can now and persist the broader findings in $FINDINGS_DOC.
- Do not ask for user input.
- End the turn as soon as you have either a narrow fix or a concrete blocker, unless recurrence was detected; in that case stay long enough to name the root mechanism.
EOF
}

write_kimi_prompt() {
  local prompt_path="$1"
  local relaunch_command="$2"
  local report_path="$3"
  local failure_summary
  failure_summary="$(render_failure_summary "$DATA_FILE")"
  cat > "$prompt_path" <<EOF
You are the focused Kimi launch/diagnosis turn in the watchdog repair loop.

$failure_summary

Session: $SESSION
Workspace: $WORKSPACE
Run kind: $RUN_KIND
Run input: $REMOTE_SPEC
Plan name: ${PLAN_NAME:-}
Editable Arnold source: $ARNOLD_SRC
Repair data file: $DATA_FILE
JSON report path (write this before exiting): $report_path
Relaunch command: $relaunch_command

Task:
1. Start from the inline incident snapshot above. Read the repair data JSON and pointed files only if you need more detail.
   Classification guide: LIVE FAILURE means no success since latest_failure was recorded; STALE STATE means latest_failure predates success or the current block is a 0ms same-hash replay and state should be cleared/re-driven instead of source-fixed.
   For run_kind=plan, diagnose from the named plan's state/events/log/user actions; missing chain artifacts are expected.
2. Try to start the run safely. Prefer the exact relaunch command above if the session is not already up.
3. If the run comes up and appears live, stop and write a success report.
4. If it does not come up, diagnose exactly why from the current logs/state and write that diagnosis.
5. Use the raw failure signal and prior-attempt history to explain the current blocker concretely.
6. Keep the turn short; launch plus concrete diagnosis only.

Write a concise JSON report to $report_path with keys:
classification, launch_result, diagnosis, why, remaining_blockers.

Do not ask for user input.
EOF
}

run_dev_fix_turn() {
  local iteration="$1"
  local attempt_id="$2"
  local recurring="$3"
  local requested_model="$4"
  local dispatch_model="$5"
  local dispatch_kind="$6"
  local fallback_reason="$7"
  local prompt_path report_path before_sha after_sha rc dev_timeout reasoning_effort
  prompt_path="$RUN_DIR/iter${iteration}-dev-fix-prompt.md"
  report_path="$RUN_DIR/iter${iteration}-dev-fix-report.json"
  write_dev_prompt "$prompt_path" "$requested_model" "$dispatch_model" "$report_path" "$recurring"
  before_sha="$(cd "$ARNOLD_SRC" && git rev-parse HEAD 2>/dev/null || true)"
  dev_timeout="$DEV_TIMEOUT"
  reasoning_effort="$CODEX_REASONING_EFFORT"
  if [[ "$recurring" == "1" ]]; then
    dev_timeout="$DEV_ROOT_CAUSE_TIMEOUT"
    reasoning_effort="$ROOT_CAUSE_REASONING_EFFORT"
  fi
  log "iteration=$iteration dev-fix model=$dispatch_model requested=$requested_model recurring=$recurring timeout=$dev_timeout reasoning=$reasoning_effort"
  if [[ "$dispatch_kind" == "hermes" ]]; then
    (
      cd "$ARNOLD_SRC" &&
      timeout "$dev_timeout" env PYENV_VERSION="${PYENV_VERSION:-3.11.11}" python "$HERMES_LAUNCHER" \
        --model="$dispatch_model" \
        --toolsets="file,web,terminal" \
        --query_file="$prompt_path" \
        --project_dir="$ARNOLD_SRC"
    ) >> "$LOG" 2>&1 &
  else
    (
      cd "$ARNOLD_SRC" &&
      timeout "$dev_timeout" codex exec \
        --sandbox danger-full-access \
        -c model="$dispatch_model" \
        -c model_reasoning_effort="$reasoning_effort" \
        "$(cat "$prompt_path")" </dev/null
    ) >> "$LOG" 2>&1 &
  fi
  local child_pid=$!
  CHILD_PIDS+=("$child_pid")
  if wait "$child_pid"; then
    rc=0
  else
    rc=$?
  fi
  after_sha="$(cd "$ARNOLD_SRC" && git rev-parse HEAD 2>/dev/null || true)"
  repair_data_record_dev "$iteration" "$attempt_id" "$requested_model" "$dispatch_model" "$fallback_reason" "$report_path" "$rc" "$before_sha" "$after_sha"
  append_repair_finding_if_reported "$iteration" "$report_path" "$dispatch_model"
}

run_kimi_launch_turn() {
  local iteration="$1"
  local run_kind="$2"
  local plan_name="$3"
  local relaunch_command="$4"
  local prompt_path report_path rc health
  prompt_path="$RUN_DIR/iter${iteration}-kimi-prompt.md"
  report_path="$RUN_DIR/iter${iteration}-kimi-report.json"
  write_kimi_prompt "$prompt_path" "$relaunch_command" "$report_path"
  log "iteration=$iteration kimi-launch model=$KIMI_MODEL"
  (
    cd "$ARNOLD_SRC" &&
    PYTHONSAFEPATH=1 PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" \
    timeout "$KIMI_TIMEOUT" python3 -P -m arnold.agent.run_agent \
      --query="$(cat "$prompt_path")" \
      --model="$KIMI_MODEL" \
      --api_key="${KIMI_API_KEY:-}" \
      --base_url="$KIMI_BASE_URL" \
      --max_turns="$KIMI_MAX_TURNS" \
      --enabled_toolsets='"terminal,file,code_execution,todo"' \
      --save_sample=True
  ) >> "$LOG" 2>&1 &
  local child_pid=$!
  CHILD_PIDS+=("$child_pid")
  if wait "$child_pid"; then
    rc=0
  else
    rc=$?
  fi
  health="$(verify_started_and_holding "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$run_kind" "$plan_name" "$KIMI_VERIFY_INITIAL_SECS" "$KIMI_VERIFY_HOLD_SECS")" || {
    repair_data_record_kimi "$iteration" "$CURRENT_ATTEMPT_ID" "failed:$health" "$report_path" "$rc"
    kill_tmux_session_if_present "$SESSION"
    return 1
  }
  repair_data_record_kimi "$iteration" "$CURRENT_ATTEMPT_ID" "running" "$report_path" "$rc"
  return 0
}

glm_dispatch_model() {
  python3 - <<'PY'
from arnold_pipelines.megaplan.runtime.key_pool import resolve_model
try:
    resolve_model("zhipu:glm-5.2")
except Exception:
    raise SystemExit(1)
print("zhipu:glm-5.2")
PY
}

write_needs_human_marker() {
  local discord_status="$1"
  python3 - "$DATA_FILE" "$NEEDS_HUMAN_FILE" "$discord_status" <<'PY'
import datetime as dt
import json
import pathlib
import sys

data_path, out_path, discord_status = sys.argv[1:]
payload = json.loads(pathlib.Path(data_path).read_text(encoding="utf-8"))
iterations = payload.get("iterations") or []
summary_parts = []
for item in iterations:
    summary_parts.append(
        f"i{item.get('i')} dev={item.get('dev_model', '')} sha={item.get('dev_fix_sha', '') or 'none'} "
        f"mechanical={item.get('mechanical_launch', '') or 'n/a'} "
        f"kimi={item.get('kimi_launch', '') or 'n/a'} why={item.get('why', '') or item.get('kimi_diagnosis', '') or 'n/a'}"
    )
marker = {
    "session": payload.get("session"),
    "workspace": payload.get("workspace"),
    "spec": payload.get("spec"),
    "summary": " | ".join(summary_parts),
    "repair_data_path": data_path,
    "discord_status": discord_status,
    "recorded_at": dt.datetime.now(dt.timezone.utc).isoformat(),
}
pathlib.Path(out_path).write_text(json.dumps(marker, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

send_discord_escalation() {
  local result_path result_status
  result_path="$RUN_DIR/discord-result.json"
  result_status="helper_unavailable"
  if [[ ! -x "$DISCORD_DM_BIN" ]]; then
    printf '%s' "$result_status"
    return 0
  fi
  python3 - "$DATA_FILE" > "$RUN_DIR/discord-payload.json" <<'PY'
import json
import pathlib
import sys

data = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
iterations = data.get("iterations") or []
fields = [
    {"label": "Session", "value": data.get("session"), "style": "code"},
    {"label": "Workspace", "value": data.get("workspace"), "style": "code"},
    {"label": "Spec", "value": data.get("spec"), "style": "code"},
]
for item in iterations:
    fields.append(
        {
            "label": f"Iteration {item.get('i')}",
            "value": [
                f"dev={item.get('dev_model', '') or 'n/a'}",
                f"sha={item.get('dev_fix_sha', '') or 'none'}",
                f"mechanical={item.get('mechanical_launch', '') or 'n/a'}",
                f"kimi={item.get('kimi_launch', '') or 'n/a'}",
                item.get('why', '') or item.get('kimi_diagnosis', '') or "no diagnosis",
            ],
            "style": "code_list",
            "joiner": " ; ",
        }
    )
payload = {
    "title": "Watchdog repair loop exhausted; needs human",
    "summary": "The bounded 3-iteration repair loop could not get the run running.",
    "fields": fields,
    "next_action": f"Read {sys.argv[1]} and intervene manually.",
}
print(json.dumps(payload))
PY
  if "$DISCORD_DM_BIN" < "$RUN_DIR/discord-payload.json" > "$result_path" 2>>"$LOG"; then
    result_status="$(python3 - "$result_path" <<'PY'
import json
import sys
try:
    payload = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    print("invalid_result")
    raise SystemExit(0)
if payload.get("ok"):
    print("delivered")
else:
    print(payload.get("reason") or "send_failed")
PY
)"
  else
    result_status="send_failed"
  fi
  printf '%s' "$result_status"
}

log "starting session=$SESSION workspace=$WORKSPACE spec=$REMOTE_SPEC source=$ARNOLD_SRC branch=$SYNC_BRANCH"
guard_against_recursive_repair_loop || exit 0
acquire_repair_lock || exit 75
export CLOUD_WATCHDOG_REPAIR_LOOP_ACTIVE=1
export CLOUD_WATCHDOG_REPAIR_LOOP_SESSION="$SESSION"
export CLOUD_WATCHDOG_REPAIR_LOOP_PID="$$"

RUN_KIND="$(json_field "$MARKER_PATH" run_kind 2>/dev/null || true)"
PLAN_NAME="$(json_field "$MARKER_PATH" plan_name 2>/dev/null || true)"
RELAUNCH_COMMAND="$(json_field "$MARKER_PATH" relaunch_command 2>/dev/null || true)"
if [[ -z "$RUN_KIND" ]]; then
  if [[ -n "$PLAN_NAME" ]]; then
    RUN_KIND="plan"
  else
    RUN_KIND="chain"
  fi
fi
exit_if_repair_target_complete "start"

INITIAL_HEALTH="$(session_health_status "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME")"
repair_data_init "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND" "$INITIAL_HEALTH"

STALE_CLEAR_STATUS="$(repair_clear_stale_state_if_needed 2>>"$LOG" || true)"
if [[ "$STALE_CLEAR_STATUS" == cleared:* ]]; then
  log "stale state cleared before dev-fix: ${STALE_CLEAR_STATUS#cleared:}"
  mechanical_status="$(mechanical_launch_step "1" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
    repair_data_record_mechanical "1" "0" "$mechanical_status" "after stale-state clear: $mechanical_status"
  }
  if [[ "${mechanical_status:-}" == "running" ]]; then
    repair_data_record_mechanical "1" "0" "running" "stale state cleared; mechanical launch came up and held"
    repair_data_set_outcome "running"
    clear_repair_markers
    log "repair loop succeeded after stale-state clear"
    exit 0
  fi
fi

GLM_MODEL=""
GLM_FALLBACK=""
if GLM_MODEL="$(glm_dispatch_model 2>/dev/null)"; then
  :
else
  GLM_MODEL="gpt-5.4"
  GLM_FALLBACK="zhipu:glm-5.2 unresolved on this box; falling back to gpt-5.4 for iteration 1"
fi

for iteration in 1 2 3; do
  exit_if_repair_target_complete "iteration-$iteration-start"
  case "$iteration" in
    1)
      DEV_REQUESTED_MODEL="glm-5.2"
      if [[ "$GLM_MODEL" == "gpt-5.4" ]]; then
        DEV_DISPATCH_MODEL="gpt-5.4"
        DEV_DISPATCH_KIND="codex"
      else
        DEV_DISPATCH_MODEL="$GLM_MODEL"
        DEV_DISPATCH_KIND="hermes"
      fi
      DEV_FALLBACK_REASON="$GLM_FALLBACK"
      ;;
    2)
      DEV_REQUESTED_MODEL="codex:gpt-5.4"
      DEV_DISPATCH_MODEL="gpt-5.4"
      DEV_DISPATCH_KIND="codex"
      DEV_FALLBACK_REASON=""
      ;;
    3)
      DEV_REQUESTED_MODEL="codex:gpt-5.5"
      DEV_DISPATCH_MODEL="gpt-5.5"
      DEV_DISPATCH_KIND="codex"
      DEV_FALLBACK_REASON=""
      ;;
  esac

  IFS=$'\t' read -r CURRENT_ATTEMPT_ID CURRENT_RECURRING <<< "$(repair_recurrence_prepare_attempt "$iteration" "$DEV_REQUESTED_MODEL" "$DEV_DISPATCH_MODEL")"
  run_dev_fix_turn "$iteration" "$CURRENT_ATTEMPT_ID" "${CURRENT_RECURRING:-0}" "$DEV_REQUESTED_MODEL" "$DEV_DISPATCH_MODEL" "$DEV_DISPATCH_KIND" "$DEV_FALLBACK_REASON"
  exit_if_repair_target_complete "iteration-$iteration-post-dev-fix"

  mechanical_status="$(mechanical_launch_step "$iteration" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
    repair_data_record_mechanical "$iteration" "$CURRENT_ATTEMPT_ID" "$mechanical_status" "$mechanical_status"
  }
  if [[ "${mechanical_status:-}" == "running" ]]; then
    repair_data_record_mechanical "$iteration" "$CURRENT_ATTEMPT_ID" "running" "mechanical launch came up and held"
    repair_data_set_outcome "running"
    clear_repair_markers
    log "repair loop succeeded mechanically iteration=$iteration"
    exit 0
  fi

  if [[ -z "${KIMI_API_KEY:-}" ]]; then
    repair_data_record_kimi "$iteration" "$CURRENT_ATTEMPT_ID" "failed:KIMI_API_KEY missing" "$RUN_DIR/iter${iteration}-kimi-report.json" 78
    continue
  fi

  exit_if_repair_target_complete "iteration-$iteration-pre-kimi"
  resolved_relaunch_command="$(resolve_relaunch_command "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND" 2>/dev/null || true)"
  if run_kimi_launch_turn "$iteration" "$RUN_KIND" "$PLAN_NAME" "$resolved_relaunch_command"; then
    repair_data_set_outcome "running"
    clear_repair_markers
    log "repair loop succeeded via Kimi iteration=$iteration"
    exit 0
  fi
done

if [[ "$(repair_exhausted_should_retry_without_human)" == "1" ]]; then
  repair_data_set_outcome "recurring_retry_pending"
  log "repair loop exhausted but recurrence detected; leaving session for another root-cause repair dispatch session=$SESSION data=$DATA_FILE"
  exit 1
fi

repair_data_set_outcome "discord_escalated"
discord_status="$(send_discord_escalation)"
write_needs_human_marker "$discord_status"
log "repair loop exhausted; needs human session=$SESSION discord=$discord_status data=$DATA_FILE"
exit 1

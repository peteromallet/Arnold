      log "repair goal control snapshot failed closed session=$SESSION phase=$phase"
      return 1
    }
    IFS=$'\t' read -r status action reason <<< "$(
      python3 -c 'import json,sys; d=json.load(sys.stdin); e=d.get("evaluation") or {}; print("\t".join((str(d.get("status") or ""), str(e.get("control_action") or ""), str(e.get("reason") or ""))))' <<< "$result"
    )"
    case "$status:$action" in
      progressed:*)
        repair_data_set_outcome "progressed" "$status"
        clear_repair_markers
        log "retained goal owner verified beyond-stage recovery session=$SESSION phase=$phase reason=$reason"
        return 0
        ;;
      approval_required:*)
        repair_data_set_outcome "true_human_blocker" "$status"
        write_needs_human_marker "goal_gate_recorded" "approval_required: $reason"
        log "retained goal owner reached explicit approval gate session=$SESSION phase=$phase reason=$reason"
        return 0
        ;;
      active:preserve_live)
        ensure_repair_budget_available "goal-preserve-live-$phase"
        sleep_secs="$(cap_timeout_to_repair_budget "$REPAIR_GOAL_POLL_SECS" "goal-preserve-live-$phase")"
        log "preserving correct live worker while retained goal remains active session=$SESSION phase=$phase poll_secs=$sleep_secs reason=$reason"
        sleep "$sleep_secs"
        ;;
      active:replan)
        repair_data_set_outcome "deterministic_failure"
        log "deterministic owner circuit breaker requires L2 replan session=$SESSION phase=$phase reason=$reason"
        return 2
        ;;
      *)
        return 1
        ;;
    esac
  done
}

repair_save_verdict_evidence() {
  # best-effort: do not require the repair lock (the data file has already
  # been written by repair_data_set_outcome or save_repair_data). If the
  # data file is missing or unreadable, skip quietly.
  local verdict_path="${DATA_FILE%.repair-data.json}.repair-verdict.json"
  local repair_goal_status_override="${1:-}"
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$verdict_path" "$SESSION" "${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}" "${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}" "$repair_goal_status_override" <<'PY'
import pathlib
import sys

data_path_raw, verdict_path_raw, session, blocker_id, request_id, repair_goal_status_override = sys.argv[1:]
data_path = pathlib.Path(data_path_raw)
verdict_path = pathlib.Path(verdict_path_raw)

try:
    from arnold_pipelines.megaplan.cloud.repair_contract import (
        build_ordinary_repair_verdict,
        load_json,
        save_repair_verdict,
    )
except Exception:
    raise SystemExit(0)

payload = load_json(data_path, default=None)
if payload is None:
    raise SystemExit(0)

verdict = build_ordinary_repair_verdict(
    repair_data_payload=payload,
    session=session,
    request_id=request_id or payload.get("request_id", ""),
    blocker_id=blocker_id or payload.get("blocker_id", ""),
    attempted_actions=tuple(payload.get("attempted_actions") or ()),
    before_evidence_refs=tuple(payload.get("before_evidence_refs") or ()),
    after_evidence_refs=tuple(payload.get("after_evidence_refs") or ()),
    durable_refs=tuple(payload.get("durable_refs") or ()),
    repair_goal_status_override=repair_goal_status_override,
)
save_repair_verdict(verdict_path, verdict)

# --- repair success without custody check ---
# When the repair verdict indicates success (cleared), verify that custody
# evidence exists for this session.  If custody is missing or shows an
# unmanaged/blocked state, the repair success cannot be fully trusted and
# should be flagged.
if verdict.verdict_kind == "cleared":
    import json as _json
    _snapshot_path = pathlib.Path("/workspace/.megaplan/status/cloud-status.json")
    try:
        _snapshot = _json.loads(_snapshot_path.read_text(encoding="utf-8"))
    except Exception:
        _snapshot = None
    if isinstance(_snapshot, dict):
        _sessions = _snapshot.get("sessions")
        if isinstance(_sessions, list):
            _custody_kind = ""
            for _entry in _sessions:
                if isinstance(_entry, dict) and _entry.get("session") == session:
                    _cc = _entry.get("cloud_custody")
                    if isinstance(_cc, dict):
                        _custody_kind = _cc.get("custody_kind", "")
                    break
            # Managed-running or complete custody backs the repair success.
            # Any other custody state (unmanaged-warning, blocked-relaunch,
            # escalated-unchanged, or missing) indicates the repair success
            # should not be fully trusted without custody evidence.
            if _custody_kind not in ("managed-running", "complete", ""):
                # Write a custody-gap sidecar so S4 consumers can find it.
                _gap_path = pathlib.Path(
                    "/workspace/.megaplan/cloud-sessions/repair-data"
                ) / f"{session}.repair-custody-gap.json"
                try:
                    _gap_path.parent.mkdir(parents=True, exist_ok=True)
                    _gap_payload = {
                        "session": session,
                        "verdict_kind": verdict.verdict_kind,
                        "custody_kind": _custody_kind,
                        "evidence_timestamp": verdict.evidence_timestamp,
                        "message": (
                            f"repair verdict cleared but custody is {_custody_kind or 'missing'}; "
                            f"repair success not backed by managed custody evidence"
                        ),
                    }
                    _gap_path.write_text(
                        _json.dumps(_gap_payload, indent=2, sort_keys=True) + "\n",
                        encoding="utf-8",
                    )
                except Exception:
                    pass
PY
}

repair_clear_stale_state_if_needed() {
  require_repair_lock_held
  ensure_repair_budget_available "stale-state-clear"
  local failure_context failure_context_file
  failure_context="$(collect_failure_context_json "$WORKSPACE" "$SESSION" "$RUN_KIND" "$PLAN_NAME")"
  failure_context_file="$(mktemp)"
  printf '%s' "$failure_context" > "$failure_context_file"
  PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$failure_context_file" <<'PY'
import datetime as dt
import json
import os
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.repair_contract import atomic_write_json, load_json, save_repair_data

data_path_raw, failure_context_path_raw = sys.argv[1:]
data_path = pathlib.Path(data_path_raw)
failure_context = json.loads(pathlib.Path(failure_context_path_raw).read_text(encoding="utf-8"))
stale_state = failure_context.get("stale_state") if isinstance(failure_context, dict) else {}
if not isinstance(stale_state, dict):
    stale_state = {}
state_mismatch = failure_context.get("state_mismatch") if isinstance(failure_context, dict) else {}
if not isinstance(state_mismatch, dict):
    state_mismatch = {}
resolver_output = failure_context.get("resolver_output") if isinstance(failure_context, dict) else {}
if not isinstance(resolver_output, dict):
    resolver_output = {}
stale_kinds = {
    str(item.get("kind") or "").strip()
    for item in resolver_output.get("stale_evidence", [])
    if isinstance(item, dict)
}
has_dead_active_step = (
    stale_state.get("classification") == "NO LATEST FAILURE"
    and "stale_active_step_dead_pid" in stale_kinds
)
has_stale_state = stale_state.get("classification") == "STALE STATE" or has_dead_active_step
has_state_mismatch = bool(state_mismatch.get("detected"))
if not has_stale_state and not has_state_mismatch:
    print("none")
    raise SystemExit(0)

plan_failure = failure_context.get("plan_latest_failure") if isinstance(failure_context, dict) else {}
state_path_raw = plan_failure.get("state_path") if isinstance(plan_failure, dict) else ""
if not state_path_raw:
    state_path_raw = state_mismatch.get("plan_state_path") or ""
if not state_path_raw:
    print("failed:missing_state_path")
    raise SystemExit(1)
state_path = pathlib.Path(str(state_path_raw))
try:
    state = json.loads(state_path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"failed:state_unreadable:{exc}")
    raise SystemExit(1)
if not isinstance(state, dict):
    print("failed:state_not_object")
    raise SystemExit(1)

actions: list[str] = []
stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
if has_dead_active_step:
    active_step = state.get("active_step")
    if isinstance(active_step, dict) and any(
        active_step.get(key) not in (None, "")
        for key in ("phase", "step", "worker_pid", "pid", "session_id")
    ):
        state.pop("active_step", None)
        actions.append("cleared orphaned active_step for dead worker PID")
if has_stale_state and stale_state.get("latest_failure_stale") and state.get("latest_failure") is not None:
    state["latest_failure"] = None
    success = stale_state.get("latest_success_after_failure")
    success_ts = success.get("timestamp") if isinstance(success, dict) else "unknown"
    actions.append(f"latest_failure was stale (predates last success at {success_ts}) -- cleared")

block = stale_state.get("stale_block_replay") if has_stale_state else {}
if isinstance(block, dict) and block.get("detected"):
    artifact_hash = block.get("artifact_hash")
    history = state.get("history")
    if isinstance(history, list) and artifact_hash:
        removed = 0
        while history:
            item = history[-1]
            if not isinstance(item, dict):
                break
            try:
                duration_zero = int(item.get("duration_ms") or 0) == 0
            except (TypeError, ValueError):
                duration_zero = False
            if (
                str(item.get("result") or "").lower() == "blocked"
                and item.get("artifact_hash") == artifact_hash
                and duration_zero
            ):
                history.pop()
                removed += 1
                continue
            break
        if removed:
            actions.append(f"removed {removed} trailing stale 0ms blocked history entr{'y' if removed == 1 else 'ies'} with artifact_hash={artifact_hash}")
    phase_result_path = state_path.parent / "phase_result.json"
    if phase_result_path.exists():
        backup = state_path.parent / f"phase_result.stale-{stamp}.json"
        try:
            os.replace(phase_result_path, backup)
            actions.append(f"moved stale phase_result.json to {backup.name}")
        except OSError as exc:
            actions.append(f"failed to move stale phase_result.json: {exc}")

if has_state_mismatch:
    chain_state_path = pathlib.Path(str(state_mismatch.get("chain_state_path") or ""))
    plan_current_state = str(state.get("current_state") or state_mismatch.get("plan_state") or "").strip()
    chain_was = str(state_mismatch.get("chain_last_state") or "").strip()
    if not chain_state_path:
        actions.append("state mismatch detected but chain state path was unavailable")
    elif not plan_current_state:
        actions.append("state mismatch detected but plan current_state was unavailable")
    else:
        try:
            chain_payload = json.loads(chain_state_path.read_text(encoding="utf-8"))
        except Exception as exc:
            actions.append(f"state mismatch detected but chain state was unreadable: {exc}")
        else:
            if not isinstance(chain_payload, dict):
                actions.append("state mismatch detected but chain state was not a JSON object")
            else:
                chain_was = str(chain_payload.get("last_state") or chain_was or "").strip()
                chain_payload["last_state"] = plan_current_state
                metadata = chain_payload.setdefault("metadata", {})
                if isinstance(metadata, dict):
                    records = metadata.setdefault("watchdog_repair_state_mismatch_clears", [])
                    if isinstance(records, list):
                        records.append(
                            {
                                "cleared_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                                "plan_state": plan_current_state,
                                "chain_last_state_was": chain_was,
                                "plan_state_path": str(state_path),
                                "chain_state_path": str(chain_state_path),
                            }
                        )
                atomic_write_json(chain_state_path, chain_payload)
                state_mismatch["cleared"] = True
                state_mismatch["action_taken"] = (
                    f"cleared chain last_state to match plan current_state ({plan_current_state})"
                )
                actions.append(
                    "state mismatch detected + cleared "
                    f"(plan={plan_current_state}, chain was {chain_was or 'unknown'}, synced)"
                )

if not actions:
    print("none")
    raise SystemExit(0)

meta = state.setdefault("meta", {})
if isinstance(meta, dict):
    records = meta.setdefault("watchdog_repair_stale_state_clears", [])
    if isinstance(records, list):
        records.append(
            {
                "cleared_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                "actions": actions,
                "stale_state": stale_state,
                "state_mismatch": state_mismatch,
            }
        )

atomic_write_json(state_path, state)

payload = load_json(data_path, default={})
failure_context["state_mismatch"] = state_mismatch
payload.setdefault("stale_state_actions", []).append(
    {
        "recorded_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "actions": actions,
        "stale_state": stale_state,
        "state_mismatch": state_mismatch,
        "state_path": str(state_path),
    }
)
initial = payload.setdefault("initial_facts", {})
initial["failure_context"] = failure_context
initial["stale_state"] = stale_state
initial["state_mismatch"] = state_mismatch
save_repair_data(data_path, payload)
print("cleared:" + "; ".join(actions))
PY
  local rc=$?
  rm -f "$failure_context_file"
  return "$rc"
}


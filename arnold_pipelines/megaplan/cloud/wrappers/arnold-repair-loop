if repair_dependency_manifests_if_possible; then
  mechanical_status="$(mechanical_launch_step "1" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
    repair_data_record_mechanical "1" "0" "$mechanical_status" "after dependency-manifest repair: $mechanical_status"
  }
  if [[ "${mechanical_status:-}" == "running" ]]; then
    repair_data_record_mechanical "1" "0" "running" "dependency manifest repaired; mechanical launch came up and held"
    repair_data_set_outcome "live_with_fresh_activity"
    log "repair loop reached live_with_fresh_activity after dependency manifest repair"
    exit 0
  fi
fi

STALE_CLEAR_STATUS="$(repair_clear_stale_state_if_needed 2>>"$LOG" || true)"
if [[ "$STALE_CLEAR_STATUS" == cleared:* ]]; then
  log "stale state cleared before dev-fix: ${STALE_CLEAR_STATUS#cleared:}"
  mechanical_status="$(mechanical_launch_step "1" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
    repair_data_record_mechanical "1" "0" "$mechanical_status" "after stale-state clear: $mechanical_status"
  }
  if [[ "${mechanical_status:-}" == "running" ]]; then
    repair_data_record_mechanical "1" "0" "running" "stale state cleared; mechanical launch came up and held"
    repair_data_set_outcome "live_with_fresh_activity"
    log "repair loop reached live_with_fresh_activity after stale-state clear"
    exit 0
  fi
fi

mechanical_status="$(mechanical_launch_step "0" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
  repair_data_record_mechanical "0" "0" "$mechanical_status" "baseline mechanical relaunch: $mechanical_status"
}
if [[ "${mechanical_status:-}" == "running" ]]; then
  repair_data_record_mechanical "0" "0" "running" "baseline mechanical relaunch came up and held"
  repair_data_set_outcome "live_with_fresh_activity"
  log "repair loop reached live_with_fresh_activity via baseline mechanical relaunch"
  exit 0
fi

GLM_MODEL=""
GLM_FALLBACK="zhipu:glm-5.2 disabled by default for watchdog repair; using gpt-5.4 for iteration 1"
if [[ "${CLOUD_WATCHDOG_DEV_FIX_ENABLE_GLM:-0}" == "1" ]]; then
  if GLM_MODEL="$(glm_dispatch_model 2>/dev/null)"; then
    GLM_FALLBACK=""
  else
    GLM_MODEL="gpt-5.4"
    GLM_FALLBACK="zhipu:glm-5.2 unresolved on this box; falling back to gpt-5.4 for iteration 1"
  fi
else
  GLM_MODEL="gpt-5.4"
fi

for iteration in 1 2 3; do
  if (( iteration > REPAIR_ITERATION_MAX )); then
    break
  fi
  BREAKER_TRIPPED="${BREAKER_TRIPPED:-0}"
  exit_if_repair_target_complete "iteration-$iteration-start"
  exit_if_repair_target_recovered "iteration-$iteration-start"
  case "$iteration" in
    1)
      DEV_REQUESTED_MODEL="glm-5.2"
      if [[ "$GLM_MODEL" == "gpt-5.4" ]]; then
        DEV_DISPATCH_MODEL="gpt-5.4"
        DEV_DISPATCH_KIND="codex"
      else
        DEV_DISPATCH_MODEL="$GLM_MODEL"
        DEV_DISPATCH_KIND="hermes"
      fi
      DEV_FALLBACK_REASON="$GLM_FALLBACK"
      ;;
    2)
      DEV_REQUESTED_MODEL="codex:gpt-5.4"
      DEV_DISPATCH_MODEL="gpt-5.4"
      DEV_DISPATCH_KIND="codex"
      DEV_FALLBACK_REASON=""
      ;;
    3)
      DEV_REQUESTED_MODEL="codex:gpt-5.5"
      DEV_DISPATCH_MODEL="gpt-5.5"
      DEV_DISPATCH_KIND="codex"
      DEV_FALLBACK_REASON=""
      ;;
  esac

  if ! IFS=$'\t' read -r CURRENT_ATTEMPT_ID CURRENT_RECURRING CURRENT_DETERMINISTIC_BREAKER <<< "$(repair_recurrence_prepare_attempt "$iteration" "$DEV_REQUESTED_MODEL" "$DEV_DISPATCH_MODEL")"; then
    log "failed to prepare recurrence context; continuing in shallow mode iteration=$iteration"
    CURRENT_ATTEMPT_ID="0"
    CURRENT_RECURRING="0"
    CURRENT_DETERMINISTIC_BREAKER="0"
  fi
  if [[ "${CURRENT_DETERMINISTIC_BREAKER:-0}" == "1" && "${CLOUD_WATCHDOG_DETERMINISTIC_BREAKER:-1}" == "1" ]]; then
    repair_data_set_outcome "deterministic_failure"
    BREAKER_TRIPPED="1"
    log "deterministic-failure breaker tripped before iteration=$iteration dev-fix; problem signature unchanged from prior iteration session=$SESSION"
    break
  fi
  run_dev_fix_turn "$iteration" "$CURRENT_ATTEMPT_ID" "${CURRENT_RECURRING:-0}" "$DEV_REQUESTED_MODEL" "$DEV_DISPATCH_MODEL" "$DEV_DISPATCH_KIND" "$DEV_FALLBACK_REASON"
  exit_if_repair_target_complete "iteration-$iteration-post-dev-fix"

  mechanical_status="$(mechanical_launch_step "$iteration" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
    repair_data_record_mechanical "$iteration" "$CURRENT_ATTEMPT_ID" "$mechanical_status" "$mechanical_status"
  }
  if [[ "${mechanical_status:-}" == "running" ]]; then
    repair_data_record_mechanical "$iteration" "$CURRENT_ATTEMPT_ID" "running" "mechanical launch came up and held"
    repair_data_set_outcome "live_with_fresh_activity"
    log "repair loop reached live_with_fresh_activity mechanically iteration=$iteration"
    exit 0
  fi

  if [[ -z "${KIMI_API_KEY:-}" ]]; then
    repair_data_record_kimi "$iteration" "$CURRENT_ATTEMPT_ID" "failed:KIMI_API_KEY missing" "$RUN_DIR/iter${iteration}-kimi-report.json" 78
    continue
  fi

  exit_if_repair_target_complete "iteration-$iteration-pre-kimi"
  resolved_relaunch_command="$(resolve_relaunch_command "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND" 2>/dev/null || true)"
  if run_kimi_launch_turn "$iteration" "$RUN_KIND" "$PLAN_NAME" "$resolved_relaunch_command"; then
    repair_data_set_outcome "live_with_fresh_activity"
    log "repair loop reached live_with_fresh_activity via Kimi iteration=$iteration"
    exit 0
  fi
  exit_if_repair_target_complete "iteration-$iteration-post-kimi"
done

exit_if_repair_target_complete "post-iterations"
exit_if_repair_target_recovered "post-iterations"

if [[ "${BREAKER_TRIPPED:-0}" == "1" ]]; then
  discord_status="$(send_discord_escalation)"
  if [[ "$discord_status" == "delivered" ]]; then
    write_needs_human_marker "$discord_status" "deterministic_failure - breaker tripped before another iteration (same unresolved signature)"
  fi
  log "deterministic-failure breaker session=$SESSION discord=$discord_status data=$DATA_FILE"
  exit 1
fi

if [[ "$(repair_exhausted_should_retry_without_human)" == "1" ]]; then
  repair_data_set_outcome "recurring_retry_pending"
  log "repair loop exhausted but recurrence detected; leaving session for another root-cause repair dispatch session=$SESSION data=$DATA_FILE"
  exit 1
fi

repair_data_set_outcome "discord_escalated"
discord_status="$(send_discord_escalation)"
if [[ "$discord_status" == "delivered" ]]; then
  write_needs_human_marker "$discord_status"
fi
log "repair loop exhausted; needs human session=$SESSION discord=$discord_status data=$DATA_FILE"
exit 1

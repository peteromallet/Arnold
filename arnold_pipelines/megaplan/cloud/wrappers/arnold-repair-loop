repair_source_workspace_if_possible() {
  require_repair_lock_held
  ensure_repair_budget_available "source-workspace-repair"
  local result_path="" tmp_root="" tmp_clone="" status=1 entry base source_origin="" workspace_origin=""
  result_path="$RUN_DIR/source-workspace-repair.json"
  if [[ ! -d "$ARNOLD_SRC/.git" ]]; then
    printf '%s\n' '{"repaired": false, "reason": "source_git_missing", "details": {}}' >"$result_path"
    log "source workspace repair not applicable status=2 result=$result_path"
    return 1
  fi
  source_origin="$(git -C "$ARNOLD_SRC" remote get-url origin 2>/dev/null || true)"
  if [[ -d "$WORKSPACE/.git" ]] || git -C "$WORKSPACE" rev-parse --show-toplevel >/dev/null 2>&1; then
    workspace_origin="$(git -C "$WORKSPACE" remote get-url origin 2>/dev/null || true)"
    if [[ -n "$source_origin" && "$workspace_origin" != "$source_origin" ]]; then
      git -C "$WORKSPACE" remote set-url origin "$source_origin" >>"$LOG" 2>&1
      python3 - "$result_path" "$WORKSPACE" "$source_origin" <<'PY'
import json
import pathlib
import sys

result_path, workspace, source_origin = sys.argv[1:]
pathlib.Path(result_path).write_text(
    json.dumps(
        {
            "repaired": True,
            "reason": "source_workspace_remote_repaired",
            "details": {
                "workspace": workspace,
                "origin": source_origin,
            },
        },
        indent=2,
    )
    + "\n",
    encoding="utf-8",
)
PY
      log "source workspace repair succeeded result=$result_path"
      return 0
    fi
    printf '%s\n' '{"repaired": false, "reason": "workspace_git_present", "details": {}}' >"$result_path"
    log "source workspace repair not applicable status=2 result=$result_path"
    return 1
  fi

  tmp_root="$(mktemp -d)"
  tmp_clone="$tmp_root/repo"
  mkdir -p "$WORKSPACE"
  if ! git clone --shared --branch "$SYNC_BRANCH" "$ARNOLD_SRC" "$tmp_clone" >>"$LOG" 2>&1; then
    printf '%s\n' '{"repaired": false, "reason": "clone_failed", "details": {}}' >"$result_path"
    rm -rf "$tmp_root"
    log "source workspace repair not applicable status=2 result=$result_path"
    return 1
  fi
  if [[ -n "$source_origin" ]]; then
    git -C "$tmp_clone" remote set-url origin "$source_origin" >>"$LOG" 2>&1 || true
  fi

  shopt -s dotglob nullglob
  for entry in "$tmp_clone"/* "$tmp_clone"/.[!.]* "$tmp_clone"/..?*; do
    [[ -e "$entry" ]] || continue
    base="$(basename "$entry")"
    if [[ "$base" == ".git" || "$base" == ".megaplan" ]]; then
      continue
    fi
    rm -rf "$WORKSPACE/$base"
    cp -a "$entry" "$WORKSPACE/$base"
  done
  shopt -u dotglob nullglob
  rm -rf "$WORKSPACE/.git"
  cp -a "$tmp_clone/.git" "$WORKSPACE/.git"
  rm -rf "$tmp_root"

  python3 - "$result_path" "$WORKSPACE" "$ARNOLD_SRC" "$SYNC_BRANCH" <<'PY'
import json
import pathlib
import sys

result_path, workspace, source_root, branch = sys.argv[1:]
pathlib.Path(result_path).write_text(
    json.dumps(
        {
            "repaired": True,
            "reason": "source_workspace_restored",
            "details": {
                "workspace": workspace,
                "source_root": source_root,
                "branch": branch,
            },
        },
        indent=2,
    )
    + "\n",
    encoding="utf-8",
)
PY
  log "source workspace repair succeeded result=$result_path"
  return 0
}

if repair_source_initiative_if_possible; then
  exit_if_repair_target_complete "post-source-initiative-repair"
  mechanical_status="$(mechanical_launch_step "1" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
    repair_data_record_mechanical "1" "0" "$mechanical_status" "after source initiative repair: $mechanical_status"
  }
  if [[ "${mechanical_status:-}" == "running" ]]; then
    repair_data_record_mechanical "1" "0" "running" "source initiative restored; mechanical launch came up and held"
    repair_data_set_outcome "live_with_fresh_activity"
    log "repair loop reached live_with_fresh_activity after source initiative repair"
    exit 0
  fi

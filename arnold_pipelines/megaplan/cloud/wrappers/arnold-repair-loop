print(json.dumps(redact_payload(payload)))
PY
  if "$DISCORD_DM_BIN" < "$RUN_DIR/discord-payload.json" > "$result_path" 2>>"$LOG"; then
    result_status="$(PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$result_path" "$context_path" "$DATA_DIR" <<'PY'
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.human_blockers import EscalationLedgerWriter

result_path, context_path, data_dir = sys.argv[1:]
context = json.loads(pathlib.Path(context_path).read_text(encoding="utf-8"))
writer = EscalationLedgerWriter()

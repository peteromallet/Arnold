def _parse_ts(value: object) -> tuple[int, str]:
    text = str(value or "").strip()
    if not text:
        return (0, "")
    return (1, text.replace("Z", "+00:00"))


def _event_timestamp(event: dict[str, object]) -> str:
    for key in ("ts_utc", "timestamp", "completed_at", "created_at", "recorded_at"):
        value = event.get(key)
        if value not in (None, ""):
            return str(value)
    payload = event.get("payload")
    if isinstance(payload, dict):
        for key in ("ts_utc", "timestamp", "completed_at", "created_at", "recorded_at"):
            value = payload.get(key)
            if value not in (None, ""):
                return str(value)
    return ""


def _is_success_value(value: object) -> bool:
    return str(value or "").strip().lower() in {
        "success",
        "succeeded",
        "pass",
        "passed",
        "proceed",
        "done",
        "approved",
        "accepted",
    }


def _is_success_event(event: dict[str, object]) -> bool:
    kind = str(event.get("kind") or "").lower()
    phase = str(event.get("phase") or "").lower()
    payload = event.get("payload")
    payload_dict = payload if isinstance(payload, dict) else {}
    if kind == "plan_finished":
        return True
    if kind == "state_transition" and str(payload_dict.get("to") or "").lower() in {
        "done",
        "executed",
        "reviewed",
        "finalized",
        "approved",
    }:
        return True
    if kind == "phase_end":
        for key in ("result", "status", "exit_kind", "recommendation", "verdict"):
            if _is_success_value(payload_dict.get(key)):
                return True
        # Some older journals record only a phase_end marker. Count gate/review
        # phase endings as success only when the payload says so; execute phase
        # endings can follow internal_error paths and must not clear failures.
        return False
    if phase == "gate" and _is_success_value(payload_dict.get("recommendation")):
        return True
    if phase == "review" and _is_success_value(payload_dict.get("verdict") or payload_dict.get("status")):
        return True
    for key in ("result", "status", "exit_kind", "recommendation", "verdict"):
        if _is_success_value(payload_dict.get(key)):
            return True
    return False


def _read_events(path: pathlib.Path) -> list[dict[str, object]]:
    events: list[dict[str, object]] = []
    try:
        raw_lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return events
    for raw in raw_lines:
        try:
            event = json.loads(raw)
        except Exception:
            continue
        if isinstance(event, dict):
            events.append(event)
    events.sort(key=lambda item: item.get("seq", 0) if isinstance(item.get("seq"), int) else 0)
    return events


def _latest_gate_event(path: pathlib.Path | None) -> dict[str, object]:
    if path is None or not path.exists():
        return {}
    for event in reversed(_read_events(path)):
        payload = event.get("payload")
        payload_dict = payload if isinstance(payload, dict) else {}
        recommendation = payload_dict.get("recommendation") or event.get("recommendation")
        if recommendation in (None, ""):
            continue
        phase = str(event.get("phase") or payload_dict.get("phase") or "").strip()
        kind = str(event.get("kind") or "").strip()
        if phase != "gate" and kind not in {"gate", "phase_end"}:
            continue
        return {
            "recommendation": recommendation,
            "kind": kind,
            "phase": phase,
            "seq": event.get("seq"),
            "timestamp": _event_timestamp(event),
        }
    return {}


def _latest_success_after_failure(
    plan_state: dict[str, object],
    events_path: pathlib.Path,
    latest_failure: dict[str, object],
) -> dict[str, object]:
    recorded_at = str(latest_failure.get("recorded_at") or "")
    if not recorded_at:
        return {}
    recorded_key = _parse_ts(recorded_at)
    candidates: list[dict[str, object]] = []
    for event in _read_events(events_path):
        if not _is_success_event(event):
            continue
        ts = _event_timestamp(event)
        if ts and _parse_ts(ts) > recorded_key:
            candidates.append(
                {
                    "source": "events.ndjson",
                    "timestamp": ts,
                    "seq": event.get("seq"),
                    "kind": event.get("kind") or "",
                    "phase": event.get("phase") or "",
                }
            )
    history = plan_state.get("history")
    if isinstance(history, list):
        for item in history:
            if not isinstance(item, dict) or not _is_success_value(item.get("result")):
                continue
            ts = str(item.get("timestamp") or item.get("completed_at") or "")
            if ts and _parse_ts(ts) > recorded_key:
                candidates.append(
                    {
                        "source": "state.history",
                        "timestamp": ts,
                        "step": item.get("step") or "",
                        "result": item.get("result") or "",
                        "artifact_hash": item.get("artifact_hash") or "",
                    }
                )
    candidates.sort(key=lambda item: (_parse_ts(item.get("timestamp")), int(item.get("seq") or 0)))
    return candidates[-1] if candidates else {}


def _stale_block_replay(plan_state: dict[str, object]) -> dict[str, object]:
    history = plan_state.get("history")
    if not isinstance(history, list) or len(history) < 2:
        return {"detected": False}
    blocked = [
        item for item in history
        if isinstance(item, dict)
        and str(item.get("result") or "").lower() == "blocked"
        and item.get("artifact_hash")
    ]
    if len(blocked) < 2:
        return {"detected": False}
    current = blocked[-1]
    current_hash = current.get("artifact_hash")
    prior_matches = [
        item for item in blocked[:-1]
        if item.get("artifact_hash") == current_hash
    ]
    if not prior_matches:
        return {"detected": False}
    try:
        duration_zero = int(current.get("duration_ms") or 0) == 0
    except (TypeError, ValueError):
        duration_zero = False
    if not duration_zero:
        return {"detected": False}
    prior = prior_matches[-1]
    repeated_tail_count = 0
    for item in reversed(history):
        if not isinstance(item, dict):
            break
        try:
            item_duration_zero = int(item.get("duration_ms") or 0) == 0
        except (TypeError, ValueError):
            item_duration_zero = False
        if (
            str(item.get("result") or "").lower() == "blocked"
            and item.get("artifact_hash") == current_hash
            and item_duration_zero
        ):
            repeated_tail_count += 1
            continue
        break
    return {
        "detected": True,
        "artifact_hash": current_hash,
        "duration_ms": current.get("duration_ms"),
        "current_timestamp": current.get("timestamp") or current.get("completed_at") or "",
        "prior_timestamp": prior.get("timestamp") or prior.get("completed_at") or "",
        "step": current.get("step") or "",
        "output_file": current.get("output_file") or "",
        "repeated_tail_count": repeated_tail_count,
        "prior_match_count": len(prior_matches),
    }


def _stale_state_analysis(
    plan_state: dict[str, object],
    events_path: pathlib.Path,
    latest_failure: dict[str, object],
) -> dict[str, object]:
    latest_success = _latest_success_after_failure(plan_state, events_path, latest_failure)
    block_replay = _stale_block_replay(plan_state)
    latest_failure_stale = bool(latest_failure and latest_success)
    stale_block = bool(block_replay.get("detected"))
    current_state = str(plan_state.get("current_state") or "").strip().lower()
    clarification = plan_state.get("clarification") if isinstance(plan_state.get("clarification"), dict) else {}
    clarification_source = str(clarification.get("source") or "").strip().lower()
    if latest_failure_stale or stale_block:
        classification = "STALE STATE"
        summary_parts = []
        if latest_failure_stale:
            summary_parts.append(
                "latest_failure was stale (predates last success at "
                f"{latest_success.get('timestamp')})"
            )
        if stale_block:
            summary_parts.append(
                "stale block replay detected "
                f"(artifact_hash={block_replay.get('artifact_hash')}, "
                f"duration_ms={block_replay.get('duration_ms')})"
            )
        recommended_action = "clear stale state and re-drive; do not dispatch dev-fix for a source bug"
    elif latest_failure:
        classification = "LIVE FAILURE"
        summary_parts = ["latest_failure is recent; no successful event was found after it"]
        failure_kind = str(latest_failure.get("kind") or "").strip().lower()
        failure_phase = str(latest_failure.get("phase") or "").strip().lower()
        failure_message = str(latest_failure.get("message") or "").strip().lower()
        if (
            failure_kind == "execution_blocked"
            or failure_phase == "execute"
            or "prerequisite-blocked tasks" in failure_message
        ):
            if "no files modified" in failure_message and "budget exhausted" in failure_message:
                recommended_action = (
                    "implement or requeue the blocked target task, then recover plan state; "
                    "do not patch Arnold source unless the engine itself prevented the task "
                    "from being retried"
                )
            else:
                recommended_action = (
                    "investigate the blocked execute task; fix the task-level target code or "
                    "plan state when the blocker is not an Arnold engine bug"
                )
        else:
            recommended_action = (
                "investigate the live failure root cause; fix Arnold source only when "
                "the evidence points to an Arnold engine bug"
            )
    elif current_state == "awaiting_human_verify":
        classification = "NO LATEST FAILURE"
        if clarification_source == "prep":
            questions = clarification.get("questions") if isinstance(clarification.get("questions"), list) else []
            summary_parts = [
                f"plan is paused for prep clarification ({len(questions)} blocking questions)"
            ]
            recommended_action = (
                "resolve the prep clarification and run `megaplan override resume-clarify`; "
                "do not redispatch dev-fix"
            )
        else:
            summary_parts = ["plan is awaiting human verification"]
            recommended_action = "resolve the human verification gate; do not redispatch dev-fix"
    else:
        classification = "NO LATEST FAILURE"
        summary_parts = ["no latest_failure is set"]
        recommended_action = "mechanical re-drive only"
    return {
        "classification": classification,
        "latest_failure_stale": latest_failure_stale,
        "latest_success_after_failure": latest_success,
        "stale_block_replay": block_replay,
        "summary": " — ".join(summary_parts),
        "recommended_action": recommended_action,
    }


def _state_mismatch_analysis(
    plan_latest_failure: dict[str, object],
    chain_state_summary: dict[str, object],
) -> dict[str, object]:
    plan_state = str(plan_latest_failure.get("current_state") or "").strip()
    chain_last_state = str(chain_state_summary.get("last_state") or "").strip()
    chain_state_path = str(chain_state_summary.get("path") or "").strip()
    plan_state_path = str(plan_latest_failure.get("state_path") or "").strip()
    chain_plan = str(chain_state_summary.get("current_plan_name") or "").strip()
    plan_name = str(plan_latest_failure.get("plan_name") or "").strip()
    has_latest_failure = bool(
        str(plan_latest_failure.get("kind") or "").strip()
        or str(plan_latest_failure.get("message") or "").strip()
        or str(plan_latest_failure.get("state") or "").strip()
    )
    detected = (
        bool(plan_state_path)
        and bool(chain_state_path)
        and plan_state == "finalized"
        and chain_last_state in {"awaiting_human", "blocked"}
        and not has_latest_failure
        and (not chain_plan or not plan_name or chain_plan == plan_name)
    )
    if not detected:
        return {"detected": False}
    return {
        "detected": True,
        "plan_state": plan_state,
        "chain_last_state": chain_last_state,
        "plan_name": plan_name or chain_plan,
        "chain_plan_name": chain_plan,
        "plan_state_path": plan_state_path,
        "chain_state_path": chain_state_path,
        "classification": "PLAN_CHAIN_STATE_MISMATCH",
        "summary": (
            f"state mismatch detected: plan={plan_state} is ready to execute, "
            f"but chain last_state={chain_last_state} is stale"
        ),
        "recommended_action": (
            "sync chain last_state from plan current_state and mechanically re-drive"
        ),
    }


def _collect_signal_values(value: object, prefix: str = "", depth: int = 0) -> list[str]:
    if depth > 4:
        return []
    signal_keys = {
        "stderr",
        "stdout",
        "output",
        "raw_output",
        "error",
        "errors",
        "exception",
        "traceback",
        "message",
        "detail",
        "details",
        "reason",
        "status",
        "exit_code",
        "returncode",
        "return_code",
        "rc",
        "command",
        "cmd",
        "args",
        "argv",
        "missing_base_ref",
        "last_error",
        "failure",
    }
    collected: list[str] = []
    if isinstance(value, dict):
        for key, child in value.items():
            child_prefix = f"{prefix}.{key}" if prefix else str(key)
            if str(key).lower() in signal_keys and child not in (None, "", [], {}):
                rendered = json.dumps(child, sort_keys=True) if isinstance(child, (dict, list)) else str(child)
                rendered = _clip_text(rendered, limit=2000)
                collected.append(f"{child_prefix}: {rendered}")
            collected.extend(_collect_signal_values(child, child_prefix, depth + 1))
    elif isinstance(value, list):
        for idx, child in enumerate(value[-25:]):
            collected.extend(_collect_signal_values(child, f"{prefix}[{idx}]", depth + 1))
    return collected


def _classify_failure(
    signals: list[str],
    latest_failure: dict[str, object],
    chain_state: dict[str, object],
    plan_runtime: dict[str, object],
) -> str:
    combined = "\n".join(signals).lower()
    kind = str(latest_failure.get("kind") or "").lower()
    phase = str(latest_failure.get("phase") or "").lower()
    last_state = str(chain_state.get("last_state") or "").lower()
    current_state = str(chain_state.get("current_state") or "").lower()
    current_plan_name = str(chain_state.get("current_plan_name") or "").strip()
    plan_current_state = str(plan_runtime.get("current_state") or "").strip().lower()
    if (
        last_state == "done"
        and current_state in {"", "done", "unknown"}
        and current_plan_name.lower() in {"", "unknown"}
        and _chain_is_complete(chain_state)
    ):
        return "chain_completed"
    if plan_current_state == "awaiting_human_verify":
        return "awaiting_human_user_action_gate"
    if (
        "no_next_step" in combined
        or "no next_step" in combined
        or "no next step" in combined
        or kind == "no_next_step"
    ):
        return "no_next_step_state_mapping_failure"
    if "unrecognized arguments" in combined or "usage:" in combined:
        return "cli_or_argument_error"
    if "couldn't find remote ref" in combined or "missing_base_ref" in combined or last_state == "missing_base_ref":
        return "git_or_branch_resolution_error"
    # Prefer the authoritative live failure shape over stale ambient log text.
    # Older critique warnings can mention missing credentials long after a later
    # execute step has blocked for an unrelated reason.
    if "awaiting_human" in combined or last_state == "awaiting_human":
        return "awaiting_human_user_action_gate"
    if "blocked" in combined or phase == "recover-blocked" or kind in {"execution_blocked", "iteration_cap", "repeated_failure_signature"}:
        return "blocked_state_or_recovery_error"
    if "timeout" in combined or "stall" in combined or kind == "stalled":
        return "timeout_or_hang"
    if (
        "git push" in combined
        and (
            "gh001" in combined
            or "large files detected" in combined
            or "exceeds github" in combined
            or "exceeds file size limit" in combined
            or "100.00 mb" in combined
        )
    ):
        return "git_large_file_push_rejection"
    if "authentication" in combined or "missing credentials" in combined or "api key" in combined or re.search(r"\b401\b", combined):
        return "authentication_or_credentials_error"
    if "credit balance is too low" in combined or "insufficient credits" in combined or "quota" in combined:
        return "billing_or_quota_error"
    if "external_error" in kind:
        return "external_dependency_error"
    if "phase_callback_failed" in kind:
        return "post_phase_callback_error"
    return "unknown_failure_mode"



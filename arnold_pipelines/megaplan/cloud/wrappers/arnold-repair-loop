#!/usr/bin/env bash
set -uo pipefail
set -m

if [[ $# -lt 3 ]]; then
  echo "usage: arnold-repair-loop <session> <workspace> <remote-spec>" >&2
  exit 64
fi

SESSION="$1"
WORKSPACE="$2"
REMOTE_SPEC="$3"

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

MARKER_DIR="${CLOUD_WATCHDOG_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
MARKER_PATH="$MARKER_DIR/$SESSION.json"
ROOT="${CLOUD_WATCHDOG_REPAIR_ROOT:-${KIMI_GOAL_OPERATOR_ROOT:-/workspace/kimi-goal-operator}}"
DATA_DIR="${CLOUD_WATCHDOG_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
REPAIR_LOCK_FILE="${CLOUD_WATCHDOG_REPAIR_LOCK_FILE:-$MARKER_DIR/repair-loop.lock}"
ARNOLD_SRC="${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}"
SYNC_BRANCH="${CLOUD_WATCHDOG_SYNC_BRANCH:-editible-install}"
PRINCIPLES_PATH="${KIMI_GOAL_PRINCIPLES_PATH:-/usr/local/share/arnold-watchdog/principles.md}"
HERMES_LAUNCHER="${CLOUD_WATCHDOG_HERMES_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
KIMI_MODEL="${KIMI_GOAL_MODEL:-kimi-k2.7-code}"
KIMI_BASE_URL="${KIMI_BASE_URL:-https://api.kimi.com/coding/v1}"
DEV_TIMEOUT="${CLOUD_WATCHDOG_DEV_FIX_TIMEOUT_SECS:-600}"
KIMI_TIMEOUT="${CLOUD_WATCHDOG_KIMI_TIMEOUT_SECS:-600}"
MECHANICAL_VERIFY_INITIAL_SECS="${CLOUD_WATCHDOG_MECHANICAL_VERIFY_INITIAL_SECS:-12}"
MECHANICAL_VERIFY_HOLD_SECS="${CLOUD_WATCHDOG_MECHANICAL_VERIFY_HOLD_SECS:-18}"
KIMI_VERIFY_INITIAL_SECS="${CLOUD_WATCHDOG_KIMI_VERIFY_INITIAL_SECS:-12}"
KIMI_VERIFY_HOLD_SECS="${CLOUD_WATCHDOG_KIMI_VERIFY_HOLD_SECS:-18}"
KIMI_MAX_TURNS="${CLOUD_WATCHDOG_KIMI_MAX_TURNS:-40}"
CODEX_REASONING_EFFORT="${CLOUD_WATCHDOG_CODEX_REASONING_EFFORT:-low}"
DISCORD_DM_BIN="${DISCORD_DM_BIN:-$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-discord-dm}"

TS="$(date -u +%Y%m%dT%H%M%SZ)"
SAFE_SESSION="$(printf '%s' "$SESSION" | tr -c 'A-Za-z0-9_.-' '-')"
RUN_DIR="$ROOT/${TS}-${SAFE_SESSION}"
LOG="$RUN_DIR/operator.log"
DATA_FILE="$DATA_DIR/${SAFE_SESSION}.repair-data.json"
NEEDS_HUMAN_FILE="$DATA_DIR/${SAFE_SESSION}.needs-human.json"

mkdir -p "$RUN_DIR" "$DATA_DIR"

CHILD_PIDS=()
CLEANUP_CHILDREN_RAN=0
cleanup_children() {
  local pid pgid
  if [[ "$CLEANUP_CHILDREN_RAN" == "1" ]]; then
    return
  fi
  CLEANUP_CHILDREN_RAN=1
  for pid in "${CHILD_PIDS[@]:-}"; do
    if kill -0 "$pid" 2>/dev/null; then
      pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
      if [[ -n "$pgid" ]] && kill -- -"$pgid" 2>/dev/null; then
        :
      else
        kill "$pid" 2>/dev/null || true
      fi
    fi
  done
  sleep 0.5
  for pid in "${CHILD_PIDS[@]:-}"; do
    pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
    if [[ -n "$pgid" ]]; then
      kill -9 -- -"$pgid" 2>/dev/null || true
    fi
    kill -9 "$pid" 2>/dev/null || true
  done
}
trap cleanup_children EXIT INT TERM HUP

log() {
  echo "[repair-loop $(date -Iseconds)] $*" | tee -a "$LOG"
}

acquire_repair_lock() {
  mkdir -p "$(dirname "$REPAIR_LOCK_FILE")"
  if ! command -v flock >/dev/null 2>&1; then
    log "flock unavailable; cannot enforce single active repair loop"
    return 1
  fi
  exec {REPAIR_LOCK_FD}> "$REPAIR_LOCK_FILE"
  if ! flock -n "$REPAIR_LOCK_FD"; then
    log "another repair loop is already active; exiting session=$SESSION"
    return 1
  fi
}

safe_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-'
}

json_field() {
  local path="$1"
  local field="$2"
  python3 - "$path" "$field" <<'PY'
import json
import sys

path, field = sys.argv[1:]
try:
    payload = json.load(open(path, encoding="utf-8"))
except Exception:
    raise SystemExit(1)
value = payload.get(field)
if value is None:
    raise SystemExit(1)
if isinstance(value, str):
    print(value)
else:
    print(json.dumps(value, sort_keys=True))
PY
}

chain_wait_status() {
  local workspace="$1"
  python3 - "$workspace" <<'PY'
import json
import pathlib
import subprocess
import sys

workspace = pathlib.Path(sys.argv[1])
plans_dir = workspace / ".megaplan" / "plans"
chain_paths = sorted(
    {
        *plans_dir.glob(".chains/*.json"),
        *workspace.glob(".megaplan/briefs/*/.megaplan/plans/.chains/*.json"),
        *(workspace / ".megaplan").glob("**/chain_state.json"),
    },
    key=lambda path: path.stat().st_mtime,
    reverse=True,
)

for path in chain_paths:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    if payload.get("last_state") != "awaiting_pr_merge":
        continue
    pr_number = payload.get("pr_number")
    if not pr_number:
        print("awaiting_pr_merge")
        raise SystemExit(0)
    try:
        proc = subprocess.run(
            ["gh", "pr", "view", str(int(pr_number)), "--json", "state"],
            cwd=workspace,
            check=False,
            capture_output=True,
            text=True,
            timeout=120,
        )
        if proc.returncode == 0:
            state = json.loads(proc.stdout or "{}").get("state", "")
            if isinstance(state, str) and state.lower() == "merged":
                print("none")
                raise SystemExit(0)
    except Exception:
        pass
    print("awaiting_pr_merge")
    raise SystemExit(0)

print("none")
PY
}

plan_process_is_alive() {
  local plan_name="$1"
  if [[ -z "$plan_name" ]]; then
    return 1
  fi
  if ps -eww -o args= \
    | grep -E "[p]ython[0-9.]*([[:space:]]+-P)?[[:space:]]+-m arnold_pipelines.megaplan (init|auto|resume|plan|prep|critique|revise|gate|finalize|execute|review)" \
    | grep -Eq -- "(--plan[=[:space:]]$plan_name|--name[=[:space:]]$plan_name.*--auto-start|--auto-start.*--name[=[:space:]]$plan_name)"; then
    return 0
  fi
  if ps -eww -o args= \
    | grep -E "[a]rnold (auto|resume)|[m]egaplan (auto|resume)" \
    | grep -Fq -- "--plan $plan_name"; then
    return 0
  fi
  return 1
}

session_health_status() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local wait_status
  if ! tmux has-session -t "$session" 2>/dev/null; then
    if [[ "$run_kind" == "chain" ]]; then
      wait_status="$(chain_wait_status "$workspace")"
      if [[ "$wait_status" != "none" ]]; then
        echo "$wait_status"
        return 0
      fi
    fi
    echo "stopped"
    return 0
  fi

  local pane log_path
  pane="$(tmux capture-pane -pt "$session" -S -120 2>/dev/null || true)"
  if printf '%s\n' "$pane" | grep -Eq 'cmd exited rc=[1-9]|error retry [0-9]+/[0-9]+'; then
    echo "retrying_failure"
    return 0
  fi

  if [[ "$run_kind" == "chain" ]]; then
    if [[ "$session" == "megaplan-chain" ]]; then
      log_path="$workspace/.megaplan/cloud-chain.log"
    else
      log_path="$workspace/.megaplan/cloud-chain-${session}.log"
    fi
    if [[ -f "$log_path" ]] && tail -80 "$log_path" 2>/dev/null | grep -Eq '"error": "invalid_spec"|invalid_spec|"error": "git_refresh_failed"|git_refresh_failed|fatal: couldn'\''t find remote ref'; then
      echo "chain_log_failure"
      return 0
    fi
    if ps -eww -o args= | grep -E "[p]ython[0-9.]*([[:space:]]+-P)?[[:space:]]+-m arnold_pipelines.megaplan chain start" | grep -F -- "--spec" | grep -Fq -- "$remote_spec"; then
      echo "alive"
      return 0
    fi
    if plan_process_is_alive "$plan_name"; then
      echo "alive"
      return 0
    fi
    wait_status="$(chain_wait_status "$workspace")"
    if [[ "$wait_status" != "none" ]]; then
      echo "$wait_status"
      return 0
    fi
  elif [[ -n "$plan_name" ]]; then
    if plan_process_is_alive "$plan_name"; then
      echo "alive"
      return 0
    fi
  fi

  echo "stopped"
}

default_plan_relaunch_command() {
  local plan_name="$1"
  local workspace="$2"
  local log_path="$workspace/.megaplan/cloud-logs/${plan_name}.log"
  printf 'if [[ -f /workspace/.cloud-hot-env ]]; then set -a; . /workspace/.cloud-hot-env; set +a; fi; cd %q && PYTHONSAFEPATH=1 PYTHONPATH=%q:${PYTHONPATH:-} MEGAPLAN_TRUSTED_CONTAINER=1 python3 -P -m arnold_pipelines.megaplan auto --plan %q --project-dir %q >> %q 2>&1' \
    "$ARNOLD_SRC" "$ARNOLD_SRC" "$plan_name" "$workspace" "$log_path"
}

resolve_relaunch_command() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local relaunch_command="${6:-}"
  if [[ -n "$relaunch_command" ]]; then
    printf '%s' "$relaunch_command"
    return 0
  fi
  if [[ "$run_kind" == "plan" ]]; then
    [[ -n "$plan_name" ]] || return 1
    default_plan_relaunch_command "$plan_name" "$workspace"
    return 0
  fi
  local log_relative
  if [[ "$session" == "megaplan-chain" ]]; then
    log_relative=".megaplan/cloud-chain.log"
  else
    log_relative=".megaplan/cloud-chain-${session}.log"
  fi
  printf 'if [[ -f /workspace/.cloud-hot-env ]]; then set -a; . /workspace/.cloud-hot-env; set +a; fi; cd %q && PYTHONSAFEPATH=1 PYTHONPATH=%q:${PYTHONPATH:-} MEGAPLAN_TRUSTED_CONTAINER=1 python3 -P -m arnold_pipelines.megaplan chain start --spec %q --project-dir %q >> %q 2>&1' \
    "$ARNOLD_SRC" "$ARNOLD_SRC" "$remote_spec" "$workspace" "$workspace/$log_relative"
}

collect_failure_context_json() {
  local workspace="$1"
  local session="$2"
  python3 - "$workspace" "$session" <<'PY'
import json
import pathlib
import sys

workspace = pathlib.Path(sys.argv[1])
session = sys.argv[2]


def _tail_text(path: pathlib.Path, lines: int = 15) -> str:
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return ""
    tail = text.splitlines()[-lines:]
    return "\n".join(tail)


def _latest_plan_state(root: pathlib.Path) -> pathlib.Path | None:
    candidates = []
    for pattern in (
        ".megaplan/plans/*/state.json",
        ".megaplan/briefs/*/.megaplan/plans/*/state.json",
    ):
        for path in root.glob(pattern):
            try:
                candidates.append((path.stat().st_mtime, path))
            except OSError:
                continue
    candidates.sort(reverse=True)
    return candidates[0][1] if candidates else None


def _latest_chain_state(root: pathlib.Path) -> pathlib.Path | None:
    chains_root = root / ".megaplan"
    candidates = set()
    candidates.update((root / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(root.glob(".megaplan/briefs/*/.megaplan/plans/.chains/*.json"))
    candidates.update(chains_root.glob("**/chain_state.json"))
    ordered = []
    for path in candidates:
        try:
            ordered.append((path.stat().st_mtime, path))
        except OSError:
            continue
    ordered.sort(reverse=True)
    return ordered[0][1] if ordered else None


log_candidates = []
session_log = workspace / ".megaplan" / f"cloud-chain-{session}.log"
default_log = workspace / ".megaplan" / "cloud-chain.log"
if session != "megaplan-chain":
    log_candidates.append(session_log)
log_candidates.append(default_log)
if session == "megaplan-chain":
    log_candidates.append(session_log)
log_path = next((path for path in log_candidates if path.exists()), None)

plan_latest_failure = {}
plan_state_path = _latest_plan_state(workspace)
if plan_state_path is not None:
    try:
        plan_state = json.loads(plan_state_path.read_text(encoding="utf-8"))
    except Exception:
        plan_state = {}
    latest_failure = plan_state.get("latest_failure") or {}
    metadata = latest_failure.get("metadata") or {}
    plan_latest_failure = {
        "plan_name": plan_state.get("name") or plan_state_path.parent.name,
        "state_path": str(plan_state_path),
        "current_state": plan_state.get("current_state") or plan_state.get("state") or "",
        "phase": latest_failure.get("phase") or plan_state.get("phase") or "",
        "iteration": plan_state.get("iteration"),
        "kind": latest_failure.get("kind") or "",
        "message": latest_failure.get("message") or "",
        "metadata": {
            "stderr": metadata.get("stderr") or "",
            "exit_code": metadata.get("exit_code"),
        },
    }

chain_state_summary = {}
chain_state_path = _latest_chain_state(workspace)
if chain_state_path is not None:
    try:
        chain_state = json.loads(chain_state_path.read_text(encoding="utf-8"))
    except Exception:
        chain_state = {}
    chain_state_summary = {
        "path": str(chain_state_path),
        "current_plan_name": chain_state.get("current_plan_name") or "",
        "current_state": chain_state.get("current_state") or "",
        "last_state": chain_state.get("last_state") or "",
        "missing_base_ref": chain_state.get("missing_base_ref"),
        "error": chain_state.get("error"),
    }

payload = {
    "mechanical_log_tail": _tail_text(log_path, lines=15) if log_path is not None else "",
    "mechanical_log_path": str(log_path) if log_path is not None else "",
    "plan_latest_failure": plan_latest_failure,
    "chain_state_summary": chain_state_summary,
}
print(json.dumps(payload, sort_keys=True))
PY
}

render_failure_summary() {
  local data_path="$1"
  python3 - "$data_path" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
payload = json.loads(path.read_text(encoding="utf-8"))
iterations = payload.get("iterations") or []
initial = payload.get("initial_facts") or {}

latest_context = None
for entry in reversed(iterations):
    if (
        entry.get("mechanical_log_tail")
        or entry.get("plan_latest_failure")
        or entry.get("chain_state_summary")
    ):
        latest_context = entry
        break
if latest_context is None:
    latest_context = initial

plan_failure = latest_context.get("plan_latest_failure") or {}
chain_state = latest_context.get("chain_state_summary") or {}
metadata = plan_failure.get("metadata") or {}
stderr = metadata.get("stderr") or plan_failure.get("stderr") or ""
stderr_lines = stderr.splitlines()[:5]
stderr_block = "\n".join(stderr_lines) if stderr_lines else "(none captured)"
log_tail = latest_context.get("mechanical_log_tail") or latest_context.get("chain_log_tail") or "(none captured)"

plan_state = (
    plan_failure.get("current_state")
    or (latest_context.get("chain_state_summary") or {}).get("current_state")
    or "unknown"
)
phase = plan_failure.get("phase") or "unknown"
iteration = plan_failure.get("iteration")
iteration_text = iteration if iteration not in (None, "") else "unknown"
kind = plan_failure.get("kind") or "unknown"
message = plan_failure.get("message") or "unknown"
chain_last_state = chain_state.get("last_state") or "unknown"
chain_current_state = chain_state.get("current_state") or "unknown"
chain_plan_name = chain_state.get("current_plan_name") or "unknown"
chain_missing_base_ref = chain_state.get("missing_base_ref")
chain_error = chain_state.get("error")
chain_notes = []
if chain_missing_base_ref:
    chain_notes.append(f"missing_base_ref={chain_missing_base_ref}")
if chain_error:
    chain_notes.append(f"error={chain_error}")
chain_notes_text = f" ({'; '.join(chain_notes)})" if chain_notes else ""

history_lines = []
for item in iterations:
    why = (
        item.get("mechanical_detail")
        or item.get("why")
        or item.get("kimi_diagnosis")
        or item.get("dev_hypothesis")
        or "n/a"
    )
    history_lines.append(
        f"- i{item.get('i')} model={item.get('dev_model') or item.get('dev_model_requested') or 'n/a'} "
        f"sha={item.get('dev_fix_sha') or 'none'} mechanical={item.get('mechanical_launch') or 'n/a'} "
        f"kimi={item.get('kimi_launch') or 'n/a'} why={why}"
    )
if not history_lines:
    history_lines.append("- none yet")

summary = "\n".join(
    [
        "## Why the chain stopped (most recent failure)",
        f"- plan state: {plan_state} / phase {phase} / iter {iteration_text}",
        f"- chain state: last_state={chain_last_state} current_state={chain_current_state} current_plan={chain_plan_name}{chain_notes_text}",
        f"- latest_failure: kind={kind} message={message}",
        "- execute error:",
        "```text",
        stderr_block,
        "```",
        "- chain log (last 15 lines):",
        "```text",
        log_tail,
        "```",
        "",
        "## Prior iterations (what was tried)",
        *history_lines,
    ]
)
print(summary)
PY
}

repair_data_init() {
  local run_kind="$1"
  local plan_name="$2"
  local relaunch_command="$3"
  local initial_health="$4"
  local marker_json source_git workspace_git chain_log watchdog_log tmux_info chain_state failure_context
  marker_json="$(cat "$MARKER_PATH" 2>/dev/null || true)"
  source_git="$(cd "$ARNOLD_SRC" 2>/dev/null && { git branch --show-current; git status --short; git log -1 --oneline; } 2>&1 || true)"
  workspace_git="$(cd "$WORKSPACE" 2>/dev/null && { git branch --show-current; git status --short; git log -1 --oneline; } 2>&1 || true)"
  chain_log="$(tail -120 "$WORKSPACE/.megaplan/cloud-chain.log" 2>/dev/null || tail -120 "$WORKSPACE/.megaplan/cloud-chain-${SESSION}.log" 2>/dev/null || true)"
  watchdog_log="$(tail -120 /workspace/watchdog.log 2>/dev/null || true)"
  tmux_info="$(tmux capture-pane -pt "$SESSION" -S -80 2>/dev/null || true)"
  chain_state="$(find "$WORKSPACE/.megaplan" -path '*/.chains/*.json' -o -name 'chain_state.json' 2>/dev/null | sort | tail -10)"
  failure_context="$(collect_failure_context_json "$WORKSPACE" "$SESSION")"
  python3 - "$DATA_FILE" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$run_kind" "$plan_name" "$ARNOLD_SRC" "$SYNC_BRANCH" "$RUN_DIR" "$relaunch_command" "$initial_health" "$marker_json" "$source_git" "$workspace_git" "$chain_log" "$watchdog_log" "$tmux_info" "$chain_state" "$failure_context" <<'PY'
import json
import sys

(
    path,
    session,
    workspace,
    spec,
    run_kind,
    plan_name,
    arnold_src,
    sync_branch,
    run_dir,
    relaunch_command,
    initial_health,
    marker_json,
    source_git,
    workspace_git,
    chain_log,
    watchdog_log,
    tmux_info,
    chain_state,
    failure_context,
) = sys.argv[1:]
failure_context_payload = json.loads(failure_context)

payload = {
    "session": session,
    "workspace": workspace,
    "spec": spec,
    "run_kind": run_kind,
    "plan_name": plan_name,
    "arnold_src": arnold_src,
    "sync_branch": sync_branch,
    "run_dir": run_dir,
    "initial_facts": {
        "relaunch_command": relaunch_command,
        "initial_health": initial_health,
        "marker_json": marker_json,
        "source_git": source_git,
        "workspace_git": workspace_git,
        "chain_log_tail": chain_log,
        "mechanical_log_tail": failure_context_payload.get("mechanical_log_tail", ""),
        "mechanical_log_path": failure_context_payload.get("mechanical_log_path", ""),
        "plan_latest_failure": failure_context_payload.get("plan_latest_failure", {}),
        "chain_state_summary": failure_context_payload.get("chain_state_summary", {}),
        "watchdog_log_tail": watchdog_log,
        "tmux_pane_tail": tmux_info,
        "chain_state_files": chain_state,
    },
    "iterations": [],
    "outcome": "repairing",
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2, sort_keys=True)
    handle.write("\n")
PY
}

repair_data_record_dev() {
  local iteration="$1"
  local requested_model="$2"
  local dispatch_model="$3"
  local fallback_reason="$4"
  local report_path="$5"
  local turn_rc="$6"
  local before_sha="$7"
  local after_sha="$8"
  python3 - "$DATA_FILE" "$iteration" "$requested_model" "$dispatch_model" "$fallback_reason" "$report_path" "$turn_rc" "$before_sha" "$after_sha" <<'PY'
import json
import pathlib
import sys

path, iteration_raw, requested_model, dispatch_model, fallback_reason, report_path, turn_rc, before_sha, after_sha = sys.argv[1:]
iteration = int(iteration_raw)
payload = json.loads(pathlib.Path(path).read_text(encoding="utf-8"))
report = {}
report_file = pathlib.Path(report_path)
if report_file.exists():
    try:
        report = json.loads(report_file.read_text(encoding="utf-8"))
    except Exception:
        report = {}

iterations = payload.setdefault("iterations", [])
while len(iterations) < iteration:
    iterations.append({"i": len(iterations) + 1})
entry = iterations[iteration - 1]
entry["i"] = iteration
entry["dev_model_requested"] = requested_model
entry["dev_model"] = dispatch_model
if fallback_reason:
    entry["dev_model_fallback"] = fallback_reason
entry["dev_turn_rc"] = int(turn_rc)
entry["dev_fix_sha"] = (
    report.get("pushed_commit")
    or report.get("commit")
    or (after_sha if after_sha and after_sha != before_sha else "")
)
entry["dev_hypothesis"] = (
    report.get("hypothesis")
    or report.get("root_cause")
    or report.get("classification")
    or ""
)
entry["dev_summary"] = (
    report.get("what_tried")
    or report.get("fix_summary")
    or report.get("source_changes")
    or ""
)
entry["dev_validation"] = report.get("validation") or []
entry["dev_report"] = report

pathlib.Path(path).write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

repair_data_record_mechanical() {
  local iteration="$1"
  local status="$2"
  local detail="$3"
  local failure_context
  failure_context="$(collect_failure_context_json "$WORKSPACE" "$SESSION")"
  python3 - "$DATA_FILE" "$iteration" "$status" "$detail" "$failure_context" <<'PY'
import json
import pathlib
import sys

path, iteration_raw, status, detail, failure_context = sys.argv[1:]
iteration = int(iteration_raw)
payload = json.loads(pathlib.Path(path).read_text(encoding="utf-8"))
failure_context_payload = json.loads(failure_context)
iterations = payload.setdefault("iterations", [])
while len(iterations) < iteration:
    iterations.append({"i": len(iterations) + 1})
entry = iterations[iteration - 1]
entry["i"] = iteration
entry["mechanical_launch"] = status
entry["mechanical_detail"] = detail
entry["mechanical_log_tail"] = failure_context_payload.get("mechanical_log_tail", "")
entry["mechanical_log_path"] = failure_context_payload.get("mechanical_log_path", "")
entry["plan_latest_failure"] = failure_context_payload.get("plan_latest_failure", {})
entry["chain_state_summary"] = failure_context_payload.get("chain_state_summary", {})
pathlib.Path(path).write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}


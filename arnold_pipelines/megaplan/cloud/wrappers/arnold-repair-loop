#!/usr/bin/env bash
set -uo pipefail
set -m

if [[ $# -lt 3 ]]; then
  echo "usage: arnold-repair-loop <session> <workspace> <remote-spec>" >&2
  exit 64
fi

SESSION="$1"
WORKSPACE="$2"
REMOTE_SPEC="$3"

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

WRAPPER_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../../../.." && pwd)"

MARKER_DIR="${CLOUD_WATCHDOG_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
MARKER_PATH="$MARKER_DIR/$SESSION.json"
ROOT="${CLOUD_WATCHDOG_REPAIR_ROOT:-${KIMI_GOAL_OPERATOR_ROOT:-/workspace/kimi-goal-operator}}"
DATA_DIR="${CLOUD_WATCHDOG_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
FINDINGS_DIR="${CLOUD_WATCHDOG_REPAIR_FINDINGS_DIR:-/workspace/repair-findings}"
FINDINGS_DOC="${CLOUD_WATCHDOG_REPAIR_FINDINGS_DOC:-$FINDINGS_DIR/persistent-problems.md}"
ARNOLD_SRC="${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}"
SYNC_BRANCH="${CLOUD_WATCHDOG_SYNC_BRANCH:-editible-install}"
PRINCIPLES_PATH="${KIMI_GOAL_PRINCIPLES_PATH:-/usr/local/share/arnold-watchdog/principles.md}"
HERMES_LAUNCHER="${CLOUD_WATCHDOG_HERMES_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
KIMI_MODEL="${KIMI_GOAL_MODEL:-kimi-k2.7-code}"
KIMI_BASE_URL="${KIMI_BASE_URL:-https://api.kimi.com/coding/v1}"
DEV_TIMEOUT="${CLOUD_WATCHDOG_DEV_FIX_TIMEOUT_SECS:-600}"
DEV_ROOT_CAUSE_TIMEOUT="${CLOUD_WATCHDOG_DEV_FIX_ROOT_CAUSE_TIMEOUT_SECS:-3600}"
KIMI_TIMEOUT="${CLOUD_WATCHDOG_KIMI_TIMEOUT_SECS:-600}"
MECHANICAL_VERIFY_INITIAL_SECS="${CLOUD_WATCHDOG_MECHANICAL_VERIFY_INITIAL_SECS:-12}"
MECHANICAL_VERIFY_HOLD_SECS="${CLOUD_WATCHDOG_MECHANICAL_VERIFY_HOLD_SECS:-18}"
KIMI_VERIFY_INITIAL_SECS="${CLOUD_WATCHDOG_KIMI_VERIFY_INITIAL_SECS:-12}"
KIMI_VERIFY_HOLD_SECS="${CLOUD_WATCHDOG_KIMI_VERIFY_HOLD_SECS:-18}"
KIMI_MAX_TURNS="${CLOUD_WATCHDOG_KIMI_MAX_TURNS:-40}"
CODEX_REASONING_EFFORT="${CLOUD_WATCHDOG_CODEX_REASONING_EFFORT:-low}"
ROOT_CAUSE_REASONING_EFFORT="${CLOUD_WATCHDOG_ROOT_CAUSE_REASONING_EFFORT:-high}"
REPAIR_RECURRENCE_MIN_DISPATCHES="${CLOUD_WATCHDOG_REPAIR_RECURRENCE_MIN_DISPATCHES:-3}"
REPAIR_RECURRENCE_WINDOW_SECS="${CLOUD_WATCHDOG_REPAIR_RECURRENCE_WINDOW_SECS:-21600}"
REPAIR_BUDGET_SECS="${CLOUD_WATCHDOG_REPAIR_BUDGET_SECS:-7200}"
REPAIR_ITERATION_MAX="${CLOUD_WATCHDOG_REPAIR_ITERATION_MAX:-3}"
DISCORD_DM_BIN="${DISCORD_DM_BIN:-$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-discord-dm}"

TS="$(date -u +%Y%m%dT%H%M%SZ)"
SAFE_SESSION="$(printf '%s' "$SESSION" | tr -c 'A-Za-z0-9_.-' '-')"
RUN_DIR="$ROOT/${TS}-${SAFE_SESSION}"
LOG="$RUN_DIR/operator.log"
DATA_FILE="$DATA_DIR/${SAFE_SESSION}.repair-data.json"
PROGRESS_FILE="$MARKER_DIR/${SAFE_SESSION}.repair-progress.json"
NEEDS_HUMAN_FILE="$DATA_DIR/${SAFE_SESSION}.needs-human.json"
REPAIR_PID_FILE="${CLOUD_WATCHDOG_REPAIR_PID_FILE:-$MARKER_DIR/${SAFE_SESSION}.repair-loop.pid}"
REPAIR_LOCK_DIR="${CLOUD_WATCHDOG_REPAIR_LOCK_DIR:-$MARKER_DIR/${SAFE_SESSION}.repair-loop.lock}"

if ! [[ "$REPAIR_BUDGET_SECS" =~ ^[0-9]+$ ]] || (( REPAIR_BUDGET_SECS <= 0 )); then
  REPAIR_BUDGET_SECS=7200
fi
if ! [[ "$REPAIR_ITERATION_MAX" =~ ^[0-9]+$ ]] || (( REPAIR_ITERATION_MAX <= 0 )); then
  REPAIR_ITERATION_MAX=3
fi
REPAIR_STARTED_AT_EPOCH="$(date -u +%s)"
REPAIR_DEADLINE_EPOCH="$((REPAIR_STARTED_AT_EPOCH + REPAIR_BUDGET_SECS))"

mkdir -p "$RUN_DIR" "$DATA_DIR"

CHILD_PIDS=()
CLEANUP_CHILDREN_RAN=0
REPAIR_LOCK_DIR_OWNED=0
REPAIR_PID_FILE_OWNED=0
REPAIR_SHUTDOWN_RAN=0
cleanup_children() {
  local pid pgid
  if [[ "$CLEANUP_CHILDREN_RAN" == "1" ]]; then
    return
  fi
  CLEANUP_CHILDREN_RAN=1
  for pid in "${CHILD_PIDS[@]:-}"; do
    if kill -0 "$pid" 2>/dev/null; then
      pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
      if [[ -n "$pgid" ]] && kill -- -"$pgid" 2>/dev/null; then
        :
      else
        kill "$pid" 2>/dev/null || true
      fi
    fi
  done
  sleep 0.5
  for pid in "${CHILD_PIDS[@]:-}"; do
    pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
    if [[ -n "$pgid" ]]; then
      kill -9 -- -"$pgid" 2>/dev/null || true
    fi
    kill -9 "$pid" 2>/dev/null || true
  done
}

log() {
  local message
  message="$(redact_inline_text "$*")"
  echo "[repair-loop $(date -Iseconds)] $message" | tee -a "$LOG"
}

redact_inline_text() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$1" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

print(redact_text(sys.argv[1]), end="")
PY
}

redact_file_in_place() {
  local path="${1:-}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$path" <<'PY'
from pathlib import Path
import sys

from arnold_pipelines.megaplan.cloud.redact import redact_text

path = Path(sys.argv[1])
path.write_text(redact_text(path.read_text(encoding="utf-8")), encoding="utf-8")
PY
}

prepare_repair_agent_exec_env() {
  # Repair prompts can include large summarized incident context. If allexport
  # leaks in from the parent shell or sourced hot env, those locals become
  # exported environment strings and Linux can reject execve with E2BIG before
  # the repair agent starts.
  set +a
  export -n failure_summary chain_health_block recurrence_block mode_tasks relaunch_command 2>/dev/null || true
}

entry_target_missing_reason() {
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$SESSION" "$MARKER_DIR" "$DATA_DIR" "$ARNOLD_SRC" <<'PY'
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.current_target import resolve_current_target
from arnold_pipelines.megaplan.cloud.source_initiative_repair import source_initiative_restore_available

session, marker_dir, repair_data_dir, arnold_src = sys.argv[1:]
record = resolve_current_target(
    session,
    marker_dir=marker_dir,
    repair_data_dir=repair_data_dir,
)
active_step = record.get("active_step_heartbeat")
if isinstance(active_step, dict) and active_step.get("active"):
    raise SystemExit(0)
if str(record.get("authoritative_source") or "").strip() == "live_sibling_session":
    raise SystemExit(0)
sibling_sessions = record.get("sibling_sessions") if isinstance(record.get("sibling_sessions"), list) else []
if any(
    isinstance(item, dict) and str(item.get("live_status") or "").strip() == "alive"
    for item in sibling_sessions
):
    raise SystemExit(0)
current_refs = record.get("current_refs") if isinstance(record.get("current_refs"), dict) else {}
run_kind = str(current_refs.get("run_kind") or "").strip().lower()
workspace = str(current_refs.get("workspace") or "").strip()
remote_spec = str(current_refs.get("remote_spec") or "").strip()
stale_evidence = record.get("stale_evidence") if isinstance(record.get("stale_evidence"), list) else []
stale_kinds = {
    str(item.get("kind") or "").strip()
    for item in stale_evidence
    if isinstance(item, dict)
}
plan_state = record.get("plan_state") if isinstance(record.get("plan_state"), dict) else {}
chain_state = record.get("chain_state") if isinstance(record.get("chain_state"), dict) else {}
chain_log = record.get("chain_log") if isinstance(record.get("chain_log"), dict) else {}
has_live_artifacts = (
    bool(plan_state.get("present"))
    or bool(chain_state.get("present"))
    or bool(chain_log.get("present"))
)
can_restore_source_initiative = (
    workspace
    and remote_spec
    and not has_live_artifacts
    and source_initiative_restore_available(
        workspace=pathlib.Path(workspace),
        remote_spec=pathlib.Path(remote_spec),
        arnold_src=pathlib.Path(arnold_src),
    )
)
if "workspace_missing" in stale_kinds:
    if can_restore_source_initiative:
        raise SystemExit(0)
    print("workspace_missing")
elif (
    "spec_missing" in stale_kinds
    and run_kind in {"chain", "epic_chain"}
    and not has_live_artifacts
):
    if can_restore_source_initiative:
        raise SystemExit(0)
    print("stale_marker")
PY
}


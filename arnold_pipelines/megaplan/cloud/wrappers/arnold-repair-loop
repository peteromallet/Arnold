repair_agent_workdir() {
  # The repair target is the cloud session workspace. Most live
  # execution_blocked incidents are target-repo task failures, and launching the
  # agent from /workspace/arnold biases it into an engine-only repair. Arnold
  # engine/superfixer fixes remain available via the explicit $ARNOLD_SRC
  # prompt contract and PYTHONPATH below.
  if [[ -d "$WORKSPACE" ]]; then
    printf '%s\n' "$WORKSPACE"
  else
    printf '%s\n' "$ARNOLD_SRC"
  fi
}

require_investigation_before_mutation() {
  require_repair_lock_held
  local mutation_label="${1:-mutation}"
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" "$MEGAPLAN_SUPERVISOR_PYTHON" -P - \
    "$INVESTIGATION_CONTEXT_PATH" "$INVESTIGATOR_RECEIPT_PATH" "$INVESTIGATION_CONTEXT_DIGEST" "$mutation_label" <<'PY' >>"$LOG" 2>&1
import hashlib
import json
import sys
from pathlib import Path

from arnold_pipelines.megaplan.cloud.repair_goal import capture_checkpoint
from arnold_pipelines.megaplan.cloud.repair_investigation import validate_investigator_receipt

context_path, receipt_path, expected_digest, mutation_label = sys.argv[1:]
context = json.loads(Path(context_path).read_text(encoding="utf-8"))
receipt = json.loads(Path(receipt_path).read_text(encoding="utf-8"))
validated = validate_investigator_receipt(receipt, expected_context_digest=expected_digest)
recomputed = hashlib.sha256(json.dumps(
    {key: value for key, value in context.items() if key != "context_digest"},
    sort_keys=True, separators=(",", ":"), default=str,
).encode("utf-8")).hexdigest()
if context.get("context_digest") != expected_digest or recomputed != expected_digest:
    raise SystemExit("investigation context digest changed before mutation")
fresh = capture_checkpoint(
    workspace=context.get("workspace") or ".",
    plan_name=str((context.get("current") or {}).get("plan_name") or ""),
    remote_spec=str(context.get("remote_spec") or ""),
)
investigated = context.get("current") or {}
for field in ("plan_name", "target_stage", "plan_state", "latest_failure"):
    if fresh.get(field) != investigated.get(field):
        raise SystemExit(f"target evidence changed after investigation: {field}")
fresh_worker = fresh.get("active_worker") or {}
investigated_worker = investigated.get("active_worker") or {}
for field in ("run_id", "worker_pid"):
    if fresh_worker.get(field) != investigated_worker.get(field):
        raise SystemExit(f"target worker custody changed after investigation: {field}")
if validated.get("target_kind") != "l1_repair_target":
    raise SystemExit("investigation target kind does not authorize L1 mutation")
if validated.get("recommended_action") in {"preserve_live", "replan"}:
    raise SystemExit("investigator handoff does not authorize mutation")
target = validated.get("safe_repair_target") or {}
if target.get("kind") == "none":
    raise SystemExit("investigator handoff has no safe repair target")
print(json.dumps({
    "mutation_label": mutation_label,
    "receipt_digest": validated.get("receipt_digest"),
    "recommended_action": validated.get("recommended_action"),
    "safe_repair_target": target,
}, sort_keys=True))
PY
}


mechanical_launch_step() {
  require_investigation_before_mutation "mechanical-launch"
  require_repair_lock_held
  ensure_repair_budget_available "mechanical-relaunch-$1"
  local iteration="$1"
  local session="$2"
  local workspace="$3"
  local remote_spec="$4"
  local run_kind="$5"
  local plan_name="$6"
  local relaunch_command="$7"
  local quoted_command launch_script safe detail health control_result control_status control_action control_blocker_cleared

  control_result="$(repair_goal_control_snapshot "pre-mechanical-relaunch-$iteration")" || {
    echo "failed:repair_goal_control_unavailable"
    return 1
  }
  IFS=$'\t' read -r control_status control_action control_blocker_cleared <<< "$(
    python3 -c 'import json,sys; d=json.load(sys.stdin); e=d.get("evaluation") or {}; print("\t".join((str(d.get("status") or ""), str(e.get("control_action") or ""), "true" if e.get("blocker_cleared") else "false")))' <<< "$control_result"
  )"
  if [[ "$control_status" == "active" && "$control_action" == "preserve_live" ]]; then
    # mechanical_launch_step is consumed through command substitution. Keep
    # diagnostics off stdout so the caller receives one exact status token.
    log "mechanical relaunch fenced: correct target worker is alive and fresh session=$session iteration=$iteration" >&2
    echo "preserved:live_progress"
    return 0
  fi
  if [[ "$control_status" == "active" && "$control_action" == "replan" ]]; then
    log "mechanical relaunch fenced: deterministic owner circuit requires replan session=$session iteration=$iteration" >&2
    echo "failed:replan_required"
    return 1
  fi
  if [[ "$control_status" == "active" && "$control_blocker_cleared" == "true" ]] && {
    { [[ "$run_kind" == "chain" ]] && chain_process_is_alive "$remote_spec"; } ||
    { [[ -n "$plan_name" ]] && plan_process_is_alive "$plan_name"; }
  }; then
    log "mechanical relaunch fenced: matching target runner is alive in a blocker-cleared transition session=$session iteration=$iteration" >&2
    echo "preserved:runner_transition"
    return 0
  fi

  quoted_command="$(resolve_relaunch_command "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name" "$relaunch_command")" || {
    echo "failed:missing_relaunch_command"
    return 1
  }
  kill_tmux_session_if_present "$session"
  kill_matching_runner_processes "$session" "$remote_spec" "$run_kind" "$plan_name"
  safe="$(safe_name "$session")"
  launch_script="$(mktemp)"
  cat > "$launch_script" <<EOF
#!/usr/bin/env bash
set -euo pipefail
# Unlink only after this child has opened the script.  Removing it in the
# parent immediately after tmux new-session -d races tmux startup and can
# turn a valid canonical relaunch into a false failed:stopped result.
rm -f -- "\${BASH_SOURCE[0]}"
cd $(printf '%q' "$workspace")
export ARNOLD_REPAIR_QUEUE_ROOT=$(printf '%q' "${ARNOLD_REPAIR_QUEUE_ROOT:-$REPAIR_QUEUE_DIR}")
export ARNOLD_REPAIR_MARKER_DIR=$(printf '%q' "$MARKER_DIR")
export ARNOLD_REPAIR_SESSION=$(printf '%q' "$session")
export ARNOLD_REPAIR_RUN_KIND=$(printf '%q' "$run_kind")
exec /usr/local/bin/arnold-supervise "watchdog-$safe" bash -lc "$quoted_command"
EOF
  chmod +x "$launch_script"
  if ! tmux new-session -d -s "$session" -c "$workspace" "bash '$launch_script'"; then
    rm -f "$launch_script"
    echo "failed:tmux_launch_failed"
    return 1
  fi
  health="$(verify_started_and_holding "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name" "$MECHANICAL_VERIFY_INITIAL_SECS" "$MECHANICAL_VERIFY_HOLD_SECS")" || {
    detail="$health"
    kill_tmux_session_if_present "$session"
    echo "failed:$detail"
    return 1
  }
  echo "running"
}

repair_recurrence_prepare_attempt() {
  require_repair_lock_held
  ensure_repair_budget_available "recurrence-prepare-$1"
  local iteration="$1"
  local requested_model="$2"
  local dispatch_model="$3"
  local failure_context failure_context_file rc
  failure_context="$(collect_failure_context_json "$WORKSPACE" "$SESSION" "$RUN_KIND" "$PLAN_NAME")"
  failure_context_file="$(mktemp)"
  printf '%s' "$failure_context" > "$failure_context_file"
  PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$PROGRESS_FILE" "$failure_context_file" "$iteration" "$requested_model" "$dispatch_model" "$REPAIR_RECURRENCE_MIN_DISPATCHES" "$REPAIR_RECURRENCE_WINDOW_SECS" "${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}" "${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}" <<'PY'
import datetime as dt
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud import repair_recurrence

(
    data_path_raw,
    progress_path_raw,
    failure_context_path_raw,
    iteration_raw,
    requested_model,
    dispatch_model,
    min_dispatches_raw,
    window_seconds_raw,
    request_id,
    blocker_id,
) = sys.argv[1:]
data_path = pathlib.Path(data_path_raw)
progress_path = pathlib.Path(progress_path_raw)
failure_context = json.loads(pathlib.Path(failure_context_path_raw).read_text(encoding="utf-8"))
payload = json.loads(data_path.read_text(encoding="utf-8"))
try:
    progress_payload = json.loads(progress_path.read_text(encoding="utf-8"))
except Exception:
    progress_payload = {}

iteration = int(iteration_raw)
min_dispatches = max(int(min_dispatches_raw), 1)
window_seconds = max(int(window_seconds_raw), 0)
dispatched_at = dt.datetime.now(dt.timezone.utc).isoformat()
signature = repair_recurrence.build_problem_signature(failure_context)
advancement = repair_recurrence.build_advancement_snapshot(
    failure_context,
    run_kind=str(payload.get("run_kind") or ""),
    workspace=str(payload.get("workspace") or failure_context.get("workspace") or ""),
    logger=lambda message: print(f"repair_recurrence: {message}", file=sys.stderr),
)
session_snapshot = repair_recurrence.update_session_repair_snapshot(
    progress_payload,
    advancement,
    dispatched_at=dispatched_at,
    min_dispatches=min_dispatches,
    window_seconds=window_seconds,
)
recurrence = repair_recurrence.evaluate_recurrence(
    signature,
    payload.get("attempts") if isinstance(payload.get("attempts"), list) else [],
    session_snapshot,
)
attempt_id = int(payload.get("attempt_counter") or 0) + 1
payload["attempt_counter"] = attempt_id
payload["current_attempt_id"] = attempt_id
payload["current_failure_context"] = failure_context
payload["current_signature"] = signature
payload["current_advancement_snapshot"] = advancement
dispatch_request_id = str(request_id or payload.get("request_id") or "").strip()
dispatch_blocker_id = str(blocker_id or payload.get("blocker_id") or "").strip()
payload["request_id"] = dispatch_request_id or payload.get("request_id")
payload["blocker_id"] = dispatch_blocker_id or payload.get("blocker_id")
payload["current_recurrence"] = {
    **recurrence,
    "attempt_id": attempt_id,
    "iteration": iteration,
    "requested_model": requested_model,
    "dispatch_model": dispatch_model,
    "dispatched_at": dispatched_at,
    "root_cause_mode": bool(recurrence.get("detected")),
    "request_id": dispatch_request_id,
    "blocker_id": dispatch_blocker_id,
}
payload["run_recurrence_detected"] = bool(payload.get("run_recurrence_detected")) or bool(recurrence.get("detected"))
repair_recurrence.atomic_write_json(data_path, payload)
repair_recurrence.atomic_write_json(progress_path, session_snapshot)
breaker = 1 if recurrence.get("deterministic_failure_breaker") else 0
print(f"{attempt_id}\t{1 if recurrence.get('detected') else 0}\t{breaker}")
PY
  rc=$?
  rm -f "$failure_context_file"
  return "$rc"
}

render_recurrence_block() {
  python3 - "$DATA_FILE" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
payload = json.loads(path.read_text(encoding="utf-8"))
recurrence = payload.get("current_recurrence") or {}
if not recurrence.get("detected"):
    raise SystemExit(0)
attempts = payload.get("attempts") if isinstance(payload.get("attempts"), list) else []
matching_ids = {
    int(item)
    for item in (recurrence.get("layer1") or {}).get("matching_attempt_ids") or []
    if str(item).strip()
}
if matching_ids:
    relevant = [
        item
        for item in attempts
        if isinstance(item, dict) and int(item.get("attempt_id") or 0) in matching_ids
    ]
else:
    take = max(int((recurrence.get("layer2") or {}).get("no_advance_dispatch_count") or 1) - 1, 1)
    relevant = [item for item in attempts if isinstance(item, dict)][-take:]
signature = recurrence.get("problem_signature") or {}
signature_bits = []
for key in (
    "failure_kind",
    "current_state",
    "phase_or_step",
    "milestone_or_plan",
    "gate_recommendation",
    "blocked_task_id",
):
    value = str(signature.get(key) or "").strip() or "-"
    signature_bits.append(f"{key}={value}")
print("## RECURRENCE EVIDENCE")
print(
    "- This is attempt "
    f"{recurrence.get('attempt_number')} for the same controlled-field symptom (recurrence detected)."
)
layer1 = recurrence.get("layer1") or {}
layer2 = recurrence.get("layer2") or {}
if layer1.get("detected"):
    print(
        "- Layer 1 fired: the same controlled-field problem signature returned after "
        f"{layer1.get('repeat_count')} prior repair dispatch(es)."
    )
if layer2.get("detected"):
    print(
        "- Layer 2 fired: the session absorbed "
        f"{layer2.get('no_advance_dispatch_count')} repair dispatches within "
        f"{layer2.get('window_seconds')} seconds with no milestone/state advancement."
    )
print("- The symptom came back despite these prior fixes:")
print("- Recurrence means the prior attempts may have treated symptoms, not the cause.")
print(f"- Controlled signature: `({' ; '.join(signature_bits)})`")
print("- Prior fixes for this problem:")
if not relevant:
    print("- none captured")
for item in relevant[-4:]:
    model = item.get("dev_model") or item.get("dev_model_requested") or "n/a"
    attempted = item.get("dev_summary") or "n/a"
    dev_report = item.get("dev_report") if isinstance(item.get("dev_report"), dict) else {}
    if attempted == "n/a" and dev_report:
        attempted = dev_report.get("what_tried") or dev_report.get("fix_summary") or "n/a"
    commit = item.get("dev_fix_sha") or "none"
    conclusion = item.get("dev_hypothesis") or item.get("why") or item.get("kimi_diagnosis") or "n/a"
    print(
        f"- attempt {item.get('attempt_id') or item.get('i') or '?'}: "
        f"model={model} what_tried={attempted} commit={commit} conclusion={conclusion}"
    )
PY
}


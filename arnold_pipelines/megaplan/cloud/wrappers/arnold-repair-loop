ensure_repair_goal_custody() {
  local blocker_id request_id result
  blocker_id="${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}"
  request_id="${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}"
  if [[ -z "$blocker_id" || -z "$request_id" ]]; then
    log "durable repair goal custody missing request/blocker identity session=$SESSION request_present=$([[ -n "$request_id" ]] && printf yes || printf no) blocker_present=$([[ -n "$blocker_id" ]] && printf yes || printf no)"
    return 1
  fi
  result="$(
    PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" "$MEGAPLAN_SUPERVISOR_PYTHON" -P -m \
      arnold_pipelines.megaplan.cloud.repair_goal ensure \
      --marker-dir "$MARKER_DIR" \
      --session "$SESSION" \
      --workspace "$WORKSPACE" \
      --remote-spec "$REMOTE_SPEC" \
      --plan-name "$PLAN_NAME" \
      --blocker-id "$blocker_id" \
      --request-id "$request_id" \
      --owner-run-id "${ARNOLD_MANAGED_AGENT_RUN_ID:-}" \
      --owner-manifest-path "${ARNOLD_MANAGED_AGENT_MANIFEST:-}"
  )" || return 1
  IFS=$'\t' read -r ARNOLD_REPAIR_GOAL_ID ARNOLD_REPAIR_GOAL_PATH ARNOLD_REPAIR_CHECKPOINT_DIGEST <<< "$(
    python3 -c 'import json,sys; d=json.load(sys.stdin); print("\t".join(str(d.get(k) or "") for k in ("goal_id","goal_path","checkpoint_digest")))' <<< "$result"
  )"
  if [[ -z "$ARNOLD_REPAIR_GOAL_ID" || -z "$ARNOLD_REPAIR_GOAL_PATH" || -z "$ARNOLD_REPAIR_CHECKPOINT_DIGEST" ]]; then
    log "durable repair goal custody could not be established session=$SESSION"
    return 1
  fi
  export ARNOLD_REPAIR_GOAL_ID ARNOLD_REPAIR_GOAL_PATH ARNOLD_REPAIR_CHECKPOINT_DIGEST
  log "durable repair goal attached session=$SESSION goal_id=$ARNOLD_REPAIR_GOAL_ID checkpoint=$ARNOLD_REPAIR_CHECKPOINT_DIGEST path=$ARNOLD_REPAIR_GOAL_PATH"
}


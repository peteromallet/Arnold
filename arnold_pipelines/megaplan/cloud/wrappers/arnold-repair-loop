repair_target_completion_status() {
  local workspace="$1"
  local run_kind="$2"
  local plan_name="${3:-}"
  PYTHONPATH="${WRAPPER_REPO_ROOT:-$ARNOLD_SRC}:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$workspace" "$run_kind" "$plan_name" "$REMOTE_SPEC" "$SESSION" "${MARKER_DIR:-/workspace/.megaplan/cloud-sessions}" "$ARNOLD_SRC" <<'PY'
import hashlib
import json
import pathlib
import sys

workspace = pathlib.Path(sys.argv[1])
run_kind = sys.argv[2]
plan_name = sys.argv[3]
remote_spec = pathlib.Path(sys.argv[4]) if len(sys.argv) > 4 and sys.argv[4] else None
session = sys.argv[5] if len(sys.argv) > 5 else ""
marker_dir = pathlib.Path(sys.argv[6]) if len(sys.argv) > 6 and sys.argv[6] else pathlib.Path("/workspace/.megaplan/cloud-sessions")
arnold_src = pathlib.Path(sys.argv[7]) if len(sys.argv) > 7 and sys.argv[7] else pathlib.Path("/workspace/arnold")

def load_json(path: pathlib.Path | None) -> dict[str, object]:
    if path is None:
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}

def _resolve_remote_spec(root: pathlib.Path, path: pathlib.Path | None) -> pathlib.Path | None:
    if path is None:
        return None
    candidates = [path]
    if not path.is_absolute():
        candidates.append(root / path)
    for candidate in candidates:
        try:
            resolved = candidate.resolve()
        except OSError:
            resolved = candidate
        if resolved.exists():
            return resolved
    return candidates[-1]

def spec_milestone_count(root: pathlib.Path, spec_path: pathlib.Path | None) -> int:
    resolved_spec = _resolve_remote_spec(root, spec_path)
    candidates = [resolved_spec] if resolved_spec is not None and resolved_spec.exists() else []
    candidates.extend(sorted(root.glob(".megaplan/initiatives/**/chain.yaml")))
    for path in candidates:
        try:
            count = 0
            in_milestones = False
            for raw in path.read_text(encoding="utf-8").splitlines():
                stripped = raw.strip()
                if stripped == "milestones:":
                    in_milestones = True
                    continue
                if in_milestones and stripped and not raw.startswith((" ", "-")):
                    break
                if in_milestones and stripped.startswith("- label:"):
                    count += 1
            if count:
                return count
        except Exception:
            continue
    return 0

def candidate_plan_states(root: pathlib.Path) -> list[pathlib.Path]:
    candidates: list[tuple[float, pathlib.Path]] = []
    for pattern in (
        ".megaplan/plans/*/state.json",
        ".megaplan/initiatives/*/.megaplan/plans/*/state.json",
    ):
        for path in root.glob(pattern):
            try:
                candidates.append((path.stat().st_mtime, path))
            except OSError:
                continue
    candidates.sort(reverse=True)
    return [path for _, path in candidates]

def latest_chain_state(root: pathlib.Path) -> pathlib.Path | None:
    resolved_spec = _resolve_remote_spec(root, remote_spec)
    if resolved_spec is not None:
        try:
            digest = hashlib.sha1(str(resolved_spec.resolve()).encode("utf-8")).hexdigest()[:12]
        except OSError:
            digest = hashlib.sha1(str(resolved_spec).encode("utf-8")).hexdigest()[:12]
        for candidate in (
            root / ".megaplan" / "plans" / ".chains" / f"{resolved_spec.stem}-{digest}.json",
            resolved_spec.parent / ".megaplan" / "plans" / ".chains" / f"{resolved_spec.stem}-{digest}.json",
        ):
            if candidate.exists():
                return candidate
    candidates = set()
    candidates.update((root / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(root.glob(".megaplan/initiatives/*/.megaplan/plans/.chains/*.json"))
    candidates.update((root / ".megaplan").glob("**/chain_state.json"))
    ordered: list[tuple[float, pathlib.Path]] = []
    for path in candidates:
        try:
            ordered.append((path.stat().st_mtime, path))
        except OSError:
            continue
    ordered.sort(reverse=True)
    return ordered[0][1] if ordered else None

def resolve_plan_state(root: pathlib.Path, preferred_name: str) -> pathlib.Path | None:
    candidates = candidate_plan_states(root)
    if preferred_name:
        preferred = [path for path in candidates if path.parent.name == preferred_name]
        if preferred:
            return preferred[0]
        return None
    return candidates[0] if candidates else None

def is_terminal_plan(plan_state: dict[str, object]) -> tuple[bool, str]:
    current_state = str(plan_state.get("current_state") or plan_state.get("state") or "").strip().lower()
    if current_state in {"done", "complete"}:
        return True, f"plan_state={current_state}"
    return False, current_state

def chain_completion_reason(chain_state: dict[str, object]) -> str:
    last_state = str(chain_state.get("last_state") or "").strip().lower()
    milestones = chain_state.get("milestones")
    milestones = milestones if isinstance(milestones, list) else []
    completed = chain_state.get("completed")
    completed = completed if isinstance(completed, list) else []
    milestone_count = len(milestones) or spec_milestone_count(workspace, remote_spec)
    completed_count = len(completed)
    current_idx = chain_state.get("current_milestone_index")
    try:
        current_idx_int = int(current_idx)
    except (TypeError, ValueError):
        current_idx_int = None
    if milestone_count and current_idx_int is not None and current_idx_int >= milestone_count:
        return f"current_milestone_index={current_idx_int} past_last_milestone={milestone_count - 1}"
    milestone_labels = [
        str(item.get("label") or item.get("id") or "").strip()
        for item in milestones
        if isinstance(item, dict)
    ]
    completed_labels = {
        str(item.get("label") or item.get("id") or item.get("plan") or "").strip()
        for item in completed
        if isinstance(item, dict)
    }
    milestone_labels = [label for label in milestone_labels if label]
    if milestone_labels and all(label in completed_labels for label in milestone_labels):
        return f"all_milestones_completed={len(milestone_labels)}/{milestone_count}"
    if milestone_count and completed_count >= milestone_count:
        return f"completed_entries={completed_count}/{milestone_count}"
    if last_state in {"done", "complete"}:
        return ""
    return ""

def manifest_completion_reason(root: pathlib.Path, spec_path: pathlib.Path | None) -> tuple[str, pathlib.Path | None]:
    resolved_spec = _resolve_remote_spec(root, spec_path)
    if resolved_spec is None:
        return "", None
    manifest_path = resolved_spec.parent / "completion-manifest.json"
    manifest = load_json(manifest_path)
    if str(manifest.get("schema") or "").strip() != "arnold.megaplan.chain_completion_manifest.v1":
        return "", manifest_path
    milestones = manifest.get("milestones")
    if not isinstance(milestones, list) or not milestones:
        return "", manifest_path
    terminal = {"done", "complete", "completed"}
    statuses = [
        str(item.get("status") or "").strip().lower()
        for item in milestones
        if isinstance(item, dict)
    ]
    if len(statuses) != len(milestones) or any(status not in terminal for status in statuses):
        return "", manifest_path
    return f"completion_manifest_all_milestones_done={len(statuses)}/{len(milestones)}", manifest_path

def chain_health_blocks_terminal_shortcut() -> bool:
    if not session:
        return False
    payload = load_json(marker_dir / f"{session}.chain-health.progress.json")
    if payload.get("chain_complete") is not False:
        return False
    try:
        completed_count = int(payload.get("completed_count") or 0)
    except Exception:
        completed_count = 0
    try:
        milestone_count = int(payload.get("milestone_count") or 0)
    except Exception:
        milestone_count = 0
    pr_state = str(payload.get("pr_state") or "").strip().lower()
    if milestone_count and completed_count < milestone_count:
        return True
    if pr_state and pr_state not in {"merged", "closed"}:
        return True
    return True


exit_if_repair_target_complete() {
  local phase="$1"
  ensure_repair_budget_available "state-inspection-$phase"
  local complete_flag scope reason chain_path plan_path plan_state
  IFS=$'\t' read -r complete_flag scope reason chain_path plan_path plan_state <<< "$(repair_target_completion_status "$WORKSPACE" "$RUN_KIND" "$PLAN_NAME")"
  if [[ "${complete_flag:-0}" != "1" ]]; then
    return 0
  fi
  if [[ -f "$DATA_FILE" ]]; then
    repair_data_set_outcome "complete"
  fi
  clear_repair_markers
  if [[ "$scope" == "stale_marker" ]]; then
    rm -f "$MARKER_PATH" 2>/dev/null || true
    log "stale marker retired; no repair needed session=$SESSION phase=$phase reason=$reason marker_path=${MARKER_PATH:-n/a}"
  elif [[ "$scope" == "chain" ]]; then
    log "chain already complete; no repair needed session=$SESSION phase=$phase reason=$reason chain_state_path=${chain_path:-n/a} plan_state=${plan_state:-unknown} plan_state_path=${plan_path:-n/a}"
  else
    log "plan already complete; no repair needed session=$SESSION phase=$phase reason=$reason plan_state_path=${plan_path:-n/a}"
  fi
  exit 0
}

# Mirror of the pre-loop INITIAL_HEALTH=="alive" bail (see ~4673), but callable
# at iteration boundaries and post-loop. Once the target is back and emitting
# fresh activity, ordinary repair should treat that as terminal success.
exit_if_repair_target_recovered() {
  local phase="$1"
  local health forced_reason
  health="$(session_health_status "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME")"
  if [[ "$health" != "alive" ]]; then
    return 0
  fi
  forced_reason="$(marker_requires_repair_despite_alive || true)"
  if [[ -n "$forced_reason" ]]; then
    log "repair target alive at $phase but marker requires repair session=$SESSION reason=$forced_reason"
    return 0
  fi
  repair_data_set_outcome "live_with_fresh_activity"
  log "repair target has fresh activity at $phase; verified recovery session=$SESSION"
  exit 0
}

verify_started_and_holding() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="$4"
  local plan_name="$5"
  local initial_secs="$6"
  local hold_secs="$7"
  local health first_health second_health initial_sleep hold_sleep

  initial_sleep="$(cap_timeout_to_repair_budget "$initial_secs" "verify-$session-initial-wait")"
  sleep "$initial_sleep"
  ensure_repair_budget_available "verify-$session-initial-health"
  first_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$first_health" != "alive" ]]; then
    echo "$first_health"
    return 1
  fi
  hold_sleep="$(cap_timeout_to_repair_budget "$hold_secs" "verify-$session-hold-wait")"
  sleep "$hold_sleep"
  ensure_repair_budget_available "verify-$session-hold-health"
  second_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$second_health" == "alive" ]]; then
    echo "alive"
    return 0
  fi
  echo "$second_health"
  return 1
}


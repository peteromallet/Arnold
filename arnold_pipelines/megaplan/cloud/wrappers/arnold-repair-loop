repair_loop_pid_matches_session() {
  local pid="$1"
  local session="${2:-}"
  python3 - "$pid" "$session" <<'PY'
import os
import pathlib
import shlex
import subprocess
import sys

pid_text, session = sys.argv[1:]
try:
    pid = int(pid_text)
except (TypeError, ValueError):
    raise SystemExit(1)
if pid <= 0:
    raise SystemExit(1)

def parse_args() -> list[str]:
    cmdline_path = pathlib.Path(f"/proc/{pid}/cmdline")
    if cmdline_path.exists():
        raw = cmdline_path.read_bytes()
        return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]
    proc = subprocess.run(
        ["ps", "-ww", "-o", "args=", "-p", str(pid)],
        check=False,
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        return []
    text = proc.stdout.strip()
    if not text:
        return []
    try:
        return shlex.split(text)
    except ValueError:
        return text.split()

args = parse_args()
if not args:
    raise SystemExit(1)

def match_at(idx: int) -> bool:
    if idx >= len(args):
        return False
    base = os.path.basename(args[idx])
    if base != "arnold-repair-loop":
        return False
    if not session:
        return True
    return idx + 1 < len(args) and args[idx + 1] == session

for idx in range(len(args)):
    if match_at(idx):
        raise SystemExit(0)
    base = os.path.basename(args[idx])
    if base in {"bash", "sh"} and match_at(idx + 1):
        raise SystemExit(0)

raise SystemExit(1)
PY
}

find_live_repair_loop_for_session() {
  local session="${1:-$SESSION}"
  python3 - "$session" "$$" <<'PY'
import os
import pathlib
import sys

session, self_pid_text = sys.argv[1:]
try:
    self_pid = int(self_pid_text)
except Exception:
    self_pid = -1
excluded_pids = {self_pid, os.getppid()}


def parse_args(pid: int) -> list[str]:
    try:
        raw = pathlib.Path(f"/proc/{pid}/cmdline").read_bytes()
    except Exception:
        return []
    return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]


def matches(args: list[str]) -> bool:
    def match_at(idx: int) -> bool:
        if idx >= len(args):
            return False
        base = os.path.basename(args[idx])
        if base != "arnold-repair-loop":
            return False
        return idx + 1 < len(args) and args[idx + 1] == session

    for idx in range(len(args)):
        if match_at(idx):
            return True
        if os.path.basename(args[idx]) in {"bash", "sh"} and match_at(idx + 1):
            return True
    return False


for proc_dir in sorted(pathlib.Path("/proc").iterdir(), key=lambda path: path.name):
    if not proc_dir.name.isdigit():
        continue
    pid = int(proc_dir.name)
    if pid in excluded_pids:
        continue
    if matches(parse_args(pid)):
        print(pid)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

release_repair_lock() {
  local current_pid=""
  if [[ "$REPAIR_PID_FILE_OWNED" == "1" ]]; then
    if [[ -r "$REPAIR_PID_FILE" ]]; then
      read -r current_pid < "$REPAIR_PID_FILE" || current_pid=""
    fi
    if [[ "$current_pid" == "$$" ]]; then
      rm -f "$REPAIR_PID_FILE" 2>/dev/null || true
    fi
  fi
  REPAIR_PID_FILE_OWNED=0
  if [[ "$REPAIR_LOCK_DIR_OWNED" == "1" ]]; then
    PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$REPAIR_LOCK_DIR" "$$" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.repair_lock import release_repair_lock

lock_dir, pid_text = sys.argv[1:]
raise SystemExit(0 if release_repair_lock(lock_dir, expected_pid=int(pid_text)) else 1)
PY
    REPAIR_LOCK_DIR_OWNED=0
  fi
}

release_active_repair_claim() {
  local blocker_id="${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}"
  local request_id="${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}"
  local owner_pid="${CLOUD_WATCHDOG_REPAIR_CLAIM_OWNER_PID:-}"
  if [[ -z "$blocker_id" || ! "$owner_pid" =~ ^[0-9]+$ ]]; then
    return
  fi
  PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$MARKER_DIR" "$blocker_id" "$owner_pid" "$request_id" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud import repair_requests
from arnold_pipelines.megaplan.cloud.repair_lock import inspect_repair_lock

marker_dir, blocker_id, owner_pid_text, request_id = sys.argv[1:]
try:
    owner_pid = int(owner_pid_text)
except ValueError:
    raise SystemExit(0)

queue_dir = repair_requests.repair_queue_dir(marker_dir)
lock_dir = repair_requests.active_repair_claim_lock_dir(queue_dir, blocker_id)
owner = inspect_repair_lock(lock_dir).owner
if request_id and isinstance(owner, dict):
    owner_request_id = str(owner.get("request_id") or "")
    if owner_request_id and owner_request_id != request_id:
        raise SystemExit(0)

repair_requests.release_active_repair_request_claim(
    queue_dir,
    blocker_id=blocker_id,
    expected_pid=owner_pid,
)
raise SystemExit(0)
PY
}

shutdown_repair_loop() {
  if [[ "$REPAIR_SHUTDOWN_RAN" == "1" ]]; then
    return
  fi
  REPAIR_SHUTDOWN_RAN=1
  cleanup_children
  release_active_repair_claim
  release_repair_lock
}

trap 'shutdown_repair_loop' EXIT
trap 'shutdown_repair_loop; exit 129' HUP
trap 'shutdown_repair_loop; exit 130' INT
trap 'shutdown_repair_loop; exit 143' TERM

acquire_repair_lock() {
  local existing_pid="" live_pid="" lock_owner_pid="" lock_status="" stale_lock_json="" repair_lock_output=""
  local -a _repair_lock_result=()
  mkdir -p "$(dirname "$REPAIR_PID_FILE")"
  repair_lock_output="$(
    PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$REPAIR_LOCK_DIR" "$SESSION" "$$" "$WORKSPACE" "$0" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" <<'PY'
import json
import os
import sys

from arnold_pipelines.megaplan.cloud.repair_lock import acquire_repair_lock

lock_dir, session, pid_text, workspace, *command_parts = sys.argv[1:]

def is_pid_live(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True

result = acquire_repair_lock(
    lock_dir,
    session=session,
    pid=int(pid_text),
    command=" ".join(command_parts),
    cwd=workspace,
    is_pid_live=is_pid_live,
)
owner_pid = ""
if isinstance(result.owner, dict):
    owner_pid = str(result.owner.get("pid") or "")
print(result.status)
print(owner_pid)
print(json.dumps(result.stale_evidence or {}, sort_keys=True))
PY
  )" || repair_lock_output=""
  while IFS= read -r line; do
    _repair_lock_result+=("$line")
  done <<EOF
$repair_lock_output
EOF
  lock_status="${_repair_lock_result[0]:-}"
  lock_owner_pid="${_repair_lock_result[1]:-}"
  stale_lock_json="${_repair_lock_result[2]:-}"
  if [[ -z "$stale_lock_json" ]]; then
    stale_lock_json='{}'
  fi
  if [[ "$lock_status" == "busy" ]]; then
    log "another repair loop is already active; exiting session=$SESSION owner_pid=${lock_owner_pid:-unknown} pidfile=$REPAIR_PID_FILE"
    return 1
  fi
  if [[ "$lock_status" == "acquired" ]]; then
    REPAIR_LOCK_DIR_OWNED=1
  elif [[ "$lock_status" == "stale" ]]; then
    log "stale repair lock detected; leaving evidence in place session=$SESSION lock_dir=$REPAIR_LOCK_DIR"
    if [[ -f "$DATA_FILE" ]]; then
      PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$stale_lock_json" <<'PY'
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.repair_contract import load_json, merge_additive_fields, save_repair_data

path = pathlib.Path(sys.argv[1])
stale_evidence = json.loads(sys.argv[2])

clear_session_repair_markers_now() {
  require_repair_lock_held
  rm -f "$NEEDS_HUMAN_FILE" "$MARKER_DIR/$SESSION.kimi-dispatch" "$MARKER_DIR/$SESSION.kimi-pgid" 2>/dev/null || true
}

repair_loop_pid_matches_session() {
  local pid="$1"
  local session="${2:-}"
  python3 - "$pid" "$session" <<'PY'
import os
import pathlib
import shlex
import subprocess
import sys

pid_text, session = sys.argv[1:]
try:
    pid = int(pid_text)
except (TypeError, ValueError):
    raise SystemExit(1)
if pid <= 0:
    raise SystemExit(1)

def parse_args() -> list[str]:
    cmdline_path = pathlib.Path(f"/proc/{pid}/cmdline")
    if cmdline_path.exists():
        raw = cmdline_path.read_bytes()
        return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]
    proc = subprocess.run(
        ["ps", "-ww", "-o", "args=", "-p", str(pid)],
        check=False,
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        return []
    text = proc.stdout.strip()
    if not text:
        return []
    try:
        return shlex.split(text)
    except ValueError:
        return text.split()

args = parse_args()
if not args:
    raise SystemExit(1)

def match_at(idx: int) -> bool:
    if idx >= len(args):
        return False
    base = os.path.basename(args[idx])
    if base != "arnold-repair-loop":
        return False
    if not session:
        return True
    return idx + 1 < len(args) and args[idx + 1] == session

for idx in range(len(args)):
    if match_at(idx):
        raise SystemExit(0)
    base = os.path.basename(args[idx])
    if base in {"bash", "sh"} and match_at(idx + 1):
        raise SystemExit(0)

raise SystemExit(1)
PY
}

find_live_repair_loop_for_session() {
  local session="${1:-$SESSION}"
  python3 - "$session" "$$" <<'PY'
import os
import pathlib
import sys

session, self_pid_text = sys.argv[1:]
try:
    self_pid = int(self_pid_text)
except Exception:
    self_pid = -1
excluded_pids = {self_pid, os.getppid()}


def parse_args(pid: int) -> list[str]:
    try:
        raw = pathlib.Path(f"/proc/{pid}/cmdline").read_bytes()
    except Exception:
        return []
    return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]


def matches(args: list[str]) -> bool:
    def match_at(idx: int) -> bool:
        if idx >= len(args):
            return False
        base = os.path.basename(args[idx])
        if base != "arnold-repair-loop":
            return False
        return idx + 1 < len(args) and args[idx + 1] == session

    for idx in range(len(args)):
        if match_at(idx):
            return True
        if os.path.basename(args[idx]) in {"bash", "sh"} and match_at(idx + 1):
            return True
    return False


for proc_dir in sorted(pathlib.Path("/proc").iterdir(), key=lambda path: path.name):
    if not proc_dir.name.isdigit():
        continue
    pid = int(proc_dir.name)
    if pid in excluded_pids:
        continue
    if matches(parse_args(pid)):
        print(pid)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

release_repair_lock() {
  local current_pid=""
  if [[ "$REPAIR_PID_FILE_OWNED" == "1" ]]; then
    if [[ -r "$REPAIR_PID_FILE" ]]; then
      read -r current_pid < "$REPAIR_PID_FILE" || current_pid=""
    fi
    if [[ "$current_pid" == "$$" ]]; then
      rm -f "$REPAIR_PID_FILE" 2>/dev/null || true
    fi
  fi
  REPAIR_PID_FILE_OWNED=0
  if [[ "$REPAIR_LOCK_DIR_OWNED" == "1" ]]; then
    PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$REPAIR_LOCK_DIR" "$$" <<'PY'
import sys

from arnold_pipelines.megaplan.cloud.repair_lock import release_repair_lock

lock_dir, pid_text = sys.argv[1:]
raise SystemExit(0 if release_repair_lock(lock_dir, expected_pid=int(pid_text)) else 1)
PY
    REPAIR_LOCK_DIR_OWNED=0
  fi
}

shutdown_repair_loop() {
  if [[ "$REPAIR_SHUTDOWN_RAN" == "1" ]]; then
    return
  fi
  REPAIR_SHUTDOWN_RAN=1
  cleanup_children
  release_repair_lock
}

trap 'shutdown_repair_loop' EXIT
trap 'shutdown_repair_loop; exit 129' HUP
trap 'shutdown_repair_loop; exit 130' INT
trap 'shutdown_repair_loop; exit 143' TERM

acquire_repair_lock() {
  local existing_pid="" live_pid="" lock_owner_pid="" lock_status="" stale_lock_json="" repair_lock_output=""
  local -a _repair_lock_result=()
  mkdir -p "$(dirname "$REPAIR_PID_FILE")"
  repair_lock_output="$(
    PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$REPAIR_LOCK_DIR" "$SESSION" "$$" "$WORKSPACE" "$0" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" <<'PY'
import json
import os
import sys

from arnold_pipelines.megaplan.cloud.repair_lock import acquire_repair_lock

lock_dir, session, pid_text, workspace, *command_parts = sys.argv[1:]

def is_pid_live(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True

result = acquire_repair_lock(
    lock_dir,
    session=session,
    pid=int(pid_text),
    command=" ".join(command_parts),
    cwd=workspace,
    is_pid_live=is_pid_live,
)
owner_pid = ""
if isinstance(result.owner, dict):
    owner_pid = str(result.owner.get("pid") or "")
print(result.status)
print(owner_pid)
print(json.dumps(result.stale_evidence or {}, sort_keys=True))
PY
  )" || repair_lock_output=""
  while IFS= read -r line; do
    _repair_lock_result+=("$line")
  done <<EOF
$repair_lock_output
EOF
  lock_status="${_repair_lock_result[0]:-}"
  lock_owner_pid="${_repair_lock_result[1]:-}"
  stale_lock_json="${_repair_lock_result[2]:-}"
  if [[ -z "$stale_lock_json" ]]; then
    stale_lock_json='{}'
  fi
  if [[ "$lock_status" == "busy" ]]; then
    log "another repair loop is already active; exiting session=$SESSION owner_pid=${lock_owner_pid:-unknown} pidfile=$REPAIR_PID_FILE"
    return 1
  fi
  if [[ "$lock_status" == "acquired" ]]; then
    REPAIR_LOCK_DIR_OWNED=1
  elif [[ "$lock_status" == "stale" ]]; then
    log "stale repair lock detected; leaving evidence in place session=$SESSION lock_dir=$REPAIR_LOCK_DIR"
    if [[ -f "$DATA_FILE" ]]; then
      PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$stale_lock_json" <<'PY'
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.repair_contract import load_json, merge_additive_fields, save_repair_data

path = pathlib.Path(sys.argv[1])
stale_evidence = json.loads(sys.argv[2])
payload = load_json(path, default={})
verification = dict(payload.get("verification") or {})
verification["repair_lock"] = {
    "status": "stale",
    "stale_evidence": stale_evidence,
}
payload = merge_additive_fields(payload, verification=verification)
save_repair_data(path, payload)
PY
    fi
    repair_lock_output="$(
      PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$REPAIR_LOCK_DIR" "$SESSION" "$$" "$WORKSPACE" "$0" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" <<'PY'
import json
import os
import sys

from arnold_pipelines.megaplan.cloud.repair_lock import acquire_repair_lock, release_repair_lock

lock_dir, session, pid_text, workspace, *command_parts = sys.argv[1:]

def is_pid_live(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True

release_repair_lock(lock_dir)
result = acquire_repair_lock(
    lock_dir,
    session=session,
    pid=int(pid_text),
    command=" ".join(command_parts),
    cwd=workspace,
    is_pid_live=is_pid_live,
)
owner_pid = ""
if isinstance(result.owner, dict):
    owner_pid = str(result.owner.get("pid") or "")
print(result.status)
print(owner_pid)
print(json.dumps(result.stale_evidence or {}, sort_keys=True))
PY
    )" || repair_lock_output=""
    _repair_lock_result=()
    while IFS= read -r line; do
      _repair_lock_result+=("$line")
    done <<EOF
$repair_lock_output
EOF
    lock_status="${_repair_lock_result[0]:-}"
    lock_owner_pid="${_repair_lock_result[1]:-}"
    stale_lock_json="${_repair_lock_result[2]:-}"
    if [[ -z "$stale_lock_json" ]]; then
      stale_lock_json='{}'
    fi
    if [[ "$lock_status" == "busy" ]]; then
      log "another repair loop is already active after stale lock recovery; exiting session=$SESSION owner_pid=${lock_owner_pid:-unknown} pidfile=$REPAIR_PID_FILE"
      return 1
    fi
    if [[ "$lock_status" == "acquired" ]]; then
      REPAIR_LOCK_DIR_OWNED=1
      log "stale repair lock reclaimed session=$SESSION lock_dir=$REPAIR_LOCK_DIR"
    fi
  fi
  while true; do
    if ( set -o noclobber; printf '%s\n' "$$" > "$REPAIR_PID_FILE" ) 2>/dev/null; then
      REPAIR_PID_FILE_OWNED=1
      log "repair pid claimed session=$SESSION pid=$$ pidfile=$REPAIR_PID_FILE"
      return 0
    fi
    if [[ -r "$REPAIR_PID_FILE" ]]; then
      read -r existing_pid < "$REPAIR_PID_FILE" || existing_pid=""
    else
      existing_pid=""
    fi
    if [[ -n "$existing_pid" && "$existing_pid" != "$$" ]] && repair_loop_pid_matches_session "$existing_pid" "$SESSION"; then
      if [[ "$REPAIR_LOCK_DIR_OWNED" == "1" ]]; then
        release_repair_lock
      fi
      log "another repair loop is already active; exiting session=$SESSION owner_pid=$existing_pid pidfile=$REPAIR_PID_FILE"
      return 1
    fi
    if live_pid="$(find_live_repair_loop_for_session "$SESSION" 2>/dev/null)"; then
      if [[ "$REPAIR_LOCK_DIR_OWNED" == "1" ]]; then
        release_repair_lock
      fi
      log "another repair loop is already active; exiting session=$SESSION owner_pid=$live_pid pidfile=$REPAIR_PID_FILE"
      return 1
    fi
    if [[ -n "$existing_pid" ]]; then
      log "stale repair pidfile detected; reclaiming session=$SESSION stale_pid=$existing_pid pidfile=$REPAIR_PID_FILE"
    else
      log "empty repair pidfile detected; reclaiming session=$SESSION pidfile=$REPAIR_PID_FILE"
    fi
    rm -f "$REPAIR_PID_FILE" 2>/dev/null || true
    sleep 0.05
  done
}

safe_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-'
}

guard_against_recursive_repair_loop() {
  local parent_pid="${CLOUD_WATCHDOG_REPAIR_LOOP_PID:-}"
  if [[ "${CLOUD_WATCHDOG_REPAIR_LOOP_ACTIVE:-0}" != "1" ]]; then
    return 0
  fi
  if [[ "$parent_pid" == "$$" ]]; then
    return 0
  fi
  if [[ -n "$parent_pid" ]] && ! repair_loop_pid_matches_session "$parent_pid"; then
    return 0
  fi
  log "repair loop recursion blocked; parent repair loop already active owner_session=${CLOUD_WATCHDOG_REPAIR_LOOP_SESSION:-unknown} owner_pid=${parent_pid:-unknown} requested_session=$SESSION"
  return 1
}

remaining_repair_budget_secs() {
  local now remaining
  now="$(date -u +%s)"
  remaining=$((REPAIR_DEADLINE_EPOCH - now))
  if (( remaining < 0 )); then
    remaining=0
  fi
  printf '%s\n' "$remaining"
}

require_repair_lock_held() {
  local current_pid=""
  if [[ "$REPAIR_LOCK_DIR_OWNED" != "1" || "$REPAIR_PID_FILE_OWNED" != "1" ]]; then
    log "repair lock invariant violated; mutation attempted without held lock session=$SESSION"
    exit 75
  fi
  if [[ -r "$REPAIR_PID_FILE" ]]; then
    read -r current_pid < "$REPAIR_PID_FILE" || current_pid=""
  fi
  if [[ "$current_pid" != "$$" ]]; then
    log "repair lock invariant violated; pidfile owner mismatch session=$SESSION owner_pid=${current_pid:-unknown} expected_pid=$$"
    exit 75
  fi
}

record_repair_timeout_and_exit() {
  local phase="$1"
  require_repair_lock_held
  if [[ -f "$DATA_FILE" ]]; then
    repair_data_set_outcome "repair_timeout"
  fi
  log "repair budget exhausted; timing out session=$SESSION phase=$phase budget_secs=$REPAIR_BUDGET_SECS data=$DATA_FILE"
  exit 1
}

ensure_repair_budget_available() {
  local phase="$1"
  local remaining
  remaining="$(remaining_repair_budget_secs)"
  if (( remaining <= 0 )); then
    record_repair_timeout_and_exit "$phase"
  fi
}

cap_timeout_to_repair_budget() {
  local requested="$1"
  local phase="$2"
  local remaining
  ensure_repair_budget_available "$phase"
  remaining="$(remaining_repair_budget_secs)"
  if (( requested <= 0 )); then
    printf '%s\n' "$remaining"
    return 0
  fi
  if (( remaining < requested )); then
    printf '%s\n' "$remaining"
    return 0
  fi
  printf '%s\n' "$requested"
}


chain_wait_status() {
  local workspace="$1"
  python3 - "$workspace" <<'PY'
import json
import pathlib
import subprocess
import sys

workspace = pathlib.Path(sys.argv[1])
plans_dir = workspace / ".megaplan" / "plans"
chain_paths = sorted(
    {
        *plans_dir.glob(".chains/*.json"),
        *workspace.glob(".megaplan/briefs/*/.megaplan/plans/.chains/*.json"),
        *(workspace / ".megaplan").glob("**/chain_state.json"),
    },
    key=lambda path: path.stat().st_mtime,
    reverse=True,
)

for path in chain_paths:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    if payload.get("last_state") != "awaiting_pr_merge":
        continue
    pr_number = payload.get("pr_number")
    if not pr_number:
        print("awaiting_pr_merge")
        raise SystemExit(0)
    try:
        proc = subprocess.run(
            ["gh", "pr", "view", str(int(pr_number)), "--json", "state"],
            cwd=workspace,
            check=False,
            capture_output=True,
            text=True,
            timeout=120,
        )
        if proc.returncode == 0:
            state = json.loads(proc.stdout or "{}").get("state", "")
            if isinstance(state, str) and state.lower() == "merged":
                print("none")
                raise SystemExit(0)
    except Exception:
        pass
    print("awaiting_pr_merge")
    raise SystemExit(0)

print("none")
PY
}

plan_process_is_alive() {
  local plan_name="$1"
  if [[ -z "$plan_name" ]]; then
    return 1
  fi
  if ps -eww -o args= \
    | grep -E "[p]ython[0-9.]*([[:space:]]+-P)?[[:space:]]+-m arnold_pipelines.megaplan (init|auto|resume|plan|prep|critique|revise|gate|finalize|execute|review)" \
    | grep -Eq -- "(--plan[=[:space:]]$plan_name|--name[=[:space:]]$plan_name.*--auto-start|--auto-start.*--name[=[:space:]]$plan_name)"; then
    return 0
  fi
  if ps -eww -o args= \
    | grep -E "[a]rnold (auto|resume)|[m]egaplan (auto|resume)" \
    | grep -Fq -- "--plan $plan_name"; then
    return 0
  fi
  return 1
}

session_health_status() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local wait_status
  if ! tmux has-session -t "$session" 2>/dev/null; then
    if [[ "$run_kind" == "chain" ]]; then
      wait_status="$(chain_wait_status "$workspace")"
      if [[ "$wait_status" != "none" ]]; then
        echo "$wait_status"
        return 0
      fi
    fi
    echo "stopped"
    return 0
  fi

  local pane log_path
  pane="$(tmux capture-pane -pt "$session" -S -120 2>/dev/null || true)"
  if printf '%s\n' "$pane" | grep -Eq 'cmd exited rc=[1-9]|error retry [0-9]+/[0-9]+'; then
    echo "retrying_failure"
    return 0
  fi

  if [[ "$run_kind" == "chain" ]]; then
    if [[ "$session" == "megaplan-chain" ]]; then
      log_path="$workspace/.megaplan/cloud-chain.log"
    else
      log_path="$workspace/.megaplan/cloud-chain-${session}.log"
    fi
    if [[ -f "$log_path" ]] && tail -80 "$log_path" 2>/dev/null | grep -Eq '"error": "invalid_spec"|invalid_spec|"error": "git_refresh_failed"|git_refresh_failed|fatal: couldn'\''t find remote ref'; then
      echo "chain_log_failure"
      return 0
    fi
    if ps -eww -o args= | grep -E "[p]ython[0-9.]*([[:space:]]+-P)?[[:space:]]+-m arnold_pipelines.megaplan chain start" | grep -F -- "--spec" | grep -Fq -- "$remote_spec"; then
      echo "alive"
      return 0
    fi
    if plan_process_is_alive "$plan_name"; then
      echo "alive"
      return 0
    fi
    wait_status="$(chain_wait_status "$workspace")"
    if [[ "$wait_status" != "none" ]]; then
      echo "$wait_status"
      return 0
    fi
  elif [[ -n "$plan_name" ]]; then
    if plan_process_is_alive "$plan_name"; then
      echo "alive"
      return 0
    fi
  fi

  echo "stopped"
}

default_plan_relaunch_command() {
  local plan_name="$1"
  local workspace="$2"
  local log_path="$workspace/.megaplan/cloud-logs/${plan_name}.log"
  printf 'if [[ -f /workspace/.cloud-hot-env ]]; then set -a; . /workspace/.cloud-hot-env; set +a; fi; cd %q && PYTHONSAFEPATH=1 PYTHONPATH=%q:${PYTHONPATH:-} MEGAPLAN_TRUSTED_CONTAINER=1 python3 -P -m arnold_pipelines.megaplan auto --plan %q --project-dir %q >> %q 2>&1' \
    "$ARNOLD_SRC" "$ARNOLD_SRC" "$plan_name" "$workspace" "$log_path"
}

resolve_relaunch_command() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="${4:-chain}"
  local plan_name="${5:-}"
  local relaunch_command="${6:-}"
  if [[ -n "$relaunch_command" ]]; then
    printf '%s' "$relaunch_command"
    return 0
  fi
  if [[ "$run_kind" == "plan" ]]; then
    [[ -n "$plan_name" ]] || return 1
    default_plan_relaunch_command "$plan_name" "$workspace"
    return 0
  fi
  local log_relative
  if [[ "$session" == "megaplan-chain" ]]; then
    log_relative=".megaplan/cloud-chain.log"
  else
    log_relative=".megaplan/cloud-chain-${session}.log"
  fi
  printf 'if [[ -f /workspace/.cloud-hot-env ]]; then set -a; . /workspace/.cloud-hot-env; set +a; fi; cd %q && PYTHONSAFEPATH=1 PYTHONPATH=%q:${PYTHONPATH:-} MEGAPLAN_TRUSTED_CONTAINER=1 python3 -P -m arnold_pipelines.megaplan chain start --spec %q --project-dir %q >> %q 2>&1' \
    "$ARNOLD_SRC" "$ARNOLD_SRC" "$remote_spec" "$workspace" "$workspace/$log_relative"
}

repair_target_completion_status() {
  local workspace="$1"
  local run_kind="$2"
  local plan_name="${3:-}"
  python3 - "$workspace" "$run_kind" "$plan_name" <<'PY'
import json
import pathlib
import sys

workspace = pathlib.Path(sys.argv[1])
run_kind = sys.argv[2]
plan_name = sys.argv[3]

def load_json(path: pathlib.Path | None) -> dict[str, object]:
    if path is None:
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}

def candidate_plan_states(root: pathlib.Path) -> list[pathlib.Path]:
    candidates: list[tuple[float, pathlib.Path]] = []
    for pattern in (
        ".megaplan/plans/*/state.json",
        ".megaplan/briefs/*/.megaplan/plans/*/state.json",
    ):
        for path in root.glob(pattern):
            try:
                candidates.append((path.stat().st_mtime, path))
            except OSError:
                continue
    candidates.sort(reverse=True)
    return [path for _, path in candidates]

def latest_chain_state(root: pathlib.Path) -> pathlib.Path | None:
    candidates = set()
    candidates.update((root / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(root.glob(".megaplan/briefs/*/.megaplan/plans/.chains/*.json"))
    candidates.update((root / ".megaplan").glob("**/chain_state.json"))
    ordered: list[tuple[float, pathlib.Path]] = []
    for path in candidates:
        try:
            ordered.append((path.stat().st_mtime, path))
        except OSError:
            continue
    ordered.sort(reverse=True)
    return ordered[0][1] if ordered else None

def resolve_plan_state(root: pathlib.Path, preferred_name: str) -> pathlib.Path | None:
    candidates = candidate_plan_states(root)
    if preferred_name:
        preferred = [path for path in candidates if path.parent.name == preferred_name]
        if preferred:
            return preferred[0]
        return None
    return candidates[0] if candidates else None

def is_terminal_plan(plan_state: dict[str, object]) -> tuple[bool, str]:
    current_state = str(plan_state.get("current_state") or plan_state.get("state") or "").strip().lower()
    if current_state in {"done", "complete"}:
        return True, f"plan_state={current_state}"
    return False, current_state

def chain_completion_reason(chain_state: dict[str, object]) -> str:
    last_state = str(chain_state.get("last_state") or "").strip().lower()
    if last_state in {"done", "complete"}:
        return f"last_state={last_state}"
    milestones = chain_state.get("milestones")
    milestones = milestones if isinstance(milestones, list) else []
    completed = chain_state.get("completed")
    completed = completed if isinstance(completed, list) else []
    milestone_count = len(milestones)
    completed_count = len(completed)
    current_idx = chain_state.get("current_milestone_index")
    try:
        current_idx_int = int(current_idx)
    except (TypeError, ValueError):
        current_idx_int = None
    if milestone_count and current_idx_int is not None and current_idx_int >= milestone_count:
        return f"current_milestone_index={current_idx_int} past_last_milestone={milestone_count - 1}"
    milestone_labels = [
        str(item.get("label") or item.get("id") or "").strip()
        for item in milestones
        if isinstance(item, dict)
    ]
    completed_labels = {
        str(item.get("label") or item.get("id") or item.get("plan") or "").strip()
        for item in completed
        if isinstance(item, dict)
    }
    milestone_labels = [label for label in milestone_labels if label]
    if milestone_labels and all(label in completed_labels for label in milestone_labels):
        return f"all_milestones_completed={len(milestone_labels)}/{milestone_count}"
    if milestone_count and completed_count >= milestone_count:
        return f"completed_entries={completed_count}/{milestone_count}"
    return ""

chain_path = latest_chain_state(workspace) if run_kind == "chain" else None
chain_state = load_json(chain_path)
preferred_plan_name = plan_name or str(chain_state.get("current_plan_name") or "").strip()
plan_path = resolve_plan_state(workspace, preferred_plan_name)
plan_state = load_json(plan_path)
plan_complete, plan_reason = is_terminal_plan(plan_state)
chain_reason = chain_completion_reason(chain_state) if run_kind == "chain" else ""

if run_kind == "chain" and chain_reason:
    print(
        "\t".join(
            [
                "1",
                "chain",
                chain_reason,
                str(chain_path or ""),
                str(plan_path or ""),
                str(plan_state.get("current_state") or plan_state.get("state") or ""),
            ]
        )
    )
elif run_kind == "plan" and plan_complete:
    print(
        "\t".join(
            [
                "1",
                "plan",
                plan_reason,
                str(chain_path or ""),
                str(plan_path or ""),
                str(plan_state.get("current_state") or plan_state.get("state") or ""),
            ]
        )
    )
else:
    print(
        "\t".join(
            [
                "0",
                "",
                "",
                str(chain_path or ""),
                str(plan_path or ""),
                str(plan_state.get("current_state") or plan_state.get("state") or ""),
            ]
        )
    )
PY
}

collect_failure_context_json() {
  local workspace="$1"
  local session="$2"
  local run_kind="${3:-chain}"
  local plan_name="${4:-}"
  python3 - "$workspace" "$session" "$run_kind" "$plan_name" <<'PY'
import json
import pathlib
import re
import sys

workspace = pathlib.Path(sys.argv[1])
session = sys.argv[2]
run_kind = sys.argv[3]
marker_plan_name = sys.argv[4]


def _tail_text(path: pathlib.Path, lines: int = 20) -> str:
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return ""
    tail = text.splitlines()[-lines:]
    return "\n".join(tail)


def _clip_text(text: object, limit: int = 12000) -> str:
    rendered = str(text or "")
    if len(rendered) <= limit:
        return rendered
    return rendered[-limit:]


def _load_json(path: pathlib.Path) -> dict[str, object]:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}


def _artifact_sort_key(path: pathlib.Path) -> tuple[float, str]:
    try:
        mtime = path.stat().st_mtime
    except OSError:
        mtime = 0.0
    return (mtime, path.name)


def _newest_artifact(plan_dir: pathlib.Path, pattern: str) -> pathlib.Path | None:
    candidates = [path for path in plan_dir.glob(pattern) if path.is_file()]
    if not candidates:
        return None
    return sorted(candidates, key=_artifact_sort_key)[-1]


def _task_id(task: dict[str, object]) -> str:
    for key in ("task_id", "id"):
        value = task.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


def _task_excerpt(task: dict[str, object]) -> dict[str, object]:
    excerpt: dict[str, object] = {
        "task_id": _task_id(task),
        "status": task.get("status") or "",
        "executor_notes": _clip_text(task.get("executor_notes") or task.get("executor_note") or "", limit=1200),
        "reviewer_verdict": task.get("reviewer_verdict") or "",
    }
    for key in ("description", "kind", "depends_on"):
        value = task.get(key)
        if value not in (None, "", [], {}):
            excerpt[key] = _clip_text(value, limit=600)
    return excerpt


def _task_status_counts(tasks: list[dict[str, object]]) -> dict[str, int]:
    counts: dict[str, int] = {}
    for task in tasks:
        status = str(task.get("status") or "unknown").strip().lower() or "unknown"
        if status == "done":
            status = "completed"
        counts[status] = counts.get(status, 0) + 1
    return counts


def _task_is_blocked_or_deferred(task: dict[str, object]) -> bool:
    status = str(task.get("status") or "").strip().lower()
    verdict = str(task.get("reviewer_verdict") or "").strip().lower()
    notes = str(task.get("executor_notes") or "").strip().lower()
    return (
        status in {"blocked", "skipped", "deferred"}
        or "blocked" in verdict
        or "deferred" in verdict
        or "blocked" in notes
        or "deferred" in notes
    )


def _extract_task_updates(payload: dict[str, object]) -> list[dict[str, object]]:
    for key in ("task_updates", "tasks"):
        value = payload.get(key)
        if isinstance(value, list):
            return [item for item in value if isinstance(item, dict)]
    return []


def _summarize_execute_batch_artifact(path: pathlib.Path | None) -> dict[str, object]:
    if path is None:
        return {}
    payload = _load_json(path)
    if not payload:
        return {"path": str(path), "readable": False}
    tasks = [_task_excerpt(task) for task in _extract_task_updates(payload)]
    blocked_tasks = [task for task in tasks if _task_is_blocked_or_deferred(task)]
    return {
        "path": str(path),
        "readable": True,
        "status": payload.get("status") or payload.get("result") or "",
        "task_count": len(tasks),
        "status_counts": _task_status_counts(tasks),
        "tasks": tasks,
        "blocked_or_deferred_tasks": blocked_tasks,
        "output": _clip_text(payload.get("output") or "", limit=2000),
    }


def _summarize_finalize_artifact(path: pathlib.Path) -> dict[str, object]:
    payload = _load_json(path)
    if not payload:
        return {}
    tasks = [_task_excerpt(task) for task in _extract_task_updates(payload)]
    skipped_or_deferred = [
        task
        for task in tasks
        if str(task.get("status") or "").strip().lower() in {"skipped", "deferred", "blocked"}
        or str(task.get("reviewer_verdict") or "").strip()
    ]
    return {
        "path": str(path),
        "baseline_test_failures": payload.get("baseline_test_failures"),
        "baseline_test_note": payload.get("baseline_test_note") or "",
        "baseline_test_collection_errors": payload.get("baseline_test_collection_errors") or [],
        "baseline_test_command": payload.get("baseline_test_command") or "",
        "status_counts": _task_status_counts(tasks),
        "skipped_or_deferred_tasks": skipped_or_deferred,
        "task_count": len(tasks),
    }


def _summarize_full_suite_backstop(path: pathlib.Path) -> dict[str, object]:
    payload = _load_json(path)
    if not payload:
        return {}
    return {
        "path": str(path),
        "status": payload.get("status") or "",
        "baseline_failing_count": payload.get("baseline_failing_count"),
        "current_failing_count": payload.get("current_failing_count") or payload.get("failed"),
        "failing_tests": payload.get("failing_tests") or [],
        "collection_errors": payload.get("collection_errors") or [],
        "note": payload.get("note") or "",
        "command": payload.get("command") or "",
    }


def _history_tail_summary(plan_state: dict[str, object]) -> dict[str, object]:
    history = plan_state.get("history")
    if not isinstance(history, list):
        return {"last_entries": [], "consecutive_execute_blocked": 0}
    entries = [item for item in history if isinstance(item, dict)]
    last_entries = [
        {
            "step": item.get("step") or "",
            "result": item.get("result") or "",
            "timestamp": item.get("timestamp") or item.get("completed_at") or "",
            "output_file": item.get("output_file") or "",
        }
        for item in entries[-5:]
    ]
    consecutive = 0
    for item in reversed(entries):
        if (
            str(item.get("step") or "").strip().lower() == "execute"
            and str(item.get("result") or "").strip().lower() == "blocked"
        ):
            consecutive += 1
            continue
        break
    return {"last_entries": last_entries, "consecutive_execute_blocked": consecutive}


def _collect_execute_attempt_context(plan_dir: pathlib.Path, plan_state: dict[str, object]) -> dict[str, object]:
    output_path = _newest_artifact(plan_dir, "execute_batch_*_output.json")
    execution_path = _newest_artifact(plan_dir, "execution_batch_*.json")
    context: dict[str, object] = {
        "plan_dir": str(plan_dir),
        "execute_batch_output": _summarize_execute_batch_artifact(output_path),
        "execution_batch": _summarize_execute_batch_artifact(execution_path),
        "plan_history": _history_tail_summary(plan_state),
    }
    finalize_path = plan_dir / "finalize.json"
    if finalize_path.exists():
        context["finalize"] = _summarize_finalize_artifact(finalize_path)
    full_suite_path = plan_dir / "full_suite_backstop.json"
    if full_suite_path.exists():
        context["full_suite_backstop"] = _summarize_full_suite_backstop(full_suite_path)
    context["has_execute_artifacts"] = bool(
        context.get("execute_batch_output")
        or context.get("execution_batch")
        or context.get("finalize")
        or context.get("full_suite_backstop")
        or (context.get("plan_history") or {}).get("last_entries")
    )
    return context


def _unique_strings(values: list[str]) -> list[str]:
    seen: set[str] = set()
    ordered: list[str] = []
    for value in values:
        text = str(value or "").strip()
        if not text or text in seen:
            continue
        seen.add(text)
        ordered.append(text)
    return ordered


def _interesting_log_lines(text: str, limit: int = 8) -> list[str]:
    if not text:
        return []
    patterns = (
        "error",
        "fatal",
        "traceback",
        "exception",
        "failed",
        "blocked",
        "usage:",
        "unrecognized arguments",
        "missing authentication",
        "missing credentials",
        "credit",
        "timeout",
        "couldn't find remote ref",
    )
    picked: list[str] = []
    for line in text.splitlines():
        lower = line.lower()
        if any(token in lower for token in patterns):
            picked.append(line.strip())
    return _unique_strings(picked)[-limit:]


def _format_event_line(event: dict[str, object]) -> str:
    kind = str(event.get("kind") or "event")
    phase = str(event.get("phase") or "")
    payload = event.get("payload")
    details: list[str] = []
    if isinstance(payload, dict):
        for key in ("msg", "message", "error", "reason", "state", "status", "task_id", "base_branch", "provider"):
            value = payload.get(key)
            if value not in (None, "", [], {}):
                rendered = json.dumps(value, sort_keys=True) if isinstance(value, (dict, list)) else str(value)
                details.append(f"{key}={rendered}")
    elif payload not in (None, "", [], {}):
        details.append(str(payload))
    prefix = f"{phase}:{kind}" if phase else kind
    return f"{prefix} | {'; '.join(details[:4])}" if details else prefix


def _events_tail(path: pathlib.Path, limit: int = 12) -> str:
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return ""
    rendered: list[str] = []
    for raw in lines[-limit:]:
        try:
            event = json.loads(raw)
        except Exception:
            rendered.append(raw.strip())
            continue
        if isinstance(event, dict):
            rendered.append(_format_event_line(event))
        else:
            rendered.append(str(event))
    return "\n".join(line for line in rendered if line)


def _candidate_plan_states(root: pathlib.Path) -> list[pathlib.Path]:
    candidates = []
    for pattern in (
        ".megaplan/plans/*/state.json",
        ".megaplan/briefs/*/.megaplan/plans/*/state.json",
    ):
        for path in root.glob(pattern):
            try:
                candidates.append((path.stat().st_mtime, path))
            except OSError:
                continue
    candidates.sort(reverse=True)
    return [path for _, path in candidates]


def _latest_chain_state(root: pathlib.Path) -> pathlib.Path | None:
    chains_root = root / ".megaplan"
    candidates = set()
    candidates.update((root / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(root.glob(".megaplan/briefs/*/.megaplan/plans/.chains/*.json"))
    candidates.update(chains_root.glob("**/chain_state.json"))
    ordered = []
    for path in candidates:
        try:
            ordered.append((path.stat().st_mtime, path))
        except OSError:
            continue
    ordered.sort(reverse=True)
    return ordered[0][1] if ordered else None


def _resolve_plan_state(root: pathlib.Path, preferred_plan_name: str) -> pathlib.Path | None:
    candidates = _candidate_plan_states(root)
    if preferred_plan_name:
        preferred = [path for path in candidates if path.parent.name == preferred_plan_name]
        if preferred:
            return preferred[0]
        return None
    return candidates[0] if candidates else None


def _metadata_excerpt(metadata: object) -> dict[str, object]:
    if not isinstance(metadata, dict):
        return {}
    excerpt: dict[str, object] = {}
    for key in (
        "stderr",
        "stdout",
        "output",
        "raw_output",
        "error",
        "message",
        "detail",
        "details",
        "reason",
        "command",
        "cmd",
        "args",
        "argv",
        "exit_code",
        "returncode",
        "return_code",
        "rc",
        "iteration",
        "provider",
        "provider_error_code",
        "status_code",
        "retry_after_s",
        "error_layer",
        "stall_timeout_s",
        "elapsed_s",
        "missing_base_ref",
        "checkpoint_reconciliation",
        "max_iterations",
    ):
        value = metadata.get(key)
        if value not in (None, "", [], {}):
            excerpt[key] = value
    return excerpt


def _parse_ts(value: object) -> tuple[int, str]:
    text = str(value or "").strip()
    if not text:
        return (0, "")
    return (1, text.replace("Z", "+00:00"))


def _event_timestamp(event: dict[str, object]) -> str:
    for key in ("ts_utc", "timestamp", "completed_at", "created_at", "recorded_at"):
        value = event.get(key)
        if value not in (None, ""):
            return str(value)
    payload = event.get("payload")
    if isinstance(payload, dict):
        for key in ("ts_utc", "timestamp", "completed_at", "created_at", "recorded_at"):
            value = payload.get(key)
            if value not in (None, ""):
                return str(value)
    return ""


def _is_success_value(value: object) -> bool:
    return str(value or "").strip().lower() in {
        "success",
        "succeeded",
        "pass",
        "passed",
        "proceed",
        "done",
        "approved",
        "accepted",
    }


def _is_success_event(event: dict[str, object]) -> bool:
    kind = str(event.get("kind") or "").lower()
    phase = str(event.get("phase") or "").lower()
    payload = event.get("payload")
    payload_dict = payload if isinstance(payload, dict) else {}
    if kind == "plan_finished":
        return True
    if kind == "state_transition" and str(payload_dict.get("to") or "").lower() in {
        "done",
        "executed",
        "reviewed",
        "finalized",
        "approved",
    }:
        return True
    if kind == "phase_end":
        for key in ("result", "status", "exit_kind", "recommendation", "verdict"):
            if _is_success_value(payload_dict.get(key)):
                return True
        # Some older journals record only a phase_end marker. Count gate/review
        # phase endings as success only when the payload says so; execute phase
        # endings can follow internal_error paths and must not clear failures.
        return False
    if phase == "gate" and _is_success_value(payload_dict.get("recommendation")):
        return True
    if phase == "review" and _is_success_value(payload_dict.get("verdict") or payload_dict.get("status")):
        return True
    for key in ("result", "status", "exit_kind", "recommendation", "verdict"):
        if _is_success_value(payload_dict.get(key)):
            return True
    return False


def _read_events(path: pathlib.Path) -> list[dict[str, object]]:
    events: list[dict[str, object]] = []
    try:
        raw_lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return events
    for raw in raw_lines:
        try:
            event = json.loads(raw)
        except Exception:
            continue
        if isinstance(event, dict):
            events.append(event)
    events.sort(key=lambda item: item.get("seq", 0) if isinstance(item.get("seq"), int) else 0)
    return events


def _latest_gate_event(path: pathlib.Path | None) -> dict[str, object]:
    if path is None or not path.exists():
        return {}
    for event in reversed(_read_events(path)):
        payload = event.get("payload")
        payload_dict = payload if isinstance(payload, dict) else {}
        recommendation = payload_dict.get("recommendation") or event.get("recommendation")
        if recommendation in (None, ""):
            continue
        phase = str(event.get("phase") or payload_dict.get("phase") or "").strip()
        kind = str(event.get("kind") or "").strip()
        if phase != "gate" and kind not in {"gate", "phase_end"}:
            continue
        return {
            "recommendation": recommendation,
            "kind": kind,
            "phase": phase,
            "seq": event.get("seq"),
            "timestamp": _event_timestamp(event),
        }
    return {}


def _latest_success_after_failure(
    plan_state: dict[str, object],
    events_path: pathlib.Path,
    latest_failure: dict[str, object],
) -> dict[str, object]:
    recorded_at = str(latest_failure.get("recorded_at") or "")
    if not recorded_at:
        return {}
    recorded_key = _parse_ts(recorded_at)
    candidates: list[dict[str, object]] = []
    for event in _read_events(events_path):
        if not _is_success_event(event):
            continue
        ts = _event_timestamp(event)
        if ts and _parse_ts(ts) > recorded_key:
            candidates.append(
                {
                    "source": "events.ndjson",
                    "timestamp": ts,
                    "seq": event.get("seq"),
                    "kind": event.get("kind") or "",
                    "phase": event.get("phase") or "",
                }
            )
    history = plan_state.get("history")
    if isinstance(history, list):
        for item in history:
            if not isinstance(item, dict) or not _is_success_value(item.get("result")):
                continue
            ts = str(item.get("timestamp") or item.get("completed_at") or "")
            if ts and _parse_ts(ts) > recorded_key:
                candidates.append(
                    {
                        "source": "state.history",
                        "timestamp": ts,
                        "step": item.get("step") or "",
                        "result": item.get("result") or "",
                        "artifact_hash": item.get("artifact_hash") or "",
                    }
                )
    candidates.sort(key=lambda item: (_parse_ts(item.get("timestamp")), int(item.get("seq") or 0)))
    return candidates[-1] if candidates else {}


def _stale_block_replay(plan_state: dict[str, object]) -> dict[str, object]:
    history = plan_state.get("history")
    if not isinstance(history, list) or len(history) < 2:
        return {"detected": False}
    blocked = [
        item for item in history
        if isinstance(item, dict)
        and str(item.get("result") or "").lower() == "blocked"
        and item.get("artifact_hash")
    ]
    if len(blocked) < 2:
        return {"detected": False}
    current = blocked[-1]
    current_hash = current.get("artifact_hash")
    prior_matches = [
        item for item in blocked[:-1]
        if item.get("artifact_hash") == current_hash
    ]
    if not prior_matches:
        return {"detected": False}
    try:
        duration_zero = int(current.get("duration_ms") or 0) == 0
    except (TypeError, ValueError):
        duration_zero = False
    if not duration_zero:
        return {"detected": False}
    prior = prior_matches[-1]
    repeated_tail_count = 0
    for item in reversed(history):
        if not isinstance(item, dict):
            break
        try:
            item_duration_zero = int(item.get("duration_ms") or 0) == 0
        except (TypeError, ValueError):
            item_duration_zero = False
        if (
            str(item.get("result") or "").lower() == "blocked"
            and item.get("artifact_hash") == current_hash
            and item_duration_zero
        ):
            repeated_tail_count += 1
            continue
        break
    return {
        "detected": True,
        "artifact_hash": current_hash,
        "duration_ms": current.get("duration_ms"),
        "current_timestamp": current.get("timestamp") or current.get("completed_at") or "",
        "prior_timestamp": prior.get("timestamp") or prior.get("completed_at") or "",
        "step": current.get("step") or "",
        "output_file": current.get("output_file") or "",
        "repeated_tail_count": repeated_tail_count,
        "prior_match_count": len(prior_matches),
    }


def _stale_state_analysis(
    plan_state: dict[str, object],
    events_path: pathlib.Path,
    latest_failure: dict[str, object],
) -> dict[str, object]:
    latest_success = _latest_success_after_failure(plan_state, events_path, latest_failure)
    block_replay = _stale_block_replay(plan_state)
    latest_failure_stale = bool(latest_failure and latest_success)
    stale_block = bool(block_replay.get("detected"))
    if latest_failure_stale or stale_block:
        classification = "STALE STATE"
        summary_parts = []
        if latest_failure_stale:
            summary_parts.append(
                "latest_failure was stale (predates last success at "
                f"{latest_success.get('timestamp')})"
            )
        if stale_block:
            summary_parts.append(
                "stale block replay detected "
                f"(artifact_hash={block_replay.get('artifact_hash')}, "
                f"duration_ms={block_replay.get('duration_ms')})"
            )
        recommended_action = "clear stale state and re-drive; do not dispatch dev-fix for a source bug"
    elif latest_failure:
        classification = "LIVE FAILURE"
        summary_parts = ["latest_failure is recent; no successful event was found after it"]
        recommended_action = "dispatch dev-fix to fix the Arnold source root cause"
    else:
        classification = "NO LATEST FAILURE"
        summary_parts = ["no latest_failure is set"]
        recommended_action = "mechanical re-drive only"
    return {
        "classification": classification,
        "latest_failure_stale": latest_failure_stale,
        "latest_success_after_failure": latest_success,
        "stale_block_replay": block_replay,
        "summary": " — ".join(summary_parts),
        "recommended_action": recommended_action,
    }


def _state_mismatch_analysis(
    plan_latest_failure: dict[str, object],
    chain_state_summary: dict[str, object],
) -> dict[str, object]:
    plan_state = str(plan_latest_failure.get("current_state") or "").strip()
    chain_last_state = str(chain_state_summary.get("last_state") or "").strip()
    chain_state_path = str(chain_state_summary.get("path") or "").strip()
    plan_state_path = str(plan_latest_failure.get("state_path") or "").strip()
    chain_plan = str(chain_state_summary.get("current_plan_name") or "").strip()
    plan_name = str(plan_latest_failure.get("plan_name") or "").strip()
    has_latest_failure = bool(
        str(plan_latest_failure.get("kind") or "").strip()
        or str(plan_latest_failure.get("message") or "").strip()
        or str(plan_latest_failure.get("state") or "").strip()
    )
    detected = (
        bool(plan_state_path)
        and bool(chain_state_path)
        and plan_state == "finalized"
        and chain_last_state in {"awaiting_human", "blocked"}
        and not has_latest_failure
        and (not chain_plan or not plan_name or chain_plan == plan_name)
    )
    if not detected:
        return {"detected": False}
    return {
        "detected": True,
        "plan_state": plan_state,
        "chain_last_state": chain_last_state,
        "plan_name": plan_name or chain_plan,
        "chain_plan_name": chain_plan,
        "plan_state_path": plan_state_path,
        "chain_state_path": chain_state_path,
        "classification": "PLAN_CHAIN_STATE_MISMATCH",
        "summary": (
            f"state mismatch detected: plan={plan_state} is ready to execute, "
            f"but chain last_state={chain_last_state} is stale"
        ),
        "recommended_action": (
            "sync chain last_state from plan current_state and mechanically re-drive"
        ),
    }


def _collect_signal_values(value: object, prefix: str = "", depth: int = 0) -> list[str]:
    if depth > 4:
        return []
    signal_keys = {
        "stderr",
        "stdout",
        "output",
        "raw_output",
        "error",
        "errors",
        "exception",
        "traceback",
        "message",
        "detail",
        "details",
        "reason",
        "status",
        "exit_code",
        "returncode",
        "return_code",
        "rc",
        "command",
        "cmd",
        "args",
        "argv",
        "missing_base_ref",
        "last_error",
        "failure",
    }
    collected: list[str] = []
    if isinstance(value, dict):
        for key, child in value.items():
            child_prefix = f"{prefix}.{key}" if prefix else str(key)
            if str(key).lower() in signal_keys and child not in (None, "", [], {}):
                rendered = json.dumps(child, sort_keys=True) if isinstance(child, (dict, list)) else str(child)
                rendered = _clip_text(rendered, limit=2000)
                collected.append(f"{child_prefix}: {rendered}")
            collected.extend(_collect_signal_values(child, child_prefix, depth + 1))
    elif isinstance(value, list):
        for idx, child in enumerate(value[-25:]):
            collected.extend(_collect_signal_values(child, f"{prefix}[{idx}]", depth + 1))
    return collected


def _classify_failure(signals: list[str], latest_failure: dict[str, object], chain_state: dict[str, object]) -> str:
    combined = "\n".join(signals).lower()
    kind = str(latest_failure.get("kind") or "").lower()
    phase = str(latest_failure.get("phase") or "").lower()
    last_state = str(chain_state.get("last_state") or "").lower()
    current_state = str(chain_state.get("current_state") or "").lower()
    current_plan_name = str(chain_state.get("current_plan_name") or "").strip()
    if (
        last_state == "done"
        and current_state in {"", "done", "unknown"}
        and current_plan_name.lower() in {"", "unknown"}
    ):
        return "chain_completed"
    if "unrecognized arguments" in combined or "usage:" in combined:
        return "cli_or_argument_error"
    if "couldn't find remote ref" in combined or "missing_base_ref" in combined or last_state == "missing_base_ref":
        return "git_or_branch_resolution_error"
    if "authentication" in combined or "missing credentials" in combined or "api key" in combined or re.search(r"\b401\b", combined):
        return "authentication_or_credentials_error"
    if "credit balance is too low" in combined or "insufficient credits" in combined or "quota" in combined:
        return "billing_or_quota_error"
    if "timeout" in combined or "stall" in combined or kind == "stalled":
        return "timeout_or_hang"
    if "awaiting_human" in combined or last_state == "awaiting_human":
        return "awaiting_human_user_action_gate"
    if "blocked" in combined or phase == "recover-blocked" or kind in {"execution_blocked", "iteration_cap"}:
        return "blocked_state_or_recovery_error"
    if "external_error" in kind:
        return "external_dependency_error"
    if "phase_callback_failed" in kind:
        return "post_phase_callback_error"
    return "unknown_failure_mode"



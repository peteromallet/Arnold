repair_goal_evaluate_or_exit() {
  local phase="$1" result status reason
  result="$(
    PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" "$MEGAPLAN_SUPERVISOR_PYTHON" -P -m \
      arnold_pipelines.megaplan.cloud.repair_goal evaluate \
      --goal-path "$ARNOLD_REPAIR_GOAL_PATH" \
      --action "$phase" \
      --owner-run-id "${ARNOLD_MANAGED_AGENT_RUN_ID:-}" \
      --owner-manifest-path "${ARNOLD_MANAGED_AGENT_MANIFEST:-}"
  )" || {
    repair_data_set_outcome "repairing"
    log "repair goal verification failed closed session=$SESSION phase=$phase"
    return 1
  }
  IFS=$'\t' read -r status reason <<< "$(
    python3 -c 'import json,sys; d=json.load(sys.stdin); e=d.get("evaluation") or {}; print(str(d.get("status") or "")+"\t"+str(e.get("reason") or ""))' <<< "$result"
  )"
  case "$status" in
    progressed)
      repair_data_set_outcome "progressed" "$status"
      clear_repair_markers
      log "repair goal verified authoritative progress session=$SESSION phase=$phase goal_id=$ARNOLD_REPAIR_GOAL_ID reason=$reason"
      exit 0
      ;;
    approval_required)
      repair_data_set_outcome "true_human_blocker" "$status"
      write_needs_human_marker "goal_gate_recorded" "approval_required: $reason"
      log "repair goal reached explicit approval gate session=$SESSION phase=$phase goal_id=$ARNOLD_REPAIR_GOAL_ID reason=$reason"
      exit 0
      ;;
    *)
      repair_data_set_outcome "repairing"
      log "repair goal remains active; liveness is not acceptance progress session=$SESSION phase=$phase goal_id=$ARNOLD_REPAIR_GOAL_ID reason=$reason"
      return 1
      ;;
  esac
}


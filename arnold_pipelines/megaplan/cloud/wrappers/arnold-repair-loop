log "starting session=$SESSION workspace=$WORKSPACE spec=$REMOTE_SPEC source=$ARNOLD_SRC branch=$SYNC_BRANCH"

RUN_KIND="$(json_field "$MARKER_PATH" run_kind 2>/dev/null || true)"
PLAN_NAME="$(json_field "$MARKER_PATH" plan_name 2>/dev/null || true)"
RELAUNCH_COMMAND="$(json_field "$MARKER_PATH" relaunch_command 2>/dev/null || true)"
if [[ -z "$RUN_KIND" ]]; then
  if [[ -n "$PLAN_NAME" ]]; then
    RUN_KIND="plan"
  else
    RUN_KIND="chain"
  fi
fi

# Environment-gone backstop: if the workspace dir is gone the repair loop has
# nothing to repair (it is a code-fixer, not a provisioner — it cannot recreate
# a wiped workspace). Persist an environment_gone outcome for audit and exit 0
# so we do not burn iterations or escalate to Discord. The watchdog primary
# gate retires the session cleanly on its next tick. A direct repair-loop
# entry can bypass that watchdog tolerance, so we also consult the resolver:
# when the workspace is missing, or when a chain/epic-chain marker points at a
# missing spec AND there are no live chain/plan artifacts left, this session is
# stale rather than repairable. This guard runs BEFORE acquire_repair_lock, so
# it writes repair-data via save_repair_data directly rather than
# repair_data_set_outcome (which requires the lock). Best-effort: a failed
# write must not block the no-op exit.
ENTRY_TARGET_MISSING_REASON=""
ENTRY_TARGET_MISSING_REASON="$(entry_target_missing_reason 2>>"$LOG" || true)"
if [[ -z "$ENTRY_TARGET_MISSING_REASON" && ! -d "$WORKSPACE" ]]; then
  if ! entry_workspace_restore_available 2>>"$LOG"; then
    ENTRY_TARGET_MISSING_REASON="workspace_missing"
  fi
fi
if [[ -n "$ENTRY_TARGET_MISSING_REASON" ]]; then
  log "environment gone at entry; exiting without repair session=$SESSION workspace=$WORKSPACE spec=$REMOTE_SPEC reason=$ENTRY_TARGET_MISSING_REASON"
  PYTHONPATH="$WRAPPER_REPO_ROOT:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$ENTRY_TARGET_MISSING_REASON" "$MARKER_PATH" "$PROGRESS_FILE" "$NEEDS_HUMAN_FILE" <<'PY' || true
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.repair_contract import (
    COMPLETE,
    ENVIRONMENT_GONE,
    load_json,
    save_repair_data,
)

(
    data_path_raw,
    session,
    workspace,
    remote_spec,
    entry_reason,
    marker_path_raw,
    progress_path_raw,
    needs_human_path_raw,
) = sys.argv[1:]
data_path = pathlib.Path(data_path_raw)
marker_path = pathlib.Path(marker_path_raw)
progress_path = pathlib.Path(progress_path_raw)
needs_human_path = pathlib.Path(needs_human_path_raw)
payload = load_json(data_path, default={})
if not isinstance(payload, dict):
    payload = {}
payload.setdefault("session", session)
payload.setdefault("workspace", workspace)
payload["workspace"] = workspace
payload["outcome"] = COMPLETE if entry_reason == "stale_marker" else ENVIRONMENT_GONE
save_repair_data(data_path, payload)
if entry_reason == "stale_marker":
    for path in (marker_path, progress_path, needs_human_path):
        try:
            path.unlink()
        except FileNotFoundError:
            pass
        except OSError:
            pass
PY
  exit 0
fi

guard_against_recursive_repair_loop || exit 0

acquire_repair_lock || exit 75
export CLOUD_WATCHDOG_REPAIR_LOOP_ACTIVE=1
export CLOUD_WATCHDOG_REPAIR_LOOP_SESSION="$SESSION"
export CLOUD_WATCHDOG_REPAIR_LOOP_PID="$$"
exit_if_repair_target_complete "start"

INITIAL_HEALTH="$(session_health_status "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME")"
repair_data_init "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND" "$INITIAL_HEALTH"
if [[ "$INITIAL_HEALTH" == "alive" ]]; then
  forced_repair_reason="$(marker_requires_repair_despite_alive || true)"
  if [[ -n "$forced_repair_reason" ]]; then
    log "repair target is alive but marker requires repair session=$SESSION reason=$forced_repair_reason"
  else
  repair_data_set_outcome "live_with_fresh_activity"
  log "repair target already running; verified recovery session=$SESSION"
  exit 0
  fi
fi



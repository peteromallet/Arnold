if repair_source_workspace_if_possible; then
  exit_if_repair_target_complete "post-source-workspace-repair"
  mechanical_status="$(mechanical_launch_step "0" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_KIND" "$PLAN_NAME" "$RELAUNCH_COMMAND")" || {
    repair_data_record_mechanical "0" "0" "$mechanical_status" "after source workspace repair: $mechanical_status"
  }
  if [[ "${mechanical_status:-}" == "running" ]]; then
    repair_data_record_mechanical "0" "0" "running" "source workspace restored; mechanical launch came up and held"
    repair_data_set_outcome "live_with_fresh_activity"
    log "repair loop reached live_with_fresh_activity after source workspace repair"
    exit 0

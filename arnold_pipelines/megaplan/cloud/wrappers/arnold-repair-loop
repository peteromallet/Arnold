render_chain_health_block() {
  # Read the chain-health artifact the watchdog writes when it detects a
  # chain-level cycle / stuck-state / completion-guard rejection, and render the
  # evidence block for the dev-fix prompt. Returns empty when no chain-level
  # issue is flagged (so plan-level prompts are unchanged).
  local artifact
  artifact="$(dirname "$DATA_FILE")/${SESSION}.chain-health.json"
  [[ -f "$artifact" ]] || return 0
  python3 - "$artifact" <<'PY'
import json, pathlib, sys
try:
    artifact = pathlib.Path(sys.argv[1])
    d = json.load(open(artifact))
except Exception:
    sys.exit(0)
if not d or d.get("status") == "ok":
    sys.exit(0)
snapshot = d.get("snapshot") if isinstance(d.get("snapshot"), dict) else {}
chain_summary = d.get("chain_state_summary") if isinstance(d.get("chain_state_summary"), dict) else {}
chain_path_text = str(chain_summary.get("path") or "").strip()
current_plan = str(chain_summary.get("current_plan_name") or "").strip()
last_state = str(chain_summary.get("last_state") or "").strip()
if (
    d.get("issue_kind") == "chain_no_advance"
    and snapshot.get("plan_has_active_step") is False
    and current_plan
    and last_state == "blocked"
    and chain_path_text
):
    try:
        chain_path = pathlib.Path(chain_path_text)
        state_path = chain_path.parent.parent / current_plan / "state.json"
        state = json.load(open(state_path))
        if (
            isinstance(state, dict)
            and state.get("current_state") == "blocked"
            and not state.get("active_step")
        ):
            artifact.unlink(missing_ok=True)
            sys.exit(0)
    except Exception:
        pass
md = d.get("evidence_markdown") or ""
if md:
    print(md)
    sys.exit(0)
issue = d.get("issue_kind") or d.get("status") or "chain-level issue"
summary = (d.get("summary") or "").strip()
print("## CHAIN HEALTH EVIDENCE")
print(f"- Issue: {issue}")
if summary:
    print(f"- Summary: {summary}")
print("- This is a CHAIN-DRIVER issue (completion guard / state progression), not a plan bug.")
print("- Investigate: arnold_pipelines/megaplan/chain/__init__.py and arnold_pipelines/megaplan/chain/status.py")
PY
}

render_canonical_block() {
  # Read the status snapshot and extract canonical resolver fields for this
  # session. Returns empty when observe mode is off or no canonical data exists.
  python3 - "$SNAPSHOT_PATH" "$SESSION" "$ARNOLD_SRC" <<'PY'
import json
import os
import pathlib
import sys

snapshot_path = pathlib.Path(sys.argv[1])
session = sys.argv[2]

observe = os.environ.get("ARNOLD_RESOLVER_OBSERVE", "1").strip().lower()
if observe in ("0", "false", "no", "off"):
    sys.exit(0)

if not snapshot_path.exists():
    sys.exit(0)

try:
    snapshot = json.loads(snapshot_path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    sys.exit(0)

sessions = snapshot.get("sessions") if isinstance(snapshot.get("sessions"), list) else []
entry = None
for item in sessions:
    if isinstance(item, dict) and item.get("session") == session:
        entry = item
        break

if entry is None:
    sys.exit(0)

canonical_state = entry.get("canonical_state")
canonical_reason = entry.get("canonical_reason")
canonical_resolver = entry.get("canonical_resolver") if isinstance(entry.get("canonical_resolver"), dict) else {}

if not canonical_state and not canonical_resolver:
    sys.exit(0)

confidence = canonical_resolver.get("confidence", "medium")
source_of_truth = canonical_resolver.get("source_of_truth") or []
stale_sources = canonical_resolver.get("stale_sources") or []
next_action = canonical_resolver.get("next_action", "")
reason = canonical_resolver.get("reason") or canonical_reason or ""
fingerprint = ""
for item in canonical_resolver.get("evidence") or []:
    if not isinstance(item, dict):
        continue
    if item.get("key") == "root_cause_fingerprint":
        fingerprint = str(item.get("value") or "").strip()
        break
    if item.get("kind") == "root_cause_fingerprint":
        fingerprint = str(item.get("summary") or "").strip()
        break
running = canonical_resolver.get("running", False)
repairable = canonical_resolver.get("repairable", False)
human_required = entry.get("canonical_human_required") or canonical_resolver.get("human_required", False)
human_gate = entry.get("canonical_human_gate") or canonical_resolver.get("human_gate")

print("## CANONICAL STATE (observe-only resolver)")
print(f"- canonical_state: {canonical_state}")
if confidence:
    print(f"- confidence: {confidence}")
if source_of_truth:
    print(f"- source_of_truth: {', '.join(str(s) for s in source_of_truth)}")
if stale_sources:
    print(f"- stale_sources (do NOT trust): {', '.join(str(s) for s in stale_sources)}")
if fingerprint:
    print(f"- root_cause_fingerprint: {fingerprint}")
if reason:
    print(f"- reason: {reason}")
if next_action:
    print(f"- next_action: {next_action}")
if running:
    print("- running: true - a live worker is active; do NOT kill or restart it")
if repairable:
    print("- repairable: true - automated repair is indicated by resolver")
if human_required:
    gate_label = f" (gate: {human_gate})" if human_gate else ""
    print(f"- human_required: true{gate_label} - resolver believes human intervention is required")

plan_state = entry.get("plan_state") if isinstance(entry.get("plan_state"), dict) else {}
active_step = bool(plan_state.get("active_step"))
deferred_tasks = plan_state.get("deferred") if isinstance(plan_state.get("deferred"), list) else []
pending_tasks = plan_state.get("pending") if isinstance(plan_state.get("pending"), list) else []
total_incomplete = len(deferred_tasks) + len(pending_tasks)

if canonical_state in ("REAL_IMPLEMENTATION_BLOCK",) and not active_step and total_incomplete > 0:
    print()
    print("### CONTEXT: Unattempted Target Implementation Work")
    print("This session has real implementation blockers (e.g. route-metadata mismatch, AWF018) and")
    print(f"unattempted tasks ({total_incomplete} incomplete). The repair loop should NOT attempt")
    print("generic engine repair. Instead, verify whether the target implementation work is correctly")
    print("scoped and whether the blocker can be cleared by resolving the route/metadata issue.")
    print("Do NOT patch engine code unless there is clear evidence of an engine bug independent of")
    print("the route/metadata problem.")
elif canonical_state in ("BROKEN_STATE_MACHINE", "RETRYABLE_EXECUTION_BLOCK"):
    print()
    print("### CONTEXT: Engine Repair Required")
    print("This session is classified as an engine-level issue (not unattempted target work).")
    print("Focus on finding and fixing the root cause in the Arnold engine/source code.")
    if fingerprint:
        print(f"The root-cause fingerprint '{fingerprint}' may help identify the pattern.")
PY
}

write_dev_prompt() {
  set +a
  local prompt_path="$1"
  local requested_model="$2"
  local dispatch_model="$3"
  local report_path="$4"
  local recurrence_mode="${5:-0}"
  local failure_summary chain_health_block recurrence_block canonical_block mode_tasks investigation_receipt
  failure_summary="$(render_failure_summary "$DATA_FILE")"
  chain_health_block="$(render_chain_health_block)"
  recurrence_block="$(render_recurrence_block)"
  canonical_block="$(render_canonical_block)"
  investigation_receipt="$(cat "$INVESTIGATOR_RECEIPT_PATH" 2>/dev/null || true)"
  if [[ "$recurrence_mode" == "1" ]]; then
    mode_tasks="$(cat <<EOF
10. This is a recurring problem. Do NOT pick the likely fix. Do NOT repeat the prior approaches listed above.
11. Trace the actual mechanism end-to-end: inspect the real stderr/exit code, the actual SHAs, prompt contents, chain/plan state, and any worker inputs the run received versus what it should have received.
12. Do not stop at a status label. Name the precise mechanism that recreates the symptom before you propose a fix.
13. Use the extra time in this root-cause attempt; depth matters more than turn-shortness here.
14. Write a concise JSON report to $report_path with keys:
    classification, hypothesis, what_tried, validation, pushed_commit, remaining_blockers,
    structural_pattern, other_instantiations, human_review_recommendation,
    findings_doc_path, findings_doc_appended.
EOF
)"
  else
    mode_tasks="$(cat <<EOF
10. Use the raw failure signal, run narrative, and prior-attempt history to avoid repeating failed ideas.
11. Keep the turn short. Pick the most likely fix from the current evidence instead of broad exploration.
12. Write a concise JSON report to $report_path with keys:
    classification, hypothesis, what_tried, validation, pushed_commit, remaining_blockers,
    structural_pattern, other_instantiations, human_review_recommendation,
    findings_doc_path, findings_doc_appended.
EOF
)"
  fi
  cat > "$prompt_path" <<EOF
You are the watchdog repair-loop dev-fix agent for a stopped Arnold cloud session.

$failure_summary
$chain_health_block
$recurrence_block
$canonical_block

**IF A "CHAIN HEALTH EVIDENCE" BLOCK IS PRESENT ABOVE: the root cause is a CHAIN-DRIVER code bug (completion guard / state progression / authority_divergence cycle) in arnold_pipelines/megaplan/chain/, NOT a plan bug. Read the recurring chain-log lines and the completion-guard verdict in that block, then fix the chain driver there. Do NOT chase the plan's latest_failure -- for a chain-level cycle the plan is a victim, not the cause.**
**IF A "RECURRENCE EVIDENCE" BLOCK IS PRESENT ABOVE: recurrence means the symptom came back after prior fixes. Do NOT reuse those approaches. Move into root-cause mode and trace the precise mechanism that regenerates the stop.**
**IF A "CANONICAL STATE" BLOCK IS PRESENT ABOVE: the resolver has classified this session. Use the canonical_state, stale_sources, root_cause_fingerprint, and next_action hints to guide your investigation. The CONTEXT section distinguishes unattempted target implementation work from engine repair - follow the guidance there.**

Session: $SESSION
Workspace: $WORKSPACE
Repair agent launch workdir: $WORKSPACE by default; cd to $ARNOLD_SRC only when the evidence points to an Arnold engine/superfixer bug.
Run kind: $RUN_KIND
Run input: $REMOTE_SPEC
Plan name: ${PLAN_NAME:-}
Editable Arnold source: $ARNOLD_SRC
Editable source branch: $SYNC_BRANCH
Repair data file: $DATA_FILE
Durable repair goal: $ARNOLD_REPAIR_GOAL_PATH
Repair goal ID: $ARNOLD_REPAIR_GOAL_ID
Frozen acceptance checkpoint digest: $ARNOLD_REPAIR_CHECKPOINT_DIGEST
Bounded investigator context: $INVESTIGATION_CONTEXT_PATH
Validated investigator receipt: $INVESTIGATOR_RECEIPT_PATH
Investigator context digest: ${INVESTIGATION_CONTEXT_DIGEST:-unavailable}
Accepted investigation handoff (authoritative for mutation scope):
<investigation_handoff>
$investigation_receipt
</investigation_handoff>
Persistent findings doc: $FINDINGS_DOC
JSON report path (write this before exiting): $report_path
Requested model label for this iteration: $requested_model
Actual dispatch model: $dispatch_model

Task:
0. You are the sole high-reasoning goal owner for this repair cycle. Consume the embedded validated investigator handoff. Cite its context_digest, actual_failure, evidence_sources, safe_repair_target, and intended_recovery in your report; do not independently choose a different mutation target. Keep working through productive evidence-changing iterations inside this turn, but report \`replan\` when the same deterministic failure/progress token repeats. Never launch or retain a second mutating owner.
1. Start from the inline incident snapshot above. Read the repair data JSON and pointed files only if you need deeper evidence.
   Read the LAST EXECUTE ATTEMPT summary first. The root cause might be in the Arnold SOURCE (a code bug) OR in the PLAN STATE (a deferred task, a missing baseline, stale tests for deleted modules). If a task was deferred or blocked rather than failed, investigate the task-level deferral reason; the fix might be to clear or resolve the deferral/state, not to change source code.
   Classification guide:
   - LIVE FAILURE: The latest_failure is recent (no success since it was recorded). Fix the root cause at the level indicated by the evidence: Arnold source for engine bugs, target/workspace code for task implementation bugs, or plan state for deferrals/stale blocked tasks.
     If the blocked execute task says the executor exhausted its budget, made no file changes, or must be re-queued from scratch, the primary repair is target-task implementation/requeue plus plan-state recovery. Do not report success from an Arnold source/harness patch unless you also prove the target task was implemented or the plan was recovered so that the task is being retried.
   - STALE STATE: The latest_failure predates a successful run or the current block is a 0ms same-hash replay. CLEAR latest_failure to null in the plan's state.json, clear stale blocks, and re-drive the run. Do NOT try to fix a source bug; the issue was already addressed.
   For run_kind=plan, use the named plan's state.json, events.ndjson, plan log, and user-action artifacts. Missing chain state, chain logs, chain.yaml, milestones, and base refs are expected and not evidence of a bug.
   For run_kind=chain, use chain state/logs/milestones when present.
2. If the incident is awaiting_human, first distinguish the gate type:
   - Prep Clarification Gate: read the listed questions, plan state/events, initiative assets under .megaplan/initiatives, chain/epic specs, north-star/end-state docs, and the relevant repo code. If the existing evidence is enough, make the best defensible judgment call, record the answers as a note, and resume the plan:
     cd "$WORKSPACE" && MEGAPLAN_ACTOR_ID=repair-loop-dev-fix PYTHONPATH="$ARNOLD_SRC:\${PYTHONPATH:-}" python3 -P -m arnold_pipelines.megaplan override add-note --plan "${PLAN_NAME:-<PLAN_NAME_FROM_SNAPSHOT>}" --source repair-loop-dev-fix --note "Prep clarification answers: ..."
     cd "$WORKSPACE" && MEGAPLAN_ACTOR_ID=repair-loop-dev-fix PYTHONPATH="$ARNOLD_SRC:\${PYTHONPATH:-}" python3 -P -m arnold_pipelines.megaplan override resume-clarify --plan "${PLAN_NAME:-<PLAN_NAME_FROM_SNAPSHOT>}"
     Escalate only when the question requires genuinely human product judgment or evidence is missing after checking those sources.
   - User Action Gate: ATTEMPT to resolve those user actions before treating this as a human stop. Read user_actions.md plus user_action_resolutions.json, inspect the referenced evidence/artifacts/code, make the best defensible judgment call, and record each decision with the CLI instead of hand-writing JSON. Use:
   cd "$WORKSPACE" && MEGAPLAN_ACTOR_ID=repair-loop-dev-fix PYTHONPATH="$ARNOLD_SRC:\${PYTHONPATH:-}" python3 -P -m arnold_pipelines.megaplan user-action resolve --plan "${PLAN_NAME:-<PLAN_NAME_FROM_SNAPSHOT>}" --action-id <ACTION_ID> --resolution <satisfied|accepted_blocked|waived|manual_required|rejected> --reason "..." --instructions "..." --tasks "<TASK_ID,...>"
   Prefer satisfied when the evidence clearly answers the action. Use accepted_blocked or waived only when the action itself permits a fallback. Leave unresolved or mark manual_required only when the decision is genuinely ambiguous, unusually difficult, or requires human-only judgment.
3. When provider/profile settings are implicated, read the Provider/Profile Viability block carefully. Do not switch to a vendor whose route is unavailable on this worker. Remember that override set-profile preserves the current premium vendor when rewriting a named profile; if you actually need to change vendor families, pair it with override set-vendor / set-model or pick a viable non-premium/DeepSeek profile.
4. Go to the deepest structural level you can reach in this bounded turn. Do not just fix the one symptom that caused this stop; find the underlying pattern and check whether it has other instantiations.
5. Apply the narrowest safe root-cause fix at the correct ownership boundary: use $ARNOLD_SRC on branch $SYNC_BRANCH for Arnold engine/superfixer bugs, and use $WORKSPACE for target application code when the blocker is a task implementation failure in that repo. Prefer a general engine fix over a workflow-specific patch only when the evidence points to Arnold itself.
6. If you spot a structural pattern with other instantiations you cannot fix in this turn, append it to the findings doc at $FINDINGS_DOC so it can be reviewed. Capture what you fixed, the deeper pattern, the other instantiations you could not fix, and a recommendation for what a human should review.
7. Validate minimally: py_compile for touched python files and/or the smallest relevant focused test.
8. If code changes pass validation, commit and push them in the repo you changed ($ARNOLD_SRC for engine/superfixer fixes, $WORKSPACE for target-repo fixes).
9. Do not relaunch the run yourself. The wrapper will use the marker's run-kind-aware command only when the durable goal proves there is no correct fresh worker to preserve.
   Your process exit, report, commit, push, or a fresh target heartbeat is not semantic success. Success requires the blocker cleared, the correct worker alive where applicable, fresh progress, and the original plan advancing beyond its frozen stage, or an explicit approval/authorization gate. Never weaken a completion, safety, authority, or verification guard to manufacture progress.
$mode_tasks

Constraints:
- Do not edit outside $ARNOLD_SRC or $WORKSPACE. Use $ARNOLD_SRC for Arnold engine/superfixer fixes; use $WORKSPACE for target-repo task fixes. You may update the active plan's user_action_resolutions.json and state metadata only through the user-action or override CLI commands above.
- Do not hardcode a workflow-specific workaround when a general engine fix is appropriate.
- Do not escalate awaiting_human just because a user action exists. Escalate only after you have reviewed the evidence and cannot make a confident decision.
- If you find a pattern such as flags positioned wrong across multiple dispatch sites or stale recovery logic duplicated in several places, fix what you can now and persist the broader findings in $FINDINGS_DOC.
- Do not ask for user input.
- End the turn as soon as you have either a narrow fix or a concrete blocker, unless recurrence was detected; in that case stay long enough to name the root mechanism.
EOF
  redact_file_in_place "$prompt_path"
}


recover_blocked_after_dev_fix_if_possible() {
  require_investigation_before_mutation "blocked-state-recovery"
  require_repair_lock_held
  local iteration="${1:-0}"
  local attempt_id="${2:-0}"
  ensure_repair_budget_available "blocked-recovery-$iteration"
  local recovery_summary=""
  recovery_summary="$(
    PYTHONPATH="${WRAPPER_REPO_ROOT:-$ARNOLD_SRC}:$ARNOLD_SRC:${PYTHONPATH:-}" python3 - \
      "$WORKSPACE" "$RUN_KIND" "$PLAN_NAME" "$REMOTE_SPEC" "$SESSION" \
      "${MARKER_DIR:-/workspace/.megaplan/cloud-sessions}" "$iteration" "$attempt_id" <<'PY'
import json
from datetime import datetime, timezone
from pathlib import Path
import sys

workspace = Path(sys.argv[1])
run_kind = str(sys.argv[2] or "").strip().lower()
plan_name_hint = str(sys.argv[3] or "").strip()
remote_spec = str(sys.argv[4] or "").strip()
session = str(sys.argv[5] or "").strip()
marker_dir = Path(sys.argv[6]) if sys.argv[6] else Path("/workspace/.megaplan/cloud-sessions")
iteration = int(sys.argv[7] or 0)
attempt_id = int(sys.argv[8] or 0)


def load_json(path: Path | None) -> dict[str, object]:
    if path is None:
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}


def write_json(path: Path, payload: dict[str, object]) -> None:
    path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")


try:
    from arnold_pipelines.megaplan.cloud.current_target import resolve_current_target
    from arnold_pipelines.megaplan.chain.advancement import (
        AdvancementPolicy,
        assess_advancement,
        policy_for_spec_path,
    )
except Exception:
    print("")
    raise SystemExit(0)

target = resolve_current_target(
    session,
    marker_dir=marker_dir,
    repair_data_dir=marker_dir / "repair-data",
)
plan_state_info = target.get("plan_state") if isinstance(target.get("plan_state"), dict) else {}
plan_path_text = str(plan_state_info.get("path") or "").strip()
plan_path = Path(plan_path_text) if plan_path_text else None
if plan_path is None or not plan_path.exists():
    fallback_name = plan_name_hint or str(
        (
            target.get("chain_state", {})
            if isinstance(target.get("chain_state"), dict)
            else {}
        ).get("current_plan_name")
        or ""
    ).strip()
    if fallback_name:
        candidate = workspace / ".megaplan" / "plans" / fallback_name / "state.json"
        if candidate.exists():
            plan_path = candidate
    if plan_path is None and workspace.exists():
        plan_candidates = sorted(
            (workspace / ".megaplan" / "plans").glob("*/state.json"),
            key=lambda path: path.stat().st_mtime if path.exists() else 0.0,
            reverse=True,
        )
        if plan_candidates:
            plan_path = plan_candidates[0]
if plan_path is None or not plan_path.exists():
    print("")
    raise SystemExit(0)
plan_state = load_json(plan_path)
if not plan_state:
    print("")
    raise SystemExit(0)

current_state = str(plan_state.get("current_state") or "").strip().lower()
if current_state not in {"blocked", "manual_review"}:
    print("")
    raise SystemExit(0)
if plan_state.get("active_step"):
    print("")
    raise SystemExit(0)

resume_cursor = plan_state.get("resume_cursor")
resume_cursor = resume_cursor if isinstance(resume_cursor, dict) else {}
retry_strategy = str(resume_cursor.get("retry_strategy") or "").strip().lower()
resume_phase = str(resume_cursor.get("phase") or "").strip().lower()
latest_failure = plan_state.get("latest_failure")
latest_failure = latest_failure if isinstance(latest_failure, dict) else {}
failure_kind = str(latest_failure.get("kind") or "").strip().lower()
failure_phase = str(latest_failure.get("phase") or "").strip().lower()
if retry_strategy != "manual_review":
    print("")
    raise SystemExit(0)
if failure_kind not in {
    "blocked_recovery_not_resolved",
    "execution_blocked",
    "no_next_step_state_mapping_failure",
}:
    print("")
    raise SystemExit(0)
if (resume_phase and resume_phase != "execute") or (failure_phase and failure_phase != "execute"):
    print("")
    raise SystemExit(0)

needs_human = target.get("needs_human") if isinstance(target.get("needs_human"), dict) else {}
stale_kinds = {
    str(item.get("kind") or "")
    for item in (target.get("stale_evidence") or [])
    if isinstance(item, dict)
}
explicit_gate = None
if needs_human.get("present") and "stale_needs_human_plan_ref" not in stale_kinds:
    explicit_gate = str(needs_human.get("summary") or "needs_human")
try:
    policy = policy_for_spec_path(remote_spec) if remote_spec else AdvancementPolicy(
        merge_policy="auto",
        clean_milestone_pr="auto",
        auto_approve=True,
        source="repair_default",
    )
except Exception:
    policy = AdvancementPolicy(
        merge_policy="unknown",
        clean_milestone_pr="unknown",
        auto_approve=False,
        source="unreadable_spec",
    )
advancement = assess_advancement(
    policy,
    current_state="blocked",
    chain_last_state="blocked",
    explicit_human_gate=explicit_gate,
    failure_kind=failure_kind,
)
if advancement.action == "await_human":
    print(f"human gate preserved; blocked recovery not rewritten: {advancement.reason}")
    raise SystemExit(0)
if advancement.action != "repair":
    print("")
    raise SystemExit(0)

plan_name = str(plan_state.get("name") or plan_path.parent.name or plan_name_hint).strip()
meta = plan_state.get("meta")
meta = meta if isinstance(meta, dict) else {}
recoveries = meta.get("watchdog_dev_fix_recoveries")
recoveries = recoveries if isinstance(recoveries, list) else []
recoveries.append(
    {
        "recovered_at": datetime.now(timezone.utc).isoformat(),
        "iteration": iteration,
        "attempt_id": attempt_id,
        "reason": "dev_fix_cleared_repairable_execute_block",
        "previous_state": current_state,
        "previous_retry_strategy": retry_strategy,
        "previous_failure_kind": failure_kind,
        "advancement_policy": advancement.to_dict(),
    }
)
meta["watchdog_dev_fix_recoveries"] = recoveries
plan_state["meta"] = meta
plan_state["current_state"] = "finalized"
plan_state["resume_cursor"] = {"phase": "execute", "retry_strategy": "rerun_phase"}
plan_state["latest_failure"] = None
plan_state.pop("active_step", None)
write_json(plan_path, plan_state)

chain_state_info = target.get("chain_state") if isinstance(target.get("chain_state"), dict) else {}
chain_path_text = str(chain_state_info.get("path") or "").strip()
chain_path = Path(chain_path_text) if chain_path_text else None
if (chain_path is None or not chain_path.exists()) and run_kind == "chain" and workspace.exists():
    chain_candidates = sorted(
        (workspace / ".megaplan" / "plans" / ".chains").glob("*.json"),
        key=lambda path: path.stat().st_mtime if path.exists() else 0.0,
        reverse=True,
    )
    if chain_candidates:
        chain_path = chain_candidates[0]
if run_kind == "chain" and chain_path is not None and chain_path.exists():
    chain_state = load_json(chain_path)
    if (
        chain_state
        and str(chain_state.get("current_plan_name") or "").strip() == plan_name
        and str(chain_state.get("last_state") or "").strip().lower() == "blocked"
    ):
        chain_state["last_state"] = "finalized"
        chain_state["latest_failure"] = None
        write_json(chain_path, chain_state)

print(f"recovered blocked execute plan={plan_name} path={plan_path}")
PY
  )"
  if [[ -n "$recovery_summary" ]]; then
    log "$recovery_summary session=$SESSION iteration=$iteration attempt_id=$attempt_id"
  fi
}

verify_started_and_holding() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="$4"
  local plan_name="$5"
  local initial_secs="$6"
  local hold_secs="$7"
  local health first_health second_health initial_sleep hold_sleep

  initial_sleep="$(cap_timeout_to_repair_budget "$initial_secs" "verify-$session-initial-wait")"
  sleep "$initial_sleep"
  ensure_repair_budget_available "verify-$session-initial-health"
  first_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$first_health" != "alive" ]]; then
    echo "$first_health"
    return 1
  fi
  hold_sleep="$(cap_timeout_to_repair_budget "$hold_secs" "verify-$session-hold-wait")"
  sleep "$hold_sleep"
  ensure_repair_budget_available "verify-$session-hold-health"
  second_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$second_health" == "alive" ]]; then
    echo "alive"
    return 0
  fi
  echo "$second_health"
  return 1
}


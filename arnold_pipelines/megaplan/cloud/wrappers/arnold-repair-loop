CLEANUP_CHILDREN_RAN=0
REPAIR_LOCK_DIR_OWNED=0
REPAIR_PID_FILE_OWNED=0
REPAIR_SHUTDOWN_RAN=0
cleanup_children() {
  local pid pgid
  if [[ "$CLEANUP_CHILDREN_RAN" == "1" ]]; then
    return
  fi
  CLEANUP_CHILDREN_RAN=1
  for pid in "${CHILD_PIDS[@]:-}"; do
    if kill -0 "$pid" 2>/dev/null; then
      pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
      if [[ -n "$pgid" ]] && kill -- -"$pgid" 2>/dev/null; then
        :
      else
        kill "$pid" 2>/dev/null || true
      fi
    fi
  done
  sleep 0.5
  for pid in "${CHILD_PIDS[@]:-}"; do
    pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
    if [[ -n "$pgid" ]]; then
      kill -9 -- -"$pgid" 2>/dev/null || true
    fi
    kill -9 "$pid" 2>/dev/null || true
  done
}


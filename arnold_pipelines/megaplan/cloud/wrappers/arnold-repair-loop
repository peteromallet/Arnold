def _format_count_summary(counts: object) -> str:
    if not isinstance(counts, dict) or not counts:
        return "unknown"
    ordered_keys = ["completed", "done", "pending", "blocked", "skipped", "deferred", "failed", "error", "unknown"]
    parts: list[str] = []
    seen: set[str] = set()
    for key in ordered_keys + sorted(str(item) for item in counts):
        if key in seen:
            continue
        seen.add(key)
        value = counts.get(key)
        if isinstance(value, int) and value:
            label = "completed" if key == "done" else key
            parts.append(f"{value} {label}")
    return ", ".join(parts) if parts else "unknown"


def _task_key(task: object) -> str:
    if not isinstance(task, dict):
        return ""
    return str(task.get("task_id") or task.get("id") or "").strip()


def _blocked_task_candidates(context: object) -> list[dict[str, object]]:
    if not isinstance(context, dict):
        return []
    execution_batch = context.get("execution_batch")
    execute_batch_output = context.get("execute_batch_output")
    has_execute_blockers = False
    for section in (execution_batch, execute_batch_output):
        if not isinstance(section, dict):
            continue
        tasks = section.get("blocked_or_deferred_tasks")
        if isinstance(tasks, list) and any(isinstance(task, dict) for task in tasks):
            has_execute_blockers = True
            break
    execution_incomplete = False
    for section in (execution_batch, context.get("finalize")):
        if not isinstance(section, dict):
            continue
        counts = section.get("status_counts")
        if isinstance(counts, dict) and any(
            isinstance(counts.get(key), int) and counts.get(key) > 0
            for key in ("pending", "blocked", "deferred")
        ):
            execution_incomplete = True
            break
    candidates: list[dict[str, object]] = []
    for section_name, key in (
        ("execution_batch", "blocked_or_deferred_tasks"),
        ("execute_batch_output", "blocked_or_deferred_tasks"),
        ("finalize", "skipped_or_deferred_tasks"),
    ):
        section = context.get(section_name)
        if not isinstance(section, dict):
            continue
        tasks = section.get(key)
        if not isinstance(tasks, list):
            continue
        for task in tasks:
            if isinstance(task, dict):
                if (
                    section_name == "finalize"
                    and execution_incomplete
                    and not has_execute_blockers
                    and str(task.get("reviewer_verdict") or "").strip()
                    == "deferred_baseline_unavailable"
                ):
                    continue
                merged = dict(task)
                merged["_source"] = section_name
                candidates.append(merged)
    deduped: list[dict[str, object]] = []
    seen: set[str] = set()
    for task in candidates:
        key = _task_key(task) or json.dumps(task, sort_keys=True)
        if key in seen:
            continue
        seen.add(key)
        deduped.append(task)
    return deduped


def _task_reason(task: dict[str, object]) -> str:
    verdict = str(task.get("reviewer_verdict") or "").strip()
    notes = str(task.get("executor_notes") or "").strip()
    if verdict and notes:
        return f"{verdict}: {notes}"
    return verdict or notes or str(task.get("status") or "").strip() or "see artifact"


def _pending_task_candidates(context: object) -> list[dict[str, object]]:
    if not isinstance(context, dict):
        return []
    finalize = context.get("finalize")
    if not isinstance(finalize, dict):
        return []
    tasks = finalize.get("tasks")
    if not isinstance(tasks, list):
        return []
    pending: list[dict[str, object]] = []
    for task in tasks:
        if not isinstance(task, dict):
            continue
        if str(task.get("status") or "").strip().lower() == "pending":
            pending.append(task)
    return pending


def _review_blocking_items(context: object) -> list[dict[str, object]]:
    if not isinstance(context, dict):
        return []
    review = context.get("review")
    if not isinstance(review, dict):
        return []
    items = review.get("blocking_rework_items")
    if not isinstance(items, list):
        return []
    return [item for item in items if isinstance(item, dict)]


def _render_last_execute_attempt(context: object, plan_failure: dict[str, object]) -> str:
    lines = ["## LAST EXECUTE ATTEMPT"]
    if not isinstance(context, dict) or not context.get("has_execute_artifacts"):
        lines.append("- No execute-level artifacts found; using latest_failure, events, and logs below.")
    else:
        source = {}
        source_label = ""
        for label in ("finalize", "execution_batch", "execute_batch_output"):
            candidate = context.get(label)
            if isinstance(candidate, dict) and candidate.get("status_counts"):
                source = candidate
                source_label = label
                break
        task_count = source.get("task_count") if isinstance(source, dict) else None
        source_path = source.get("path") if isinstance(source, dict) else ""
        task_prefix = f"{task_count} task records" if isinstance(task_count, int) and task_count else "Tasks"
        lines.append(
            f"- Tasks: {_format_count_summary(source.get('status_counts') if isinstance(source, dict) else {})}"
            + (f" ({task_prefix}; source: {source_label} `{source_path}`)" if source_path else "")
        )

        blocked_tasks = _blocked_task_candidates(context)
        if blocked_tasks:
            first = blocked_tasks[0]
            blocked_ids = ", ".join(_task_key(task) or "(unknown)" for task in blocked_tasks[:5])
            if len(blocked_tasks) > 5:
                blocked_ids += f", +{len(blocked_tasks) - 5} more"
            lines.append(f"- Blocked/deferred task: {blocked_ids}")
            reason = _task_reason(first)
            lines.append(f"- Block reason: {reason}")
            notes = str(first.get("executor_notes") or "").strip()
            if notes:
                lines.append(f"  -> {notes}")
            lowered_block = f"{reason}\n{notes}".lower()
            if "no files modified" in lowered_block and "budget exhausted" in lowered_block:
                lines.append(
                    "- Repair directive: this is target-task budget exhaustion with no "
                    "implementation. Implement/requeue the target task and recover the plan "
                    "state; do not count an Arnold harness/classification patch as success "
                    "unless it directly enables that task to run again."
                )
        else:
            lines.append("- Blocked/deferred task: none found in execute/finalize artifacts")
            pending_tasks = _pending_task_candidates(context)
            if pending_tasks:
                pending_ids = ", ".join(_task_key(task) or "(unknown)" for task in pending_tasks[:5])
                if len(pending_tasks) > 5:
                    pending_ids += f", +{len(pending_tasks) - 5} more"
                lines.append(f"- Pending execute tasks: {pending_ids}")

        finalize = context.get("finalize")
        if isinstance(finalize, dict) and finalize:
            if finalize.get("baseline_test_failures") is None and "baseline_test_failures" in finalize:
                lines.append("  -> baseline_test_failures is null (baseline never captured)")
            note = str(finalize.get("baseline_test_note") or "").strip()
            if note:
                lines.append(f"  -> baseline capture failed: {note}")
            collection_errors = finalize.get("baseline_test_collection_errors")
            if isinstance(collection_errors, list) and collection_errors:
                lines.append(
                    f"  -> baseline pytest collection: {len(collection_errors)} errors "
                    f"(first: {collection_errors[0]})"
                )

        backstop = context.get("full_suite_backstop")
        if isinstance(backstop, dict) and backstop:
            status = backstop.get("status") or "unknown"
            base = backstop.get("baseline_failing_count")
            current = backstop.get("current_failing_count")
            lines.append(f"- Full suite backstop: status={status} baseline_failing_count={base} current_failing_count={current}")
            failing_tests = backstop.get("failing_tests")
            if isinstance(failing_tests, list) and failing_tests:
                lines.append(f"  -> failing_tests: {', '.join(str(item) for item in failing_tests[:5])}")
            collection_errors = backstop.get("collection_errors")
            if isinstance(collection_errors, list) and collection_errors:
                lines.append(
                    f"  -> pytest collection: {len(collection_errors)} errors "
                    f"(first: {collection_errors[0]})"
                )

        history = context.get("plan_history")
        if isinstance(history, dict):
            consecutive = history.get("consecutive_execute_blocked") or 0
            last_entries = history.get("last_entries") if isinstance(history.get("last_entries"), list) else []
            rendered_tail = ", ".join(
                f"{entry.get('step') or '?'}={entry.get('result') or '?'}"
                for entry in last_entries
                if isinstance(entry, dict)
            )
            if consecutive:
                lines.append(
                    f"- Plan history: {consecutive} consecutive execute=blocked "
                    "(not failed - this is a STATE block pattern, not necessarily a code bug)"
                )
            elif rendered_tail:
                lines.append(f"- Plan history last entries: {rendered_tail}")

        review = context.get("review")
        blocking_items = _review_blocking_items(context)
        if isinstance(review, dict) and review:
            verdict = review.get("review_verdict") or review.get("result") or review.get("state") or "unknown"
            lines.append(f"- Review verdict: {verdict} (source: `{review.get('path') or 'review.json'}`)")
        if blocking_items:
            ids = ", ".join(str(item.get("task_id") or "(unknown)") for item in blocking_items[:6])
            if len(blocking_items) > 6:
                ids += f", +{len(blocking_items) - 6} more"
            lines.append(
                f"- Review blocking rework: {ids} "
                "(these are concrete implementation blockers, not a human gate)"
            )

    kind = plan_failure.get("kind") or "unknown"
    message = plan_failure.get("message") or "unknown"
    phase = plan_failure.get("phase") or "unknown"
    latest_line = f"- latest_failure: {kind}: {phase} {message}".strip()
    if isinstance(context, dict):
        history = context.get("plan_history")
        blocked_tail = isinstance(history, dict) and bool(history.get("consecutive_execute_blocked"))
        if blocked_tail and str(kind) in {"phase_failed", "internal_error"} or blocked_tail:
            latest_line += (
                " (NOTE: this may be STALE - the execute is BLOCKING, not failing. "
                "Investigate the blocked/deferred task above before chasing latest_failure.)"
            )
    lines.append(latest_line)
    return "\n".join(lines)


last_execute_attempt_summary = _render_last_execute_attempt(execute_attempt_context, plan_failure)

review_blocking_items = _review_blocking_items(execute_attempt_context)
if review_blocking_items:
    review_blocker_lines = []
    for idx, item in enumerate(review_blocking_items[:8], start=1):
        task_id = item.get("task_id") or "(unknown)"
        issue = str(item.get("issue") or "missing issue").strip()
        expected = str(item.get("expected") or "").strip()
        actual = str(item.get("actual") or "").strip()
        evidence_file = str(item.get("evidence_file") or "").strip()
        command = str(item.get("deterministic_command") or "").strip()
        review_blocker_lines.append(f"{idx}. {task_id}: {issue}")
        if expected:
            review_blocker_lines.append(f"   expected: {expected}")
        if actual:
            review_blocker_lines.append(f"   actual: {actual}")
        if evidence_file:
            review_blocker_lines.append(f"   evidence_file: {evidence_file}")
        if command:
            review_blocker_lines.append(f"   deterministic_check: {command}")
    if len(review_blocking_items) > 8:
        review_blocker_lines.append(f"... +{len(review_blocking_items) - 8} more blocking items")
else:
    review_blocker_lines = ["- none detected"]

mismatch_lines = []
if state_mismatch.get("detected"):
    mismatch_lines = [
        "",
        "## STATE MISMATCH DETECTED + CLEARED",
        f"- Plan state: {state_mismatch.get('plan_state') or 'unknown'} (ready to execute)",
        (
            f"- Chain state was: {state_mismatch.get('chain_last_state') or 'unknown'} "
            "(STALE - from a prior run)"
        ),
        "- Action taken: cleared chain last_state to match plan current_state",
        (
            "- The chain should now proceed. If it still stops, investigate WHY the "
            "execute phase re-blocks despite the plan being ready."
        ),
    ]

user_action_context = latest_context.get("user_action_context") or {}
plan_runtime_state = latest_context.get("plan_runtime_state") or {}
clarification_questions = (
    plan_runtime_state.get("clarification_questions")
    if isinstance(plan_runtime_state.get("clarification_questions"), list)
    else []
)
clarification_source = str(plan_runtime_state.get("clarification_source") or "").strip()
if clarification_questions:
    prep_clarification_lines = [
        f"- source: {clarification_source or 'unknown'}",
        "- blocking question(s):",
        *[
            f"  {idx}. {question}"
            for idx, question in enumerate(clarification_questions, start=1)
        ],
        (
            "- If the repo, initiative assets, and prior plan documents provide enough "
            "evidence, answer these yourself with `megaplan override add-note` and then "
            "run `megaplan override resume-clarify`."
        ),
    ]
else:
    prep_clarification_lines = ["- none detected"]
unresolved_user_actions = user_action_context.get("unresolved_user_actions") or []
if unresolved_user_actions:
    user_action_lines = [
        f"- {item.get('id')}: state={item.get('resolution_state', 'unresolved')} "
        f"phase={item.get('phase', '')} blocks={', '.join(item.get('blocks_task_ids') or []) or 'unspecified'} "
        f"summary={item.get('summary') or item.get('rationale') or 'see user_actions.md'}"
        for item in unresolved_user_actions
        if isinstance(item, dict)
    ]
else:
    user_action_lines = ["- none detected"]
user_actions_md = str(user_action_context.get("user_actions_md") or "").strip()
if user_actions_md:
    user_actions_md = user_actions_md[:4000]
else:
    user_actions_md = "(none captured)"

history_lines = []
for item in iterations:
    attempted = item.get("dev_summary") or item.get("dev_hypothesis") or "n/a"
    why = item.get("why") or item.get("kimi_diagnosis") or item.get("mechanical_detail") or "n/a"
    history_lines.append(
        f"- i{item.get('i')} model={item.get('dev_model') or item.get('dev_model_requested') or 'n/a'} "
        f"attempted={attempted} outcome=mechanical:{item.get('mechanical_launch') or 'n/a'} "
        f"kimi:{item.get('kimi_launch') or 'n/a'} why_not_enough={why}"
    )
if not history_lines:
    history_lines.append("- none yet")

detail_paths = [f"- repair data: {path}"]
for label, value in (
    ("plan state", plan_failure.get("state_path")),
    ("plan events", plan_failure.get("events_path") or latest_context.get("plan_events_path")),
    ("chain state", chain_state.get("path")),
    ("run log", latest_context.get("run_log_path") or latest_context.get("chain_log_path") or latest_context.get("mechanical_log_path")),
    ("user actions", user_action_context.get("user_actions_path")),
    ("user action resolutions", user_action_context.get("resolutions_path")),
    ("finalize", user_action_context.get("finalize_path")),
):
    if value:
        detail_paths.append(f"- {label}: {value}")

summary = "\n".join(
    [
        last_execute_attempt_summary,
        "",
        "## Incident Snapshot",
        f"- run kind: {run_kind}",
        f"- failure classification: {classification}",
        f"- stale/live classification: {state_classification}",
        f"- stale-state analysis: {stale_summary}",
        f"- recommended repair action: {stale_recommendation or 'use failure classification'}",
        f"- plan state: {plan_state} / phase {phase} / iter {iteration_text}",
        chain_state_line,
        f"- latest_failure: kind={kind} recorded_at={recorded_at} exit_code={exit_code_text}",
        f"- latest_failure message: {message}",
        "- primary failure signal(s):",
        "```text",
        signal_text,
        "```",
        run_narrative_label,
        "```text",
        log_tail,
        "```",
        "- recent plan event journal tail:",
        "```text",
        events_tail,
        "```",
        "",
        "## Review Blocking Rework",
        "- These items are actionable implementation/test work. Do not classify them as a human-only stop merely because the plan is terminal `blocked` or `valid_next` is empty.",
        "- Repair path: implement the missing work, validate the deterministic checks, then let the wrapper mechanically relaunch/review.",
        *review_blocker_lines,
        "",
        "## Prep Clarification Gate",
        *prep_clarification_lines,
        "",
        "## User Action Gate",
        f"- plan dir: {user_action_context.get('plan_dir') or '(unknown)'}",
        "- unresolved action(s):",
        *user_action_lines,
        "- user_actions.md excerpt:",
        "```markdown",
        user_actions_md,
        "```",
        *mismatch_lines,
        "",
        "## Prior repair attempts",
        *history_lines,
        "",
        "## Full detail paths",
        *detail_paths,
    ]
)
print(summary)
PY
}

repair_data_init() {
  require_repair_lock_held
  local run_kind="$1"
  local plan_name="$2"
  local relaunch_command="$3"
  local initial_health="$4"
  local marker_json source_git workspace_git chain_log watchdog_log tmux_info chain_state failure_context payload_dir rc
  marker_json="$(cat "$MARKER_PATH" 2>/dev/null || true)"
  source_git="$(cd "$ARNOLD_SRC" 2>/dev/null && { git branch --show-current; git status --short; git log -1 --oneline; } 2>&1 || true)"
  workspace_git="$(cd "$WORKSPACE" 2>/dev/null && { git branch --show-current; git status --short; git log -1 --oneline; } 2>&1 || true)"
  chain_log="$(tail -120 "$WORKSPACE/.megaplan/cloud-chain.log" 2>/dev/null || tail -120 "$WORKSPACE/.megaplan/cloud-chain-${SESSION}.log" 2>/dev/null || true)"
  watchdog_log="$(tail -120 /workspace/watchdog.log 2>/dev/null || true)"
  tmux_info="$(tmux capture-pane -pt "$SESSION" -S -80 2>/dev/null || true)"
  chain_state="$(find "$WORKSPACE/.megaplan" -path '*/.chains/*.json' -o -name 'chain_state.json' 2>/dev/null | sort | tail -10)"
  failure_context="$(collect_failure_context_json "$WORKSPACE" "$SESSION" "$run_kind" "$plan_name")"
  payload_dir="$(mktemp -d)"
  printf '%s' "$marker_json" > "$payload_dir/marker_json"
  printf '%s' "$source_git" > "$payload_dir/source_git"
  printf '%s' "$workspace_git" > "$payload_dir/workspace_git"
  printf '%s' "$chain_log" > "$payload_dir/chain_log"
  printf '%s' "$watchdog_log" > "$payload_dir/watchdog_log"
  printf '%s' "$tmux_info" > "$payload_dir/tmux_info"
  printf '%s' "$chain_state" > "$payload_dir/chain_state"
  printf '%s' "$failure_context" > "$payload_dir/failure_context"
  PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$PROGRESS_FILE" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$run_kind" "$plan_name" "$ARNOLD_SRC" "$SYNC_BRANCH" "$RUN_DIR" "$relaunch_command" "$initial_health" "$payload_dir" "${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}" "${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}" <<'PY'
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud.repair_contract import (
    load_json,
    merge_additive_fields,
    save_repair_data,
)

(
    path,
    progress_path,
    session,
    workspace,
    spec,
    run_kind,
    plan_name,
    arnold_src,
    sync_branch,
    run_dir,
    relaunch_command,
    initial_health,
    payload_dir_raw,
    request_id,
    blocker_id,
) = sys.argv[1:]
payload_dir = pathlib.Path(payload_dir_raw)

def read_payload(name: str) -> str:
    try:
        return (payload_dir / name).read_text(encoding="utf-8")
    except FileNotFoundError:
        return ""

marker_json = read_payload("marker_json")
source_git = read_payload("source_git")
workspace_git = read_payload("workspace_git")
chain_log = read_payload("chain_log")
watchdog_log = read_payload("watchdog_log")
tmux_info = read_payload("tmux_info")
chain_state = read_payload("chain_state")
failure_context_payload = json.loads(read_payload("failure_context") or "{}")
data_path = pathlib.Path(path)
existing = load_json(data_path, default={})
attempts = existing.get("attempts") if isinstance(existing.get("attempts"), list) else []
if not attempts and isinstance(existing.get("iterations"), list):
    attempts = [item for item in existing.get("iterations") if isinstance(item, dict)]
repair_run_count = int(existing.get("repair_run_count") or 0) + 1

# Derive a stable incident_id from the session so the incident bridge and
# watchdog can both reference the same incident across repair cycles.
incident_id = str(existing.get("incident_id") or "").strip() or f"inc-{session}"

# Preserve dispatch-level request/blocker identity from triggering env.
dispatch_request_id = str(request_id or existing.get("request_id") or "").strip()
dispatch_blocker_id = str(blocker_id or existing.get("blocker_id") or "").strip()

payload = {
    "session": session,
    "workspace": workspace,
    "spec": spec,
    "run_kind": run_kind,
    "plan_name": plan_name,
    "arnold_src": arnold_src,
    "sync_branch": sync_branch,
    "run_dir": run_dir,
    "progress_path": progress_path,
    "repair_run_count": repair_run_count,
    "attempt_counter": int(existing.get("attempt_counter") or len(attempts)),
    "initial_facts": {
        "relaunch_command": relaunch_command,
        "initial_health": initial_health,
        "marker_json": marker_json,
        "source_git": source_git,
        "workspace_git": workspace_git,
        "failure_context": failure_context_payload,
        "chain_log_tail": failure_context_payload.get("chain_log_tail", chain_log),
        "chain_log_path": failure_context_payload.get("chain_log_path", ""),
        "run_log_tail": failure_context_payload.get("run_log_tail", ""),
        "run_log_path": failure_context_payload.get("run_log_path", ""),
        "chain_recent_events": failure_context_payload.get("chain_recent_events", []),
        "plan_events_tail": failure_context_payload.get("plan_events_tail", ""),
        "plan_events_path": failure_context_payload.get("plan_events_path", ""),
        "failure_classification": failure_context_payload.get("failure_classification", ""),
        "stale_state": failure_context_payload.get("stale_state", {}),
        "state_mismatch": failure_context_payload.get("state_mismatch", {}),
        "raw_failure_signals": failure_context_payload.get("raw_failure_signals", []),
        "mechanical_log_tail": failure_context_payload.get("mechanical_log_tail", ""),
        "mechanical_log_path": failure_context_payload.get("mechanical_log_path", ""),
        "plan_latest_failure": failure_context_payload.get("plan_latest_failure", {}),
        "chain_state_summary": failure_context_payload.get("chain_state_summary", {}),
        "plan_runtime_state": failure_context_payload.get("plan_runtime_state", {}),
        "last_gate": failure_context_payload.get("last_gate", {}),
        "user_action_context": failure_context_payload.get("user_action_context", {}),
        "execute_attempt_context": failure_context_payload.get("execute_attempt_context", {}),
        "watchdog_log_tail": watchdog_log,
        "tmux_pane_tail": tmux_info,
        "chain_state_files": chain_state,
    },
    "attempts": attempts,
    "current_attempt_id": None,
    "current_signature": {},
    "current_advancement_snapshot": {},
    "current_recurrence": {},
    "current_failure_context": failure_context_payload,
    "run_recurrence_detected": False,
    "iterations": [],
    "outcome": "repairing",
    "request_id": dispatch_request_id,
    "blocker_id": dispatch_blocker_id,
}
resolver_output = failure_context_payload.get("resolver_output")
payload["initial_facts"]["resolver_output"] = resolver_output or {}
payload = merge_additive_fields(payload, target=resolver_output or {}, incident_id=incident_id)
save_repair_data(data_path, payload)
PY
  rc=$?
  rm -rf "$payload_dir"
  return "$rc"
}


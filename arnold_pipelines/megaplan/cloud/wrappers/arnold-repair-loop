safe_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-'
}

guard_against_recursive_repair_loop() {
  local parent_pid="${CLOUD_WATCHDOG_REPAIR_LOOP_PID:-}"
  local parent_session="${CLOUD_WATCHDOG_REPAIR_LOOP_SESSION:-}"
  if [[ "${CLOUD_WATCHDOG_REPAIR_LOOP_ACTIVE:-0}" != "1" ]]; then
    return 0
  fi
  if [[ "$parent_pid" == "$$" ]]; then
    return 0
  fi
  if [[ -n "$parent_session" && "$parent_session" != "$SESSION" ]]; then
    return 0
  fi
  if [[ -n "$parent_pid" ]] && ! repair_loop_pid_matches_session "$parent_pid" "$SESSION"; then
    return 0
  fi
  log "repair loop recursion blocked; parent repair loop already active owner_session=${CLOUD_WATCHDOG_REPAIR_LOOP_SESSION:-unknown} owner_pid=${parent_pid:-unknown} requested_session=$SESSION"
  return 1
}

remaining_repair_budget_secs() {
  local now remaining
  now="$(date -u +%s)"
  remaining=$((REPAIR_DEADLINE_EPOCH - now))
  if (( remaining < 0 )); then
    remaining=0
  fi
  printf '%s\n' "$remaining"
}

require_repair_lock_held() {
  local current_pid=""
  if [[ "$REPAIR_LOCK_DIR_OWNED" != "1" || "$REPAIR_PID_FILE_OWNED" != "1" ]]; then
    log "repair lock invariant violated; mutation attempted without held lock session=$SESSION"
    exit 75
  fi
  if [[ -r "$REPAIR_PID_FILE" ]]; then
    read -r current_pid < "$REPAIR_PID_FILE" || current_pid=""
  fi
  if [[ "$current_pid" != "$$" ]]; then
    log "repair lock invariant violated; pidfile owner mismatch session=$SESSION owner_pid=${current_pid:-unknown} expected_pid=$$"
    exit 75
  fi
}

record_repair_timeout_and_exit() {
  local phase="$1"
  require_repair_lock_held
  if [[ -f "$DATA_FILE" ]]; then
    repair_data_set_outcome "repair_timeout"
  fi
  repair_goal_record_terminal_failure \
    "repair-timeout-$phase" \
    "repair_timeout" \
    "bounded repair budget exhausted before the original checkpoint advanced" || true
  log "repair budget exhausted; timing out session=$SESSION phase=$phase budget_secs=$REPAIR_BUDGET_SECS data=$DATA_FILE"
  exit 1
}

ensure_repair_budget_available() {
  local phase="$1"
  local remaining
  remaining="$(remaining_repair_budget_secs)"
  if (( remaining <= 0 )); then
    record_repair_timeout_and_exit "$phase"
  fi
}

cap_timeout_to_repair_budget() {
  local requested="$1"
  local phase="$2"
  local remaining
  ensure_repair_budget_available "$phase"
  remaining="$(remaining_repair_budget_secs)"
  if (( requested <= 0 )); then
    printf '%s\n' "$remaining"
    return 0
  fi
  if (( remaining < requested )); then
    printf '%s\n' "$remaining"
    return 0
  fi
  printf '%s\n' "$requested"
}


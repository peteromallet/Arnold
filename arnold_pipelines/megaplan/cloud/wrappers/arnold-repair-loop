collect_failure_context_json() {
  local workspace="$1"
  local session="$2"
  local run_kind="${3:-chain}"
  local plan_name="${4:-}"
  python3 - "$workspace" "$session" "$run_kind" "$plan_name" "$MARKER_DIR" "$DATA_DIR" "$REMOTE_SPEC" <<'PY'
import hashlib
import json
import pathlib
import re
import sys

workspace = pathlib.Path(sys.argv[1])
session = sys.argv[2]
run_kind = sys.argv[3]
marker_plan_name = sys.argv[4]
marker_dir = pathlib.Path(sys.argv[5]) if len(sys.argv) > 5 else workspace / ".megaplan" / "cloud-sessions"
repair_data_dir = pathlib.Path(sys.argv[6]) if len(sys.argv) > 6 else marker_dir / "repair-data"
remote_spec = pathlib.Path(sys.argv[7]) if len(sys.argv) > 7 and sys.argv[7] else None


def _tail_text(path: pathlib.Path, lines: int = 20) -> str:
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return ""
    tail = text.splitlines()[-lines:]
    return "\n".join(tail)


def _clip_text(text: object, limit: int = 12000) -> str:
    rendered = str(text or "")
    if len(rendered) <= limit:
        return rendered
    return rendered[-limit:]


def _load_json(path: pathlib.Path) -> dict[str, object]:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}


def _resolve_remote_spec(root: pathlib.Path, path: pathlib.Path | None) -> pathlib.Path | None:
    if path is None:
        return None
    candidates = [path]
    if not path.is_absolute():
        candidates.append(root / path)
    for candidate in candidates:
        try:
            resolved = candidate.resolve()
        except OSError:
            resolved = candidate
        if resolved.exists():
            return resolved
    return candidates[-1]


def _spec_milestone_count(root: pathlib.Path, spec_path: pathlib.Path | None) -> int:
    resolved_spec = _resolve_remote_spec(root, spec_path)
    candidates = [resolved_spec] if resolved_spec is not None and resolved_spec.exists() else []
    candidates.extend(sorted(root.glob(".megaplan/initiatives/**/chain.yaml")))
    seen: set[pathlib.Path] = set()
    for path in candidates:
        if path in seen:
            continue
        seen.add(path)
        try:
            count = 0
            in_milestones = False
            for raw in path.read_text(encoding="utf-8").splitlines():
                stripped = raw.strip()
                if stripped == "milestones:":
                    in_milestones = True
                    continue
                if in_milestones and stripped and not raw.startswith((" ", "-")):
                    break
                if in_milestones and stripped.startswith("- label:"):
                    count += 1
            if count:
                return count
        except Exception:
            continue
    return 0


def _chain_is_complete(chain_state: dict[str, object]) -> bool:
    milestones = chain_state.get("milestones") if isinstance(chain_state.get("milestones"), list) else []
    completed = chain_state.get("completed") if isinstance(chain_state.get("completed"), list) else []
    milestone_count = len(milestones) or _spec_milestone_count(workspace, remote_spec)
    try:
        current_idx = int(chain_state.get("current_milestone_index") or 0)
    except (TypeError, ValueError):
        current_idx = 0
    if milestone_count == 0:
        return str(chain_state.get("last_state") or "").strip().lower() in {"done", "complete"}
    return current_idx >= milestone_count or len(completed) >= milestone_count


def _artifact_sort_key(path: pathlib.Path) -> tuple[float, str]:
    try:
        mtime = path.stat().st_mtime
    except OSError:
        mtime = 0.0
    return (mtime, path.name)


def _newest_artifact(plan_dir: pathlib.Path, pattern: str) -> pathlib.Path | None:
    candidates = [path for path in plan_dir.glob(pattern) if path.is_file()]
    if not candidates:
        return None
    return sorted(candidates, key=_artifact_sort_key)[-1]


def _task_id(task: dict[str, object]) -> str:
    for key in ("task_id", "id"):
        value = task.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


def _task_excerpt(task: dict[str, object]) -> dict[str, object]:
    excerpt: dict[str, object] = {
        "task_id": _task_id(task),
        "status": task.get("status") or "",
        "executor_notes": _clip_text(task.get("executor_notes") or task.get("executor_note") or "", limit=1200),
        "reviewer_verdict": task.get("reviewer_verdict") or "",
    }
    for key in ("description", "kind", "depends_on"):
        value = task.get(key)
        if value not in (None, "", [], {}):
            excerpt[key] = _clip_text(value, limit=600)
    return excerpt


def _task_status_counts(tasks: list[dict[str, object]]) -> dict[str, int]:
    counts: dict[str, int] = {}
    for task in tasks:
        status = str(task.get("status") or "unknown").strip().lower() or "unknown"
        if status == "done":
            status = "completed"
        counts[status] = counts.get(status, 0) + 1
    return counts


def _task_is_blocked_or_deferred(task: dict[str, object]) -> bool:
    status = str(task.get("status") or "").strip().lower()
    verdict = str(task.get("reviewer_verdict") or "").strip().lower()
    notes = str(task.get("executor_notes") or "").strip().lower()
    return (
        status in {"blocked", "skipped", "deferred"}
        or "blocked" in verdict
        or "deferred" in verdict
        or "blocked" in notes
        or "deferred" in notes
    )


def _extract_task_updates(payload: dict[str, object]) -> list[dict[str, object]]:
    for key in ("task_updates", "tasks"):
        value = payload.get(key)
        if isinstance(value, list):
            return [item for item in value if isinstance(item, dict)]
    return []


def _summarize_execute_batch_artifact(path: pathlib.Path | None) -> dict[str, object]:
    if path is None:
        return {}
    payload = _load_json(path)
    if not payload:
        return {"path": str(path), "readable": False}
    tasks = [_task_excerpt(task) for task in _extract_task_updates(payload)]
    blocked_tasks = [task for task in tasks if _task_is_blocked_or_deferred(task)]
    return {
        "path": str(path),
        "readable": True,
        "status": payload.get("status") or payload.get("result") or "",
        "task_count": len(tasks),
        "status_counts": _task_status_counts(tasks),
        "tasks": tasks,
        "blocked_or_deferred_tasks": blocked_tasks,
        "output": _clip_text(payload.get("output") or "", limit=2000),
    }


def _summarize_finalize_artifact(path: pathlib.Path) -> dict[str, object]:
    payload = _load_json(path)
    if not payload:
        return {}
    tasks = [_task_excerpt(task) for task in _extract_task_updates(payload)]
    skipped_or_deferred = [
        task
        for task in tasks
        if str(task.get("status") or "").strip().lower() in {"skipped", "deferred", "blocked"}
        or str(task.get("reviewer_verdict") or "").strip()
    ]
    return {
        "path": str(path),
        "baseline_test_failures": payload.get("baseline_test_failures"),
        "baseline_test_note": payload.get("baseline_test_note") or "",
        "baseline_test_collection_errors": payload.get("baseline_test_collection_errors") or [],
        "baseline_test_command": payload.get("baseline_test_command") or "",
        "status_counts": _task_status_counts(tasks),
        "tasks": tasks,
        "skipped_or_deferred_tasks": skipped_or_deferred,
        "task_count": len(tasks),
    }


def _summarize_full_suite_backstop(path: pathlib.Path) -> dict[str, object]:
    payload = _load_json(path)
    if not payload:
        return {}
    return {
        "path": str(path),
        "status": payload.get("status") or "",
        "baseline_failing_count": payload.get("baseline_failing_count"),
        "current_failing_count": payload.get("current_failing_count") or payload.get("failed"),
        "failing_tests": payload.get("failing_tests") or [],
        "collection_errors": payload.get("collection_errors") or [],
        "note": payload.get("note") or "",
        "command": payload.get("command") or "",
    }


def _review_blocker_excerpt(item: object) -> dict[str, object]:
    if not isinstance(item, dict):
        return {}
    target = item.get("target") if isinstance(item.get("target"), dict) else {}
    deterministic = (
        item.get("deterministic_check")
        if isinstance(item.get("deterministic_check"), dict)
        else {}
    )
    return {
        "task_id": item.get("task_id") or target.get("task_id") or target.get("id") or "",
        "issue": _clip_text(item.get("issue") or "", limit=1200),
        "expected": _clip_text(item.get("expected") or "", limit=1200),
        "actual": _clip_text(item.get("actual") or "", limit=1200),
        "evidence_file": item.get("evidence_file") or "",
        "source": item.get("source") or "",
        "deterministic_command": deterministic.get("command") or "",
        "deterministic_post_status": deterministic.get("post_status") or "",
    }


def _summarize_review_artifact(path: pathlib.Path) -> dict[str, object]:
    payload = _load_json(path)
    if not payload:
        return {}
    blocking = [
        excerpt
        for excerpt in (_review_blocker_excerpt(item) for item in payload.get("blocking_rework_items") or [])
        if excerpt
    ]
    advisory_failed = [
        {
            "name": _clip_text(item.get("name") or "", limit=800),
            "priority": item.get("priority") or "",
            "pass": item.get("pass") or "",
            "evidence": _clip_text(item.get("evidence") or "", limit=1200),
        }
        for item in (payload.get("advisory_failed_criteria") or [])
        if isinstance(item, dict)
    ]
    outcome = payload.get("outcome") if isinstance(payload.get("outcome"), dict) else {}
    return {
        "path": str(path),
        "result": outcome.get("result") or payload.get("result") or "",
        "review_verdict": outcome.get("review_verdict") or payload.get("review_verdict") or "",
        "state": outcome.get("state") or payload.get("state") or "",
        "blocking_rework_items": blocking,
        "advisory_failed_criteria": advisory_failed[:8],
    }


def _history_tail_summary(plan_state: dict[str, object]) -> dict[str, object]:
    history = plan_state.get("history")
    if not isinstance(history, list):
        return {"last_entries": [], "consecutive_execute_blocked": 0}
    entries = [item for item in history if isinstance(item, dict)]
    last_entries = [
        {
            "step": item.get("step") or "",
            "result": item.get("result") or "",
            "timestamp": item.get("timestamp") or item.get("completed_at") or "",
            "output_file": item.get("output_file") or "",
        }
        for item in entries[-5:]
    ]
    consecutive = 0
    for item in reversed(entries):
        if (
            str(item.get("step") or "").strip().lower() == "execute"
            and str(item.get("result") or "").strip().lower() == "blocked"
        ):
            consecutive += 1
            continue
        break
    return {"last_entries": last_entries, "consecutive_execute_blocked": consecutive}


def _collect_execute_attempt_context(plan_dir: pathlib.Path, plan_state: dict[str, object]) -> dict[str, object]:
    output_path = _newest_artifact(plan_dir, "execute_batch_*_output.json")
    execution_path = _newest_artifact(plan_dir, "execution_batch_*.json")
    context: dict[str, object] = {
        "plan_dir": str(plan_dir),
        "execute_batch_output": _summarize_execute_batch_artifact(output_path),
        "execution_batch": _summarize_execute_batch_artifact(execution_path),
        "plan_history": _history_tail_summary(plan_state),
    }
    finalize_path = plan_dir / "finalize.json"
    if finalize_path.exists():
        context["finalize"] = _summarize_finalize_artifact(finalize_path)
    full_suite_path = plan_dir / "full_suite_backstop.json"
    if full_suite_path.exists():
        context["full_suite_backstop"] = _summarize_full_suite_backstop(full_suite_path)
    review_path = plan_dir / "review.json"
    if review_path.exists():
        context["review"] = _summarize_review_artifact(review_path)
    context["has_execute_artifacts"] = bool(
        context.get("execute_batch_output")
        or context.get("execution_batch")
        or context.get("finalize")
        or context.get("full_suite_backstop")
        or context.get("review")
        or (context.get("plan_history") or {}).get("last_entries")
    )
    return context


def _unique_strings(values: list[str]) -> list[str]:
    seen: set[str] = set()
    ordered: list[str] = []
    for value in values:
        text = str(value or "").strip()
        if not text or text in seen:
            continue
        seen.add(text)
        ordered.append(text)
    return ordered


def _interesting_log_lines(text: str, limit: int = 8) -> list[str]:
    if not text:
        return []
    patterns = (
        "error",
        "fatal",
        "traceback",
        "exception",
        "failed",
        "blocked",
        "usage:",
        "unrecognized arguments",
        "missing authentication",
        "missing credentials",
        "credit",
        "timeout",
        "couldn't find remote ref",
    )
    picked: list[str] = []
    for line in text.splitlines():
        lower = line.lower()
        if lower.startswith("state_written | state="):
            # Full state snapshots routinely contain config keys like
            # test_baseline_timeout that are not failure evidence.
            continue
        if any(token in lower for token in patterns):
            picked.append(line.strip())
    return _unique_strings(picked)[-limit:]


def _format_event_line(event: dict[str, object]) -> str:
    kind = str(event.get("kind") or "event")
    phase = str(event.get("phase") or "")
    payload = event.get("payload")
    details: list[str] = []
    if isinstance(payload, dict):
        for key in ("msg", "message", "error", "reason", "state", "status", "task_id", "base_branch", "provider"):
            value = payload.get(key)
            if value not in (None, "", [], {}):
                rendered = json.dumps(value, sort_keys=True) if isinstance(value, (dict, list)) else str(value)
                details.append(f"{key}={rendered}")
    elif payload not in (None, "", [], {}):
        details.append(str(payload))
    prefix = f"{phase}:{kind}" if phase else kind
    return f"{prefix} | {'; '.join(details[:4])}" if details else prefix


def _events_tail(path: pathlib.Path, limit: int = 12) -> str:
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return ""
    rendered: list[str] = []
    for raw in lines[-limit:]:
        try:
            event = json.loads(raw)
        except Exception:
            rendered.append(raw.strip())
            continue
        if isinstance(event, dict):
            rendered.append(_format_event_line(event))
        else:
            rendered.append(str(event))
    return "\n".join(line for line in rendered if line)


def _candidate_plan_states(root: pathlib.Path) -> list[pathlib.Path]:
    candidates = []
    for pattern in (
        ".megaplan/plans/*/state.json",
        ".megaplan/initiatives/*/.megaplan/plans/*/state.json",
    ):
        for path in root.glob(pattern):
            try:
                candidates.append((path.stat().st_mtime, path))
            except OSError:
                continue
    candidates.sort(reverse=True)
    return [path for _, path in candidates]


def _latest_chain_state(root: pathlib.Path) -> pathlib.Path | None:
    resolved_spec = _resolve_remote_spec(root, remote_spec)
    if resolved_spec is not None:
        try:
            digest = hashlib.sha1(str(resolved_spec.resolve()).encode("utf-8")).hexdigest()[:12]
        except OSError:
            digest = hashlib.sha1(str(resolved_spec).encode("utf-8")).hexdigest()[:12]
        for candidate in (
            root / ".megaplan" / "plans" / ".chains" / f"{resolved_spec.stem}-{digest}.json",
            resolved_spec.parent / ".megaplan" / "plans" / ".chains" / f"{resolved_spec.stem}-{digest}.json",
        ):
            if candidate.exists():
                return candidate
    chains_root = root / ".megaplan"
    candidates = set()
    candidates.update((root / ".megaplan" / "plans" / ".chains").glob("*.json"))
    candidates.update(root.glob(".megaplan/initiatives/*/.megaplan/plans/.chains/*.json"))
    candidates.update(chains_root.glob("**/chain_state.json"))
    ordered = []
    for path in candidates:
        try:
            ordered.append((path.stat().st_mtime, path))
        except OSError:
            continue
    ordered.sort(reverse=True)
    return ordered[0][1] if ordered else None


def _resolve_plan_state(root: pathlib.Path, preferred_plan_name: str) -> pathlib.Path | None:
    candidates = _candidate_plan_states(root)
    if preferred_plan_name:
        preferred = [path for path in candidates if path.parent.name == preferred_plan_name]
        if preferred:
            return preferred[0]
        return None
    return candidates[0] if candidates else None


def _metadata_excerpt(metadata: object) -> dict[str, object]:
    if not isinstance(metadata, dict):
        return {}
    excerpt: dict[str, object] = {}
    for key in (
        "stderr",
        "stdout",
        "output",
        "raw_output",
        "error",
        "message",
        "detail",
        "details",
        "reason",
        "command",

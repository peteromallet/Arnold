run_dev_fix_turn() {
  require_repair_lock_held
  require_investigation_before_mutation "dev-fix"
  local iteration="$1"
  local attempt_id="$2"
  local recurring="$3"
  local requested_model="$4"
  local dispatch_model="$5"
  local dispatch_kind="$6"
  local fallback_reason="$7"
  local prompt_path report_path before_sha after_sha rc dev_timeout reasoning_effort repair_workdir run_id_file managed_run_id
  local -a managed_cmd worker_cmd
  prompt_path="$RUN_DIR/iter${iteration}-dev-fix-prompt.md"
  report_path="$RUN_DIR/iter${iteration}-dev-fix-report.json"
  write_dev_prompt "$prompt_path" "$requested_model" "$dispatch_model" "$report_path" "$recurring"
  repair_workdir="$(repair_agent_workdir)"
  before_sha="$(cd "$repair_workdir" && git rev-parse HEAD 2>/dev/null || true)"
  dev_timeout="$DEV_TIMEOUT"
  reasoning_effort="$CODEX_REASONING_EFFORT"
  if [[ "$recurring" == "1" ]]; then
    dev_timeout="$DEV_ROOT_CAUSE_TIMEOUT"
    reasoning_effort="$ROOT_CAUSE_REASONING_EFFORT"
  fi
  dev_timeout="$(cap_timeout_to_repair_budget "$dev_timeout" "dev-dispatch-$iteration")"
  log "iteration=$iteration dev-fix model=$dispatch_model requested=$requested_model recurring=$recurring timeout=$dev_timeout reasoning=$reasoning_effort workdir=$repair_workdir"
  prepare_repair_agent_exec_env
  run_id_file="$RUN_DIR/iter${iteration}-dev-fix-managed-run-id"
  if [[ "$dispatch_kind" == "hermes" ]]; then
    worker_cmd=(timeout "$dev_timeout" env PYENV_VERSION="${PYENV_VERSION:-3.11.11}" PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python "$HERMES_LAUNCHER" --model="$dispatch_model" --toolsets="file,web,terminal" --query_file=@managed-stdin@ --project_dir="$repair_workdir")
  else
    worker_cmd=(timeout "$dev_timeout" env PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" codex exec --sandbox danger-full-access -c model="$dispatch_model" -c model_reasoning_effort="$reasoning_effort" -)
  fi
  managed_cmd=(
    python3 -m arnold_pipelines.megaplan.managed_agent run
    --run-kind automatic_repair_retry
    --identity-key "${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-$SESSION}:dev:$attempt_id:$iteration:$dispatch_model"
    --project-dir "$repair_workdir"
    --task-kind root_cause
    # The watchdog-authorized root is difficulty 8. High reasoning is carried
    # independently; never exceed the inherited managed-agent custody ceiling.
    --difficulty "$([[ "$recurring" == "1" ]] && printf 8 || printf 7)"
    --model "$dispatch_model"
    --reasoning-effort "$reasoning_effort"
    --route-class "repair_${dispatch_kind}${fallback_reason:+_fallback}"
    --backend "$dispatch_kind"
    --command-display "automatic repair dev-fix iteration $iteration"
    --description "Mutating fixer for ${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-repair blocker} in $SESSION at ${PLAN_NAME:-current plan}; authorized by investigator verdict ${INVESTIGATOR_RECOMMENDED_ACTION:-repair}"
    --origin-kind repair_loop_worker
    --origin-id "${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-$SESSION}"
    --origin-component arnold-repair-loop
    --trigger-id "$attempt_id"
    --require-output
    --lineage-key "repair-retry:${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-$SESSION}:dev"
    --run-id-file "$run_id_file"
    --link "repair_request_id=${CLOUD_WATCHDOG_REPAIR_REQUEST_ID:-}"
    --link "blocker_id=${CLOUD_WATCHDOG_REPAIR_BLOCKER_ID:-}"
    --link "cloud_session=$SESSION"
    --link "chain=$REMOTE_SPEC"
    --link "plan=$PLAN_NAME"
    --link "phase=dev_fix"
    --link "attempt=$attempt_id"
    --link "repair_goal_id=$ARNOLD_REPAIR_GOAL_ID"
    --link "repair_goal_path=$ARNOLD_REPAIR_GOAL_PATH"
    --link "repair_checkpoint_digest=$ARNOLD_REPAIR_CHECKPOINT_DIGEST"
  )
  if [[ -n "${ARNOLD_MANAGED_AGENT_RUN_ID:-}" ]]; then
    managed_cmd+=(--parent-run-id "$ARNOLD_MANAGED_AGENT_RUN_ID")
  fi
  managed_cmd+=(--stdin-file "$prompt_path")
  managed_cmd+=(-- "${worker_cmd[@]}")
  (cd "$repair_workdir" && "${managed_cmd[@]}") >> "$LOG" 2>&1 &
  local child_pid=$!
  CHILD_PIDS+=("$child_pid")
  if wait "$child_pid"; then
    rc=0
  else
    rc=$?
  fi
  managed_run_id="$(cat "$run_id_file" 2>/dev/null || true)"
  export CURRENT_MANAGED_REPAIR_WORKER_RUN_ID="$managed_run_id"
  after_sha="$(cd "$repair_workdir" && git rev-parse HEAD 2>/dev/null || true)"
  repair_data_record_dev "$iteration" "$attempt_id" "$requested_model" "$dispatch_model" "$fallback_reason" "$report_path" "$rc" "$before_sha" "$after_sha"
  append_repair_finding_if_reported "$iteration" "$report_path" "$dispatch_model"
}


#!/usr/bin/env bash
set -uo pipefail
set -m

if [[ $# -lt 3 ]]; then
  echo "usage: arnold-repair-loop <session> <workspace> <remote-spec>" >&2
  exit 64
fi

SESSION="$1"
WORKSPACE="$2"
REMOTE_SPEC="$3"

if [[ -f /workspace/.cloud-hot-env ]]; then
  set -a
  # shellcheck disable=SC1091
  . /workspace/.cloud-hot-env
  set +a
fi

MARKER_DIR="${CLOUD_WATCHDOG_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
MARKER_PATH="$MARKER_DIR/$SESSION.json"
ROOT="${CLOUD_WATCHDOG_REPAIR_ROOT:-${KIMI_GOAL_OPERATOR_ROOT:-/workspace/kimi-goal-operator}}"
DATA_DIR="${CLOUD_WATCHDOG_REPAIR_DATA_DIR:-$MARKER_DIR/repair-data}"
FINDINGS_DIR="${CLOUD_WATCHDOG_REPAIR_FINDINGS_DIR:-/workspace/repair-findings}"
FINDINGS_DOC="${CLOUD_WATCHDOG_REPAIR_FINDINGS_DOC:-$FINDINGS_DIR/persistent-problems.md}"
ARNOLD_SRC="${CLOUD_WATCHDOG_ARNOLD_SRC:-/workspace/arnold}"
SYNC_BRANCH="${CLOUD_WATCHDOG_SYNC_BRANCH:-editible-install}"
PRINCIPLES_PATH="${KIMI_GOAL_PRINCIPLES_PATH:-/usr/local/share/arnold-watchdog/principles.md}"
HERMES_LAUNCHER="${CLOUD_WATCHDOG_HERMES_LAUNCHER:-/root/.claude/skills/subagent-launcher/launch_hermes_agent.py}"
KIMI_MODEL="${KIMI_GOAL_MODEL:-kimi-k2.7-code}"
KIMI_BASE_URL="${KIMI_BASE_URL:-https://api.kimi.com/coding/v1}"
DEV_TIMEOUT="${CLOUD_WATCHDOG_DEV_FIX_TIMEOUT_SECS:-600}"
DEV_ROOT_CAUSE_TIMEOUT="${CLOUD_WATCHDOG_DEV_FIX_ROOT_CAUSE_TIMEOUT_SECS:-1800}"
KIMI_TIMEOUT="${CLOUD_WATCHDOG_KIMI_TIMEOUT_SECS:-600}"
MECHANICAL_VERIFY_INITIAL_SECS="${CLOUD_WATCHDOG_MECHANICAL_VERIFY_INITIAL_SECS:-12}"
MECHANICAL_VERIFY_HOLD_SECS="${CLOUD_WATCHDOG_MECHANICAL_VERIFY_HOLD_SECS:-18}"
KIMI_VERIFY_INITIAL_SECS="${CLOUD_WATCHDOG_KIMI_VERIFY_INITIAL_SECS:-12}"
KIMI_VERIFY_HOLD_SECS="${CLOUD_WATCHDOG_KIMI_VERIFY_HOLD_SECS:-18}"
KIMI_MAX_TURNS="${CLOUD_WATCHDOG_KIMI_MAX_TURNS:-40}"
CODEX_REASONING_EFFORT="${CLOUD_WATCHDOG_CODEX_REASONING_EFFORT:-low}"
ROOT_CAUSE_REASONING_EFFORT="${CLOUD_WATCHDOG_ROOT_CAUSE_REASONING_EFFORT:-high}"
REPAIR_RECURRENCE_MIN_DISPATCHES="${CLOUD_WATCHDOG_REPAIR_RECURRENCE_MIN_DISPATCHES:-3}"
REPAIR_RECURRENCE_WINDOW_SECS="${CLOUD_WATCHDOG_REPAIR_RECURRENCE_WINDOW_SECS:-21600}"
DISCORD_DM_BIN="${DISCORD_DM_BIN:-$ARNOLD_SRC/arnold_pipelines/megaplan/cloud/wrappers/arnold-discord-dm}"

TS="$(date -u +%Y%m%dT%H%M%SZ)"
SAFE_SESSION="$(printf '%s' "$SESSION" | tr -c 'A-Za-z0-9_.-' '-')"
RUN_DIR="$ROOT/${TS}-${SAFE_SESSION}"
LOG="$RUN_DIR/operator.log"
DATA_FILE="$DATA_DIR/${SAFE_SESSION}.repair-data.json"
PROGRESS_FILE="$MARKER_DIR/${SAFE_SESSION}.repair-progress.json"
NEEDS_HUMAN_FILE="$DATA_DIR/${SAFE_SESSION}.needs-human.json"
REPAIR_PID_FILE="${CLOUD_WATCHDOG_REPAIR_PID_FILE:-$MARKER_DIR/${SAFE_SESSION}.repair-loop.pid}"

mkdir -p "$RUN_DIR" "$DATA_DIR" "$FINDINGS_DIR"

CHILD_PIDS=()
CLEANUP_CHILDREN_RAN=0
REPAIR_PID_FILE_OWNED=0
REPAIR_SHUTDOWN_RAN=0
cleanup_children() {
  local pid pgid
  if [[ "$CLEANUP_CHILDREN_RAN" == "1" ]]; then
    return
  fi
  CLEANUP_CHILDREN_RAN=1
  for pid in "${CHILD_PIDS[@]:-}"; do
    if kill -0 "$pid" 2>/dev/null; then
      pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
      if [[ -n "$pgid" ]] && kill -- -"$pgid" 2>/dev/null; then
        :
      else
        kill "$pid" 2>/dev/null || true
      fi
    fi
  done
  sleep 0.5
  for pid in "${CHILD_PIDS[@]:-}"; do
    pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
    if [[ -n "$pgid" ]]; then
      kill -9 -- -"$pgid" 2>/dev/null || true
    fi
    kill -9 "$pid" 2>/dev/null || true
  done
}

log() {
  echo "[repair-loop $(date -Iseconds)] $*" | tee -a "$LOG"
}

clear_session_repair_markers_now() {
  rm -f "$NEEDS_HUMAN_FILE" "$MARKER_DIR/$SESSION.kimi-dispatch" "$MARKER_DIR/$SESSION.kimi-pgid" 2>/dev/null || true
}

repair_loop_pid_matches_session() {
  local pid="$1"
  local session="${2:-}"
  python3 - "$pid" "$session" <<'PY'
import os
import pathlib
import shlex
import subprocess
import sys

pid_text, session = sys.argv[1:]
try:
    pid = int(pid_text)
except (TypeError, ValueError):
    raise SystemExit(1)
if pid <= 0:
    raise SystemExit(1)

def parse_args() -> list[str]:
    cmdline_path = pathlib.Path(f"/proc/{pid}/cmdline")
    if cmdline_path.exists():
        raw = cmdline_path.read_bytes()
        return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]
    proc = subprocess.run(
        ["ps", "-ww", "-o", "args=", "-p", str(pid)],
        check=False,
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        return []
    text = proc.stdout.strip()
    if not text:
        return []
    try:
        return shlex.split(text)
    except ValueError:
        return text.split()

args = parse_args()
if not args:
    raise SystemExit(1)

def match_at(idx: int) -> bool:
    if idx >= len(args):
        return False
    base = os.path.basename(args[idx])
    if base != "arnold-repair-loop":
        return False
    if not session:
        return True
    return idx + 1 < len(args) and args[idx + 1] == session

for idx in range(len(args)):
    if match_at(idx):
        raise SystemExit(0)
    base = os.path.basename(args[idx])
    if base in {"bash", "sh"} and match_at(idx + 1):
        raise SystemExit(0)

raise SystemExit(1)
PY
}

release_repair_lock() {
  local current_pid=""
  if [[ "$REPAIR_PID_FILE_OWNED" != "1" ]]; then
    return
  fi
  if [[ -r "$REPAIR_PID_FILE" ]]; then
    read -r current_pid < "$REPAIR_PID_FILE" || current_pid=""
  fi
  if [[ "$current_pid" == "$$" ]]; then
    rm -f "$REPAIR_PID_FILE" 2>/dev/null || true
  fi
  REPAIR_PID_FILE_OWNED=0
}

shutdown_repair_loop() {
  if [[ "$REPAIR_SHUTDOWN_RAN" == "1" ]]; then
    return
  fi
  REPAIR_SHUTDOWN_RAN=1
  cleanup_children
  release_repair_lock
}

trap 'shutdown_repair_loop' EXIT
trap 'shutdown_repair_loop; exit 129' HUP
trap 'shutdown_repair_loop; exit 130' INT
trap 'shutdown_repair_loop; exit 143' TERM

acquire_repair_lock() {
  local existing_pid=""
  mkdir -p "$(dirname "$REPAIR_PID_FILE")"
  while true; do
    if ( set -o noclobber; printf '%s\n' "$$" > "$REPAIR_PID_FILE" ) 2>/dev/null; then
      REPAIR_PID_FILE_OWNED=1
      log "repair pid claimed session=$SESSION pid=$$ pidfile=$REPAIR_PID_FILE"
      return 0
    fi
    if [[ -r "$REPAIR_PID_FILE" ]]; then
      read -r existing_pid < "$REPAIR_PID_FILE" || existing_pid=""
    else
      existing_pid=""
    fi
    if repair_loop_pid_matches_session "$existing_pid" "$SESSION"; then
      log "another repair loop is already active; exiting session=$SESSION owner_pid=$existing_pid pidfile=$REPAIR_PID_FILE"
      return 1
    fi
    if [[ -n "$existing_pid" ]]; then
      log "stale repair pidfile detected; reclaiming session=$SESSION stale_pid=$existing_pid pidfile=$REPAIR_PID_FILE"
    else
      log "empty repair pidfile detected; reclaiming session=$SESSION pidfile=$REPAIR_PID_FILE"
    fi
    rm -f "$REPAIR_PID_FILE" 2>/dev/null || true
    sleep 0.05
  done
}

safe_name() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-'
}

guard_against_recursive_repair_loop() {
  local parent_pid="${CLOUD_WATCHDOG_REPAIR_LOOP_PID:-}"
  if [[ "${CLOUD_WATCHDOG_REPAIR_LOOP_ACTIVE:-0}" != "1" ]]; then
    return 0
  fi
  if [[ "$parent_pid" == "$$" ]]; then
    return 0
  fi
  if [[ -n "$parent_pid" ]] && ! repair_loop_pid_matches_session "$parent_pid"; then
    return 0
  fi
  log "repair loop recursion blocked; parent repair loop already active owner_session=${CLOUD_WATCHDOG_REPAIR_LOOP_SESSION:-unknown} owner_pid=${parent_pid:-unknown} requested_session=$SESSION"
  return 1
}


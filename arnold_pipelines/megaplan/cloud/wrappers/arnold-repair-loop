import datetime as dt
import json
import os
import pathlib
import sys

data_path_raw, failure_context_raw = sys.argv[1:]
data_path = pathlib.Path(data_path_raw)
failure_context = json.loads(failure_context_raw)
stale_state = failure_context.get("stale_state") if isinstance(failure_context, dict) else {}
if not isinstance(stale_state, dict):
    stale_state = {}
state_mismatch = failure_context.get("state_mismatch") if isinstance(failure_context, dict) else {}
if not isinstance(state_mismatch, dict):
    state_mismatch = {}
has_stale_state = stale_state.get("classification") == "STALE STATE"
has_state_mismatch = bool(state_mismatch.get("detected"))
if not has_stale_state and not has_state_mismatch:
    print("none")
    raise SystemExit(0)

plan_failure = failure_context.get("plan_latest_failure") if isinstance(failure_context, dict) else {}
state_path_raw = plan_failure.get("state_path") if isinstance(plan_failure, dict) else ""
if not state_path_raw:
    state_path_raw = state_mismatch.get("plan_state_path") or ""
if not state_path_raw:
    print("failed:missing_state_path")
    raise SystemExit(1)
state_path = pathlib.Path(str(state_path_raw))
try:
    state = json.loads(state_path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"failed:state_unreadable:{exc}")
    raise SystemExit(1)
if not isinstance(state, dict):
    print("failed:state_not_object")
    raise SystemExit(1)

actions: list[str] = []
stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
if has_stale_state and stale_state.get("latest_failure_stale") and state.get("latest_failure") is not None:
    state["latest_failure"] = None
    success = stale_state.get("latest_success_after_failure")
    success_ts = success.get("timestamp") if isinstance(success, dict) else "unknown"
    actions.append(f"latest_failure was stale (predates last success at {success_ts}) -- cleared")

block = stale_state.get("stale_block_replay") if has_stale_state else {}
if isinstance(block, dict) and block.get("detected"):
    artifact_hash = block.get("artifact_hash")
    history = state.get("history")
    if isinstance(history, list) and artifact_hash:
        removed = 0
        while history:
            item = history[-1]
            if not isinstance(item, dict):
                break
            try:
                duration_zero = int(item.get("duration_ms") or 0) == 0
            except (TypeError, ValueError):
                duration_zero = False
            if (
                str(item.get("result") or "").lower() == "blocked"
                and item.get("artifact_hash") == artifact_hash
                and duration_zero
            ):
                history.pop()
                removed += 1
                continue
            break
        if removed:
            actions.append(f"removed {removed} trailing stale 0ms blocked history entr{'y' if removed == 1 else 'ies'} with artifact_hash={artifact_hash}")
    phase_result_path = state_path.parent / "phase_result.json"
    if phase_result_path.exists():
        backup = state_path.parent / f"phase_result.stale-{stamp}.json"
        try:
            os.replace(phase_result_path, backup)
            actions.append(f"moved stale phase_result.json to {backup.name}")
        except OSError as exc:
            actions.append(f"failed to move stale phase_result.json: {exc}")

if has_state_mismatch:
    chain_state_path = pathlib.Path(str(state_mismatch.get("chain_state_path") or ""))
    plan_current_state = str(state.get("current_state") or state_mismatch.get("plan_state") or "").strip()
    chain_was = str(state_mismatch.get("chain_last_state") or "").strip()
    if not chain_state_path:
        actions.append("state mismatch detected but chain state path was unavailable")
    elif not plan_current_state:
        actions.append("state mismatch detected but plan current_state was unavailable")
    else:
        try:
            chain_payload = json.loads(chain_state_path.read_text(encoding="utf-8"))
        except Exception as exc:
            actions.append(f"state mismatch detected but chain state was unreadable: {exc}")
        else:
            if not isinstance(chain_payload, dict):
                actions.append("state mismatch detected but chain state was not a JSON object")
            else:
                chain_was = str(chain_payload.get("last_state") or chain_was or "").strip()
                chain_payload["last_state"] = plan_current_state
                metadata = chain_payload.setdefault("metadata", {})
                if isinstance(metadata, dict):
                    records = metadata.setdefault("watchdog_repair_state_mismatch_clears", [])
                    if isinstance(records, list):
                        records.append(
                            {
                                "cleared_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                                "plan_state": plan_current_state,
                                "chain_last_state_was": chain_was,
                                "plan_state_path": str(state_path),
                                "chain_state_path": str(chain_state_path),
                            }
                        )
                tmp_chain_path = chain_state_path.with_suffix(chain_state_path.suffix + ".tmp")
                tmp_chain_path.write_text(
                    json.dumps(chain_payload, indent=2, sort_keys=True) + "\n",
                    encoding="utf-8",
                )
                os.replace(tmp_chain_path, chain_state_path)
                state_mismatch["cleared"] = True
                state_mismatch["action_taken"] = (
                    f"cleared chain last_state to match plan current_state ({plan_current_state})"
                )
                actions.append(
                    "state mismatch detected + cleared "
                    f"(plan={plan_current_state}, chain was {chain_was or 'unknown'}, synced)"
                )

if not actions:
    print("none")
    raise SystemExit(0)

meta = state.setdefault("meta", {})
if isinstance(meta, dict):
    records = meta.setdefault("watchdog_repair_stale_state_clears", [])
    if isinstance(records, list):
        records.append(
            {
                "cleared_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                "actions": actions,
                "stale_state": stale_state,
                "state_mismatch": state_mismatch,
            }
        )

tmp_path = state_path.with_suffix(state_path.suffix + ".tmp")
tmp_path.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n", encoding="utf-8")
os.replace(tmp_path, state_path)

payload = json.loads(data_path.read_text(encoding="utf-8"))
failure_context["state_mismatch"] = state_mismatch
payload.setdefault("stale_state_actions", []).append(
    {
        "recorded_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "actions": actions,
        "stale_state": stale_state,
        "state_mismatch": state_mismatch,
        "state_path": str(state_path),
    }
)
initial = payload.setdefault("initial_facts", {})
initial["failure_context"] = failure_context
initial["stale_state"] = stale_state
initial["state_mismatch"] = state_mismatch
data_path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print("cleared:" + "; ".join(actions))
PY
}

clear_repair_markers() {
  clear_session_repair_markers_now
}

exit_if_repair_target_complete() {
  local phase="$1"
  local complete_flag scope reason chain_path plan_path plan_state
  IFS=$'\t' read -r complete_flag scope reason chain_path plan_path plan_state <<< "$(repair_target_completion_status "$WORKSPACE" "$RUN_KIND" "$PLAN_NAME")"
  if [[ "${complete_flag:-0}" != "1" ]]; then
    return 0
  fi
  if [[ -f "$DATA_FILE" ]]; then
    repair_data_set_outcome "complete"
  fi
  clear_repair_markers
  if [[ "$scope" == "chain" ]]; then
    log "chain already complete; no repair needed session=$SESSION phase=$phase reason=$reason chain_state_path=${chain_path:-n/a} plan_state=${plan_state:-unknown} plan_state_path=${plan_path:-n/a}"
  else
    log "plan already complete; no repair needed session=$SESSION phase=$phase reason=$reason plan_state_path=${plan_path:-n/a}"
  fi
  exit 0
}

verify_started_and_holding() {
  local session="$1"
  local workspace="$2"
  local remote_spec="$3"
  local run_kind="$4"
  local plan_name="$5"
  local initial_secs="$6"
  local hold_secs="$7"
  local health first_health second_health

  sleep "$initial_secs"
  first_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$first_health" != "alive" ]]; then
    echo "$first_health"
    return 1
  fi
  sleep "$hold_secs"
  second_health="$(session_health_status "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name")"
  if [[ "$second_health" == "alive" ]]; then
    echo "alive"
    return 0
  fi
  echo "$second_health"
  return 1
}

kill_tmux_session_if_present() {
  local session="$1"
  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session" 2>/dev/null || true
    for _ in 1 2 3 4 5; do
      tmux has-session -t "$session" 2>/dev/null || break
      sleep 0.2
    done
  fi
}

mechanical_launch_step() {
  local iteration="$1"
  local session="$2"
  local workspace="$3"
  local remote_spec="$4"
  local run_kind="$5"
  local plan_name="$6"
  local relaunch_command="$7"
  local quoted_command launch_script safe detail health

  quoted_command="$(resolve_relaunch_command "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name" "$relaunch_command")" || {
    echo "failed:missing_relaunch_command"
    return 1
  }
  kill_tmux_session_if_present "$session"
  safe="$(safe_name "$session")"
  launch_script="$(mktemp)"
  cat > "$launch_script" <<EOF
#!/usr/bin/env bash
set -euo pipefail
cd $(printf '%q' "$workspace")
exec /usr/local/bin/arnold-supervise "watchdog-$safe" bash -lc "$quoted_command"
EOF
  chmod +x "$launch_script"
  if ! tmux new-session -d -s "$session" -c "$workspace" "bash '$launch_script'"; then
    rm -f "$launch_script"
    echo "failed:tmux_launch_failed"
    return 1
  fi
  rm -f "$launch_script"
  health="$(verify_started_and_holding "$session" "$workspace" "$remote_spec" "$run_kind" "$plan_name" "$MECHANICAL_VERIFY_INITIAL_SECS" "$MECHANICAL_VERIFY_HOLD_SECS")" || {
    detail="$health"
    kill_tmux_session_if_present "$session"
    echo "failed:$detail"
    return 1
  }
  echo "running"
}

repair_recurrence_prepare_attempt() {
  local iteration="$1"
  local requested_model="$2"
  local dispatch_model="$3"
  local failure_context
  failure_context="$(collect_failure_context_json "$WORKSPACE" "$SESSION" "$RUN_KIND" "$PLAN_NAME")"
  PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" python3 - "$DATA_FILE" "$PROGRESS_FILE" "$failure_context" "$iteration" "$requested_model" "$dispatch_model" "$REPAIR_RECURRENCE_MIN_DISPATCHES" "$REPAIR_RECURRENCE_WINDOW_SECS" <<'PY'
import datetime as dt
import json
import pathlib
import sys

from arnold_pipelines.megaplan.cloud import repair_recurrence

(
    data_path_raw,
    progress_path_raw,
    failure_context_raw,
    iteration_raw,
    requested_model,
    dispatch_model,
    min_dispatches_raw,
    window_seconds_raw,
) = sys.argv[1:]
data_path = pathlib.Path(data_path_raw)
progress_path = pathlib.Path(progress_path_raw)
failure_context = json.loads(failure_context_raw)
payload = json.loads(data_path.read_text(encoding="utf-8"))
try:
    progress_payload = json.loads(progress_path.read_text(encoding="utf-8"))
except Exception:
    progress_payload = {}

iteration = int(iteration_raw)
min_dispatches = max(int(min_dispatches_raw), 1)
window_seconds = max(int(window_seconds_raw), 0)
dispatched_at = dt.datetime.now(dt.timezone.utc).isoformat()
signature = repair_recurrence.build_problem_signature(failure_context)
advancement = repair_recurrence.build_advancement_snapshot(
    failure_context,
    run_kind=str(payload.get("run_kind") or ""),
)
session_snapshot = repair_recurrence.update_session_repair_snapshot(
    progress_payload,
    advancement,
    dispatched_at=dispatched_at,
    min_dispatches=min_dispatches,
    window_seconds=window_seconds,
)
recurrence = repair_recurrence.evaluate_recurrence(
    signature,
    payload.get("attempts") if isinstance(payload.get("attempts"), list) else [],
    session_snapshot,
)
attempt_id = int(payload.get("attempt_counter") or 0) + 1
payload["attempt_counter"] = attempt_id
payload["current_attempt_id"] = attempt_id
payload["current_failure_context"] = failure_context
payload["current_signature"] = signature
payload["current_advancement_snapshot"] = advancement
payload["current_recurrence"] = {
    **recurrence,
    "attempt_id": attempt_id,
    "iteration": iteration,
    "requested_model": requested_model,
    "dispatch_model": dispatch_model,
    "dispatched_at": dispatched_at,
    "root_cause_mode": bool(recurrence.get("detected")),
}
payload["run_recurrence_detected"] = bool(payload.get("run_recurrence_detected")) or bool(recurrence.get("detected"))
data_path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
progress_path.write_text(json.dumps(session_snapshot, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(f"{attempt_id}\t{1 if recurrence.get('detected') else 0}")
PY
}

render_recurrence_block() {
  python3 - "$DATA_FILE" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
payload = json.loads(path.read_text(encoding="utf-8"))
recurrence = payload.get("current_recurrence") or {}
if not recurrence.get("detected"):
    raise SystemExit(0)
attempts = payload.get("attempts") if isinstance(payload.get("attempts"), list) else []
matching_ids = {
    int(item)
    for item in (recurrence.get("layer1") or {}).get("matching_attempt_ids") or []
    if str(item).strip()
}
if matching_ids:
    relevant = [
        item
        for item in attempts
        if isinstance(item, dict) and int(item.get("attempt_id") or 0) in matching_ids
    ]
else:
    take = max(int((recurrence.get("layer2") or {}).get("no_advance_dispatch_count") or 1) - 1, 1)
    relevant = [item for item in attempts if isinstance(item, dict)][-take:]
signature = recurrence.get("problem_signature") or {}
signature_bits = []
for key in (
    "failure_kind",
    "current_state",
    "phase_or_step",
    "milestone_or_plan",
    "gate_recommendation",
    "blocked_task_id",
):
    value = str(signature.get(key) or "").strip() or "-"
    signature_bits.append(f"{key}={value}")
print("## RECURRENCE EVIDENCE")
print(f"- Recurrence detected for this session on attempt {recurrence.get('attempt_number')}.")
layer1 = recurrence.get("layer1") or {}
layer2 = recurrence.get("layer2") or {}
if layer1.get("detected"):
    print(
        "- Layer 1 fired: the same controlled-field problem signature returned after "
        f"{layer1.get('repeat_count')} prior repair dispatch(es)."
    )
if layer2.get("detected"):
    print(
        "- Layer 2 fired: the session absorbed "
        f"{layer2.get('no_advance_dispatch_count')} repair dispatches within "
        f"{layer2.get('window_seconds')} seconds with no milestone/state advancement."
    )
print("- Recurrence means the prior attempts treated symptoms, not the cause.")
print(f"- Controlled signature: `({' ; '.join(signature_bits)})`")
print("- Prior fixes for this problem:")
if not relevant:
    print("- none captured")
for item in relevant[-4:]:
    model = item.get("dev_model") or item.get("dev_model_requested") or "n/a"
    attempted = item.get("dev_summary") or "n/a"
    dev_report = item.get("dev_report") if isinstance(item.get("dev_report"), dict) else {}
    if attempted == "n/a" and dev_report:
        attempted = dev_report.get("what_tried") or dev_report.get("fix_summary") or "n/a"
    commit = item.get("dev_fix_sha") or "none"
    conclusion = item.get("dev_hypothesis") or item.get("why") or item.get("kimi_diagnosis") or "n/a"
    print(
        f"- attempt {item.get('attempt_id') or item.get('i') or '?'}: "
        f"model={model} what_tried={attempted} commit={commit} conclusion={conclusion}"
    )
PY
}

repair_exhausted_should_retry_without_human() {
  python3 - "$DATA_FILE" <<'PY'
import json
import pathlib
import sys

payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
recurrence = payload.get("current_recurrence") or {}
run_detected = bool(payload.get("run_recurrence_detected")) or bool(recurrence.get("detected"))
failure_context = payload.get("current_failure_context") if isinstance(payload.get("current_failure_context"), dict) else {}
plan_runtime = failure_context.get("plan_runtime_state") if isinstance(failure_context.get("plan_runtime_state"), dict) else {}
user_action_context = failure_context.get("user_action_context") if isinstance(failure_context.get("user_action_context"), dict) else {}
unresolved = user_action_context.get("unresolved_user_actions") if isinstance(user_action_context.get("unresolved_user_actions"), list) else []

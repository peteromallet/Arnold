}

run_dev_fix_turn() {
  local iteration="$1"
  local requested_model="$2"
  local dispatch_model="$3"
  local dispatch_kind="$4"
  local fallback_reason="$5"
  local prompt_path report_path before_sha after_sha rc
  prompt_path="$RUN_DIR/iter${iteration}-dev-fix-prompt.md"
  report_path="$RUN_DIR/iter${iteration}-dev-fix-report.json"
  write_dev_prompt "$prompt_path" "$requested_model" "$dispatch_model" "$report_path"
  before_sha="$(cd "$ARNOLD_SRC" && git rev-parse HEAD 2>/dev/null || true)"
  log "iteration=$iteration dev-fix model=$dispatch_model requested=$requested_model"
  if [[ "$dispatch_kind" == "hermes" ]]; then
    (
      cd "$ARNOLD_SRC" &&
      timeout "$DEV_TIMEOUT" env PYENV_VERSION="${PYENV_VERSION:-3.11.11}" python "$HERMES_LAUNCHER" \
        --model="$dispatch_model" \
        --toolsets="file,web,terminal" \
        --query_file="$prompt_path" \
        --project_dir="$ARNOLD_SRC"
    ) >> "$LOG" 2>&1 &
  else
    (
      cd "$ARNOLD_SRC" &&
      timeout "$DEV_TIMEOUT" codex exec \
        --sandbox danger-full-access \
        -c model="$dispatch_model" \
        -c model_reasoning_effort="$CODEX_REASONING_EFFORT" \
        "$(cat "$prompt_path")" </dev/null
    ) >> "$LOG" 2>&1 &
  fi
  local child_pid=$!
  CHILD_PIDS+=("$child_pid")
  if wait "$child_pid"; then
    rc=0
  else
    rc=$?
  fi
  after_sha="$(cd "$ARNOLD_SRC" && git rev-parse HEAD 2>/dev/null || true)"
  repair_data_record_dev "$iteration" "$requested_model" "$dispatch_model" "$fallback_reason" "$report_path" "$rc" "$before_sha" "$after_sha"
}

run_kimi_launch_turn() {
  local iteration="$1"
  local run_kind="$2"
  local plan_name="$3"
  local relaunch_command="$4"
  local prompt_path report_path rc health
  prompt_path="$RUN_DIR/iter${iteration}-kimi-prompt.md"
  report_path="$RUN_DIR/iter${iteration}-kimi-report.json"
  write_kimi_prompt "$prompt_path" "$relaunch_command" "$report_path"
  log "iteration=$iteration kimi-launch model=$KIMI_MODEL"
  (
    cd "$ARNOLD_SRC" &&
    PYTHONSAFEPATH=1 PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" \
    timeout "$KIMI_TIMEOUT" python3 -P -m arnold.agent.run_agent \
      --query="$(cat "$prompt_path")" \
      --model="$KIMI_MODEL" \
      --api_key="${KIMI_API_KEY:-}" \
      --base_url="$KIMI_BASE_URL" \
      --max_turns="$KIMI_MAX_TURNS" \
      --enabled_toolsets='"terminal,file,code_execution,todo"' \
      --save_sample=True
  ) >> "$LOG" 2>&1 &
  local child_pid=$!
  CHILD_PIDS+=("$child_pid")
  if wait "$child_pid"; then
    rc=0
  else
    rc=$?
  fi
  health="$(verify_started_and_holding "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$run_kind" "$plan_name" "$KIMI_VERIFY_INITIAL_SECS" "$KIMI_VERIFY_HOLD_SECS")" || {
    repair_data_record_kimi "$iteration" "failed:$health" "$report_path" "$rc"
    kill_tmux_session_if_present "$SESSION"
    return 1
  }
  repair_data_record_kimi "$iteration" "running" "$report_path" "$rc"
  return 0
}


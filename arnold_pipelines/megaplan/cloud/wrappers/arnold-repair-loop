save_repair_data(pathlib.Path(path), payload)
PY
}

append_repair_finding_if_reported() {
  local iteration="$1"
  local report_path="$2"
  local dev_model="$3"
  python3 - "$report_path" "$FINDINGS_DOC" "$iteration" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$ARNOLD_SRC" "$DATA_FILE" "$dev_model" <<'PY'
import datetime as dt
import json
import os
import pathlib
import sys

(
    report_path_raw,
    findings_doc_raw,
    iteration,
    session,
    workspace,
    remote_spec,
    arnold_src,
    data_file,
    dev_model,
) = sys.argv[1:]
report_path = pathlib.Path(report_path_raw)
findings_doc = pathlib.Path(findings_doc_raw)
if not report_path.exists():
    raise SystemExit(0)
try:
    report = json.loads(report_path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

structural_pattern = str(report.get("structural_pattern") or "").strip()
if not structural_pattern:
    raise SystemExit(0)
if report.get("findings_doc_appended") is True:
    raise SystemExit(0)

def _as_lines(value: object) -> list[str]:
    if value in (None, "", [], {}):
        return []
    if isinstance(value, list):
        lines = []
        for item in value:
            text = str(item).strip()
            if text:
                lines.append(text)
        return lines
    text = str(value).strip()
    return [text] if text else []

now = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
fixed_lines = _as_lines(
    report.get("what_tried")
    or report.get("fix_summary")
    or report.get("source_changes")
    or report.get("root_cause")
    or report.get("hypothesis")
)
instantiations = _as_lines(report.get("other_instantiations"))
recommendations = _as_lines(report.get("human_review_recommendation") or report.get("recommendation"))
remaining = _as_lines(report.get("remaining_blockers"))

lines = [
    "",
    f"## {now} -- {session} -- dev-fix iteration {iteration}",
    "",
    f"- Workspace: `{workspace}`",
    f"- Run input: `{remote_spec}`",
    f"- Arnold source: `{arnold_src}`",
    f"- Repair data: `{data_file}`",
    f"- Dev model: `{dev_model}`",
    f"- Dev report: `{report_path}`",
    "",
    "### Immediate Root / Fix",
]
lines.extend(f"- {line}" for line in fixed_lines) if fixed_lines else lines.append("- Not reported.")
lines.extend(["", "### Deeper Pattern", f"- {structural_pattern}", "", "### Other Instantiations To Review"])
lines.extend(f"- {line}" for line in instantiations) if instantiations else lines.append("- Not reported.")
lines.extend(["", "### Human Review Recommendation"])
lines.extend(f"- {line}" for line in recommendations) if recommendations else lines.append("- Not reported.")
if remaining:
    lines.extend(["", "### Remaining Blockers"])
    lines.extend(f"- {line}" for line in remaining)
lines.append("")

findings_doc.parent.mkdir(parents=True, exist_ok=True)
if not findings_doc.exists():
    findings_doc.write_text(
        "# Watchdog Repair Persistent Problems\n\n"
        "Structural findings noticed by repair-loop dev-fix agents. These are "
        "not formal megaplan tickets yet; review and promote the important ones.\n",
        encoding="utf-8",
    )
with findings_doc.open("a", encoding="utf-8") as handle:
    handle.write("\n".join(lines))
PY
}


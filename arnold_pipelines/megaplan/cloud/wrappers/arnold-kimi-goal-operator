#!/usr/bin/env bash
set -uo pipefail
set -m   # job control: background subshells get separate process groups

if [[ $# -lt 3 ]]; then
  echo "usage: arnold-kimi-goal-operator <session> <workspace> <remote-spec>" >&2
  exit 64
fi

SESSION="$1"
WORKSPACE="$2"
REMOTE_SPEC="$3"

ROOT="${KIMI_GOAL_OPERATOR_ROOT:-/workspace/kimi-goal-operator}"
ARNOLD_SRC="${KIMI_GOAL_ARNOLD_SRC:-/workspace/arnold}"
SYNC_BRANCH="${KIMI_GOAL_SYNC_BRANCH:-${CLOUD_WATCHDOG_SYNC_BRANCH:-editible-install}}"
PRINCIPLES_PATH="${KIMI_GOAL_PRINCIPLES_PATH:-/usr/local/share/arnold-watchdog/principles.md}"
MODEL="${KIMI_GOAL_MODEL:-kimi-k2.7-code}"
BASE_URL="${KIMI_BASE_URL:-https://api.kimi.com/coding/v1}"
TIMEOUT="${KIMI_GOAL_TIMEOUT_SECS:-3600}"
MAX_TURNS="${KIMI_GOAL_MAX_TURNS:-120}"
CODEX_TIMEOUT="${KIMI_GOAL_CODEX_TIMEOUT_SECS:-7200}"
CODEX_MODEL="${KIMI_GOAL_CODEX_MODEL:-gpt-5.6-sol}"
# Meta-loop repairs run under the validated partnered-5 profile
# (arnold_pipelines/megaplan/profiles/partnered-5.toml). Propagate it as the
# default so any megaplan repair subcommand dispatched by this operator's tools
# (resume/auto/doctor/chain) inherits partnered-5 unless a caller pins one.
DEFAULT_PROFILE="${KIMI_GOAL_DEFAULT_PROFILE:-partnered-5}"
export MEGAPLAN_DEFAULT_PROFILE="$DEFAULT_PROFILE"
export MEGAPLAN_REPAIR_PROFILE="$DEFAULT_PROFILE"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
SAFE_SESSION="$(printf '%s' "$SESSION" | tr -c 'A-Za-z0-9_.-' '-')"
RUN_DIR="$ROOT/${TS}-${SAFE_SESSION}"
LOG="$RUN_DIR/operator.log"
PROMPT="$RUN_DIR/prompt.md"
CODEX_PROMPT="$RUN_DIR/codex-repair-prompt.md"
CODEX_LOG="$RUN_DIR/codex-repair.log"
FACTS="$RUN_DIR/facts.txt"
REPORT="$RUN_DIR/report.json"

mkdir -p "$RUN_DIR"

CHILD_PIDS=()
CLEANUP_CHILDREN_RAN=0
cleanup_children() {
  local pid
  local pgid
  if [[ "$CLEANUP_CHILDREN_RAN" == "1" ]]; then
    return
  fi
  CLEANUP_CHILDREN_RAN=1
  for pid in "${CHILD_PIDS[@]:-}"; do
    if kill -0 "$pid" 2>/dev/null; then
      pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
      if [[ -n "$pgid" ]] && kill -- -"$pgid" 2>/dev/null; then
        :
      else
        kill "$pid" 2>/dev/null || true
      fi
    fi
  done
  sleep 0.5
  for pid in "${CHILD_PIDS[@]:-}"; do
    pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
    if [[ -n "$pgid" ]]; then
      kill -9 -- -"$pgid" 2>/dev/null || true
    fi
    kill -9 "$pid" 2>/dev/null || true
  done
}
trap cleanup_children EXIT INT TERM HUP

log() {
  echo "[kimi-goal $(date -Iseconds)] $*" | tee -a "$LOG"
}

capture() {
  local title="$1"
  shift
  {
    echo
    echo "### $title"
    "$@" 2>&1 || true
  } >> "$FACTS"
}

write_report() {
  local status="$1"
  local message="$2"
  python3 - "$REPORT" "$status" "$message" "$SESSION" "$WORKSPACE" "$REMOTE_SPEC" "$RUN_DIR" <<'PY'
import datetime as dt
import json
import sys

path, status, message, session, workspace, remote_spec, run_dir = sys.argv[1:]
payload = {
    "timestamp_utc": dt.datetime.now(dt.timezone.utc).isoformat(),
    "status": status,
    "message": message,
    "session": session,
    "workspace": workspace,
    "remote_spec": remote_spec,
    "run_dir": run_dir,
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2, sort_keys=True)
    handle.write("\n")
PY
}

log "starting session=$SESSION workspace=$WORKSPACE spec=$REMOTE_SPEC model=$MODEL"

if [[ -z "${KIMI_API_KEY:-}" ]]; then
  log "KIMI_API_KEY is missing; cannot run Kimi goal operator"
  write_report "skipped" "KIMI_API_KEY missing"
  exit 78
fi

capture "tmux sessions" tmux ls
capture "processes" bash -lc "ps -eo pid,ppid,etime,stat,cmd | grep -E 'arnold|megaplan|codex|python|tmux' | grep -v grep | tail -120"
capture "workspace files" bash -lc "ls -la '$WORKSPACE' '$WORKSPACE/.megaplan' '$WORKSPACE/.megaplan/cloud-sessions' 2>/dev/null"
capture "chain marker" bash -lc "cat /workspace/.megaplan/cloud-sessions/${SESSION}.json 2>/dev/null || true"
capture "chain state files" bash -lc "find '$WORKSPACE/.megaplan' -path '*/.chains/*.json' -o -name 'chain_state.json' 2>/dev/null | sort | xargs -r -I{} sh -c 'echo --- {}; tail -200 {}'"
capture "cloud chain logs" bash -lc "tail -240 '$WORKSPACE/.megaplan/cloud-chain.log' 2>/dev/null; tail -240 '$WORKSPACE/.megaplan/cloud-chain-${SESSION}.log' 2>/dev/null"
capture "watchdog report" bash -lc "cat /workspace/watchdog-report.json 2>/dev/null || true"
capture "watchdog log" bash -lc "tail -160 /workspace/watchdog.log 2>/dev/null || true"
capture "arnold source git" bash -lc "cd '$ARNOLD_SRC' 2>/dev/null && git status --short && git branch --show-current && git log -1 --oneline || true"
capture "workspace git" bash -lc "cd '$WORKSPACE' 2>/dev/null && git status --short && git branch --show-current && git log -1 --oneline || true"
capture "subagent launcher skill" bash -lc "for p in /root/.codex/skills/subagent-launcher/SKILL.md /root/.hermes/skills/subagent-launcher/SKILL.md /root/.agents/skills/subagent-launcher/SKILL.md /root/.claude/skills/subagent-launcher/SKILL.md /workspace/arnold/arnold_pipelines/megaplan/skills/subagent-launcher/SKILL.md; do echo --- \$p; test -f \"\$p\" && sed -n '1,180p' \"\$p\" || echo missing; done"
capture "subagent launcher commands" bash -lc "command -v codex || true; ls -la /root/.codex/skills/subagent-launcher /root/.hermes/skills/subagent-launcher /workspace/arnold/arnold_pipelines/megaplan/skills/subagent-launcher 2>/dev/null || true"

if [[ -f "$PRINCIPLES_PATH" ]]; then
  PRINCIPLES_TEXT="$(cat "$PRINCIPLES_PATH")"
else
  PRINCIPLES_TEXT="No external principles file found at $PRINCIPLES_PATH."
fi

cat > "$PROMPT" <<EOF
# Goal

The user's invariant is: workflows on this Hetzner worker should never pause unexpectedly. If a Megaplan/Arnold workflow stops, stalls, or breaks, understand the root cause, fix that root cause at ROOT in the Arnold editable install, validate it, push it, refresh the install, unblock the current run, relaunch it, and keep checking until it appears to be running again.

# Current Incident

- Machine: Hetzner cloud worker container.
- Session: $SESSION
- Workspace: $WORKSPACE
- Chain spec: $REMOTE_SPEC
- Arnold editable install source: $ARNOLD_SRC
- Arnold editable install branch: $SYNC_BRANCH
- Facts file: $FACTS
- Principles file: $PRINCIPLES_PATH

# Repair Principles

$PRINCIPLES_TEXT

# Required Behavior

1. Read the facts file and inspect the machine/repo as needed.
2. Determine why this run stopped or became unhealthy. Do not assume a restart is enough.
3. Before modifying Arnold source, confirm $ARNOLD_SRC is on $SYNC_BRANCH. Do not let MEGAPLAN_REF or the active workflow workspace branch choose the editable-install branch.
4. If the issue needs deep investigation or source changes, do not continue the repair entirely in your own context. First read the \$subagent-launcher SKILL.md from the facts file, then dispatch Codex through that skill. Your Codex brief should contain the core issue, evidence, constraints, and plausible hypotheses only; do not prescribe the implementation. Codex should determine and apply the solution in $ARNOLD_SRC.
5. If \$subagent-launcher or Codex cannot be launched, report that as a blocker with the exact command/error instead of continuing as if the repair happened.
6. Validate the fix with the smallest relevant checks. At minimum, confirm:
   - python3 -c "import arnold_pipelines.megaplan.cloud.cli"
   - python3 -c "import arnold_pipelines.megaplan.chain"
   - any focused test or smoke command you identify as relevant.
7. Commit and push the root-cause fix from $ARNOLD_SRC to $SYNC_BRANCH if source changes were made and validation passes.
8. Refresh the Arnold install from $ARNOLD_SRC after a pushed/validated fix.
9. Unblock/relaunch the affected run safely. Do not bypass true human approval gates, PR merge waits, or quality gates that require human judgment; report those as legitimate blockers.
10. Re-check after relaunch. The goal is complete only when the run is running/healthy, complete, or blocked solely on a true human/quality gate.

# Output Contract

Finish with a concise report containing:

- classification: healthy | repaired_and_relaunched | legitimate_blocker | unresolved
- root_cause
- fix_summary
- validation
- pushed_commit
- relaunch_result
- remaining_blockers

Do not ask the user for input. Keep iterating until the goal is satisfied or a non-automatable blocker remains.
EOF

cat > "$CODEX_PROMPT" <<EOF
You are the Codex repair subagent launched by the cloud watchdog via the local \$subagent-launcher contract.

Goal: workflows on this Hetzner worker should not pause unexpectedly. Investigate the current Megaplan/Arnold failure, fix the root cause in the Arnold editable install when source changes are needed, validate narrowly, commit and push to $SYNC_BRANCH, then leave enough evidence for the Kimi supervisor to relaunch or continue the run.

Context:
- Session: $SESSION
- Active workflow workspace: $WORKSPACE
- Chain spec: $REMOTE_SPEC
- Arnold editable install source: $ARNOLD_SRC
- Editable install branch: $SYNC_BRANCH
- Facts file: $FACTS
- Principles file: $PRINCIPLES_PATH

Constraints:
- Source fixes belong in $ARNOLD_SRC on $SYNC_BRANCH, not only in the active workflow checkout.
- Keep the editable install branch independent from MEGAPLAN_REF and from the active workflow branch.
- Codex phases should use the Codex plan/CLI path.
- DeepSeek phases should use direct DeepSeek API credentials, not OpenRouter, unless the chain explicitly asks for OpenRouter.
- Treat provider dependency errors as probable routing/config bugs.
- Do not blindly repin all phases to one repair model.

Evidence and plausible hypotheses:
- The watchdog marked this run unhealthy; inspect the facts file, chain state, active logs, and relevant Arnold routing code.
- A plausible class of failure is stale phase/provider routing or a provider resolver choosing OpenRouter for DeepSeek when direct DeepSeek credentials should be used.
- Another plausible class is stale runtime pins shadowing intended profile/vendor defaults.
- These are hypotheses only. Determine the actual cause from code and logs.

Required output:
- root_cause
- source_changes
- validation
- pushed_commit
- relaunch_or_supervisor_next_step
- remaining_blockers
EOF

log "launching Codex repair subagent"
if command -v codex >/dev/null 2>&1; then
  (
    cd "$ARNOLD_SRC" &&
    python3 -m arnold_pipelines.megaplan.managed_agent run \
      --run-kind automatic_legacy_fixer \
      --identity-key "legacy-fixer:${SESSION}:${TS}:codex" \
      --project-dir "$ARNOLD_SRC" \
      --task-kind root_cause \
      --difficulty 9 \
      --model "$CODEX_MODEL" \
      --reasoning-effort high \
      --route-class legacy_goal_operator_codex \
      --backend codex \
      --command-display "legacy goal operator Codex repair $SESSION" \
      --origin-kind legacy_fixer_wrapper \
      --origin-id "$SESSION" \
      --origin-component arnold-kimi-goal-operator \
      --trigger-id "$TS" \
      --stdin-file "$CODEX_PROMPT" \
      --require-output \
      --lineage-key "legacy-fixer:$SESSION:codex" \
      --link "cloud_session=$SESSION" \
      --link "chain=$REMOTE_SPEC" \
      --link phase=legacy_codex_repair \
      -- timeout "$CODEX_TIMEOUT" codex exec --sandbox danger-full-access \
        -c model="$CODEX_MODEL" -c model_reasoning_effort=high -
  ) > "$CODEX_LOG" 2>&1 &
  CODEX_PID=$!
  CHILD_PIDS+=("$CODEX_PID")
  if wait "$CODEX_PID"; then
    codex_rc=0
  else
    codex_rc=$?
  fi
  log "Codex repair subagent finished rc=$codex_rc"
  capture "codex repair subagent result" bash -lc "printf 'rc=%s\nprompt=%s\nlog=%s\n' '$codex_rc' '$CODEX_PROMPT' '$CODEX_LOG'; tail -260 '$CODEX_LOG' 2>/dev/null"
else
  log "Codex CLI missing; Kimi must report Codex launch blocker"
  capture "codex repair subagent result" bash -lc "echo 'codex CLI missing; command -v codex failed'"
  codex_rc=127
fi

log "launching Kimi goal operator"
RUN_CWD="$ARNOLD_SRC"
if [[ ! -d "$RUN_CWD" ]]; then
  RUN_CWD="$WORKSPACE"
fi
(
  cd "$RUN_CWD" &&
  PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" \
  python3 -m arnold_pipelines.megaplan.managed_agent run \
    --run-kind automatic_legacy_fixer \
    --identity-key "legacy-fixer:${SESSION}:${TS}:kimi" \
    --project-dir "$RUN_CWD" \
    --task-kind debugging \
    --difficulty 7 \
    --model "$MODEL" \
    --reasoning-effort bounded \
    --route-class legacy_goal_operator_kimi \
    --backend kimi \
    --command-display "legacy Kimi goal operator $SESSION" \
    --origin-kind legacy_fixer_wrapper \
    --origin-id "$SESSION" \
    --origin-component arnold-kimi-goal-operator \
    --trigger-id "$TS" \
    --require-output \
    --stdin-file "$PROMPT" \
    --lineage-key "legacy-fixer:$SESSION:kimi" \
    --link "cloud_session=$SESSION" \
    --link "chain=$REMOTE_SPEC" \
    --link phase=legacy_kimi_operator \
    -- env PYTHONSAFEPATH=1 PYTHONPATH="$ARNOLD_SRC:${PYTHONPATH:-}" \
      timeout "$TIMEOUT" python3 -P -m arnold.agent.run_agent \
      --query_file=@managed-stdin@ \
      --model="$MODEL" \
      --api_key="$KIMI_API_KEY" \
      --base_url="$BASE_URL" \
      --max_turns="$MAX_TURNS" \
      --enabled_toolsets='"terminal,file,code_execution,todo"' \
      --save_sample=True
) >> "$LOG" 2>&1 &
AGENT_PID=$!
CHILD_PIDS+=("$AGENT_PID")
if wait "$AGENT_PID"; then
  rc=0
else
  rc=$?
fi

if [[ $rc -eq 0 ]]; then
  log "Kimi goal operator completed"
  write_report "completed" "Kimi goal operator completed"
else
  log "Kimi goal operator failed rc=$rc"
  write_report "failed" "Kimi goal operator failed rc=$rc"
fi

exit "$rc"

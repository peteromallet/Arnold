#!/usr/bin/env bash
set -uo pipefail

MODE="${1:-tmux-unmarked}"
shift || true

MARKER_DIR="${MEGAPLAN_DISCOVER_MARKER_DIR:-/workspace/.megaplan/cloud-sessions}"
SRC_DIR="${MEGAPLAN_DISCOVER_ARNOLD_SRC:-/workspace/arnold}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --marker-dir)
      MARKER_DIR="$2"
      shift 2
      ;;
    --src-dir)
      SRC_DIR="$2"
      shift 2
      ;;
    *)
      echo "arnold-cloud-discover: unknown argument: $1" >&2
      exit 64
      ;;
  esac
done

case "$MODE" in
  tmux-unmarked)
    python3 - "$MARKER_DIR" "$SRC_DIR" <<'PY'
import pathlib
import re
import shlex
import subprocess
import sys

marker_dir = pathlib.Path(sys.argv[1])
src_dir = sys.argv[2]

try:
    panes_proc = subprocess.run(
        ["tmux", "list-panes", "-a", "-F", "#S\t#{pane_pid}\t#{pane_current_path}\t#{pane_start_command}"],
        text=True,
        capture_output=True,
        check=False,
    )
except FileNotFoundError:
    raise SystemExit(0)
if panes_proc.returncode != 0:
    raise SystemExit(0)

ps_proc = subprocess.run(
    ["ps", "-eo", "pid=,ppid=,args="],
    text=True,
    capture_output=True,
    check=False,
)
children: dict[int, list[tuple[int, str]]] = {}
if ps_proc.returncode == 0:
    for raw in ps_proc.stdout.splitlines():
        parts = raw.strip().split(None, 2)
        if len(parts) < 3:
            continue
        try:
            pid = int(parts[0])
            ppid = int(parts[1])
        except ValueError:
            continue
        children.setdefault(ppid, []).append((pid, parts[2]))


def _split(raw: str) -> list[str]:
    try:
        return shlex.split(raw)
    except Exception:
        return raw.split()


def _extract_flag(tokens: list[str], flag: str) -> str | None:
    prefix = flag + "="
    for idx, token in enumerate(tokens):
        if token == flag and idx + 1 < len(tokens):
            return tokens[idx + 1]
        if token.startswith(prefix):
            return token[len(prefix):]
    return None


def _workspace_for(current_path: str) -> str | None:
    if not current_path.startswith("/workspace/"):
        return None
    current = pathlib.Path(current_path)
    for candidate in (current, *current.parents):
        if str(candidate) == "/workspace":
            break
        if (candidate / ".megaplan").exists():
            return str(candidate)
    return None


def _descendants(root_pid: int) -> list[str]:
    stack = [root_pid]
    seen: set[int] = set()
    out: list[str] = []
    while stack:
        current = stack.pop()
        for child_pid, args in children.get(current, []):
            if child_pid in seen:
                continue
            seen.add(child_pid)
            out.append(args)
            stack.append(child_pid)
    return out


def _skip_session(session: str) -> bool:
    lowered = session.lower()
    return (
        lowered == "heartbeat"
        or lowered.startswith("watchdog-")
        or lowered.startswith("auditor-")
        or "watchdog" in lowered
        or "auditor" in lowered
        or "kimi" in lowered
    )


def _plan_relaunch_command(plan_name: str, workspace: str) -> str:
    log_path = f"{workspace}/.megaplan/cloud-logs/{plan_name}.log"
    return (
        "if [[ -f /workspace/.cloud-hot-env ]]; then set -a; . /workspace/.cloud-hot-env; set +a; fi; "
        f"cd {shlex.quote(src_dir)} && "
        f"PYTHONSAFEPATH=1 PYTHONPATH={shlex.quote(src_dir)}:${{PYTHONPATH:-}} "
        "MEGAPLAN_TRUSTED_CONTAINER=1 "
        f"python3 -P -m arnold_pipelines.megaplan auto --plan {shlex.quote(plan_name)} "
        f"--project-dir {shlex.quote(workspace)} >> {shlex.quote(log_path)} 2>&1"
    )


def _chain_relaunch_command(remote_spec: str, workspace: str, session: str) -> str:
    log_relative = ".megaplan/cloud-chain.log" if session == "megaplan-chain" else f".megaplan/cloud-chain-{session}.log"
    return (
        "if [[ -f /workspace/.cloud-hot-env ]]; then set -a; . /workspace/.cloud-hot-env; set +a; fi; "
        f"cd {shlex.quote(src_dir)} && "
        f"PYTHONSAFEPATH=1 PYTHONPATH={shlex.quote(src_dir)}:${{PYTHONPATH:-}} "
        "MEGAPLAN_TRUSTED_CONTAINER=1 "
        f"python3 -P -m arnold_pipelines.megaplan chain start --spec {shlex.quote(remote_spec)} "
        f"--project-dir {shlex.quote(workspace)} >> {shlex.quote(workspace + '/' + log_relative)} 2>&1"
    )


def _classify(session: str, workspace: str, commands: list[str]) -> dict[str, str] | None:
    run_kind = "chain"
    plan_name: str | None = None
    remote_spec: str | None = None
    relaunch_command: str | None = None

    for raw in commands:
        if not raw or "/usr/local/bin/arnold-watchdog" in raw or "/usr/local/bin/arnold-progress-auditor" in raw:
            continue
        tokens = _split(raw)
        lowered = raw.lower()
        if re.search(r"arnold_pipelines\.megaplan\s+chain\s+start\b", raw) or "arnold-chain" in lowered:
            candidate_spec = _extract_flag(tokens, "--spec")
            if candidate_spec:
                remote_spec = candidate_spec
                relaunch_command = _chain_relaunch_command(candidate_spec, workspace, session)
                break
        if (
            re.search(r"arnold_pipelines\.megaplan\s+init\b", raw)
            or re.search(r"\b(?:arnold|megaplan)\s+init\b", raw)
        ) and "--auto-start" in raw:
            plan_name = _extract_flag(tokens, "--name") or plan_name
            remote_spec = _extract_flag(tokens, "--idea-file") or remote_spec
            run_kind = "plan"
        elif (
            re.search(r"arnold_pipelines\.megaplan\s+(?:auto|resume|plan|prep|critique|revise|gate|finalize|execute|review)\b", raw)
            or re.search(r"\b(?:arnold|megaplan)\s+(?:auto|resume)\b", raw)
        ):
            plan_name = _extract_flag(tokens, "--plan") or plan_name
            run_kind = "plan"

    if run_kind == "plan":
        plans_dir = pathlib.Path(workspace) / ".megaplan" / "plans"
        if plan_name is None and plans_dir.is_dir():
            plans = sorted(p.name for p in plans_dir.iterdir() if p.is_dir())
            if len(plans) == 1:
                plan_name = plans[0]
        if plan_name is None:
            return None
        if remote_spec is None:
            remote_spec = str(pathlib.Path(workspace) / ".megaplan" / "plans" / plan_name)
        return {
            "run_kind": "plan",
            "plan_name": plan_name,
            "remote_spec": remote_spec,
            "relaunch_command": _plan_relaunch_command(plan_name, workspace),
        }

    if remote_spec is None:
        return None
    return {
        "run_kind": "chain",
        "plan_name": "",
        "remote_spec": remote_spec,
        "relaunch_command": relaunch_command or _chain_relaunch_command(remote_spec, workspace, session),
    }


for raw in panes_proc.stdout.splitlines():
    if not raw.strip():
        continue
    try:
        session, pane_pid_raw, current_path, start_command = raw.split("\t", 3)
    except ValueError:
        continue
    if _skip_session(session):
        continue
    if (marker_dir / f"{session}.json").exists():
        continue
    workspace = _workspace_for(current_path)
    if workspace is None or workspace in {"/workspace", src_dir}:
        continue
    try:
        pane_pid = int(pane_pid_raw)
    except ValueError:
        continue
    classified = _classify(session, workspace, [start_command, *_descendants(pane_pid)])
    if classified is None:
        continue
    print(
        "\t".join(
            [
                session,
                workspace,
                classified["remote_spec"],
                classified.get("run_kind", "chain"),
                classified.get("plan_name", ""),
                classified.get("relaunch_command", ""),
            ]
        )
    )
PY
    ;;
  *)
    echo "arnold-cloud-discover: unsupported mode: $MODE" >&2
    exit 64
    ;;
esac

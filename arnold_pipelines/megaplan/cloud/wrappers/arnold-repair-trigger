def _runtime_failure(reason: str) -> None:
    status_dir = Path(
        os.environ.get(
            "MEGAPLAN_SUPERVISOR_STATUS_DIR",
            os.environ.get("CLOUD_WATCHDOG_STATUS_DIR", "/workspace/.megaplan/status"),
        )
    )
    status_dir.mkdir(parents=True, exist_ok=True)
    target = status_dir / "repair-trigger.supervisor-runtime-failure.json"
    payload = {
        "component": "repair-trigger",
        "reason": reason,
        "schema_version": "arnold-supervisor-runtime-failure-v1",
        "status": "failed",
    }
    fd, tmp = tempfile.mkstemp(prefix=target.name + ".", dir=str(status_dir))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, sort_keys=True)
            handle.write("\n")
        os.replace(tmp, target)
    finally:
        try:
            os.unlink(tmp)
        except FileNotFoundError:
            pass


def _select_supervisor_interpreter() -> None:
    preferred = Path(
        os.environ.get(
            "MEGAPLAN_SUPERVISOR_PYTHON",
            "/workspace/.megaplan/supervisor-python/current/bin/python3",
        )
    )
    required = os.environ.get("MEGAPLAN_SUPERVISOR_RUNTIME_REQUIRED", "0") == "1"
    if not preferred.is_file() or not os.access(preferred, os.X_OK):
        if required:
            _runtime_failure("dedicated_interpreter_missing")
            raise SystemExit(78)
        return
    current = Path(sys.executable).resolve()
    target = preferred.resolve()
    if current == target:
        return
    env = os.environ.copy()
    env["MEGAPLAN_SUPERVISOR_PYTHON"] = str(target)
    os.execve(str(target), [str(target), str(Path(__file__).resolve()), *sys.argv[1:]], env)



HOT_ENV_PATH = Path(os.environ.get("ARNOLD_CLOUD_HOT_ENV", "/workspace/.cloud-hot-env"))


def _load_hot_env(path: Path = HOT_ENV_PATH) -> None:
    """Load simple KEY=VALUE lines so systemd path activation sees hot flags."""

    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except FileNotFoundError:
        return
    except OSError:
        return
    for raw in lines:
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export ") :].strip()
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        if not key or not key.replace("_", "").isalnum() or key[0].isdigit():
            continue
        if key in os.environ:
            continue
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
            value = value[1:-1]
        os.environ[key] = value


def main(argv: list[str] | None = None) -> int:
    _load_hot_env()
    args = _parse_args(argv)
    marker_dir = Path(args.marker_dir)
    queue_dir = repair_requests.validate_queue_root(args.queue_root)
    lock_dir = Path(args.lock_dir) if args.lock_dir else queue_dir / "repair-trigger.lock"
    repair_bin = Path(args.repair_bin)
    meta_repair_bin = Path(args.meta_repair_bin)
    enabled = feature_flags.repair_trigger_enabled()
    requested_request_id = str(args.request_id or "").strip()

    request_records = repair_requests.iter_repair_requests(
        queue_dir,
        include_malformed=True,
    )
    if requested_request_id:
        request_records = [
            record
            for record in request_records
            if str(record.get("request_id") or "") == requested_request_id
        ]
    requested_deep = any(
        isinstance(record.get("target"), Mapping)
        and str(record["target"].get("dispatch_intent") or "")
        == "deep_superfixer_repair"
        for record in request_records
    )
    authorization_path = (
        feature_flags.MUTATION_PATH_L3
        if requested_deep
        else feature_flags.MUTATION_PATH_L1
    )
    authorized = feature_flags.mutation_authorized(authorization_path)
    if not request_records:
        _emit(
            {
                "event": "repair_trigger",
                "status": "empty",
                "enabled": enabled,
                "authorized": authorized,
                "queue_dir": str(queue_dir),
            }
        )
        return 0

    # Queue inspection and target diagnostics remain available when mutation
    # authority is absent.  Do not acquire the filesystem lock in that mode:
    # lock creation/removal is itself an L1 state mutation.
    if not authorized:
        return _scan_under_lock(
            marker_dir=marker_dir,
            queue_dir=queue_dir,
            repair_data_dir=Path(args.repair_data_dir) if args.repair_data_dir else None,
            repair_bin=repair_bin,
            meta_repair_bin=meta_repair_bin,
            enabled=enabled,
            authorized=False,
            request_id=requested_request_id,
        )

    lock = acquire_repair_lock(
        lock_dir,
        session="arnold-repair-trigger",
        target_id=str(queue_dir),
        extra={"queue_dir": str(queue_dir), "enabled": enabled, "authorized": authorized},
        is_pid_live=_pid_is_live,
    )
    if not lock.acquired:
        _emit(
            {
                "event": "repair_trigger",
                "status": "busy",
                "lock_status": lock.status,
                "lock_dir": str(lock_dir),
                "owner": lock.owner or {},
                "stale_evidence": lock.stale_evidence or {},
            }
        )
        return 0

    try:
        return _scan_under_lock(
            marker_dir=marker_dir,
            queue_dir=queue_dir,
            repair_data_dir=Path(args.repair_data_dir) if args.repair_data_dir else None,
            repair_bin=repair_bin,
            meta_repair_bin=meta_repair_bin,
            enabled=enabled,
            authorized=True,
            request_id=requested_request_id,
        )
    finally:
        release_repair_lock(lock_dir, owner=lock.owner)


def _scan_under_lock(
    *,
    marker_dir: Path,
    queue_dir: Path,
    repair_data_dir: Path | None,
    repair_bin: Path,
    meta_repair_bin: Path,
    enabled: bool,
    authorized: bool,
    request_id: str = "",
) -> int:
    requested_request_id = request_id
    terminal_request_ids = _terminal_request_ids(queue_dir)
    selected_by_signature: dict[str, dict[str, Any]] = {}
    dispatch_candidate: dict[str, Any] | None = None

    records = list(repair_requests.iter_repair_requests(queue_dir, include_malformed=True))
    # Preserve the earliest accepted request as the canonical duplicate owner;
    # file-name ordering is unrelated to custody chronology.
    records.sort(key=lambda item: str(item.get("created_at") or ""))
    for record in records:
        if requested_request_id and str(record.get("request_id") or "") != requested_request_id:
            continue
        if record.get("kind") == "malformed_repair_request":
            if authorized:
                decision = repair_requests.record_malformed_file(queue_dir, record["path"], record["reason"])
                _emit({"event": "repair_trigger_decision", "decision": decision})
            else:
                _emit(
                    {
                        "event": "repair_trigger_observe",
                        "status": "observed",
                        "authorized": False,
                        "kind": "malformed_repair_request",
                        "path": record["path"],
                        "reason": record["reason"],
                    }
                )
            continue

        request_id = str(record.get("request_id") or "")
        if not request_id or request_id in terminal_request_ids:
            continue

        signature_key = str(record.get("problem_signature_key") or "")
        if signature_key in selected_by_signature:
            canonical = selected_by_signature[signature_key]
            if authorized:
                decision = repair_requests.write_decision(
                    queue_dir,
                    request_id=request_id,
                    decision="coalesced",
                    reason="matching pending request already selected by repair trigger",
                    related_request_id=str(canonical.get("request_id") or ""),
                )
                terminal_request_ids.add(request_id)
                _emit({"event": "repair_trigger_decision", "decision": decision})
            else:
                _emit(
                    {
                        "event": "repair_trigger_observe",
                        "status": "observed",
                        "authorized": False,
                        "request_id": request_id,
                        "observation": "duplicate_signature",
                        "related_request_id": str(canonical.get("request_id") or ""),
                    }
                )
            continue
        selected_by_signature[signature_key] = record

        target = _resolve_target(record, marker_dir=marker_dir, repair_data_dir=repair_data_dir)
        disposition = _classify_request(
            record,
            target,
            queue_dir=queue_dir,
            marker_dir=marker_dir,
            repair_data_dir=repair_data_dir,
        )
        if disposition["decision"] in {"stale", "superseded"}:
            if authorized:
                decision = repair_requests.write_decision(
                    queue_dir,
                    request_id=request_id,
                    decision=disposition["decision"],
                    reason=disposition["reason"],
                    related_request_id=disposition.get("related_request_id", ""),
                )
                terminal_request_ids.add(request_id)
                _emit({"event": "repair_trigger_decision", "request_id": request_id, "target": target, "decision": decision})
            else:
                _emit(
                    {
                        "event": "repair_trigger_observe",
                        "status": "observed",
                        "authorized": False,
                        "request_id": request_id,
                        "observation": disposition["decision"],
                        "reason": disposition["reason"],
                        "target": _target_summary(target),
                    }
                )
            continue

        _emit(
            {
                "event": "repair_trigger_observe",
                "status": "eligible" if authorized else "blocked",
                "request_id": request_id,
                "enabled": enabled,
                "authorized": authorized,
                "blocked_reason": "l1_mutation_not_authorized" if not authorized else "",
                "dispatch_decision": disposition["dispatch_decision"],
                "dispatch_intent": disposition["dispatch_intent"],
                "custody_bucket": disposition["custody_bucket"],
                "target": _target_summary(target),
            }
        )
        if (
            authorized
            and disposition["decision"] == "actionable"
            and not str(disposition.get("blocker_id") or "").strip()
        ):
            retry = repair_requests.record_unclaimed_request_failure(
                queue_dir,
                request_id=request_id,
                reason="canonical blocker_id missing",
            )
            _emit(
                {
                    "event": "repair_trigger_claim",
                    "status": "missing_blocker_id",
                    "request_id": request_id,
                    "evidence": retry,
                }
            )
            continue
        if dispatch_candidate is None and disposition["decision"] == "actionable":
            dispatch_candidate = {**record, **disposition, "_resolved_target": target}
        elif authorized and disposition["dispatch_decision"] == "repairing" and disposition.get("blocker_id"):
            _emit(
                {
                    "event": "repair_trigger_claim",
                    "status": "already_claimed",
                    "request_id": request_id,
                    "blocker_id": disposition["blocker_id"],
                    "evidence": {},
                }
            )

    if dispatch_candidate is None:
        _emit(
            {
                "event": "repair_trigger",
                "status": "no_actionable_requests",
                "enabled": enabled,
                "authorized": authorized,
            }
        )
        return 0

    if not authorized:
        _emit(
            {
                "event": "repair_trigger",
                "status": "blocked",
                "enabled": enabled,
                "authorized": False,
                "reason": (
                    "L3 mutation requires ARNOLD_AUTONOMY and ARNOLD_AUDIT_AUTOFIX_ENABLED"
                    if request_id
                    else "L1 mutation requires ARNOLD_AUTONOMY and ARNOLD_REPAIR_TRIGGER_ENABLED"
                ),
            }
        )
        return 0

    return _dispatch(
        queue_dir=queue_dir,
        repair_bin=repair_bin,
        meta_repair_bin=meta_repair_bin,
        request=dispatch_candidate,
    )


def _dispatch(
    *,
    queue_dir: Path,
    repair_bin: Path,
    meta_repair_bin: Path,
    request: Mapping[str, Any],
) -> int:
    target = request.get("_resolved_target") if isinstance(request.get("_resolved_target"), Mapping) else {}
    request_id = str(request.get("request_id") or "")
    session = str(target.get("target_session") or request.get("session") or "")
    refs = target.get("current_refs") if isinstance(target.get("current_refs"), Mapping) else {}
    marker = target.get("marker") if isinstance(target.get("marker"), Mapping) else {}
    workspace = str(request.get("workspace") or refs.get("workspace") or marker.get("workspace") or "")
    remote_spec = str(refs.get("remote_spec") or marker.get("remote_spec") or "")
    blocker_id = str(request.get("blocker_id") or "")
    blocker_fingerprint = (
        dict(request.get("blocker_fingerprint") or {})
        if isinstance(request.get("blocker_fingerprint"), Mapping)
        else {}
    )
    dispatch_intent = str(request.get("dispatch_intent") or "")
    deep_dispatch = dispatch_intent == "deep_superfixer_repair"
    l2_dispatch = dispatch_intent == "broken_superfixer"
    meta_dispatch = l2_dispatch or deep_dispatch
    selected_bin = meta_repair_bin if meta_dispatch else repair_bin
    mutation_path = (
        feature_flags.MUTATION_PATH_L3
        if deep_dispatch
        else feature_flags.MUTATION_PATH_L2
        if l2_dispatch
        else feature_flags.MUTATION_PATH_L1
    )

    if not session or not workspace or not remote_spec:
        decision = repair_requests.write_decision(
            queue_dir,
            request_id=request_id,
            decision="stale",
            reason="missing session/workspace/remote_spec for repair dispatch",
        )
        _emit({"event": "repair_trigger_decision", "request_id": request_id, "decision": decision})
        return 0
    if not selected_bin.exists():
        retry = repair_requests.record_unclaimed_request_failure(
            queue_dir,
            request_id=request_id,
            reason=("meta-repair executable unavailable" if meta_dispatch else "repair executable unavailable"),
        )
        _emit(
            {
                "event": "repair_trigger",
                "status": "repair_unavailable",
                "request_id": request_id,
                "repair_bin": str(selected_bin),
                "custody_retry": retry,
            }
        )
        return 0
    if not blocker_id:
        retry = repair_requests.record_unclaimed_request_failure(
            queue_dir,
            request_id=request_id,
            reason="canonical blocker_id missing",
        )
        _emit(
            {
                "event": "repair_trigger_claim",
                "status": "missing_blocker_id",
                "request_id": request_id,
                "session": session,
                "custody_retry": retry,
            }
        )
        return 0

    # Defense in depth at the claim/subprocess effect boundary.  Callers may
    # classify and observe freely, but must not create a claim or child process
    # unless the shared master-plus-L1 predicate still authorizes mutation.
    if not feature_flags.mutation_authorized(mutation_path):
        retry = repair_requests.record_unclaimed_request_failure(
            queue_dir,
            request_id=request_id,
            reason=(
                "L3 mutation authorization changed before claim"
                if deep_dispatch
                else "L2 mutation authorization changed before claim"
                if l2_dispatch
                else "L1 mutation authorization changed before claim"
            ),
        )
        _emit(
            {
                "event": "repair_trigger",
                "status": "blocked",
                "request_id": request_id,
                "authorized": False,
                "reason": (
                    "L3 mutation authorization changed before claim"
                    if deep_dispatch
                    else "L2 mutation authorization changed before claim"
                    if l2_dispatch
                    else "L1 mutation authorization changed before claim"
                ),
                "custody_retry": retry,
            }
        )
        return 0

    repair_layer = "l3" if deep_dispatch else "l2" if l2_dispatch else "l1"
    child_command = (
        f"{selected_bin} {session} l3_progress_auditor"
        if deep_dispatch
        else f"{selected_bin} {session} l1_custody_failure"
        if l2_dispatch
        else f"{selected_bin} {session} {workspace} {remote_spec}"
    )
    claim = repair_requests.claim_active_repair_request(
        queue_dir,
        blocker_id=blocker_id,
        request_id=request_id,
        actor=(
            "arnold-repair-trigger-l3"
            if deep_dispatch
            else "arnold-repair-trigger-l2"
            if l2_dispatch
            else "arnold-repair-trigger"
        ),
        session=session,
        blocker_fingerprint=blocker_fingerprint,
        pid=os.getpid(),
        command=child_command,
        cwd=workspace,
        is_pid_live=_pid_is_live,
        extra={"workspace": workspace, "remote_spec": remote_spec},
    )
    if not claim.claimed:
        retry = None
        if claim.status == "stale":
            retry = repair_requests.record_unclaimed_request_failure(
                queue_dir,
                request_id=request_id,
                reason="active claim evidence was stale",
            )
        _emit(
            {
                "event": "repair_trigger_claim",
                "status": claim.status,
                "request_id": request_id,
                "blocker_id": blocker_id,
                "evidence": claim.evidence or {},
                "custody_retry": retry,
            }
        )
        return 0

    env = dict(os.environ)
    env["CLOUD_WATCHDOG_REPAIR_REQUEST_ID"] = request_id
    env["CLOUD_WATCHDOG_REPAIR_BLOCKER_ID"] = blocker_id
    env["CLOUD_WATCHDOG_REPAIR_CLAIM_OWNER_PID"] = str(os.getpid())
    env["ARNOLD_REPAIR_QUEUE_ROOT"] = str(queue_dir)
    env["ARNOLD_REPAIR_TRIGGER_DISPATCHED"] = "1"
    request_target = request.get("target") if isinstance(request.get("target"), Mapping) else {}
    escalation_gate = (
        request_target.get("l3_escalation_gate")
        if isinstance(request_target.get("l3_escalation_gate"), Mapping)
        else {}
    )
    escalation_id = str(escalation_gate.get("escalation_id") or "")
    context_path = str(request_target.get("repair_context_path") or "")
    context_digest = str(request_target.get("repair_context_digest") or "")
    retry_of_run_id = str(request_target.get("retry_of_run_id") or "")
    outcome_path = str(Path(context_path).with_name("repair-outcome.json")) if context_path else ""
    if deep_dispatch:
        env["ARNOLD_L3_DEEP_REPAIR"] = "1"
        env["ARNOLD_L3_ESCALATION_ID"] = escalation_id
        env["ARNOLD_L3_REPAIR_CONTEXT_PATH"] = context_path
        env["ARNOLD_L3_REPAIR_CONTEXT_DIGEST"] = context_digest
        env["ARNOLD_L3_REPAIR_OUTCOME_PATH"] = outcome_path
        env["ARNOLD_META_REPAIR_DIFFICULTY"] = "9"
        env["ARNOLD_META_REPAIR_CHILD_DIFFICULTY_CEILING"] = "9"
    run_kind = (
        "automatic_root_cause_repair"
        if deep_dispatch
        else "automatic_meta_repair"
        if l2_dispatch
        else "automatic_repair"
    )
    identity_key = f"repair-trigger:{request_id}:{repair_layer}"
    managed_run_id = stable_managed_run_id(run_kind, identity_key)
    managed_project = Path(workspace).resolve()
    managed_manifest = (
        managed_project
        / ".megaplan"
        / "plans"
        / "resident-subagents"
        / managed_run_id
        / "manifest.json"
    )
    inherited_goal_path = str(request_target.get("repair_goal_path") or "").strip()
    try:
        if inherited_goal_path:
            goal_path, goal_payload = attach_repair_goal_owner(
                inherited_goal_path,
                request_id=request_id,
                owner_run_id=managed_run_id,
                owner_manifest_path=str(managed_manifest),
            )
            goal_target = (
                goal_payload.get("target")
                if isinstance(goal_payload.get("target"), Mapping)
                else {}
            )
            if goal_target.get("session") != session:
                raise ValueError("inherited repair goal targets a different cloud session")
        else:
            goal_marker_dir = Path(
                os.environ.get(
                    "CLOUD_WATCHDOG_MARKER_DIR",
                    "/workspace/.megaplan/cloud-sessions",
                )
            )
            goal_path, goal_payload = ensure_repair_goal(
                marker_dir=goal_marker_dir,
                session=session,
                workspace=workspace,
                remote_spec=remote_spec,
                plan_name=str(
                    refs.get("current_plan_name")
                    or refs.get("plan_name")
                    or marker.get("plan_name")
                    or ""
                ),
                blocker_id=blocker_id,
                request_id=request_id,
                owner_run_id=managed_run_id,
                owner_manifest_path=str(managed_manifest),
            )
    except (OSError, TypeError, ValueError) as exc:
        repair_requests.release_active_repair_request_claim(
            queue_dir,
            blocker_id=blocker_id,
            owner=claim.owner,
            expected_pid=os.getpid(),
        )
        retry = repair_requests.record_unclaimed_request_failure(
            queue_dir,
            request_id=request_id,
            reason="durable repair goal custody could not be established",
        )
        _emit(
            {
                "event": "repair_trigger_dispatch",
                "status": "goal_custody_failed",
                "request_id": request_id,
                "error_type": type(exc).__name__,
                "custody_retry": retry,
            }
        )
        return 0
    if goal_payload.get("status") != GOAL_ACTIVE:
        repair_requests.release_active_repair_request_claim(
            queue_dir,
            blocker_id=blocker_id,
            owner=claim.owner,
            expected_pid=os.getpid(),
        )
        decision = repair_requests.write_decision(
            queue_dir,
            request_id=request_id,
            decision="stale",
            reason=(
                "durable repair goal already has authoritative progress evidence"
                if goal_payload.get("status") == "progressed"
                else "durable repair goal already surfaced an explicit approval gate"
            ),
            related_request_id=str(goal_payload.get("goal_id") or ""),
        )
        _emit(
            {
                "event": "repair_trigger_dispatch",
                "status": "goal_terminal",
                "request_id": request_id,
                "goal_id": goal_payload.get("goal_id"),
                "goal_path": str(goal_path),
                "goal_status": goal_payload.get("status"),
                "decision": decision,
            }
        )
        return 0
    env["ARNOLD_REPAIR_GOAL_ID"] = str(goal_payload["goal_id"])
    env["ARNOLD_REPAIR_GOAL_PATH"] = str(goal_path)
    env["ARNOLD_REPAIR_CHECKPOINT_DIGEST"] = str(goal_payload["checkpoint_digest"])
    try:
        child_argv = (
            [str(selected_bin), session, "l3_progress_auditor"]
            if deep_dispatch
            else [str(selected_bin), session, "l1_custody_failure"]
            if l2_dispatch
            else [str(selected_bin), session, workspace, remote_spec]
        )
        manager_argv = [
            sys.executable,
            "-m",
            "arnold_pipelines.megaplan.managed_agent",
            "run",
            "--run-kind",
            run_kind,
            "--identity-key",
            identity_key,
            "--project-dir",
            str(managed_project),
            "--task-kind",
            "root_cause" if meta_dispatch else "autonomous",
            "--difficulty",
            "9" if deep_dispatch else "10" if l2_dispatch else "8",
            "--child-difficulty-ceiling",
            "9" if deep_dispatch else "10" if l2_dispatch else "8",
            "--model",
            "gpt-5.6-sol" if deep_dispatch else "control-plane",
            "--reasoning-effort",
            "high" if meta_dispatch else "bounded",
            "--route-class",
            "progress_auditor_d9_repair"
            if deep_dispatch
            else "repair_trigger_l2"
            if l2_dispatch
            else "repair_trigger_l1",
            "--backend",
            "meta-repair-loop" if meta_dispatch else "repair-loop",
            "--command-display",
            child_command,
            "--origin-kind",
            "periodic_progress_auditor"
            if deep_dispatch
            else "watchdog_meta_repair"
            if l2_dispatch
            else "watchdog_repair",
            "--origin-id",
            request_id,
            "--origin-component",
            "arnold-repair-trigger",
            "--trigger-id",
            blocker_id,
            "--lineage-key",
            f"repair-request:{request_id}",
            "--link",
            f"repair_request_id={request_id}",
            "--link",
            f"blocker_id={blocker_id}",
            "--link",
            f"repair_queue_dir={queue_dir}",
            "--link",
            f"incident_id={request.get('incident_id') or f'inc-{session}'}",
            "--link",
            f"cloud_session={session}",
            "--link",
            f"chain={remote_spec}",
            "--link",
            f"phase=repair_trigger_{repair_layer}",
            "--link",
            f"audit_escalation_id={escalation_id}",
            "--link",
            f"finding_evidence_digest={escalation_gate.get('evidence_digest') or ''}",
            "--link",
            f"repair_context_path={context_path}",
            "--link",
            f"repair_context_digest={context_digest}",
            "--link",
            f"repair_outcome_path={outcome_path}",
            "--link",
            f"repair_goal_id={goal_payload['goal_id']}",
            "--link",
            f"repair_goal_path={goal_path}",
            "--link",
            f"repair_checkpoint_digest={goal_payload['checkpoint_digest']}",
            "--",
            *child_argv,
        ]
        if retry_of_run_id:
            separator_index = manager_argv.index("--")
            manager_argv[separator_index:separator_index] = [
                "--retry-of-run-id",
                retry_of_run_id,
            ]
        proc = subprocess.Popen(
            manager_argv,
            cwd=workspace if Path(workspace).exists() else None,
            env=env,
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except OSError:
        repair_requests.release_active_repair_request_claim(
            queue_dir,
            blocker_id=blocker_id,
            owner=claim.owner,
            expected_pid=os.getpid(),
        )
        repair_requests.record_unclaimed_request_failure(
            queue_dir,
            request_id=request_id,
            reason="repair subprocess launch failed",
        )
        raise
    manifest_payload: dict[str, Any] | None = None
    deadline = time.monotonic() + 5.0
    while time.monotonic() < deadline:
        try:
            candidate = json.loads(managed_manifest.read_text(encoding="utf-8"))
        except (FileNotFoundError, OSError, json.JSONDecodeError):
            candidate = None
        if isinstance(candidate, dict):
            if candidate.get("status") == "failed":
                break
            claim_record = candidate.get("repair_claim")
            try:
                validate_automatic_managed_manifest(
                    candidate,
                    manifest_path=managed_manifest,
                )
            except (TypeError, ValueError):
                canonical_contract = False
            else:
                canonical_contract = True
            if (
                candidate.get("schema_version") == MANAGED_AGENT_SCHEMA
                and candidate.get("custodian") == MANAGED_AGENT_CUSTODIAN
                and candidate.get("run_id") == managed_run_id
                and canonical_contract
                and isinstance(claim_record, Mapping)
                and claim_record.get("request_id") == request_id
                and claim_record.get("blocker_id") == blocker_id
                and candidate.get("incident_attempt_event_id")
            ):
                manifest_payload = candidate
                break
        if proc.poll() is not None and not managed_manifest.exists():
            break
        time.sleep(0.02)
    if manifest_payload is None:
        released = repair_requests.release_active_repair_request_claim(
            queue_dir,
            blocker_id=blocker_id,
            expected_pid=proc.pid,
        )
        if not released:
            repair_requests.release_active_repair_request_claim(
                queue_dir,
                blocker_id=blocker_id,
                expected_pid=os.getpid(),
            )
        retry = repair_requests.record_unclaimed_request_failure(
            queue_dir,
            request_id=request_id,
            reason="canonical managed-agent launch evidence was not established",
        )
        _emit(
            {
                "event": "repair_trigger_dispatch",
                "status": "launch_failed",
                "request_id": request_id,
                "managed_run_id": managed_run_id,
                "managed_manifest_path": str(managed_manifest),
                "custody_retry": retry,
            }
        )
        return 0
    attempt = repair_requests.write_dispatch_attempt(
        queue_dir,
        request_id=request_id,
        blocker_id=blocker_id,
        actor=(
            "arnold-repair-trigger-l3"
            if deep_dispatch
            else "arnold-repair-trigger-l2"
            if l2_dispatch
            else "arnold-repair-trigger"
        ),
        repair_layer=repair_layer,
        command=child_command,
        child_pid=proc.pid,
        managed_run_id=managed_run_id,
        managed_manifest_path=str(managed_manifest),
    )
    decision = repair_requests.write_decision(
        queue_dir,
        request_id=request_id,
        decision="dispatched",
        reason=(
            "dispatched canonical D9 root-cause repair loop"
            if deep_dispatch
            else "dispatched existing bounded meta-repair loop"
            if l2_dispatch
            else "dispatched existing bounded repair loop"
        ),
        related_request_id=managed_run_id,
    )
    _emit(
        {
            "event": "repair_trigger_dispatch",
            "status": "dispatched",
            "request_id": request_id,
            "pid": proc.pid,
            "managed_run_id": managed_run_id,
            "managed_manifest_path": str(managed_manifest),
            "repair_goal_id": goal_payload["goal_id"],
            "repair_goal_path": str(goal_path),
            "repair_checkpoint_digest": goal_payload["checkpoint_digest"],
            "session": session,
            "workspace": workspace,
            "remote_spec": remote_spec,
            "repair_layer": repair_layer,
            "attempt": attempt,
            "decision": decision,
        }
    )
    return 0


def _classify_request(
    record: Mapping[str, Any],
    target: Mapping[str, Any],
    *,
    queue_dir: Path,
    marker_dir: Path,
    repair_data_dir: Path | None,
) -> dict[str, str]:
    session = str(record.get("session") or "")
    target_session = str(target.get("target_session") or "")
    authoritative_source = str(target.get("authoritative_source") or "")
    if authoritative_source == "live_sibling_session" or (target_session and target_session != session):
        return {
            "decision": "superseded",
            "reason": "current target is owned by a live sibling session",
            "related_request_id": target_session,
        }

    stale_kinds = [
        str(item.get("kind") or "")
        for item in target.get("stale_evidence", [])
        if isinstance(item, Mapping) and str(item.get("kind") or "") in STALE_EVIDENCE_KINDS
    ]
    if stale_kinds:
        return {
            "decision": "stale",
            "reason": "current target evidence is stale: " + ",".join(sorted(set(stale_kinds))),
            "dispatch_decision": "terminal",
            "dispatch_intent": "queue_only",
            "custody_bucket": "",
        }
    current_refs = dict(target.get("current_refs") or {}) if isinstance(target.get("current_refs"), Mapping) else {}
    target_plan = dict(target.get("plan_state") or {}) if isinstance(target.get("plan_state"), Mapping) else {}
    resume_cursor = target_plan.get("resume_cursor") if isinstance(target_plan.get("resume_cursor"), Mapping) else {}
    signature = record.get("problem_signature") if isinstance(record.get("problem_signature"), Mapping) else {}
    request_target = record.get("target") if isinstance(record.get("target"), Mapping) else {}
    # ``milestone_or_plan`` is a compatibility field and human-gate requests
    # historically store the step name there.  Prefer the explicit target plan
    # identity whenever it is present so a genuine gate is not terminalized as
    # stale merely because its step name differs from the current plan name.
    requested_plan_name = str(
        request_target.get("plan_name") or signature.get("milestone_or_plan") or ""
    )
    resolved_plan_name = str(current_refs.get("current_plan_name") or "")
    if requested_plan_name and resolved_plan_name and requested_plan_name != resolved_plan_name:
        return {
            "decision": "stale",
            "reason": (
                "repair request target advanced from "
                f"{requested_plan_name} to {resolved_plan_name}"
            ),
            "dispatch_decision": "terminal",
            "dispatch_intent": "queue_only",
            "custody_bucket": "",
        }
    current_plan_name = str(
        current_refs.get("current_plan_name")
        or current_refs.get("marker_plan_name")
        or signature.get("milestone_or_plan")
        or ""
    )
    if current_plan_name and not current_refs.get("current_plan_name"):
        current_refs["current_plan_name"] = current_plan_name
    if current_plan_name and not target_plan.get("name"):
        target_plan["name"] = current_plan_name
    normalized_target = dict(target)
    normalized_target["current_refs"] = current_refs
    normalized_target["plan_state"] = target_plan
    retry_strategy = str(
        resume_cursor.get("retry_strategy")
        or request_target.get("retry_strategy")
        or ""
    )
    if not retry_strategy and str(signature.get("failure_kind") or "") == "blocked_recovery_not_resolved":
        retry_strategy = "manual_review"
    if normalized_target.get("authoritative_source") == "chain_state":
        diagnostic_codes = dict(normalized_target.get("diagnostic_codes") or {})
        labels = list(diagnostic_codes.get("event_signature_labels") or [])
        failure_kind_token = str(signature.get("failure_kind") or "")
        if failure_kind_token and failure_kind_token not in labels:
            labels.append(failure_kind_token)
        if failure_kind_token == "blocked_recovery_not_resolved" and "execution_blocked" not in labels:
            labels.append("execution_blocked")
        diagnostic_codes["event_signature_labels"] = labels
        if retry_strategy:
            diagnostic_codes["retry_strategy"] = retry_strategy
        if failure_kind_token:
            diagnostic_codes["latest_failure_kind"] = failure_kind_token
        normalized_target["diagnostic_codes"] = diagnostic_codes
    plan_state = {
        "name": current_plan_name,
        "current_state": str(current_refs.get("plan_current_state") or signature.get("current_state") or ""),
        "resume_cursor": {"retry_strategy": retry_strategy},
        "latest_failure": {
            "kind": str(signature.get("failure_kind") or ""),
            "phase": str(signature.get("phase_or_step") or ""),
            "metadata": {"blocked_task_id": str(signature.get("blocked_task_id") or "")},
        },
    }
    workspace_raw = str(current_refs.get("workspace") or "")
    event_plan_dir = None
    if normalized_target.get("authoritative_source") == "chain_state" and workspace_raw and current_plan_name:
        event_plan_dir = Path(workspace_raw) / ".megaplan" / "plans" / current_plan_name
    try:
        canonical_run_state = (
            resolve_run_state(normalized_target or {})
            if normalized_target.get("authoritative_source") == "chain_state"
            else None
        )
    except Exception:
        canonical_run_state = None
    projection = project_repair_custody(
        plan_state=plan_state,
        current_target=normalized_target,
        canonical_run_state=canonical_run_state,
        queue_root=queue_dir,
        repair_data_dir=repair_data_dir,
    )
    human_blocker = None
    needs_human = target.get("needs_human") if isinstance(target.get("needs_human"), Mapping) else {}
    if bool(needs_human.get("present")):
        human_blocker = classify_needs_human_blocker(
            session,
            current_plan=str(plan_state.get("name") or ""),
            marker_dir=marker_dir,
            repair_data_dir=repair_data_dir,
            resolver_record=normalized_target,
        )
    lock_evidence = None
    blocker_id = str(projection.get("blocker_id") or "").strip()
    if blocker_id:
        lock_evidence = inspect_repair_lock(
            repair_requests.active_repair_claim_lock_dir(queue_dir, blocker_id)
        )
    decision = classify_repair_dispatch(
        canonical_run_state=canonical_run_state,
        event_plan_dir=event_plan_dir,
        plan_state=plan_state,
        current_target=normalized_target,
        human_blocker_classification=human_blocker,
        lock_evidence=lock_evidence,
        custody_projection=projection,
    )
    deterministic_l3 = (
        record.get("source") == "six_hour_auditor"
        and isinstance(request_target.get("deterministic_superfixer_evidence"), Mapping)
        and request_target["deterministic_superfixer_evidence"].get("actionable") is True
    )
    l2_actionable = decision.decision == "broken_superfixer" and deterministic_l3 and bool(
        projection.get("blocker_id")
    )
    requested_deep = bool(
        deterministic_l3
        and request_target.get("dispatch_intent") == "deep_superfixer_repair"
        and request_target.get("retry_strategy") == "deep_superfixer_repair"
        and isinstance(request_target.get("l3_escalation_gate"), Mapping)
        and request_target["l3_escalation_gate"].get("eligible") is True
        and request_target["l3_escalation_gate"].get("decision") == "true_stall"
    )
    deep_actionable = bool(requested_deep and l2_actionable)
    return {
        "decision": (
            "actionable"
            if decision.decision == "dispatch_l1_repair" or l2_actionable
            else "non_actionable"
        ),
        "reason": "; ".join(decision.rationale) or "shared custody classifier did not allow dispatch",
        "dispatch_decision": decision.decision,
        "dispatch_intent": (
            "deep_superfixer_repair" if deep_actionable else decision.dispatch_intent
        ),
        "custody_bucket": decision.custody_bucket,
        "blocker_id": projection.get("blocker_id", ""),
        "blocker_fingerprint": projection.get("blocker_fingerprint") or {},
    }


def _resolve_target(
    record: Mapping[str, Any],
    *,
    marker_dir: Path,
    repair_data_dir: Path | None,
) -> dict[str, Any]:
    session = str(record.get("session") or "")
    return resolve_current_target(
        session,
        marker_dir=marker_dir,
        repair_data_dir=repair_data_dir,
        session_is_live=_session_is_live,
        pid_is_live=_pid_is_live,
    )


def _terminal_request_ids(queue_dir: Path) -> set[str]:
    result: set[str] = set()
    for path in sorted(repair_requests.decisions_dir(queue_dir).glob("*.json"), key=lambda item: item.name):
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
        except Exception:
            continue
        if not isinstance(payload, dict):
            continue
        if payload.get("decision") not in TERMINAL_DECISIONS:
            continue
        request_id = payload.get("request_id")
        if isinstance(request_id, str) and request_id:
            result.add(request_id)
    return result


def _target_summary(target: Mapping[str, Any]) -> dict[str, Any]:
    return {
        "target_id": target.get("target_id", ""),
        "target_session": target.get("target_session", ""),
        "authoritative_source": target.get("authoritative_source", ""),
        "current_refs": target.get("current_refs", {}),
        "stale_evidence": target.get("stale_evidence", []),
    }


def _session_is_live(session: str) -> bool | None:
    if not session:
        return None
    if _has_command("tmux"):
        proc = subprocess.run(["tmux", "has-session", "-t", session], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return proc.returncode == 0
    return None


def _pid_is_live(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except OSError:
        return False
    return True


def _has_command(name: str) -> bool:
    for entry in os.getenv("PATH", "").split(os.pathsep):
        if entry and (Path(entry) / name).exists():
            return True
    return False


def _emit(payload: Mapping[str, Any]) -> None:
    print(json.dumps(redact_payload(dict(payload)), sort_keys=True))


def _parse_args(argv: list[str] | None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--marker-dir",
        default=os.getenv("CLOUD_WATCHDOG_MARKER_DIR", "/workspace/.megaplan/cloud-sessions"),
    )
    parser.add_argument(
        "--queue-root",
        default=os.getenv("ARNOLD_REPAIR_QUEUE_ROOT", "/workspace/.megaplan/repair-queue"),
        help="validated central <workspace>/.megaplan/repair-queue root",
    )
    parser.add_argument(
        "--repair-data-dir",
        default=os.getenv("CLOUD_WATCHDOG_REPAIR_DATA_DIR", ""),
    )
    parser.add_argument(
        "--repair-bin",
        default=os.getenv(
            "ARNOLD_REPAIR_TRIGGER_REPAIR_BIN",
            str(Path(__file__).resolve().with_name("arnold-repair-loop")),
        ),
    )
    parser.add_argument(
        "--meta-repair-bin",
        default=os.getenv(
            "ARNOLD_REPAIR_TRIGGER_META_REPAIR_BIN",
            str(Path(__file__).resolve().with_name("arnold-meta-repair-loop")),
        ),
    )
    parser.add_argument("--lock-dir", default=os.getenv("ARNOLD_REPAIR_TRIGGER_LOCK_DIR", ""))
    parser.add_argument(
        "--request-id",
        default="",
        help="process only the exact correlated repair request",
    )
    return parser.parse_args(argv)


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env python3
"""Dependency-independent stopped-marker/absent-custody detector."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import pathlib
import subprocess
import tempfile


def _load(path: pathlib.Path) -> dict[str, object]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError, TypeError):
        return {}
    return value if isinstance(value, dict) else {}


def _tmux_live(session: str) -> bool:
    if not session:
        return False
    try:
        result = subprocess.run(
            ["tmux", "has-session", "-t", session],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        return False
    return result.returncode == 0


def _dispatch_has_custody(path: pathlib.Path) -> bool:
    try:
        fields = path.read_text(encoding="utf-8").rstrip("\n").split("\t")
    except OSError:
        return False
    if len(fields) < 5 or fields[0] != "arnold-dispatch-marker-v2":
        return False
    actor, run_id, manifest = fields[1], fields[3], fields[4]
    return actor == "managed_agent" and bool(run_id) and pathlib.Path(manifest).is_file()


def _atomic_write(path: pathlib.Path, payload: dict[str, object]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=path.name + ".", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, sort_keys=True)
            handle.write("\n")
        os.replace(tmp, path)
    finally:
        try:
            os.unlink(tmp)
        except FileNotFoundError:
            pass


def scan(marker_dir: pathlib.Path, session_filter: str = "") -> dict[str, object]:
    findings: list[dict[str, object]] = []
    checked = 0
    for marker_path in sorted(marker_dir.glob("*.json")):
        marker = _load(marker_path)
        session = str(marker.get("session") or marker_path.stem).strip()
        if session_filter and session != session_filter:
            continue
        if not session or str(marker.get("run_kind") or "chain").strip().lower() != "chain":
            continue
        if marker.get("should_run") is False:
            continue
        checked += 1
        workspace = pathlib.Path(str(marker.get("workspace") or ""))
        chain_paths = list((workspace / ".megaplan" / "plans" / ".chains").glob("*.json")) if workspace else []
        repair_root = marker_dir / "repair-data"
        repair_paths = [
            repair_root / f"{session}.repair-data.json",
            marker_dir / f"{session}.repair-progress.json",
        ]
        live = _tmux_live(session)
        repair_present = any(path.exists() and path.stat().st_size > 0 for path in repair_paths) or any(
            _dispatch_has_custody(marker_dir / f"{session}.{kind}-dispatch")
            for kind in ("kimi", "meta")
        )
        if live or chain_paths or repair_present:
            continue
        outcome = marker.get("launch_outcome") if isinstance(marker.get("launch_outcome"), dict) else {}
        findings.append(
            {
                "chain_state_present": False,
                "launch_outcome": outcome,
                "marker_path": str(marker_path),
                "reason": "stopped_marker_without_chain_or_repair_state",
                "repair_state_present": False,
                "remote_spec": str(marker.get("remote_spec") or ""),
                "session": session,
                "tmux_live": False,
                "unhealthy": True,
                "workspace": str(workspace),
            }
        )
    return {
        "checked_sessions": checked,
        "findings": findings,
        "generated_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "schema_version": "arnold-supervisor-gap-scan-v1",
        "status": "unhealthy" if findings else "healthy",
    }


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--marker-dir", default="/workspace/.megaplan/cloud-sessions")
    parser.add_argument("--output", required=True)
    parser.add_argument("--session", default="")
    args = parser.parse_args()
    payload = scan(pathlib.Path(args.marker_dir), args.session)
    _atomic_write(pathlib.Path(args.output), payload)
    print(json.dumps(payload, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

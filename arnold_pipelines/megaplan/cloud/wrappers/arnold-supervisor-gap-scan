#!/usr/bin/env python3
"""Dependency-independent stopped-marker/absent-custody detector."""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import json
import os
import pathlib
import re
import subprocess
import tempfile


def _load(path: pathlib.Path) -> dict[str, object]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError, TypeError):
        return {}
    return value if isinstance(value, dict) else {}


def _tmux_live(session: str) -> bool:
    if not session:
        return False
    try:
        result = subprocess.run(
            ["tmux", "has-session", "-t", session],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        return False
    return result.returncode == 0


def _dispatch_has_custody(path: pathlib.Path) -> bool:
    try:
        fields = path.read_text(encoding="utf-8").rstrip("\n").split("\t")
    except OSError:
        return False
    if len(fields) < 5 or fields[0] != "arnold-dispatch-marker-v2":
        return False
    actor, run_id, manifest = fields[1], fields[3], fields[4]
    return actor == "managed_agent" and bool(run_id) and pathlib.Path(manifest).is_file()


def _atomic_write(path: pathlib.Path, payload: dict[str, object]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=path.name + ".", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, sort_keys=True)
            handle.write("\n")
        os.replace(tmp, path)
    finally:
        try:
            os.unlink(tmp)
        except FileNotFoundError:
            pass


def _binding_gap(
    *,
    session: str,
    marker_path: pathlib.Path,
    marker: dict[str, object],
    chain_paths: list[pathlib.Path],
) -> dict[str, object] | None:
    """Detect immutable spec/binding disagreement without importing Megaplan."""

    if not chain_paths:
        return None
    states = [(path, _load(path)) for path in chain_paths]
    bound_states: list[tuple[pathlib.Path, dict[str, object], dict[str, object]]] = []
    for path, state in states:
        metadata = state.get("metadata") if isinstance(state.get("metadata"), dict) else {}
        binding = (
            metadata.get("execution_binding")
            if isinstance(metadata.get("execution_binding"), dict)
            else {}
        )
        identity = (
            binding.get("launched_identity")
            if isinstance(binding.get("launched_identity"), dict)
            else {}
        )
        if identity:
            bound_states.append((path, state, identity))

    remote_spec = pathlib.Path(str(marker.get("remote_spec") or ""))
    if len(bound_states) > 1:
        identities = {
            str(identity.get("bundle_sha256") or "")
            for _, _, identity in bound_states
        }
        if len(identities) > 1:
            return {
                "chain_state_paths": [str(path) for path, _, _ in bound_states],
                "marker_path": str(marker_path),
                "reason": "chain_execution_binding_ambiguous",
                "remote_spec": str(remote_spec),
                "session": session,
                "unhealthy": True,
            }
    if bound_states:
        state_path, _, identity = max(
            bound_states,
            key=lambda item: item[0].stat().st_mtime if item[0].exists() else 0,
        )
        expected_spec_sha256 = str(identity.get("chain_spec_sha256") or "")
        active_spec_sha256 = (
            hashlib.sha256(remote_spec.read_bytes()).hexdigest()
            if remote_spec.is_file()
            else ""
        )
        if not expected_spec_sha256 or expected_spec_sha256 != active_spec_sha256:
            sequence = (
                identity.get("milestone_sequence")
                if isinstance(identity.get("milestone_sequence"), list)
                else []
            )
            return {
                "active_chain_spec_sha256": active_spec_sha256,
                "chain_state_path": str(state_path),
                "expected_bundle_sha256": str(identity.get("bundle_sha256") or ""),
                "expected_chain_spec_sha256": expected_spec_sha256,
                "expected_milestone_count": len(sequence),
                "marker_path": str(marker_path),
                "reason": "chain_execution_binding_drift",
                "remote_spec": str(remote_spec),
                "session": session,
                "unhealthy": True,
            }
        return None

    progressed = False
    for _, state in states:
        try:
            current_index = int(state.get("current_milestone_index", -1))
        except (TypeError, ValueError):
            current_index = -1
        progressed = progressed or bool(
            state.get("current_plan_name")
            or state.get("completed")
            or state.get("last_state") is not None
            or current_index >= 0
        )
    try:
        spec_text = remote_spec.read_text(encoding="utf-8")
    except OSError:
        spec_text = ""
    binding_required = bool(
        re.search(r"(?m)^\s*execution_binding\s*:\s*['\"]?required['\"]?\s*(?:#.*)?$", spec_text)
    )
    if progressed and binding_required:
        return {
            "chain_state_paths": [str(path) for path, _ in states],
            "marker_path": str(marker_path),
            "reason": "chain_execution_binding_missing",
            "remote_spec": str(remote_spec),
            "session": session,
            "unhealthy": True,
        }
    return None


def scan(marker_dir: pathlib.Path, session_filter: str = "") -> dict[str, object]:
    findings: list[dict[str, object]] = []
    checked = 0
    for marker_path in sorted(marker_dir.glob("*.json")):
        marker = _load(marker_path)
        session = str(marker.get("session") or marker_path.stem).strip()
        if session_filter and session != session_filter:
            continue
        # The marker directory also contains progress/evidence JSON carrying the
        # same session field.  Only an explicit launch marker owns execution
        # custody; treating auxiliary JSON as a chain marker creates a false
        # binding drift against an empty workspace/spec.
        if not session or str(marker.get("run_kind") or "").strip().lower() != "chain":
            continue
        if marker.get("should_run") is False:
            continue
        checked += 1
        workspace = pathlib.Path(str(marker.get("workspace") or ""))
        chain_paths = list((workspace / ".megaplan" / "plans" / ".chains").glob("*.json")) if workspace else []
        repair_root = marker_dir / "repair-data"
        repair_paths = [
            repair_root / f"{session}.repair-data.json",
            marker_dir / f"{session}.repair-progress.json",
        ]
        live = _tmux_live(session)
        repair_present = any(path.exists() and path.stat().st_size > 0 for path in repair_paths) or any(
            _dispatch_has_custody(marker_dir / f"{session}.{kind}-dispatch")
            for kind in ("kimi", "meta")
        )
        binding_gap = _binding_gap(
            session=session,
            marker_path=marker_path,
            marker=marker,
            chain_paths=chain_paths,
        )
        if binding_gap is not None:
            findings.append(binding_gap)
            continue
        if live or chain_paths or repair_present:
            continue
        outcome = marker.get("launch_outcome") if isinstance(marker.get("launch_outcome"), dict) else {}
        findings.append(
            {
                "chain_state_present": False,
                "launch_outcome": outcome,
                "marker_path": str(marker_path),
                "reason": "stopped_marker_without_chain_or_repair_state",
                "repair_state_present": False,
                "remote_spec": str(marker.get("remote_spec") or ""),
                "session": session,
                "tmux_live": False,
                "unhealthy": True,
                "workspace": str(workspace),
            }
        )
    return {
        "checked_sessions": checked,
        "findings": findings,
        "generated_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "schema_version": "arnold-supervisor-gap-scan-v1",
        "status": "unhealthy" if findings else "healthy",
    }


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--marker-dir", default="/workspace/.megaplan/cloud-sessions")
    parser.add_argument("--output", required=True)
    parser.add_argument("--session", default="")
    args = parser.parse_args()
    payload = scan(pathlib.Path(args.marker_dir), args.session)
    _atomic_write(pathlib.Path(args.output), payload)
    print(json.dumps(payload, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

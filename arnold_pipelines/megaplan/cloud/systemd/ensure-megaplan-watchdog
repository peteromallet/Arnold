#!/usr/bin/env bash
set -u

CONTAINER="${MEGAPLAN_CLOUD_CONTAINER:-megaplan-cloud-agent}"
LOG="${MEGAPLAN_WATCHDOG_ENSURE_LOG:-/var/log/megaplan-watchdog-ensure.log}"

now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }
log() { printf "[%s] %s\n" "$(now)" "$*" >> "$LOG"; }

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
  log "container_missing container=$CONTAINER"
  exit 1
fi

running="$(docker inspect -f "{{.State.Running}}" "$CONTAINER" 2>/dev/null || echo false)"
if [[ "$running" != "true" ]]; then
  log "container_not_running starting container=$CONTAINER"
  if ! docker start "$CONTAINER" >> "$LOG" 2>&1; then
    log "container_start_failed container=$CONTAINER"
    exit 1
  fi
fi

# The watchdog tmux session may EXIST yet be HUNG — the snapshot-staleness
# failure mode: the loop is alive in tmux but not sweeping, so cloud-status.json
# and the heartbeat go stale. The watchdog touches watchdog.heartbeat at each
# sweep start, so a heartbeat older than the threshold means the session is
# stuck; kill it and fall through to a fresh restart. Tune the threshold to ~2x
# the watchdog INTERVAL (default 60m) + grace; the default 130m assumes that.
# (watchdog-snapshot-staleness-fix.md P3)
STALE_HEARTBEAT_MIN="${MEGAPLAN_WATCHDOG_STALE_HEARTBEAT_MIN:-130}"
HEARTBEAT="/workspace/.megaplan/status/watchdog.heartbeat"

if docker exec "$CONTAINER" bash -lc "tmux has-session -t watchdog" >/dev/null 2>&1; then
  stale="$(docker exec "$CONTAINER" bash -lc "find '$HEARTBEAT' -mmin +${STALE_HEARTBEAT_MIN} 2>/dev/null | head -n1 || true")"
  if [[ -n "$stale" ]]; then
    log "watchdog_heartbeat_stale container=$CONTAINER (older than ${STALE_HEARTBEAT_MIN}m); killing hung session to restart"
    docker exec "$CONTAINER" bash -lc "tmux kill-session -t watchdog 2>/dev/null || true"
    # fall through to restart below
  else
    log "watchdog_alive container=$CONTAINER"
    exit 0
  fi
fi

log "watchdog_missing restarting container=$CONTAINER"
if ! docker exec "$CONTAINER" bash -lc "tmux new-session -d -s watchdog -c /workspace /usr/local/bin/arnold-watchdog" >> "$LOG" 2>&1; then
  log "watchdog_restart_failed container=$CONTAINER"
  exit 1
fi

sleep 1
if docker exec "$CONTAINER" bash -lc "tmux has-session -t watchdog" >/dev/null 2>&1; then
  log "watchdog_restarted container=$CONTAINER"
  exit 0
fi

log "watchdog_restart_failed_not_alive container=$CONTAINER"
exit 1

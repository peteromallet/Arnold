#!/usr/bin/env bash
set -u

CONTAINER="${MEGAPLAN_CLOUD_CONTAINER:-megaplan-cloud-agent}"
LOG="${MEGAPLAN_WATCHDOG_ENSURE_LOG:-/var/log/megaplan-watchdog-ensure.log}"

now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }
log() { printf "[%s] %s\n" "$(now)" "$*" >> "$LOG"; }

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
  log "container_missing container=$CONTAINER"
  exit 1
fi

running="$(docker inspect -f "{{.State.Running}}" "$CONTAINER" 2>/dev/null || echo false)"
if [[ "$running" != "true" ]]; then
  log "container_not_running starting container=$CONTAINER"
  if ! docker start "$CONTAINER" >> "$LOG" 2>&1; then
    log "container_start_failed container=$CONTAINER"
    exit 1
  fi
fi

if docker exec "$CONTAINER" bash -lc "tmux has-session -t watchdog" >/dev/null 2>&1; then
  log "watchdog_alive container=$CONTAINER"
  exit 0
fi

log "watchdog_missing restarting container=$CONTAINER"
if ! docker exec "$CONTAINER" bash -lc "tmux new-session -d -s watchdog -c /workspace \"bash -lc 'exec /usr/local/bin/arnold-watchdog'\"" >> "$LOG" 2>&1; then
  log "watchdog_restart_failed container=$CONTAINER"
  exit 1
fi

sleep 1
if docker exec "$CONTAINER" bash -lc "tmux has-session -t watchdog" >/dev/null 2>&1; then
  log "watchdog_restarted container=$CONTAINER"
  exit 0
fi

log "watchdog_restart_failed_not_alive container=$CONTAINER"
exit 1

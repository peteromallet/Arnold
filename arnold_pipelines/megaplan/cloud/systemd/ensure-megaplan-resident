#!/usr/bin/env bash
# Ensure the Discord resident tmux session is alive in the cloud container.
# Mirrors ensure-megaplan-watchdog: idempotent, host-side, fired by a 5-min
# systemd timer. This is the "never dark" guarantee — the resident self-heals
# within ~5 min of any disruption (container restart/crash/OOM/image swap),
# independent of whether the entrypoint happened to start it.
set -u

CONTAINER="${MEGAPLAN_CLOUD_CONTAINER:-megaplan-cloud-agent}"
LOG="${MEGAPLAN_RESIDENT_ENSURE_LOG:-/var/log/megaplan-resident-ensure.log}"
SESSION=megaplan-resident-discord

now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }
log() { printf "[%s] %s\n" "$(now)" "$*" >> "$LOG"; }

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
  log "container_missing container=$CONTAINER"
  exit 1
fi

running="$(docker inspect -f "{{.State.Running}}" "$CONTAINER" 2>/dev/null || echo false)"
if [[ "$running" != "true" ]]; then
  # Don't fight a stopped/restarting container — the watchdog-ensure service
  # owns starting it. Retry next tick.
  log "container_not_running container=$CONTAINER"
  exit 0
fi

if docker exec "$CONTAINER" bash -lc "tmux has-session -t $SESSION" >/dev/null 2>&1; then
  log "resident_alive container=$CONTAINER"
  exit 0
fi

log "resident_missing starting container=$CONTAINER"
# Canonical resident launch (mirrors entrypoint.sh.tmpl). The heredoc is quoted
# ('EOS') so \$ and \${...} stay literal until the resident's bash -lc expands
# them AFTER sourcing the env — exactly like the entrypoint's invocation.
if docker exec -i "$CONTAINER" bash >>"$LOG" 2>&1 <<'EOS'; then
  set -u
  if [ ! -f /workspace/.secrets/megaplan-resident-discord.env ]; then
    echo "resident_env_missing"
    exit 0
  fi
  if tmux has-session -t megaplan-resident-discord 2>/dev/null; then
    echo "resident_already_up"
    exit 0
  fi
  tmux new-session -d -s megaplan-resident-discord -c /workspace/arnold "bash -lc 'set -a; . /workspace/.secrets/megaplan-resident-discord.env; set +a; export PYTHONPATH=/workspace/arnold:\${PYTHONPATH:-}; export MEGAPLAN_RESIDENT_MODE=production MEGAPLAN_RESIDENT_DISCORD_BOT_ROLE=production; echo [resident-start] \$(date -Iseconds) provider=\${MEGAPLAN_RESIDENT_MODEL_PROVIDER} model=\${MEGAPLAN_RESIDENT_MODEL} >> /workspace/megaplan-resident-discord.log; python -m arnold_pipelines.megaplan resident discord --mode production --store-root /workspace/arnold/.megaplan/resident >> /workspace/megaplan-resident-discord.log 2>&1'"
  echo "resident_started"
EOS
  sleep 2
  if docker exec "$CONTAINER" bash -lc "tmux has-session -t $SESSION" >/dev/null 2>&1; then
    log "resident_restarted container=$CONTAINER"
    exit 0
  fi
fi

log "resident_restart_failed_not_alive container=$CONTAINER"
exit 1

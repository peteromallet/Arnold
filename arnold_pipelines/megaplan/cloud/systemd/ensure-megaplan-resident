#!/usr/bin/env bash
# Ensure the Discord resident tmux session is alive in the cloud container.
# Mirrors ensure-megaplan-watchdog: idempotent, host-side, fired by a 5-min
# systemd timer. This is the "never dark" guarantee — the resident self-heals
# within ~5 min of any disruption (container restart/crash/OOM/image swap),
# independent of whether the entrypoint happened to start it.
set -u

CONTAINER="${MEGAPLAN_CLOUD_CONTAINER:-megaplan-cloud-agent}"
LOG="${MEGAPLAN_RESIDENT_ENSURE_LOG:-/var/log/megaplan-resident-ensure.log}"
SESSION=megaplan-resident-discord

now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }
log() { printf "[%s] %s\n" "$(now)" "$*" >> "$LOG"; }

resident_healthy() {
  docker exec "$CONTAINER" bash -lc '
    set -euo pipefail
    tmux has-session -t megaplan-resident-discord
    pane_pid="$(tmux list-panes -t megaplan-resident-discord -F "#{pane_pid}" | head -1)"
    tr "\0" "\n" < "/proc/$pane_pid/cmdline" | grep -Fx -- "--store-root" >/dev/null
    set -a
    . /workspace/.secrets/megaplan-resident-discord.env
    [[ ! -f /workspace/.cloud-hot-env ]] || . /workspace/.cloud-hot-env
    [[ ! -f /workspace/.megaplan/resident-runtime.env ]] || . /workspace/.megaplan/resident-runtime.env
    set +a
    runtime_src="${MEGAPLAN_RUNTIME_SRC:-/workspace/arnold}"
    runtime_python="${MEGAPLAN_RUNTIME_PYTHON:-python}"
    store_root="${MEGAPLAN_RESIDENT_STORE_ROOT:-/workspace/arnold/.megaplan/resident}"
    [[ "$runtime_python" == */* ]] && [[ -x "$runtime_python" ]]
    [[ "$(readlink -f "/proc/$pane_pid/exe")" == "$(readlink -f "$runtime_python")" ]]
    tr "\0" "\n" < "/proc/$pane_pid/environ" |
      grep -Fx -- "MEGAPLAN_RUNTIME_SRC=$runtime_src" >/dev/null
    tr "\0" "\n" < "/proc/$pane_pid/environ" |
      grep -Fx -- "MEGAPLAN_RUNTIME_PYTHON=$runtime_python" >/dev/null
    PYTHONSAFEPATH=1 PYTHONPATH="$runtime_src:${PYTHONPATH:-}" \
      "$runtime_python" -P -m arnold_pipelines.megaplan resident health \
        --mode "${MEGAPLAN_RESIDENT_MODE:-production}" \
        --store-root "$store_root" >/dev/null
  ' >/dev/null 2>&1
}

if ! docker inspect "$CONTAINER" >/dev/null 2>&1; then
  log "container_missing container=$CONTAINER"
  exit 1
fi

running="$(docker inspect -f "{{.State.Running}}" "$CONTAINER" 2>/dev/null || echo false)"
if [[ "$running" != "true" ]]; then
  # Don't fight a stopped/restarting container — the watchdog-ensure service
  # owns starting it. Retry next tick.
  log "container_not_running container=$CONTAINER"
  exit 0
fi

if resident_healthy; then
  log "resident_alive container=$CONTAINER"
  exit 0
fi

if docker exec "$CONTAINER" bash -lc "tmux has-session -t $SESSION" >/dev/null 2>&1; then
  log "resident_unhealthy restarting container=$CONTAINER"
  docker exec "$CONTAINER" tmux kill-session -t "$SESSION" >/dev/null 2>&1 || true
else
  log "resident_missing starting container=$CONTAINER"
fi
# Canonical resident launch (mirrors entrypoint.sh.tmpl). The heredoc is quoted
# ('EOS') so \$ and \${...} stay literal until the resident's bash -lc expands
# them AFTER sourcing the env — exactly like the entrypoint's invocation.
if docker exec -i "$CONTAINER" bash >>"$LOG" 2>&1 <<'EOS'; then
  set -u
  if [ ! -f /workspace/.secrets/megaplan-resident-discord.env ]; then
    echo "resident_env_missing"
    exit 0
  fi
  if tmux has-session -t megaplan-resident-discord 2>/dev/null; then
    echo "resident_already_up"
    exit 0
  fi
  tmux new-session -d -s megaplan-resident-discord -c /workspace/arnold "bash -lc 'set -a; . /workspace/.secrets/megaplan-resident-discord.env; [[ ! -f /workspace/.cloud-hot-env ]] || . /workspace/.cloud-hot-env; [[ ! -f /workspace/.megaplan/resident-runtime.env ]] || . /workspace/.megaplan/resident-runtime.env; set +a; runtime_src=\${MEGAPLAN_RUNTIME_SRC:-/workspace/arnold}; runtime_python=\${MEGAPLAN_RUNTIME_PYTHON:-python}; store_root=\${MEGAPLAN_RESIDENT_STORE_ROOT:-/workspace/arnold/.megaplan/resident}; export PYTHONPATH=\$runtime_src:\${PYTHONPATH:-}; export MEGAPLAN_RESIDENT_DISCORD_BOT_ROLE=\${MEGAPLAN_RESIDENT_DISCORD_BOT_ROLE:-production}; echo [resident-start] \$(date -Iseconds) provider=\${MEGAPLAN_RESIDENT_MODEL_PROVIDER} model=\${MEGAPLAN_RESIDENT_MODEL} store_root=\$store_root >> /workspace/megaplan-resident-discord.log; exec \"\$runtime_python\" -P -m arnold_pipelines.megaplan resident discord --mode \${MEGAPLAN_RESIDENT_MODE:-production} --store-root \"\$store_root\" >> /workspace/megaplan-resident-discord.log 2>&1'"
  echo "resident_started"
EOS
  sleep 5
  if resident_healthy; then
    log "resident_restarted container=$CONTAINER"
    exit 0
  fi
fi

log "resident_restart_failed_not_alive container=$CONTAINER"
exit 1

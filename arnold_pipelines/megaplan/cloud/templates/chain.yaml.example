# Example chain spec consumed by `megaplan chain --spec`.
# For committed source artifacts, keep this at
# .megaplan/initiatives/<epic-slug>/chain.yaml with milestone briefs under briefs/.
# Progress is persisted under .megaplan/plans/.chains/.

# Required by default durable alignment anchor for epics.
# Keep NORTHSTAR.md beside this chain.yaml and declare it here.
# Anchor paths resolve relative to this chain.yaml, not the shell CWD.
anchors:
  north_star: NORTHSTAR.md

seed:
  # Plan that was kicked off manually before the chain took over. If its state
  # is already done/aborted/failed, the chain skips it; otherwise it is driven
  # under the same auto-loop as chained milestones.
  plan: milestone-m0-from-docs-state-20260415-0217

milestones:
  - label: m1
    idea: .megaplan/initiatives/foundation-store/briefs/M1-foundation-store.txt
    branch: megaplan/m1-foundation-store
    # Optional per-milestone init rubric knobs. Omit any of these to keep
    # existing profile/default behavior.
    profile: thoughtful
    robustness: standard
    vendor: claude              # claude | codex
    depth: high                 # minimal | low | medium | high | xhigh | max
    critic: kimi                # kimi | cross
    with_prep: true
    with_feedback: true
    deepseek_provider: direct
    # Optional milestone-level North Star that extends the epic anchor.
    # anchors:
    #   north_star: M1-northstar.md
  - label: m1a
    idea: .megaplan/initiatives/foundation-store/briefs/M1a-settings-store.txt
    branch: megaplan/m1a-settings-store
  - label: m1b
    idea: .megaplan/initiatives/foundation-store/briefs/M1b-selection-store.txt
    branch: megaplan/m1b-selection-store
  - label: m1c
    idea: .megaplan/initiatives/foundation-store/briefs/M1c-timeline-store.txt
    branch: megaplan/m1c-timeline-store
  # M2 (overlay stack) is CONDITIONAL on M1a's gate — do NOT auto-queue.

on_failure:
  abort: stop_chain          # stop_chain | skip_milestone | retry_milestone
on_escalate:
  abort: stop_chain

# auto: mark each milestone PR ready and enable squash auto-merge.
# review: mark ready, stop with chain state last_state=awaiting_pr_merge,
#         and continue to the next milestone only after the PR is merged.
merge_policy: auto           # auto | review

driver:
  # Explicit opt-out, only when there is no durable epic destination:
  # require_anchor: false
  # missing_anchor_ack: "Mechanical cleanup chain; no cross-milestone destination."
  max_stall_iterations: 5
  max_iterations: 100
  phase_timeout: 3600
  on_escalate: force-proceed  # force-proceed | abort | fail
  robustness: standard
  auto_approve: true

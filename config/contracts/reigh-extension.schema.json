{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://reigh.ai/contracts/reigh-extension.schema.json",
  "title": "Reigh Extension Manifest",
  "description": "Frozen manifest contract for Reigh editor extensions. Validates contribution kind enums, discriminated shapes, placement rules, and rejects unknown top-level collections.",
  "type": "object",
  "required": ["id", "version", "label"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Extension ID — non-empty, lowercase start, dot-separated segments of letters/digits/hyphens/underscores, max 128 chars.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"
    },
    "version": {
      "type": "string",
      "description": "Semver version string (e.g. '1.0.0').",
      "pattern": "^\\d+\\.\\d+\\.\\d+"
    },
    "label": {
      "type": "string",
      "description": "Human-readable extension label.",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Optional description of the extension."
    },
    "apiVersion": {
      "type": "integer",
      "description": "API version this extension targets (positive integer).",
      "minimum": 1
    },
    "contributions": {
      "type": "array",
      "description": "Contribution declarations.",
      "items": {
        "$ref": "#/definitions/Contribution"
      }
    },
    "permissions": {
      "type": "array",
      "description": "Descriptive permission metadata.",
      "items": {
        "$ref": "#/definitions/ExtensionPermissionDeclaration"
      }
    },
    "processes": {
      "type": "array",
      "description": "Process declarations.",
      "items": {
        "$ref": "#/definitions/ProcessManifestEntry"
      }
    },
    "migrations": {
      "type": "array",
      "description": "Typed migration hooks or legacy record entries."
    },
    "comments": {
      "type": "string",
      "description": "Human-readable comments."
    },
    "dependsOn": {
      "type": "array",
      "description": "Typed dependency declarations.",
      "items": {
        "$ref": "#/definitions/ExtensionDependency"
      }
    },
    "renderability": {
      "type": "object",
      "description": "Renderability descriptors."
    },
    "settingsDefaults": {
      "type": "object",
      "description": "Extension-scoped settings defaults."
    },
    "settingsSchema": {
      "$ref": "#/definitions/ExtensionSettingsSchema"
    },
    "messages": {
      "type": "object",
      "description": "Bundled i18n messages keyed by locale-neutral key.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "publisher": {
      "type": "string",
      "description": "Publisher identity."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier."
    },
    "icon": {
      "type": "string",
      "description": "Icon URL or data URI."
    }
  },

  "definitions": {
    "ContributionId": {
      "type": "string",
      "description": "Contribution ID — same rules as extension ID.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"
    },

    "ContributionKind": {
      "type": "string",
      "description": "Known contribution kinds matching the SDK ContributionKind enum.",
      "enum": [
        "slot",
        "dialog",
        "panel",
        "inspectorSection",
        "timelineOverlay",
        "command",
        "keybinding",
        "contextMenuItem",
        "parser",
        "outputFormat",
        "searchProvider",
        "metadataFacet",
        "assetDetailSection",
        "process",
        "effect",
        "transition",
        "clipType",
        "shader",
        "automation",
        "agentTool",
        "agent"
      ]
    },

    "SlotName": {
      "type": "string",
      "description": "Slot names recognized by the host shell.",
      "enum": [
        "header",
        "toolbar",
        "leftPanel",
        "rightPanel",
        "codePanel",
        "writingPanel",
        "stagePanel",
        "timelineFooter",
        "statusBar",
        "dialogs",
        "assetPanel",
        "inspectorPanel"
      ]
    },

    "Contribution": {
      "oneOf": [
        { "$ref": "#/definitions/SlotContribution" },
        { "$ref": "#/definitions/DialogContribution" },
        { "$ref": "#/definitions/PanelContribution" },
        { "$ref": "#/definitions/InspectorSectionContribution" },
        { "$ref": "#/definitions/TimelineOverlayContribution" },
        { "$ref": "#/definitions/CommandContribution" },
        { "$ref": "#/definitions/KeybindingContribution" },
        { "$ref": "#/definitions/ContextMenuItemContribution" },
        { "$ref": "#/definitions/ParserContribution" },
        { "$ref": "#/definitions/OutputFormatContribution" },
        { "$ref": "#/definitions/SearchProviderContribution" },
        { "$ref": "#/definitions/MetadataFacetContribution" },
        { "$ref": "#/definitions/AssetDetailSectionContribution" },
        { "$ref": "#/definitions/ProcessContribution" },
        { "$ref": "#/definitions/EffectContribution" },
        { "$ref": "#/definitions/TransitionContribution" },
        { "$ref": "#/definitions/ClipTypeContribution" },
        { "$ref": "#/definitions/ShaderContribution" },
        { "$ref": "#/definitions/AutomationContribution" },
        { "$ref": "#/definitions/AgentToolContribution" },
        { "$ref": "#/definitions/AgentContribution" }
      ]
    },

    "SlotContribution": {
      "type": "object",
      "description": "Slot contribution: renders into a named host shell slot. Must NOT specify placement.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "slot" },
        "order": { "type": "number", "description": "Lower values sort first. Default 0." },
        "slot": { "$ref": "#/definitions/SlotName" },
        "label": { "type": "string" },
        "when": { "type": "string" }
      }
    },

    "DialogContribution": {
      "type": "object",
      "description": "Dialog contribution: renders into a named dialog layer.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "dialog" },
        "order": { "type": "number" },
        "layer": { "enum": ["modal", "overlay"] },
        "label": { "type": "string" },
        "when": { "type": "string" }
      }
    },

    "PanelContribution": {
      "type": "object",
      "description": "Panel contribution: placement must be 'asset-panel' when specified.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "panel" },
        "order": { "type": "number" },
        "placement": {
          "type": "string",
          "description": "Panel placement is limited to 'asset-panel'.",
          "enum": ["asset-panel"]
        },
        "label": { "type": "string" },
        "when": { "type": "string" }
      }
    },

    "InspectorSectionContribution": {
      "type": "object",
      "description": "Inspector section contribution: placement 'before-default' or 'after-default'.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "inspectorSection" },
        "order": { "type": "number" },
        "placement": {
          "type": "string",
          "enum": ["before-default", "after-default"]
        },
        "label": { "type": "string" },
        "when": { "type": "string" }
      }
    },

    "TimelineOverlayContribution": {
      "type": "object",
      "description": "Timeline overlay contribution: renders over the timeline surface.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "timelineOverlay" },
        "order": { "type": "number" },
        "label": { "type": "string" },
        "when": { "type": "string" }
      }
    },

    "CommandContribution": {
      "type": "object",
      "description": "Command contribution: registers a command for the palette / keybinding dispatch.",
      "required": ["id", "kind", "command", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "command" },
        "command": { "type": "string", "description": "The command identifier (e.g. 'myExtension.doSomething')." },
        "label": { "type": "string", "minLength": 1 },
        "category": { "type": "string" },
        "when": { "type": "string" },
        "order": { "type": "number" }
      }
    },

    "KeybindingContribution": {
      "type": "object",
      "description": "Keybinding contribution: binds a keyboard shortcut to a command.",
      "required": ["id", "kind", "command", "key"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "keybinding" },
        "command": { "type": "string" },
        "key": { "type": "string", "description": "Platform-aware key notation (e.g. 'CtrlOrCmd+K')." },
        "when": { "type": "string" },
        "order": { "type": "number" }
      }
    },

    "ContextMenuItemContribution": {
      "type": "object",
      "description": "Context-menu item contribution for clip/track/timeline-area surfaces.",
      "required": ["id", "kind", "command", "target"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "contextMenuItem" },
        "command": { "type": "string" },
        "label": { "type": "string" },
        "target": {
          "type": "string",
          "description": "Target context where this item appears.",
          "enum": ["clip", "clip-selection", "track", "timeline-area"]
        },
        "when": { "type": "string" },
        "order": { "type": "number" },
        "icon": { "type": "string" }
      }
    },

    "ParserContribution": {
      "type": "object",
      "description": "M6: Parser contribution — enriches asset metadata during ingestion.",
      "required": ["id", "kind", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "parser" },
        "label": { "type": "string", "minLength": 1 },
        "acceptMimeTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptExtensions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxBytes": { "type": "number", "minimum": 1 },
        "required": { "type": "boolean" },
        "order": { "type": "number" }
      }
    },

    "OutputFormatContribution": {
      "type": "object",
      "description": "M6: Output format contribution — produces an artifact from timeline/asset data.",
      "required": ["id", "kind", "label", "requiresRender", "outputExtension"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "outputFormat" },
        "label": { "type": "string", "minLength": 1 },
        "requiresRender": { "type": "boolean" },
        "outputExtension": { "type": "string" },
        "outputMimeType": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "render": { "$ref": "#/definitions/RenderDependentOutputDescriptor" },
        "sampling": { "$ref": "#/definitions/SamplingConfig" },
        "sidecars": {
          "type": "array",
          "items": { "$ref": "#/definitions/RenderArtifactSidecarDescriptor" }
        }
      }
    },

    "RenderDependentOutputDescriptor": {
      "type": "object",
      "description": "M12: Route/process requirements for a render-dependent output format.",
      "required": ["routes"],
      "additionalProperties": false,
      "properties": {
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/RenderRoute" }
        },
        "requiredCapabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "processId": { "type": "string" },
        "operationId": { "type": "string" },
        "determinism": { "$ref": "#/definitions/DeterminismStatus" },
        "unavailableMessage": { "type": "string" }
      }
    },

    "RenderRoute": {
      "type": "string",
      "description": "Render route identifier.",
      "enum": ["preview", "browser-export", "worker-export", "sidecar-export"]
    },

    "DeterminismStatus": {
      "type": "string",
      "enum": ["deterministic", "preview-only", "live-unbaked", "process-dependent", "unknown"]
    },

    "SamplingConfig": {
      "type": "object",
      "description": "Declarative sampling defaults for export configuration.",
      "additionalProperties": false,
      "properties": {
        "defaultFps": { "type": "number", "minimum": 1 },
        "defaultWidth": { "type": "integer", "minimum": 1 },
        "defaultHeight": { "type": "integer", "minimum": 1 },
        "allowCustomResolution": { "type": "boolean" },
        "allowCustomFps": { "type": "boolean" }
      }
    },

    "RenderArtifactSidecarDescriptor": {
      "type": "object",
      "description": "Sidecar kind an output may emit.",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "extension": { "type": "string" },
        "mimeType": { "type": "string" },
        "label": { "type": "string" }
      }
    },

    "SearchProviderContribution": {
      "type": "object",
      "description": "M6: Search provider contribution — supplies asset/material search results.",
      "required": ["id", "kind", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "searchProvider" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "resultKinds": {
          "type": "array",
          "items": { "enum": ["asset", "material"] }
        },
        "order": { "type": "number" }
      }
    },

    "MetadataFacetContribution": {
      "type": "object",
      "description": "M6: Metadata facet contribution — surfaces a metadata field as a searchable/filterable facet.",
      "required": ["id", "kind", "fieldPath", "displayName", "valueKind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "metadataFacet" },
        "fieldPath": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "valueKind": {
          "type": "string",
          "enum": ["string", "number", "boolean", "enum", "date", "url"]
        },
        "order": { "type": "number" },
        "aggregationPosture": {
          "type": "string",
          "enum": ["exact", "range", "presence"]
        },
        "enumValues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "AssetDetailSectionContribution": {
      "type": "object",
      "description": "M6: Asset detail section contribution — named slot within the asset detail panel.",
      "required": ["id", "kind", "title", "placement"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "assetDetailSection" },
        "title": { "type": "string", "minLength": 1 },
        "placement": {
          "type": "string",
          "enum": ["before-default", "after-default"]
        },
        "fieldPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "order": { "type": "number" },
        "when": { "type": "string" }
      }
    },

    "ProcessContribution": {
      "type": "object",
      "description": "M12: Process contribution — trusted local process descriptor.",
      "required": ["id", "kind", "spec"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "process" },
        "label": { "type": "string" },
        "order": { "type": "number" },
        "spec": { "$ref": "#/definitions/ProcessManifestEntry" }
      }
    },

    "ProcessSpawnConfig": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "cwd": { "type": "string" }
      }
    },

    "CapabilityVersion": {
      "type": "object",
      "required": ["semver"],
      "additionalProperties": false,
      "properties": {
        "semver": { "type": "string" },
        "declaredBy": { "type": "string" },
        "contributionId": { "type": "string" }
      }
    },

    "CapabilitySourceRef": {
      "type": "object",
      "required": ["source"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["extension", "built-in", "registry", "manifest", "provider"]
        },
        "extensionId": { "type": "string" },
        "contributionId": { "type": "string" },
        "version": { "$ref": "#/definitions/CapabilityVersion" }
      }
    },

    "ProcessEnvFieldSpec": {
      "type": "object",
      "required": ["key"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "secret": { "type": "boolean" },
        "defaultValue": { "type": "string" },
        "platformDefaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "darwin": { "type": "string" },
            "linux": { "type": "string" },
            "win32": { "type": "string" }
          }
        }
      }
    },

    "ProcessOperationSpec": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "inputSchema": { "type": "object" },
        "outputKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "artifact",
              "material",
              "sidecar",
              "diagnostic",
              "planner-result",
              "tool-result",
              "live-source-scalar",
              "live-source-vector",
              "live-source-structured"
            ]
          }
        },
        "requiredCapabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/RenderRoute" }
        },
        "determinism": { "$ref": "#/definitions/DeterminismStatus" }
      }
    },

    "ProcessLiveSourceDeclaration": {
      "type": "object",
      "required": ["sourceId", "valueShape"],
      "additionalProperties": false,
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "valueShape": {
          "type": "string",
          "enum": ["scalar", "vector", "structured"]
        },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "sourceKind": { "type": "string" }
      }
    },

    "ProcessManifestEntry": {
      "type": "object",
      "required": ["id", "label", "spawn", "protocol"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "spawn": { "$ref": "#/definitions/ProcessSpawnConfig" },
        "protocol": {
          "type": "string",
          "enum": ["stdio-jsonrpc"]
        },
        "healthCheck": { "type": "string" },
        "shutdown": { "type": "string" },
        "restartPolicy": {
          "type": "string",
          "enum": ["never", "always", "on-failure"]
        },
        "version": { "$ref": "#/definitions/CapabilityVersion" },
        "env": {
          "type": "array",
          "items": { "$ref": "#/definitions/ProcessEnvFieldSpec" }
        },
        "operations": {
          "type": "array",
          "items": { "$ref": "#/definitions/ProcessOperationSpec" }
        },
        "liveSources": {
          "type": "array",
          "items": { "$ref": "#/definitions/ProcessLiveSourceDeclaration" }
        },
        "capabilities": { "type": "object" },
        "requiredBy": {
          "type": "array",
          "items": { "$ref": "#/definitions/CapabilitySourceRef" }
        }
      }
    },

    "EffectContribution": {
      "type": "object",
      "description": "M7: Effect contribution — trusted component effect.",
      "required": ["id", "kind", "effectId"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "effect" },
        "effectId": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "allowBrowserExport": { "type": "boolean" },
        "allowWorkerExport": { "type": "boolean" },
        "order": { "type": "number" }
      }
    },

    "TransitionContribution": {
      "type": "object",
      "description": "M8: Transition contribution — trusted component transition.",
      "required": ["id", "kind", "transitionId"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "transition" },
        "transitionId": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "allowBrowserExport": { "type": "boolean" },
        "allowWorkerExport": { "type": "boolean" },
        "order": { "type": "number" }
      }
    },

    "ClipTypeContribution": {
      "type": "object",
      "description": "M9: Clip type contribution — contributed clip type renderer/inspector.",
      "required": ["id", "kind", "clipTypeId"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "clipType" },
        "clipTypeId": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "allowBrowserExport": { "type": "boolean" },
        "allowWorkerExport": { "type": "boolean" },
        "order": { "type": "number" }
      }
    },

    "ShaderContribution": {
      "type": "object",
      "description": "M13: Shader/WebGL contribution — pass, source, uniform, texture, fallback, and materializer descriptors aligned with SDK ShaderContribution.",
      "required": ["id", "kind", "shaderId", "label", "pass"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "shader" },
        "shaderId": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "pass": {
          "oneOf": [
            { "type": "string", "enum": ["clip", "overlay", "postprocess"] },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": { "type": "string", "enum": ["clip", "overlay", "postprocess"] },
                "inputTextureUniform": { "type": "string" },
                "colorSpace": { "type": "string", "enum": ["srgb", "linear"] },
                "alpha": { "type": "string", "enum": ["preserve", "opaque"] }
              }
            }
          ]
        },
        "source": {
          "oneOf": [
            {
              "type": "object",
              "description": "Inline shader source supplied directly in the manifest.",
              "required": ["kind", "fragment"],
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "inline" },
                "fragment": { "type": "string" },
                "vertex": { "type": "string" }
              }
            },
            {
              "type": "object",
              "description": "Module-resolved shader source from an extension export.",
              "required": ["kind", "specifier"],
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "module" },
                "specifier": { "type": "string" },
                "exportName": { "type": "string" }
              }
            }
          ]
        },
        "uniforms": {
          "type": "array",
          "description": "Ordered shader uniform definitions (ShaderUniformSchema). V1 executable types: float, int, bool, vec2, vec3, vec4, color, enum, object, textureRef, frame, time. Reserved extension-param domains (output, process, agent, app) are lexical-only \u2014 they are accepted by the schema but produce composition/unsupported-target-kind diagnostics in V1.",
          "items": {
            "type": "object",
            "required": ["name", "label", "type"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["float", "int", "bool", "vec2", "vec3", "vec4", "color", "enum", "object", "textureRef", "frame", "time"]
              },
              "default": {},
              "min": { "type": "number" },
              "max": { "type": "number" },
              "step": { "type": "number" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["label", "value"],
                  "additionalProperties": false,
                  "properties": {
                    "label": { "type": "string" },
                    "value": { "type": "string" }
                  }
                }
              },
              "fields": {
                "type": "array",
                "description": "Bounded sub-field definitions for structured-object uniforms (type=object). Each sub-field is itself a scalar, vector, color, enum/selector, or boolean parameter. Sub-fields are not separately addressable as target paths in V1.",
                "items": {
                  "type": "object",
                  "required": ["name", "label", "type"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "label": { "type": "string" },
                    "description": { "type": "string" },
                    "type": {
                      "type": "string",
                      "enum": ["float", "int", "bool", "vec2", "vec3", "vec4", "color", "enum", "textureRef", "frame", "time"]
                    },
                    "default": {},
                    "min": { "type": "number" },
                    "max": { "type": "number" },
                    "step": { "type": "number" },
                    "options": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["label", "value"],
                        "additionalProperties": false,
                        "properties": {
                          "label": { "type": "string" },
                          "value": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "textures": {
          "type": "array",
          "description": "Ordered shader texture binding definitions (ShaderTextureSchema).",
          "items": {
            "type": "object",
            "required": ["name", "sourceKind"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" },
              "uniform": { "type": "string" },
              "sourceKind": { "type": "string", "enum": ["clip-frame", "static-image-asset", "live-generated-frame"] },
              "required": { "type": "boolean" },
              "colorSpace": { "type": "string", "enum": ["srgb", "linear"] },
              "filter": { "type": "string", "enum": ["nearest", "linear"] },
              "wrap": { "type": "string", "enum": ["clamp-to-edge", "repeat", "mirrored-repeat"] }
            }
          }
        },
        "fallback": {
          "type": "string",
          "description": "Host-owned fallback posture when a shader cannot compile or preview.",
          "enum": ["bypass", "transparent", "solid-black"]
        },
        "materializer": {
          "type": "object",
          "description": "Optional materializer metadata advertising planner route capability.",
          "additionalProperties": false,
          "properties": {
            "routes": {
              "type": "array",
              "items": { "$ref": "#/definitions/RenderRoute" }
            },
            "requiredCapabilities": {
              "type": "array",
              "items": { "type": "string" }
            },
            "processId": { "type": "string" },
            "operationId": { "type": "string" },
            "unavailableMessage": { "type": "string" }
          }
        },
        "order": { "type": "number" },
        "when": { "type": "string" }
      }
    },

    "AutomationContribution": {
      "type": "object",
      "description": "M9: Automation contribution — host-owned automation clip declaration.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "automation" },
        "order": { "type": "number" },
        "label": { "type": "string" },
        "when": { "type": "string" }
      }
    },

    "AgentToolContribution": {
      "type": "object",
      "description": "M10: Agent tool contribution — host-mediated, proposal-backed.",
      "required": ["id", "kind", "toolId", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "agentTool" },
        "toolId": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "inputSchema": {
          "type": "object",
          "description": "Agent tool input schema (StandardSchema-compatible subset).",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "object" },
            "properties": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "type": "string", "enum": ["string", "number", "boolean", "object"] },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "default": {},
                  "enum": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "properties": { "type": "object" },
                  "required": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            },
            "required": {
              "type": "array",
              "items": { "type": "string" }
            },
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "resultFamilies": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "mutation/proposal",
              "generation/session",
              "material/artifact",
              "enrichment/search",
              "export",
              "process",
              "ui/summary"
            ]
          }
        },
        "order": { "type": "number" },
        "when": { "type": "string" }
      }
    },

    "AgentContribution": {
      "type": "object",
      "description": "Reserved agent contribution — not yet bridged.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/ContributionId" },
        "kind": { "const": "agent" },
        "order": { "type": "number" },
        "label": { "type": "string" },
        "when": { "type": "string" }
      }
    },

    "ExtensionPermissionDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "permission": { "type": "string" },
        "reason": { "type": "string" }
      }
    },

    "ExtensionDependency": {
      "type": "object",
      "required": ["extensionId"],
      "additionalProperties": false,
      "properties": {
        "extensionId": { "type": "string" },
        "versionRange": { "type": "string" },
        "posture": {
          "type": "string",
          "enum": ["required", "optional"]
        },
        "optional": { "type": "boolean" }
      }
    },

    "ExtensionSettingsSchema": {
      "type": "object",
      "required": ["version"],
      "additionalProperties": true,
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
